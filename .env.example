# Google Analytics 4 Measurement ID (public, shipped to client)
# Find at: analytics.google.com → Admin → Data Streams → Web → Measurement ID
PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager container ID (public, shipped to client). Loads GTM
# in head + body when set. Use hostname triggers inside GTM to scope tags
# per environment.
PUBLIC_GTM_ID=GTM-XXXXXXX

# Cloudflare Web Analytics beacon token. Get from Cloudflare dashboard
# → Web Analytics → site → "Snippet" tab. Cookieless, GDPR-friendly,
# no consent banner needed.
PUBLIC_CF_BEACON_TOKEN=
