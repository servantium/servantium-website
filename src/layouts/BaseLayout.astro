---
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import TestEnvBanner from '@/components/TestEnvBanner.astro';
import CalEmbed from '@/components/CalEmbed.astro';
import '@/theme/verdant.css';
import '@/styles/global.css';

// Self-hosted fonts (no Google Fonts external requests)
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';

interface Props {
  activePage?: string;
}

const { activePage } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <TestEnvBanner />

  <!-- CSP via meta tag (not response header) so it doesn't restrict Pagefind's WASM worker -->
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob: https://app.cal.com https://www.googletagmanager.com https://static.cloudflareinsights.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' blob: data: https://contact.servantium.com https://leads.servantium.com https://cal.com https://*.google-analytics.com https://cloudflareinsights.com; frame-src https://app.cal.com; font-src 'self'" />

  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <slot name="head" />
</head>
<body class="site-body">
  <a href="#main-content" class="skip-link">Skip to content</a>

  <Nav activePage={activePage} />

  <main id="main-content" class="site-main" tabindex="-1">
    <slot />
  </main>

  <Footer />

  <CookieConsent />
  <CalEmbed />
</body>
</html>
