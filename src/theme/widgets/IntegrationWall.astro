---
interface Integration {
  name: string;
  abbrev: string;
  color: string;
  tier: 'live' | 'planned' | 'placeholder';
  logo?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  integrations: Integration[];
  capabilities?: string[];
}

const {
  title = 'Your data flows where it needs to',
  subtitle,
  integrations,
  capabilities = [],
} = Astro.props;

// Seed-based pseudo-random for deterministic builds
function seededShuffle<T>(arr: T[], seed: number): T[] {
  const shuffled = [...arr];
  let s = seed;
  for (let i = shuffled.length - 1; i > 0; i--) {
    s = (s * 1103515245 + 12345) & 0x7fffffff;
    const j = s % (i + 1);
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

const realIntegrations = integrations.filter((ig) => ig.tier !== 'placeholder');
const placeholders = integrations.filter((ig) => ig.tier === 'placeholder');

// 4 rows with concave shape, ~18 items each
const boxesPerRow = 18;
const totalRows = 4;
const rowSpeeds = ['45s', '30s', '35s', '50s'];

const rows: Integration[][] = Array.from({ length: totalRows }, () => []);

const shuffledReal = seededShuffle(realIntegrations, 42);
shuffledReal.forEach((ig, i) => {
  rows[i % totalRows].push(ig);
});

let placeholderIdx = 0;
rows.forEach((row) => {
  while (row.length < boxesPerRow) {
    if (placeholderIdx < placeholders.length) {
      row.push(placeholders[placeholderIdx++]);
    } else {
      row.push({ name: '', abbrev: '+', color: '#94a3b8', tier: 'placeholder' });
    }
  }
});

const finalRows = rows.map((row, i) => seededShuffle(row, 100 + i));
---

<!-- Desktop: ClickUp-style flat rows with centered logo -->
<section class="iw" aria-label={title}>
  <div class="iw-container">
    <!-- Text above -->
    <div class="iw-header">
      {title && <h2 class="iw-title">{title}</h2>}
      {subtitle && <p class="iw-subtitle">{subtitle}</p>}
    </div>

    <!-- Scrolling rows with centered Servantium logo -->
    <div class="iw-rows">
      {finalRows.map((row, rowIdx) => {
        const doubled = [...row, ...row];
        return (
          <div class="iw-row-wrap" data-row={rowIdx}>
          <div
            class="iw-row"
            style={`--speed: ${rowSpeeds[rowIdx]};`}
            data-row={rowIdx}
          >
            {doubled.map((ig, i) => {
              return (
                <div
                  class={`iw-box iw-box-${ig.tier}`}
                  title={ig.name || undefined}
                >
                  {ig.logo ? (
                    <img
                      src={ig.logo}
                      alt={ig.name}
                      class="iw-logo"
                      loading="lazy"
                      width="30"
                      height="30"
                    />
                  ) : (
                    <span
                      class="iw-abbrev"
                      style={ig.tier !== 'placeholder' ? `color: ${ig.color}; font-weight: 700;` : ''}
                    >
                      {ig.abbrev}
                    </span>
                  )}
                </div>
              );
            })}
          </div>
          </div>
        );
      })}

      <!-- Centered Servantium logo mark -->
      <div class="iw-center-logo">
        <img src="/S-nobg.png" alt="Servantium" width="180" height="180" />
      </div>
    </div>

    <!-- Capability pills below -->
    {capabilities.length > 0 && (
      <div class="iw-caps">
        {capabilities.map((cap) => (
          <span class="iw-pill">{cap}</span>
        ))}
      </div>
    )}
  </div>
</section>

<!-- Mobile: simplified 2-row version -->
<section class="iw-mobile" aria-label={title}>
  <div class="iw-mobile-container">
    {title && <h2 class="iw-mobile-title">{title}</h2>}
    {subtitle && <p class="iw-mobile-subtitle">{subtitle}</p>}

    <div class="iw-mobile-rows">
      {finalRows.map((row, rowIdx) => (
        <div class="iw-mobile-row" style={`--speed: ${rowIdx === 0 ? '50s' : '60s'};`} data-row={rowIdx}>
          {[...row, ...row].map((ig) => (
            <div class={`iw-mobile-box iw-mobile-box-${ig.tier}`} title={ig.name || undefined}>
              {ig.logo ? (
                <img src={ig.logo} alt={ig.name} class="iw-mobile-logo" loading="lazy" width="22" height="22" />
              ) : (
                <span style={ig.tier !== 'placeholder' ? `color: ${ig.color}; font-weight: 700;` : ''}>
                  {ig.abbrev}
                </span>
              )}
            </div>
          ))}
        </div>
      ))}
    </div>

    {capabilities.length > 0 && (
      <div class="iw-mobile-caps">
        {capabilities.map((cap) => (
          <span class="iw-mobile-pill">{cap}</span>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  /* ── Desktop: ClickUp-style flat rows ── */
  .iw {
    display: block;
    padding: var(--v-space-xl, 4rem) 0 var(--v-space-lg, 2.5rem);
    background: #fff;
    overflow: hidden;
  }

  .iw-container {
    max-width: var(--max-width, 1320px);
    margin: 0 auto;
  }

  /* Text above rows */
  .iw-header {
    text-align: center;
    padding: 0 2rem 2rem;
  }

  .iw-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-ink, #0D0D0D);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .iw-subtitle {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.95rem;
    color: var(--color-ink-muted, #6b6b6b);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 520px;
  }

  /* Scrolling rows container */
  .iw-rows {
    position: relative;
    padding: 1rem 0;
  }

  .iw-row {
    display: flex;
    align-items: center;
    gap: 10px;
    animation: iwScroll var(--speed) linear infinite;
    width: max-content;
    padding: 10px 0;
    margin-bottom: 6px;
    /* Soft fade at edges — does NOT block interaction */
    mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
  }
  .iw-row[data-row="0"] { animation-direction: normal; }
  .iw-row[data-row="1"] { animation-direction: reverse; }
  .iw-row[data-row="2"] { animation-direction: normal; }
  .iw-row[data-row="3"] { animation-direction: reverse; }

  /* Concave shape: wrapper div offsets each row vertically */
  .iw-row-wrap { position: relative; overflow: visible; }
  .iw-row-wrap[data-row="0"] { top: 14px; }
  .iw-row-wrap[data-row="1"] { top: 5px; }
  .iw-row-wrap[data-row="2"] { top: -5px; }
  .iw-row-wrap[data-row="3"] { top: -14px; }

  @keyframes iwScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Logo boxes — flat, tight, clean */
  .iw-box {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 13px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: default;
  }

  .iw-box-live {
    background: #fff;
    border: 2px solid var(--color-green, #00C26D);
    box-shadow: 0 2px 8px rgba(0, 194, 109, 0.15);
  }

  .iw-box-planned {
    background: #fff;
    border: 1px solid var(--color-cloud-grey, #E1E3E6);
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }

  .iw-box-placeholder {
    background: #fafafa;
    border: 1.5px dashed var(--color-cloud-grey, #E1E3E6);
    opacity: 0.5;
  }
  .iw-box-placeholder .iw-abbrev {
    color: #bcc3cc !important;
    font-weight: 400 !important;
    font-size: 18px;
  }

  .iw-box:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 16px rgba(0, 194, 109, 0.2);
  }

  .iw-abbrev {
    line-height: 1;
    user-select: none;
  }

  .iw-logo {
    width: 30px;
    height: 30px;
    object-fit: contain;
    pointer-events: none;
  }

  /* Centered Servantium logo */
  .iw-center-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 260px;
    height: 260px;
    background: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 48px rgba(0,0,0,0.1), 0 0 0 12px rgba(255,255,255,0.95);
    z-index: 10;
  }
  .iw-center-logo img {
    width: 180px;
    height: 180px;
    object-fit: contain;
  }

  /* Hover: pause rows */
  .iw-rows:hover .iw-row {
    animation-play-state: paused;
  }

  /* Capability pills below rows */
  .iw-caps {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem 2rem 0;
  }

  .iw-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1.1rem;
    background: rgba(0, 194, 109, 0.08);
    border: 1px solid rgba(0, 194, 109, 0.2);
    border-radius: 100px;
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-emerald, #037A47);
  }

  /* ── Mobile ── */
  .iw-mobile {
    display: none;
    padding: var(--v-space-lg, 2.5rem) 0;
    background: #fff;
    overflow: hidden;
  }

  .iw-mobile-container {
    max-width: var(--content-width, 1140px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .iw-mobile-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--color-ink, #0D0D0D);
    text-align: center;
    margin: 0 0 0.5rem;
  }

  .iw-mobile-subtitle {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9rem;
    color: var(--color-ink-muted, #6b6b6b);
    text-align: center;
    line-height: 1.6;
    margin: 0 auto 1.5rem;
    max-width: 500px;
  }

  .iw-mobile-rows {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .iw-mobile-row {
    display: flex;
    gap: 8px;
    animation: iwScroll var(--speed) linear infinite;
    width: max-content;
  }
  .iw-mobile-row[data-row="0"] { animation-direction: normal; }
  .iw-mobile-row[data-row="1"] { animation-direction: reverse; }

  .iw-mobile-box {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 11px;
  }
  .iw-mobile-box-live {
    background: #fff;
    border: 2px solid var(--color-green, #00C26D);
    box-shadow: 0 0 8px rgba(0, 194, 109, 0.15);
  }
  .iw-mobile-box-planned {
    background: #fff;
    border: 1px solid var(--color-cloud-grey, #E1E3E6);
  }
  .iw-mobile-box-placeholder {
    background: #fafafa;
    border: 1.5px dashed var(--color-cloud-grey, #E1E3E6);
    opacity: 0.4;
  }

  .iw-mobile-logo {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }

  .iw-mobile-caps {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
  .iw-mobile-pill {
    display: inline-flex;
    padding: 0.35rem 0.9rem;
    background: rgba(0, 194, 109, 0.08);
    border: 1px solid rgba(0, 194, 109, 0.2);
    border-radius: 100px;
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-emerald, #037A47);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .iw { display: none; }
    .iw-mobile { display: block; }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .iw-row,
    .iw-mobile-row {
      animation: none !important;
    }
    .iw-row {
      flex-wrap: wrap;
      width: auto;
      justify-content: center;
      gap: 8px;
      mask-image: none;
      -webkit-mask-image: none;
    }
    .iw-row .iw-box:nth-child(n+21),
    .iw-mobile-row .iw-mobile-box:nth-child(n+21) {
      display: none;
    }
  }
</style>
