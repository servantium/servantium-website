<!-- Mobile: Stacked station cards -->
<section class="journey-mobile" aria-label={title}>
  <div class="journey-mobile-container">
    {title && <h2 class="journey-mobile-title">{title}</h2>}
    {subtitle && <p class="journey-mobile-subtitle">{subtitle}</p>}
    <div class="journey-mobile-stations">
      {stops.map((stop, i) => {
        const station = stations[i] || stations[0];
        return (
          <div class="journey-mobile-card">
            <div class="journey-mobile-dot" style={`background: ${station.glow}; box-shadow: 0 0 8px ${station.glow};`}></div>
            {i < stops.length - 1 && (
              <div class="journey-mobile-connector"></div>
            )}
            <div class="journey-mobile-content" style={`border-left-color: ${station.glow};`}>
              <span class="journey-mobile-label" style={`color: ${station.glow};`}>{station.label} Station</span>
              <h3 class="journey-mobile-card-title">{stop.title}</h3>
              <p class="journey-mobile-card-desc">{stop.description}</p>
              <div class="journey-mobile-features">
                {stop.features.map((f) => (
                  <span class="journey-mobile-feature">{f}</span>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ===== Desktop: Space Journey ===== */
  .journey {
    position: relative;
    display: block;
  }

  .journey-scroll-spacer {
    position: relative;
  }

  .journey-viewport {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #0B1120;
  }
  .journey-viewport::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 1;
  }

  /* Static stars with subtle drift */
  .journey-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    animation: starDrift 20s ease-in-out infinite;
  }
  @keyframes starDrift {
    0% { transform: translate(0, 0); }
    50% { transform: translate(-10px, -5px); }
    100% { transform: translate(0, 0); }
  }
  .journey-star {
    position: absolute;
    background: #ffffff;
    border-radius: 50%;
  }

  /* ── Connection trail (center background) ── */
  .journey-connection-trail {
    position: absolute;
    left: 50%;
    top: 15%;
    bottom: 15%;
    width: 2px;
    transform: translateX(-50%);
    z-index: 2;
    pointer-events: none;
  }
  .journey-trail-line {
    position: absolute;
    inset: 0;
    border-left: 1px dotted rgba(0, 194, 109, 0.12);
  }
  .journey-trail-fill {
    position: absolute;
    left: 0;
    top: 0;
    width: 2px;
    height: 0%;
    background: linear-gradient(to bottom, rgba(0, 194, 109, 0.4), rgba(0, 194, 109, 0.1));
    transition: height 0.5s ease-out;
  }

  /* ── Progress indicator (left side) ── */
  .journey-progress {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    height: 300px;
    width: 20px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
