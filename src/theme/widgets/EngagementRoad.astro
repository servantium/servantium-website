  /* ── Header overlay ── */
  .journey-header {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 6;
    max-width: 640px;
    width: 90%;
    transition: opacity 0.5s ease;
  }
  .journey-header.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .journey-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.15;
  }
  .journey-subtitle {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 1.5rem;
  }
  .journey-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8rem;
    animation: hintBounce 2s ease-in-out infinite;
  }
  @keyframes hintBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ── Persistent CTA ── */
  .journey-cta {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 20;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--color-green, #00C26D);
    color: white;
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    transition: background 0.2s ease;
  }
  .journey-cta:hover {
    background: var(--color-green-hover, #00A95E);
  }

  /* ===== Mobile: Stacked Cards ===== */
  .journey-mobile {
    display: none;
  }
  .journey-mobile-container {
    max-width: var(--content-width, 1140px);
