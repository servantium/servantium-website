                    <text x="20" y="270" font-size="8" fill="#6b6b6b" font-family="sans-serif">Team Utilization</text>
                    <rect x="130" y="262" width="240" height="10" rx="5" fill="#F5F6F7"/>
                    <rect x="130" y="262" width="182" height="10" rx="5" fill="#26A899" opacity="0.3"/>
                    <text x="375" y="272" text-anchor="end" font-size="8" fill="#26A899" font-family="sans-serif" font-weight="600">76%</text>
                  </svg>
                )}
                {i === 4 && (
                  <!-- Learning: Knowledge graph -->
                  <svg viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" style="display: block;">
                    <rect x="1" y="1" width="398" height="298" rx="12" fill="white" stroke="#E1E3E6" stroke-width="1"/>
