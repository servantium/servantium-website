---
interface RoadStop {
  title: string;
  description: string;
  features: string[];
  color: string;
  icon: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  stops: RoadStop[];
}

const {
  title = 'The Servantium Journey',
  subtitle,
  stops,
} = Astro.props;

const stations = [
  { glow: '#00C26D', label: 'Discovery', tagline: 'Scanning for opportunities.' },
  { glow: '#4C82A7', label: 'Estimation', tagline: 'Calculating the approach.' },
  { glow: '#FFB02E', label: 'Proposal', tagline: 'Charting the course.' },
  { glow: '#26A899', label: 'Delivery', tagline: 'Mission in progress.' },
  { glow: '#8B5CF6', label: 'Learning', tagline: 'Knowledge compounds.' },
];
---

<!-- Desktop: The Servantium Journey — scroll through 5 space stations -->
<section class="journey" aria-label={title}>
  <div class="journey-scroll-spacer" style={`min-height: ${stops.length * 70}vh;`}>
    <div class="journey-viewport">
      <!-- Static starfield -->
      <div class="journey-stars" aria-hidden="true">
        {Array.from({ length: 100 }).map((_, i) => (
          <div
            class="journey-star"
            style={`left: ${(i * 17 + 3) % 100}%; top: ${(i * 29 + 7) % 100}%; width: ${1 + (i % 3)}px; height: ${1 + (i % 3)}px; opacity: ${0.2 + (i % 5) * 0.12};`}
          ></div>
        ))}
      </div>

      <!-- Connection trail — thin green dotted line that grows as you progress -->
      <div class="journey-connection-trail" aria-hidden="true">
        <div class="journey-trail-line"></div>
        <div class="journey-trail-fill"></div>
      </div>

      <!-- Progress indicator — vertical dotted line on left -->
      <div class="journey-progress" aria-hidden="true">
        <div class="journey-progress-line"></div>
        <div class="journey-progress-fill"></div>
        {stations.map((_, i) => (
          <div class="journey-progress-dot" data-progress-dot={i}></div>
        ))}
      </div>

      <!-- Floating astronaut -->
      <div class="journey-astronaut" aria-hidden="true">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
          <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
          <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
          <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
          <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
          <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
          <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
          <circle cx="50" cy="6" r="3" fill="#00C26D"/>
          <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
        </svg>
      </div>

      <!-- Station panels -->
      {stops.map((stop, i) => {
        const station = stations[i] || stations[0];
        return (
          <div
            class="station-panel"
            data-station-state={i === 0 ? 'active' : 'upcoming'}
            data-station-index={i}
          >
            <div class="station-glow" style={`background: ${station.glow};`}></div>

            <div class="station-illustration" set:html={
              i === 0 ? `<!-- Discovery Station: Satellite dish with radar -->
<svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" width="200" height="200">
  <ellipse cx="100" cy="120" rx="60" ry="20" stroke="white" stroke-width="2"/>
  <path d="M100 120 L100 60" stroke="white" stroke-width="2"/>
  <circle cx="100" cy="55" r="8" stroke="#00C26D" stroke-width="2" fill="#00C26D" fill-opacity="0.2"/>
  <path d="M100 55 L130 30" stroke="#00C26D" stroke-width="1.5" opacity="0.6"/>
  <circle cx="130" cy="30" r="3" fill="#00C26D" opacity="0.8"/>
  <path d="M80 40 Q100 25 120 40" stroke="#00C26D" stroke-width="1" fill="none" opacity="0.4"/>
  <path d="M70 30 Q100 10 130 30" stroke="#00C26D" stroke-width="1" fill="none" opacity="0.3"/>
  <rect x="85" y="120" width="30" height="40" rx="4" stroke="white" stroke-width="1.5" fill="white" fill-opacity="0.05"/>
  <circle cx="40" cy="40" r="1.5" fill="white" opacity="0.6"/>
  <circle cx="160" cy="50" r="1" fill="white" opacity="0.4"/>
  <circle cx="30" cy="90" r="1" fill="#00C26D" opacity="0.5"/>
</svg>` :
