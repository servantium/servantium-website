                    <!-- Connection lines (behind nodes) -->
                    <line x1="200" y1="150" x2="100" y2="90" stroke="#8B5CF6" stroke-width="1" opacity="0.2"/>
                    <line x1="200" y1="150" x2="310" y2="80" stroke="#8B5CF6" stroke-width="1" opacity="0.2"/>
                    <line x1="200" y1="150" x2="80" y2="200" stroke="#8B5CF6" stroke-width="1" opacity="0.2"/>
                    <line x1="200" y1="150" x2="320" y2="200" stroke="#8B5CF6" stroke-width="1" opacity="0.2"/>
                    <line x1="200" y1="150" x2="150" y2="250" stroke="#8B5CF6" stroke-width="1" opacity="0.2"/>
                    <line x1="200" y1="150" x2="270" y2="250" stroke="#8B5CF6" stroke-width="1" opacity="0.2"/>
