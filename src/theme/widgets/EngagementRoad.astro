---
interface RoadStop {
  title: string;
  description: string;
  features: string[];
  color: string;
  icon: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  stops: RoadStop[];
}

const {
  title = 'The Engagement Journey',
  subtitle,
  stops,
} = Astro.props;

// Stage accent colors and glow hues
const stageThemes = [
  { glow: '#22c55e', label: 'Discovery' },
  { glow: '#3b82f6', label: 'Estimation' },
  { glow: '#f59e0b', label: 'Proposal' },
  { glow: '#14b8a6', label: 'Delivery' },
  { glow: '#a855f7', label: 'Learning' },
];
---

<!-- Desktop: First-person space journey -->
<section class="engagement-road" aria-label={title}>
  <div class="road-scroll-spacer" style={`height: ${(stops.length + 1) * 100}vh;`}>
    <div class="road-viewport">
      <!-- Starfield background (CSS-only) — covers full viewport -->
      <div class="starfield" aria-hidden="true">
        {Array.from({ length: 120 }).map((_, i) => (
          <div
            class="star"
            style={`left: ${(i * 13 + 3) % 100}%; top: ${(i * 23 + 7) % 100}%; width: ${1 + (i % 3)}px; height: ${1 + (i % 3)}px; opacity: ${0.3 + (i % 5) * 0.15};`}
          ></div>
        ))}
      </div>

      <!-- Star parallax layers for depth -->
      <div class="stars-far" aria-hidden="true">
        {Array.from({ length: 40 }).map((_, i) => (
          <div
            class="parallax-star"
            style={`left: ${(i * 17 + 11) % 100}%; top: ${(i * 29 + 5) % 100}%; width: ${1 + (i % 2)}px; height: ${1 + (i % 2)}px; opacity: ${0.15 + (i % 4) * 0.08};`}
          ></div>
        ))}
      </div>
      <div class="stars-near" aria-hidden="true">
        {Array.from({ length: 20 }).map((_, i) => (
          <div
            class="parallax-star"
            style={`left: ${(i * 23 + 7) % 100}%; top: ${(i * 31 + 13) % 100}%; width: ${2 + (i % 2)}px; height: ${2 + (i % 2)}px; opacity: ${0.4 + (i % 3) * 0.15};`}
          ></div>
        ))}
      </div>

      <!-- Star streaks during transitions -->
      <div class="star-streaks" aria-hidden="true">
        <div class="streak-line" style="top: 15%; left: 5%; right: 35%;"></div>
        <div class="streak-line" style="top: 28%; left: 12%; right: 20%;"></div>
        <div class="streak-line" style="top: 42%; left: 8%; right: 30%;"></div>
        <div class="streak-line" style="top: 55%; left: 18%; right: 12%;"></div>
        <div class="streak-line" style="top: 68%; left: 10%; right: 28%;"></div>
        <div class="streak-line" style="top: 78%; left: 22%; right: 18%;"></div>
        <div class="streak-line" style="top: 88%; left: 15%; right: 25%;"></div>
      </div>

      <!-- Floating decorative orbs -->
      <div class="floating-orbs" aria-hidden="true">
        {(() => {
          const orbConfigs = [
            { size: 8, x: 3, y: 20, delay: 0, fromLeft: true },
            { size: 12, x: 6, y: 45, delay: 1.2, fromLeft: true },
            { size: 6, x: 8, y: 70, delay: 2.5, fromLeft: true },
            { size: 14, x: 4, y: 85, delay: 0.8, fromLeft: true },
            { size: 10, x: 5, y: 35, delay: 3.1, fromLeft: true },
            { size: 10, x: 94, y: 15, delay: 0.5, fromLeft: false },
            { size: 16, x: 92, y: 40, delay: 1.8, fromLeft: false },
            { size: 8, x: 96, y: 60, delay: 2.2, fromLeft: false },
            { size: 12, x: 93, y: 78, delay: 3.5, fromLeft: false },
            { size: 6, x: 95, y: 55, delay: 0.3, fromLeft: false },
          ];
          return orbConfigs.map((orb, i) => (
            <div
              class="floating-orb"
              data-orb-index={i}
              style={`
                width: ${orb.size}px;
                height: ${orb.size}px;
                left: ${orb.x}%;
                top: ${orb.y}%;
                animation-delay: ${orb.delay}s;
                animation-name: ${orb.fromLeft ? 'orb-drift-left' : 'orb-drift-right'};
              `}
            ></div>
          ));
        })()}
      </div>

      <!-- Stop content panels -->
      {stops.map((stop, i) => {
        const theme = stageThemes[i] || stageThemes[0];
        return (
          <div
            class="stop-content"
            data-state={i === 0 ? 'active' : 'approaching'}
            data-index={i}
          >
            <div class="stop-nebula-glow" style={`background: ${theme.glow};`}></div>
            <div class="stop-icon-wrap" style={`--stage-glow: ${theme.glow};`}>
              {i === 0 && (
                <svg class="stop-svg-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="24" cy="24" r="16" stroke="white" stroke-width="1.5"/>
                  <circle cx="24" cy="24" r="8" stroke="white" stroke-width="1.5"/>
                  <line x1="24" y1="4" x2="24" y2="12" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="24" y1="36" x2="24" y2="44" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="4" y1="24" x2="12" y2="24" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="36" y1="24" x2="44" y2="24" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              )}
              {i === 1 && (
                <svg class="stop-svg-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="6" y="10" width="36" height="28" rx="3" stroke="white" stroke-width="1.5"/>
                  <polyline points="10,34 18,22 24,28 32,16 38,20" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="6" y1="34" x2="42" y2="34" stroke="white" stroke-width="1.5"/>
                </svg>
              )}
              {i === 2 && (
                <svg class="stop-svg-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="10" y="6" width="28" height="36" rx="3" stroke="white" stroke-width="1.5"/>
                  <line x1="16" y1="14" x2="32" y2="14" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="16" y1="20" x2="32" y2="20" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="16" y1="26" x2="28" y2="26" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                  <circle cx="30" cy="34" r="6" stroke="white" stroke-width="1.5"/>
                  <path d="M28 34 L30 36 L33 32" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {i === 3 && (
                <svg class="stop-svg-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M24 6 L28 20 L24 18 L20 20 Z" stroke="white" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                  <path d="M20 20 L16 26 L24 18 L32 26 L28 20" stroke="white" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                  <path d="M16 26 L14 42 L24 36 L34 42 L32 26" stroke="white" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                  <circle cx="24" cy="38" r="1" fill="white"/>
                  <circle cx="20" cy="40" r="0.8" fill="white" opacity="0.6"/>
                  <circle cx="28" cy="40" r="0.8" fill="white" opacity="0.6"/>
                </svg>
              )}
              {i === 4 && (
                <svg class="stop-svg-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M24 8 C18 8 12 14 12 22 C12 30 18 36 24 40 C30 36 36 30 36 22 C36 14 30 8 24 8Z" stroke="white" stroke-width="1.5" fill="none"/>
                  <path d="M16 20 C18 16 22 14 24 18 C26 14 30 16 32 20" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                  <path d="M16 24 C18 28 22 30 24 26 C26 30 30 28 32 24" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                  <line x1="24" y1="14" x2="24" y2="32" stroke="white" stroke-width="1" opacity="0.4"/>
                </svg>
              )}
            </div>
            <div class="stop-stage">Stage {i + 1}</div>
            <h3 class="stop-title">{stop.title}</h3>
            <p class="stop-description">{stop.description}</p>
            <div class="stop-features">
              {stop.features.map((f) => (
                <span class="stop-feature-item">
                  <svg class="stop-feature-check" viewBox="0 0 16 16" fill="none"><path d="M3 8.5 L6.5 12 L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {f}
                </span>
              ))}
            </div>
          </div>
        );
      })}

      <!-- Header overlay (shows at start) -->
      <div class="road-header" data-road-header>
        {title && <h2 class="road-title">{title}</h2>}
        {subtitle && <p class="road-subtitle">{subtitle}</p>}
        <div class="road-scroll-hint">
          <span>Scroll to begin</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 4v12M4 10l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Progress dots -->
      <div class="road-progress-dots">
        {stops.map((_, i) => (
          <button
            class={`progress-dot ${i === 0 ? 'active' : ''}`}
            data-dot-index={i}
            aria-label={`Go to stop ${i + 1}: ${stops[i].title}`}
          ></button>
        ))}
      </div>

      <!-- Persistent mini-CTA -->
      <a href="/#contact" class="road-demo-cta">
        Book a Demo &rarr;
      </a>
    </div>
  </div>
</section>

<!-- Mobile: Stacked cards -->
<section class="engagement-road-mobile" aria-label={title}>
  <div class="road-mobile-container">
    {title && <h2 class="road-mobile-title">{title}</h2>}
    {subtitle && <p class="road-mobile-subtitle">{subtitle}</p>}
    <div class="road-mobile-stops">
      {stops.map((stop, i) => (
        <div class="road-mobile-card" style={`border-left-color: ${stop.color};`}>
          <div class="road-mobile-card-header">
            <span class="road-mobile-icon">{stop.icon}</span>
            <div>
              <span class="road-mobile-stage" style={`color: ${stop.color};`}>Stage {i + 1}</span>
              <h3 class="road-mobile-card-title">{stop.title}</h3>
            </div>
          </div>
          <p class="road-mobile-card-desc">{stop.description}</p>
          <div class="road-mobile-features">
            {stop.features.map((f) => (
              <span class="road-mobile-feature">{f}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Desktop: space journey ── */
  .engagement-road {
    position: relative;
    display: block;
  }

  .road-scroll-spacer {
    position: relative;
  }

  .road-viewport {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: linear-gradient(to bottom, #0a0a1a 0%, #111827 50%, #0f172a 100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.8s ease;
    will-change: transform;
    transform-origin: center center;
  }

  /* Star parallax layers */
  .stars-far, .stars-near {
    position: absolute;
    inset: 0;
    pointer-events: none;
    will-change: transform;
    z-index: 1;
  }
  .parallax-star {
    position: absolute;
    background: #ffffff;
    border-radius: 50%;
  }

  /* Star streaks during transitions */
  .star-streaks {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }
  .streak-line {
    position: absolute;
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.3s ease;
  }
  .star-streaks.active .streak-line {
    transform: scaleX(1);
  }

  /* Starfield */
  .starfield {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .star {
    position: absolute;
    background: #ffffff;
    border-radius: 50%;
  }

  /* Warp speed transition: stars elongate */
  .road-viewport.transitioning .star {
    width: 20px !important;
    height: 1px !important;
    border-radius: 0;
    transition: width 0.3s ease, height 0.3s ease, border-radius 0.3s ease;
  }
  .star {
    transition: width 0.3s ease, height 0.3s ease, border-radius 0.3s ease;
  }

  /* Stop content panels */
  .stop-content {
    position: absolute;
    top: 50%;
    left: 50%;
    text-align: center;
    max-width: 672px;
    width: 90%;
    max-height: 50vh;
    z-index: 5;
    will-change: transform, opacity;
    transition: transform 0.5s var(--ease-spring, cubic-bezier(0.16, 1, 0.3, 1)),
                opacity 0.4s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stop-content[data-state="approaching"] {
    transform: translate(-50%, -50%) scale(0.2);
    opacity: 0;
    pointer-events: none;
  }
  .stop-content[data-state="active"] {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
    pointer-events: auto;
  }
  .stop-content[data-state="passed"] {
    transform: translate(-50%, -50%) scale(2.5);
    opacity: 0;
    pointer-events: none;
  }

  /* Nebula glow behind icon */
  .stop-nebula-glow {
    position: absolute;
    top: -30px;
    left: 50%;
    transform: translateX(-50%);
    width: 240px;
    height: 120px;
    border-radius: 50%;
    opacity: 0.2;
    filter: blur(50px);
    pointer-events: none;
    z-index: -1;
  }

  /* SVG icon wrapper with stage glow */
  .stop-icon-wrap {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
    position: relative;
    filter: drop-shadow(0 0 12px var(--stage-glow));
  }
  .stop-svg-icon {
    width: 48px;
    height: 48px;
  }

  .stop-stage {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-green, #00C26D);
    margin-bottom: 0.25rem;
  }

  .stop-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .stop-description {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 auto 1rem;
    max-width: 560px;
  }

  /* 2-column feature grid */
  .stop-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-top: 0.5rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .stop-feature-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    text-align: left;
  }

  .stop-feature-check {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: #22c55e;
  }

  /* Header overlay */
  .road-header {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 6;
    max-width: 640px;
    width: 90%;
    transition: opacity 0.5s ease;
  }
  .road-header.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .road-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .road-subtitle {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 1.5rem;
  }

  .road-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8rem;
    animation: hint-bounce 2s ease-in-out infinite;
  }
  @keyframes hint-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Progress dots */
  .road-progress-dots {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 10;
  }
  .progress-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .progress-dot.active {
    background: #22c55e;
    transform: scale(1.4);
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.6), 0 0 24px rgba(34, 197, 94, 0.3);
  }

  /* Floating decorative orbs */
  .floating-orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }
  .floating-orb {
    position: absolute;
    border-radius: 50%;
    opacity: 0.4;
    filter: blur(1px);
    background: currentColor;
    animation-duration: 6s;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    animation-fill-mode: both;
    transition: all 0.8s ease;
  }
  .road-viewport.paused .floating-orb {
    animation-play-state: paused;
  }

  @keyframes orb-drift-left {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(12px, -8px); }
  }
  @keyframes orb-drift-right {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-12px, 6px); }
  }

  /* Persistent demo CTA */
  .road-demo-cta {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 20;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--color-green, #00C26D);
    color: white;
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    transition: background 0.2s ease;
  }
  .road-demo-cta:hover {
    background: var(--color-green-hover, #00A95E);
  }

  /* ── Mobile: stacked cards ── */
  .engagement-road-mobile {
    display: none;
  }

  .road-mobile-container {
    max-width: var(--content-width, 1140px);
    margin: 0 auto;
    padding: var(--v-space-xl, 4rem) 1.5rem;
  }

  .road-mobile-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    color: var(--color-ink, #0D0D0D);
    margin: 0 0 0.75rem;
    text-align: center;
  }

  .road-mobile-subtitle {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    color: var(--color-ink-muted, #6b6b6b);
    line-height: 1.6;
    text-align: center;
    margin: 0 auto 2rem;
    max-width: 600px;
  }

  .road-mobile-stops {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .road-mobile-card {
    background: #fff;
    border: 1px solid var(--color-cloud-grey, #E1E3E6);
    border-left: 4px solid;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
  }

  .road-mobile-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .road-mobile-icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .road-mobile-stage {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 0.1rem;
  }

  .road-mobile-card-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-ink, #0D0D0D);
    margin: 0;
    line-height: 1.25;
  }

  .road-mobile-card-desc {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.92rem;
    color: var(--color-ink-light, #3d3d3d);
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .road-mobile-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .road-mobile-feature {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background: var(--color-soft-mint, #E8FBF1);
    color: var(--color-emerald, #037A47);
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 100px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .engagement-road {
      display: none;
    }
    .engagement-road-mobile {
      display: block;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .engagement-road {
      display: none;
    }
    .engagement-road-mobile {
      display: block;
    }
    .road-scroll-hint {
      animation: none;
    }
    .road-viewport {
      transition: none !important;
      transform: none !important;
      will-change: auto;
    }
    .stars-far, .stars-near {
      transform: none !important;
      will-change: auto;
    }
    .star-streaks {
      display: none;
    }
  }
</style>

<script is:inline>
  function initEngagementRoad() {
    var section = document.querySelector('.engagement-road');
    if (!section) return;

    var spacer = section.querySelector('.road-scroll-spacer');
    var viewport = section.querySelector('.road-viewport');
    var stops = section.querySelectorAll('.stop-content');
    var dots = section.querySelectorAll('.progress-dot');
    var header = section.querySelector('[data-road-header]');
    var nearStars = section.querySelector('.stars-near');
    var farStars = section.querySelector('.stars-far');
    var streaks = section.querySelector('.star-streaks');
    var totalStops = stops.length;

    if (!spacer || totalStops === 0) return;

    // Check for reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Stop accent colors for background color shift
    var stopColors = ['#00C26D', '#4C82A7', '#FFB02E', '#26A899', '#8B5CF6'];

    var lastActiveIndex = -1;
    var transitionTimeout = null;

    function updateRoad() {
      var rect = spacer.getBoundingClientRect();
      var scrollable = rect.height - window.innerHeight;
      if (scrollable <= 0) return;

      var scrolled = Math.max(0, -rect.top);
      var progress = Math.min(1, scrolled / scrollable);

      // Fade header after initial scroll
      if (header) {
        if (progress > 0.02) {
          header.classList.add('hidden');
        } else {
          header.classList.remove('hidden');
        }
      }

      // Which stop should be active?
      var rawIndex = progress * totalStops;
      var activeIndex = Math.min(totalStops - 1, Math.floor(rawIndex));
      var withinStop = rawIndex - activeIndex; // 0 to 1 progress within current stop

      // ── Viewport drift/sway during transitions ──
      var swayX = Math.sin(withinStop * Math.PI) * 30;
      var swayY = Math.sin(withinStop * Math.PI * 0.7) * 15;
      var rotation = Math.sin(withinStop * Math.PI) * 1.5;
      var zoom = 1 + (Math.sin(withinStop * Math.PI) * 0.03);

      if (viewport) {
        viewport.style.transform = 'translate(' + swayX + 'px, ' + swayY + 'px) rotate(' + rotation + 'deg) scale(' + zoom + ')';
      }

      // ── Star parallax ──
      if (nearStars) {
        nearStars.style.transform = 'translate(' + (swayX * 2) + 'px, ' + (-scrolled * 0.1) + 'px)';
      }
      if (farStars) {
        farStars.style.transform = 'translate(' + (swayX * 0.5) + 'px, ' + (-scrolled * 0.03) + 'px)';
      }

      // ── Star streaks during mid-transition ──
      if (streaks) {
        var isTransitioning = withinStop > 0.2 && withinStop < 0.8;
        if (isTransitioning) {
          streaks.style.opacity = '1';
          streaks.classList.add('active');
        } else {
          streaks.style.opacity = '0';
          streaks.classList.remove('active');
        }
      }

      // ── Background color shift ──
      if (viewport) {
        var currentColor = stopColors[activeIndex] || stopColors[0];
        viewport.style.background = 'radial-gradient(ellipse at 50% 30%, ' + currentColor + '15 0%, #0a0a1a 70%)';
      }

      stops.forEach(function(stop, i) {
        // Clear any inline style overrides
        stop.style.transform = '';
        stop.style.opacity = '';

        if (i < activeIndex) {
          stop.dataset.state = 'passed';
        } else if (i === activeIndex) {
          stop.dataset.state = 'active';
        } else {
          stop.dataset.state = 'approaching';
        }
      });

      // Pause orbs while a stop is active (not transitioning)
      if (viewport) {
        viewport.classList.add('paused');
      }

      // Warp speed effect on transition
      if (activeIndex !== lastActiveIndex) {
        if (viewport && lastActiveIndex >= 0) {
          viewport.classList.remove('paused');
          viewport.classList.add('transitioning');
          if (transitionTimeout) clearTimeout(transitionTimeout);
          transitionTimeout = setTimeout(function() {
            viewport.classList.remove('transitioning');
            viewport.classList.add('paused');
          }, 300);
        }

        // Update orb colors to match active stop's accent
        var orbColors = ['#22c55e', '#3b82f6', '#f59e0b', '#14b8a6', '#a855f7'];
        var orbColor = orbColors[activeIndex] || orbColors[0];
        var orbs = section.querySelectorAll('.floating-orb');
        orbs.forEach(function(orb) {
          orb.style.color = orbColor;
          orb.style.boxShadow = '0 0 6px ' + orbColor;
        });

        dots.forEach(function(dot, i) {
          if (i === activeIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
        lastActiveIndex = activeIndex;
      }
    }

    var ticking = false;
    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(function() {
          updateRoad();
          ticking = false;
        });
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    updateRoad();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEngagementRoad);
  } else {
    initEngagementRoad();
  }
  document.addEventListener('astro:page-load', initEngagementRoad);
</script>
