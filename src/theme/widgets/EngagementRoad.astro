  /* ===== Reduced Motion ===== */
  @media (prefers-reduced-motion: reduce) {
    .journey {
      display: none;
    }
    .journey-mobile {
      display: block;
    }
    .journey-scroll-hint {
      animation: none;
    }
    .journey-astronaut {
      animation: none;
    }
  }
</style>

<script is:inline>
  function initJourney() {
    var section = document.querySelector('.journey');
    if (!section) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var spacer = section.querySelector('.journey-scroll-spacer');
    var header = section.querySelector('[data-journey-header]');
    var panels = section.querySelectorAll('.station-panel');
    var progressDots = section.querySelectorAll('.journey-progress-dot');
    var progressFill = section.querySelector('.journey-progress-fill');
    var trailFill = section.querySelector('.journey-trail-fill');
    var astronaut = section.querySelector('.journey-astronaut');
    var totalStations = panels.length;

    if (!spacer || totalStations === 0) return;

    var lastActiveIndex = -1;

    function update() {
      var rect = spacer.getBoundingClientRect();
      var scrollable = rect.height - window.innerHeight;
      if (scrollable <= 0) return;

      var scrolled = Math.max(0, -rect.top);
      var progress = Math.min(1, scrolled / scrollable);

      // Fade header
      if (header) {
        if (progress > 0.02) {
          header.classList.add('hidden');
        } else {
          header.classList.remove('hidden');
        }
      }

      // Determine active station
      var rawIndex = progress * totalStations;
      var activeIndex = Math.min(totalStations - 1, Math.floor(rawIndex));

      // Update station states
      panels.forEach(function(panel, i) {
        if (i < activeIndex) {
          panel.dataset.stationState = 'passed';
        } else if (i === activeIndex) {
          panel.dataset.stationState = 'active';
        } else {
          panel.dataset.stationState = 'upcoming';
        }
      });

      // Update progress dots
      progressDots.forEach(function(dot, i) {
        dot.classList.remove('active', 'reached');
        if (i < activeIndex) {
          dot.classList.add('reached');
        } else if (i === activeIndex) {
          dot.classList.add('active');
        }
      });

      // Update progress fill line
      if (progressFill) {
        var fillPercent = totalStations > 1 ? (activeIndex / (totalStations - 1)) * 100 : 0;
        progressFill.style.height = fillPercent + '%';
      }

      // Update connection trail fill
      if (trailFill) {
        var trailPercent = totalStations > 1 ? (activeIndex / (totalStations - 1)) * 100 : 0;
        trailFill.style.height = trailPercent + '%';
      }

      // Position astronaut near active station
      if (astronaut) {
        var activePanel = panels[activeIndex];
        if (activePanel && activePanel.dataset.stationState === 'active') {
          astronaut.classList.add('visible');
          // Position to the right of center, offset from station
          var vpRect = section.querySelector('.journey-viewport').getBoundingClientRect();
          var centerX = vpRect.width / 2;
          var centerY = vpRect.height / 2;
          astronaut.style.left = (centerX + 180) + 'px';
          astronaut.style.top = (centerY - 80) + 'px';
        }
        if (progress < 0.01) {
          astronaut.classList.remove('visible');
        }
      }

      lastActiveIndex = activeIndex;
    }

    var ticking = false;
    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(function() {
          update();
          ticking = false;
        });
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initJourney);
  } else {
    initJourney();
  }
  document.addEventListener('astro:page-load', initJourney);
</script>
