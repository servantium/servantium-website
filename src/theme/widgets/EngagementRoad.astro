                    <!-- Central brain node -->
                    <circle cx="200" cy="150" r="28" fill="#faf5ff" stroke="#8B5CF6" stroke-width="1.5"/>
                    <path d="M188 145 C188 138 195 132 200 132 C205 132 212 138 212 145" stroke="#8B5CF6" stroke-width="1.5" fill="none"/>
                    <path d="M188 148 C188 155 195 161 200 161 C205 161 212 155 212 148" stroke="#8B5CF6" stroke-width="1.5" fill="none"/>
                    <line x1="200" y1="132" x2="200" y2="161" stroke="#8B5CF6" stroke-width="1" opacity="0.4"/>
                    <line x1="188" y1="146" x2="212" y2="146" stroke="#8B5CF6" stroke-width="1" opacity="0.4"/>
                    <!-- Outer nodes -->
                    <circle cx="100" cy="90" r="18" fill="#E8FBF1" stroke="#00C26D" stroke-width="1"/>
