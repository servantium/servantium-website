                    <circle cx="310" cy="80" r="18" fill="#eff6ff" stroke="#4C82A7" stroke-width="1"/>
                    <text x="310" y="77" text-anchor="middle" font-size="7" fill="#4C82A7" font-family="sans-serif">Quote</text>
                    <text x="310" y="87" text-anchor="middle" font-size="7" fill="#4C82A7" font-family="sans-serif">History</text>
                    <circle cx="80" cy="200" r="18" fill="#fffbeb" stroke="#FFB02E" stroke-width="1"/>
                    <text x="80" y="197" text-anchor="middle" font-size="7" fill="#FFB02E" font-family="sans-serif">Delivery</text>
                    <text x="80" y="207" text-anchor="middle" font-size="7" fill="#FFB02E" font-family="sans-serif">Logs</text>
                    <circle cx="320" cy="200" r="18" fill="#f0fdfa" stroke="#26A899" stroke-width="1"/>
                    <text x="320" y="197" text-anchor="middle" font-size="7" fill="#26A899" font-family="sans-serif">Team</text>
                    <text x="320" y="207" text-anchor="middle" font-size="7" fill="#26A899" font-family="sans-serif">Patterns</text>
                    <circle cx="150" cy="250" r="18" fill="#faf5ff" stroke="#8B5CF6" stroke-width="1"/>
                    <text x="150" y="247" text-anchor="middle" font-size="7" fill="#8B5CF6" font-family="sans-serif">Service</text>
                    <text x="150" y="257" text-anchor="middle" font-size="7" fill="#8B5CF6" font-family="sans-serif">Catalog</text>
                    <circle cx="270" cy="250" r="18" fill="#faf5ff" stroke="#8B5CF6" stroke-width="1"/>
                    <text x="270" y="247" text-anchor="middle" font-size="7" fill="#8B5CF6" font-family="sans-serif">Vector</text>
                    <text x="270" y="257" text-anchor="middle" font-size="7" fill="#8B5CF6" font-family="sans-serif">Index</text>
                    <!-- Data flow arrows -->
                    <polygon points="175,143 168,148 168,138" fill="#8B5CF6" opacity="0.4"/>
                    <polygon points="225,157 232,152 232,162" fill="#8B5CF6" opacity="0.4"/>
                  </svg>
                )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Green thread SVG — positioned at bottom of viewport as horizontal progress bar -->
    <svg class="filmstrip-thread absolute left-0 w-full pointer-events-none z-10" style="bottom: 120px; height: 3px;" preserveAspectRatio="none" viewBox="0 0 1000 3">
      <line x1="0" y1="1.5" x2="1000" y2="1.5" stroke="#E8FBF1" stroke-width="3"/>
      <line id="thread-progress" x1="0" y1="1.5" x2="0" y2="1.5" stroke="#00C26D" stroke-width="3" stroke-linecap="round"/>
    </svg>

    <!-- Progress dots — positioned at bottom aligned with thread -->
    <div class="filmstrip-dots absolute left-0 w-full flex justify-between px-[10%] z-20 pointer-events-none" style="bottom: 114px;">
      {stops.map((_, i) => (
        <div class="filmstrip-dot w-3 h-3 rounded-full transition-all duration-300" style="background: #E1E3E6;" />
      ))}
    </div>

    <!-- Stage name labels below progress dots -->
    <div class="filmstrip-stage-labels absolute left-0 w-full flex justify-between px-[10%] z-20 pointer-events-none" style="bottom: 85px;">
      {stageNames.map((name, i) => (
        <span
          class="filmstrip-stage-label text-xs opacity-40 transition-all duration-300 text-center"
          data-stage={i}
          style={`color: ${panels[i].accent};`}
        >
          {name}
        </span>
      ))}
    </div>

  </div>

  <!-- Mobile: Stacked cards (hidden on desktop, shown via CSS) -->
  <div class="filmstrip-mobile">
    <!-- Vertical green thread on the left -->
    <div class="filmstrip-mobile-thread" aria-hidden="true"></div>

    {stops.map((stop, i) => {
      const panel = panels[i] || panels[0];
      return (
        <div class="filmstrip-mobile-card" data-animate="fade-up" data-delay={String(i * 100)}>
          <!-- Dot on the thread -->
          <div class="filmstrip-mobile-dot" style={`background: ${panel.accent};`}></div>
          <div class="filmstrip-mobile-content">
            <span class="text-5xl font-bold leading-none select-none" style={`color: ${panel.accent}; opacity: 0.1;`}>{panel.number}</span>
            <h3 class="text-2xl font-medium -mt-8 mb-2" style="font-family: var(--font-display); color: var(--color-ink);">
              {stop.title}
            </h3>
            <p class="text-base leading-relaxed mb-1" style="color: var(--color-ink-muted);">
              {stop.description}
            </p>
            <p class="text-xs font-semibold italic mb-4" style={`color: ${panel.accent};`}>
              {taglines[i]}
            </p>
            <div class="grid grid-cols-2 gap-2">
              {stop.features.map((feature) => (
                <span class="flex items-center gap-1.5 text-xs" style="color: var(--color-ink-light);">
                  <svg class="w-3.5 h-3.5 flex-shrink-0" style={`color: ${panel.accent};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {feature}
                </span>
              ))}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  /* Desktop filmstrip — hidden on mobile */
  .filmstrip-viewport {
    display: flex;
    flex-direction: column;
  }

  .filmstrip-track {
    flex: 1;
    display: flex;
    align-items: stretch;
  }

  .filmstrip-panel {
    width: 100vw;
    min-height: 80vh;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 6vh 2rem 0;
  }

  .filmstrip-mobile {
    display: none;
  }

  /* Mobile layout */
  @media (max-width: 767px) {
    .filmstrip-section {
      min-height: auto !important;
    }
    .filmstrip-viewport {
      display: none !important;
    }
    .filmstrip-mobile {
      display: block;
      position: relative;
      padding: 0 1.5rem 3rem 3rem;
    }
    .filmstrip-mobile-thread {
      position: absolute;
      left: 2.25rem;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, #00C26D, #8B5CF6);
      opacity: 0.25;
    }
    .filmstrip-mobile-card {
      position: relative;
      padding: 1.5rem 0;
    }
    .filmstrip-mobile-dot {
      position: absolute;
      left: -1.3rem;
      top: 2rem;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      box-shadow: 0 0 6px rgba(0,194,109,0.3);
    }
    .filmstrip-mobile-content {
      background: white;
      border-radius: 12px;
      padding: 1.5rem;
      border: 1px solid var(--color-cloud-grey);
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
  }

  /* Reduced motion: show all panels stacked, no horizontal scroll */
  @media (prefers-reduced-motion: reduce) {
    .filmstrip-section {
      min-height: auto !important;
    }
    .filmstrip-viewport {
      position: relative !important;
      top: auto !important;
      height: auto !important;
      overflow: visible !important;
    }
    .filmstrip-track {
      flex-direction: column !important;
      width: 100% !important;
      transform: none !important;
    }
    .filmstrip-panel {
      width: 100% !important;
      height: auto !important;
      min-height: 0 !important;
      padding: 4rem 0;
    }
    .filmstrip-thread,
    .filmstrip-dots,
    .filmstrip-astronaut,
    .filmstrip-stage-labels {
      display: none !important;
    }
  }
</style>

<script is:inline>
function initFilmstrip() {
  // Bail on mobile
  if (window.innerWidth < 768) return;

  // Bail on prefers-reduced-motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var section = document.querySelector('.filmstrip-section');
  var viewport = document.querySelector('.filmstrip-viewport');
  var track = document.getElementById('filmstrip-track');
  var threadProgress = document.getElementById('thread-progress');
  var dots = document.querySelectorAll('.filmstrip-dot');
  var stageLabels = document.querySelectorAll('.filmstrip-stage-label');
  var astronaut = viewport ? viewport.querySelector('.filmstrip-astronaut') : null;
  if (!section || !track || !viewport) return;

  var heroTitle = document.getElementById('filmstrip-hero-title');
  var sectionLabel = document.getElementById('filmstrip-section-label');
  var panelLabels = ['The Engagement Journey', 'Scope & Discover', 'Estimate & Price', 'Propose & Win', 'Deliver & Staff', 'Learn & Improve'];
  var totalPanels = 5;
  var running = false;
  var slack = 100; // px of scroll before filmstrip starts moving

  // Set initial state: panel 0 active, translateX 0
  track.style.transform = 'translateX(0vw)';
  if (threadProgress) {
    threadProgress.setAttribute('x2', '0');
  }
  if (astronaut) {
    astronaut.style.left = '10%';
  }
  dots.forEach(function(dot, i) {
    if (i === 0) {
      dot.style.background = '#00C26D';
      dot.style.boxShadow = '0 0 8px rgba(0,194,109,0.5)';
    } else {
      dot.style.background = '#E1E3E6';
      dot.style.boxShadow = 'none';
    }
  });
  stageLabels.forEach(function(label, i) {
    if (i === 0) {
      label.style.opacity = '1';
      label.style.fontSize = '0.875rem';
    } else {
      label.style.opacity = '0.4';
      label.style.fontSize = '0.75rem';
    }
  });

  function update() {
    if (!running) return;

    var rect = section.getBoundingClientRect();
    var scrollable = rect.height - window.innerHeight;
    if (scrollable <= 0) {
      requestAnimationFrame(update);
      return;
    }

    // Only start counting after section top passes viewport top + slack
    var scrolled = Math.max(0, -rect.top - slack);
    var progress = Math.min(1, scrolled / (scrollable - slack));

    // Clamp progress to 0 when section hasn't reached top yet
    if (rect.top > 0) {
      progress = 0;
    }

    // Move track left (0 to -400vw)
    var translateX = progress * (totalPanels - 1) * -100;
    track.style.transform = 'translateX(' + translateX + 'vw)';

    // Flying title: visible at progress 0, fades out by progress 0.15
    if (heroTitle) {
      var titleFade = Math.max(0, 1 - (progress / 0.12));
      heroTitle.style.opacity = String(titleFade);
      heroTitle.style.transform = 'translateY(' + (-progress * 200) + 'px) scale(' + (1 + progress * 0.1) + ')';
    }

    // Extend green thread
    if (threadProgress) {
      threadProgress.setAttribute('x2', String(progress * 1000));
    }

    // Move astronaut along the thread
    if (astronaut) {
      astronaut.style.left = (10 + progress * 80) + '%';
    }

    // Update section label per panel
    var activeIndex = Math.min(totalPanels - 1, Math.floor(progress * totalPanels));
    if (sectionLabel) {
      var labelIdx = progress < 0.02 ? 0 : activeIndex + 1;
      sectionLabel.textContent = panelLabels[labelIdx] || panelLabels[0];
    }

    // Update dots
    dots.forEach(function(dot, i) {
      if (i <= activeIndex) {
        dot.style.background = '#00C26D';
        dot.style.boxShadow = '0 0 8px rgba(0,194,109,0.5)';
      } else {
        dot.style.background = '#E1E3E6';
        dot.style.boxShadow = 'none';
      }
    });

    // Update stage labels
    stageLabels.forEach(function(label, i) {
      if (i <= activeIndex) {
        label.style.opacity = '1';
        label.style.fontSize = '0.875rem';
      } else {
        label.style.opacity = '0.4';
        label.style.fontSize = '0.75rem';
      }
    });

    // Switch astronaut costume based on active panel
    if (astronaut) {
      var costumes = astronaut.querySelectorAll('.astronaut-costume');
      costumes.forEach(function(c) {
        c.style.display = parseInt(c.getAttribute('data-costume')) === activeIndex ? '' : 'none';
      });
    }

    requestAnimationFrame(update);
  }

  var observer = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) {
      if (!running) {
        running = true;
        requestAnimationFrame(update);
      }
    } else {
      running = false;
    }
  }, { threshold: 0 });

  observer.observe(section);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initFilmstrip);
} else {
  initFilmstrip();
}
document.addEventListener('astro:page-load', initFilmstrip);
</script>
