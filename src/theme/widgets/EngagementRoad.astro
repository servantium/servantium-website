---
import Astronaut from '@/theme/components/Astronaut.astro';

interface RoadStop {
  title: string;
  tagline?: string;
  description: string;
  features: string[];
  color: string;
  icon: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  stops: RoadStop[];
}

const {
  title = 'Engagement Management for Professional Services',
  subtitle = 'Everything revolves around the Engagement — a living record from first conversation through delivery.',
  stops,
} = Astro.props;

const panels = [
  { number: '01', bg: 'linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%)', accent: '#00C26D', astronaut: 'detective' as const },
  { number: '02', bg: 'linear-gradient(135deg, #ffffff 0%, #eff6ff 100%)', accent: '#4C82A7', astronaut: 'professor' as const },
  { number: '03', bg: 'linear-gradient(135deg, #ffffff 0%, #fffbeb 100%)', accent: '#FFB02E', astronaut: 'captain' as const },
  { number: '04', bg: 'linear-gradient(135deg, #ffffff 0%, #f0fdfa 100%)', accent: '#26A899', astronaut: 'chef' as const },
  { number: '05', bg: 'linear-gradient(135deg, #ffffff 0%, #faf5ff 100%)', accent: '#8B5CF6', astronaut: 'cowboy' as const },
];

const taglines = stops.map(s => s.tagline || '');

const stageNames = ['Discovery', 'Estimation', 'Proposal', 'Delivery', 'Learning'];
---

<!-- Filmstrip: Horizontal scroll driven by vertical scroll -->
<section class="filmstrip-section" style="min-height: 300vh; overflow: visible;" aria-label={title}>

  <!-- Sticky viewport -->
  <div class="filmstrip-viewport sticky top-0 h-screen overflow-hidden" style="-webkit-overflow-scrolling: touch;">

    <!-- Title — positioned at top of viewport, fades out as scroll progresses -->
    <div class="absolute top-0 left-0 right-0 z-30 pointer-events-none flex items-center justify-center" id="filmstrip-hero-title" style="height: 30vh;">
      <div class="text-center px-6">
        <div class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-green); letter-spacing: 0.12em;" id="filmstrip-section-label">The Engagement Journey</div>
        <h2 class="text-2xl md:text-4xl lg:text-5xl font-medium leading-tight" style="font-family: var(--font-display); color: var(--color-ink);">From first conversation<br/>to institutional memory</h2>
      </div>
    </div>

    <!-- Astronaut hopping above the thread — one per costume, toggled by script -->
    <div class="filmstrip-astronaut absolute z-[25]" style="bottom: 140px; left: 10%; transition: left 0.5s cubic-bezier(0.16, 1, 0.3, 1);">
      <div class="astronaut-costume" data-costume="0"><Astronaut size="md" variant="detective" /></div>
      <div class="astronaut-costume" data-costume="1" style="display:none;"><Astronaut size="md" variant="professor" /></div>
      <div class="astronaut-costume" data-costume="2" style="display:none;"><Astronaut size="md" variant="captain" /></div>
      <div class="astronaut-costume" data-costume="3" style="display:none;"><Astronaut size="md" variant="chef" /></div>
      <div class="astronaut-costume" data-costume="4" style="display:none;"><Astronaut size="md" variant="cowboy" /></div>
    </div>

    <!-- Panels track -->
    <div class="filmstrip-track flex" style="width: 500vw;" id="filmstrip-track">
      {stops.map((stop, i) => {
        const panel = panels[i] || panels[0];
        return (
          <div
            class="filmstrip-panel"
            data-panel={i}
            style={`background: ${panel.bg};`}
          >
            <div class="mx-auto max-w-7xl px-6 grid grid-cols-1 lg:grid-cols-2 gap-8 items-center w-full h-full">

              <!-- Left: Text content -->
              <div>
                <!-- Per-panel label removed; persistent overlay at top handles this -->
                <span class="text-[12rem] font-bold leading-none select-none block" style={`color: ${panel.accent}; opacity: 0.08;`}>{panel.number}</span>
                <h3 class="text-4xl md:text-5xl font-medium -mt-20 mb-4" style="font-family: var(--font-display); color: var(--color-ink);">
                  {stop.title}
                </h3>
                <p class="text-lg leading-relaxed mb-2 max-w-lg" style="color: var(--color-ink-muted);">
                  {stop.description}
                </p>
                <p class="text-sm font-semibold italic mb-6" style={`color: ${panel.accent};`}>
                  {taglines[i]}
                </p>
                <div class="grid grid-cols-2 gap-3">
                  {stop.features.map((feature) => (
                    <span class="flex items-center gap-2 text-base" style="color: var(--color-ink-light);">
                      <svg class="w-4 h-4 flex-shrink-0" style={`color: ${panel.accent};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      {feature}
                    </span>
                  ))}
                </div>
              </div>

              <!-- Right: Mockup SVG with card stack (hidden on mobile) -->
              <div class="hidden lg:flex items-center justify-center">
                <div class="relative w-full max-w-2xl">
                  <!-- Shadow/background card -->
                  <div class="absolute -top-3 -right-3 w-full h-full rounded-xl bg-slate-100 border border-slate-200 -z-10"></div>
                  <!-- Main mockup card -->
                  <div class="relative bg-white rounded-xl border border-slate-200 shadow-lg p-4">
                {i === 0 && (
                  <!-- Discovery: Engagement info screen -->
                  <svg viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" style="display: block;">
                    <rect x="1" y="1" width="398" height="298" rx="12" fill="white" stroke="#E1E3E6" stroke-width="1"/>
                    <circle cx="20" cy="16" r="4" fill="#FF5C70"/>
