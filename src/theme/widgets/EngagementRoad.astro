                    <rect x="142" y="38" width="60" height="24" rx="4" fill="transparent"/>
                    <text x="172" y="54" text-anchor="middle" font-size="9" fill="#6b6b6b" font-family="sans-serif">Timeline</text>
                    <!-- Contact card -->
