                    <circle cx="48" cy="104" r="16" fill="#E8FBF1" stroke="#00C26D" stroke-width="1"/>
                    <text x="48" y="108" text-anchor="middle" font-size="12" fill="#00C26D" font-family="sans-serif">JD</text>
                    <rect x="74" y="94" width="90" height="8" rx="2" fill="#0D0D0D" opacity="0.7"/>
                    <rect x="74" y="108" width="60" height="6" rx="2" fill="#6b6b6b" opacity="0.4"/>
