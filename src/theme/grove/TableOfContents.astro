---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <nav aria-label="On this page" class="toc-nav">
    <h2 class="mb-3 text-[11px] font-semibold uppercase tracking-widest text-slate-400" style="font-family: var(--font-body);">
      On this page
    </h2>
    <div class="relative">
      {/* Green progress bar that slides to the active item */}
      <div class="toc-progress-track absolute left-0 top-0 bottom-0 w-[2px] bg-slate-100 rounded-full" />
      <div class="toc-progress-bar absolute left-0 top-0 w-[2px] bg-[var(--color-green)] rounded-full transition-all duration-300" style="height: 0; top: 0;" id="toc-progress" />

      <ul class="space-y-1 pl-3 text-[13px]" role="list">
        {headings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'grove-toc-link block py-1 transition-all duration-200',
                heading.depth === 3
                  ? 'pl-3 text-slate-400 hover:text-slate-600'
                  : 'text-slate-500 hover:text-slate-800',
              ]}
              data-toc-link
              data-toc-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<script>
  document.addEventListener('astro:page-load', () => {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (tocLinks.length === 0) return;

    const slugs = Array.from(tocLinks).map((link) => link.dataset.tocSlug!);
    const headingElements = slugs
      .map((slug) => document.getElementById(slug))
      .filter(Boolean) as HTMLElement[];

    if (headingElements.length === 0) return;

    let activeSlug = '';

    const progressBar = document.getElementById('toc-progress');

    function setActive(slug: string) {
      if (slug === activeSlug) return;
      activeSlug = slug;

      tocLinks.forEach((link, index) => {
        const isCurrent = link.dataset.tocSlug === slug;
        if (isCurrent) {
          link.classList.add('!text-[var(--color-green)]', 'font-semibold');
          link.classList.remove('text-slate-500', 'text-slate-400');

          // Move green progress bar to this item
          if (progressBar) {
            const linkRect = link.getBoundingClientRect();
            const navRect = link.closest('.toc-nav')?.getBoundingClientRect();
            if (navRect) {
              const top = linkRect.top - navRect.top;
              progressBar.style.top = `${top + 28}px`; // offset for heading
              progressBar.style.height = `${linkRect.height}px`;
            }
          }
        } else {
          link.classList.remove('!text-[var(--color-green)]', 'font-semibold');
          if (link.classList.contains('pl-3')) {
            link.classList.add('text-slate-400');
          } else {
            link.classList.add('text-slate-500');
          }
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: '-80px 0px -65% 0px',
        threshold: 0,
      }
    );

    headingElements.forEach((el) => observer.observe(el));

    // Set initial active state
    if (slugs.length > 0) {
      setActive(slugs[0]);
    }

    // Smooth scroll on click
    tocLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = link.dataset.tocSlug!;
        const target = document.getElementById(slug);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', `#${slug}`);
          setActive(slug);
        }
      });
    });
  });
</script>
