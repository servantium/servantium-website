---
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import TestEnvBanner from '@/components/TestEnvBanner.astro';
import DocsSidebar from './DocsSidebar.astro';
import TableOfContents from './TableOfContents.astro';
import DocsSearch from './DocsSearch.astro';
import '@/theme/verdant.css';
import '@/styles/global.css';

import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';

import { docsNav } from '@/data/docs-nav';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
  currentSlug: string;
  lastUpdated?: string;
  editUrl?: string;
  autogeneratedItems?: Record<string, { label: string; slug: string }[]>;
}

const {
  title,
  description,
  headings = [],
  currentSlug,
  lastUpdated,
  editUrl,
  autogeneratedItems = {},
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Servantium Help</title>
  {description && <meta name="description" content={description} />}

  <TestEnvBanner />

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <slot name="head" />
</head>
<body class="flex flex-col min-h-screen font-body text-ink bg-white antialiased">
  <a href="#docs-content" class="skip-link">Skip to content</a>

  <Nav activePage="help" />

  <!-- Mobile sidebar toggle -->
  <button
    id="grove-sidebar-toggle"
    class="fixed bottom-6 right-6 z-50 flex items-center gap-2 rounded-full bg-green px-4 py-3 text-sm font-semibold text-white shadow-lg md:hidden"
    aria-label="Toggle documentation menu"
    aria-expanded="false"
    aria-controls="grove-sidebar-drawer"
  >
    <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
    Menu
  </button>

  <!-- Mobile sidebar drawer overlay -->
  <div
    id="grove-sidebar-drawer"
    class="fixed inset-0 z-[200] hidden"
    aria-hidden="true"
  >
    <div class="grove-drawer-backdrop absolute inset-0 bg-black/40" data-close-drawer></div>
    <aside class="grove-drawer-panel absolute inset-y-0 left-0 w-[300px] max-w-[85vw] overflow-y-auto bg-white p-6 pt-20 shadow-xl">
      <button
        class="absolute top-5 right-5 flex size-9 items-center justify-center rounded-md text-ink-muted hover:bg-mist-grey"
        data-close-drawer
        aria-label="Close menu"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <DocsSidebar currentSlug={currentSlug} nav={docsNav} autogeneratedItems={autogeneratedItems} />
    </aside>
  </div>

  <!-- Main docs layout -->
  <div class="flex-1 pt-[72px]">
    <div class="mx-auto flex max-w-[1440px]">
      <!-- Desktop sidebar -->
      <aside class="hidden md:block w-[280px] shrink-0 border-r border-cloud-grey">
        <div class="sticky top-[72px] h-[calc(100vh-72px)] overflow-y-auto p-6">
          <div class="mb-5">
            <DocsSearch />
          </div>
          <DocsSidebar currentSlug={currentSlug} nav={docsNav} autogeneratedItems={autogeneratedItems} />
        </div>
      </aside>

      <!-- Content area -->
      <main id="docs-content" class="min-w-0 flex-1 px-6 py-10 md:px-10 lg:px-16" tabindex="-1">
        <article class="mx-auto max-w-[720px]">
          <!-- Prose content -->
          <div class="grove-prose">
            <slot />
          </div>

          <!-- Edit link + last updated -->
          <footer class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-cloud-grey pt-6 text-sm text-ink-muted">
            {editUrl && (
              <a
                href={editUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 transition-colors hover:text-green"
              >
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Edit this page
              </a>
            )}
            {lastUpdated && (
              <span>Last updated: <time>{lastUpdated}</time></span>
            )}
          </footer>
        </article>
      </main>

      <!-- Table of Contents (desktop only) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block w-[220px] shrink-0">
          <div class="sticky top-[72px] h-[calc(100vh-72px)] overflow-y-auto p-6">
            <TableOfContents headings={tocHeadings} />
          </div>
        </aside>
      )}
    </div>
  </div>

  <Footer />
  <CookieConsent />

  <script>
    document.addEventListener('astro:page-load', () => {
      const toggle = document.getElementById('grove-sidebar-toggle');
      const drawer = document.getElementById('grove-sidebar-drawer');
      if (!toggle || !drawer) return;

      function openDrawer() {
        drawer!.classList.remove('hidden');
        drawer!.setAttribute('aria-hidden', 'false');
        toggle!.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        drawer!.classList.add('hidden');
        drawer!.setAttribute('aria-hidden', 'true');
        toggle!.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', openDrawer);

      drawer.querySelectorAll('[data-close-drawer]').forEach((el) => {
        el.addEventListener('click', closeDrawer);
      });

      // Close on nav link click inside drawer
      drawer.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeDrawer);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !drawer.classList.contains('hidden')) {
          closeDrawer();
        }
      });
    });
  </script>
</body>
</html>

<style>
  /* Prose typography for docs content */
  .grove-prose :global(h1) {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 1rem;
  }
  .grove-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-cloud-grey);
  }
  .grove-prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-ink);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .grove-prose :global(h4) {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .grove-prose :global(p) {
    color: var(--color-ink-light);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .grove-prose :global(a) {
    color: var(--color-green);
    text-decoration: underline;
    text-decoration-color: var(--color-pale-green);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s;
  }
  .grove-prose :global(a:hover) {
    text-decoration-color: var(--color-green);
  }
  .grove-prose :global(ul),
  .grove-prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--color-ink-light);
    font-size: 1rem;
    line-height: 1.75;
  }
  .grove-prose :global(li) {
    margin-bottom: 0.35rem;
  }
  .grove-prose :global(ul) {
    list-style-type: disc;
  }
  .grove-prose :global(ol) {
    list-style-type: decimal;
  }
  .grove-prose :global(code) {
    font-size: 0.875em;
    background: var(--color-mist-grey);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-ink);
  }
  .grove-prose :global(pre) {
    background: var(--color-ink);
    color: var(--color-cloud-grey);
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .grove-prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .grove-prose :global(blockquote) {
    border-left: 3px solid var(--color-green);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .grove-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-cloud-grey);
    margin: 2rem 0;
  }
  .grove-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.9375rem;
  }
  .grove-prose :global(th) {
    text-align: left;
    font-weight: 600;
    padding: 0.625rem 0.75rem;
    border-bottom: 2px solid var(--color-cloud-grey);
    color: var(--color-ink);
  }
  .grove-prose :global(td) {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--color-cloud-grey);
    color: var(--color-ink-light);
  }
  .grove-prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
</style>
