---
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import TestEnvBanner from '@/components/TestEnvBanner.astro';
import DocsSidebar from './DocsSidebar.astro';
import TableOfContents from './TableOfContents.astro';
import DocsPagination from './DocsPagination.astro';
import DocsSearch from './DocsSearch.astro';
import '@/theme/verdant.css';
import '@/styles/global.css';

import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface PaginationLink {
  label: string;
  slug: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
  currentSlug: string;
  lastUpdated?: string;
  editUrl?: string;
  prev?: PaginationLink | null;
  next?: PaginationLink | null;
}

const {
  title,
  description,
  headings = [],
  currentSlug,
  lastUpdated,
  editUrl,
  prev = null,
  next = null,
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Servantium Help</title>
  {description && <meta name="description" content={description} />}

  <TestEnvBanner />

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <slot name="head" />
</head>
<body class="flex min-h-screen flex-col font-body text-ink bg-white antialiased">
  <a href="#docs-content" class="skip-link">Skip to content</a>

  <Nav activePage="help" />

  <!-- Mobile sidebar toggle -->
  <button
    id="grove-sidebar-toggle"
    class="fixed bottom-6 right-6 z-50 flex items-center gap-2 rounded-full bg-green px-4 py-3 text-sm font-semibold text-white shadow-lg lg:hidden"
    aria-label="Toggle documentation menu"
    aria-expanded="false"
    aria-controls="grove-sidebar-drawer"
  >
    <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
    Menu
  </button>

  <!-- Mobile sidebar drawer overlay -->
  <div
    id="grove-sidebar-drawer"
    class="fixed inset-0 z-[200] hidden"
    aria-hidden="true"
  >
    <div class="absolute inset-0 bg-black/40 transition-opacity" data-close-drawer></div>
    <aside class="absolute inset-y-0 left-0 w-[300px] max-w-[85vw] overflow-y-auto bg-white shadow-xl">
      <div class="flex items-center justify-between border-b border-cloud-grey px-5 py-4">
        <span class="text-sm font-semibold text-ink">Documentation</span>
        <button
          class="flex size-8 items-center justify-center rounded-md text-ink-muted hover:bg-mist-grey hover:text-ink"
          data-close-drawer
          aria-label="Close menu"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="px-4 pt-4 pb-2">
        <DocsSearch />
      </div>
      <div class="px-4 pb-8">
        <DocsSidebar currentSlug={currentSlug} />
      </div>
    </aside>
  </div>

  <!-- Main docs layout: sidebar | content | toc -->
  <div class="flex-1 pt-[72px]">
    <div class="mx-auto flex max-w-[90rem]">

      <!-- Desktop sidebar -->
      <aside class="hidden lg:block w-64 shrink-0 border-r border-cloud-grey">
        <div class="sticky top-[72px] h-[calc(100vh-72px)] overflow-y-auto overscroll-contain px-4 pt-6 pb-8">
          <div class="mb-5">
            <DocsSearch />
          </div>
          <DocsSidebar currentSlug={currentSlug} />
        </div>
      </aside>

      <!-- Content area -->
      <main id="docs-content" class="min-w-0 flex-1 px-6 py-4 md:px-10 md:py-6 lg:px-16" tabindex="-1">
        <article class="mx-auto max-w-3xl">
          <!-- Page title -->
          <header class="mb-4">
            <h1 class="font-display text-[2rem] font-semibold leading-tight tracking-tight text-ink sm:text-[2.25rem]">{title}</h1>
            {description && (
              <p class="mt-1 text-base leading-relaxed text-ink-muted">{description}</p>
            )}
          </header>

          <!-- Prose content -->
          <div class="grove-prose">
            <slot />
          </div>

          <!-- Pagination -->
          <DocsPagination prev={prev} next={next} />

          <!-- Edit link + last updated -->
          {(editUrl || lastUpdated) && (
            <footer class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-cloud-grey pt-6 text-sm text-ink-muted">
              {editUrl && (
                <a
                  href={editUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 transition-colors hover:text-green"
                >
                  <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                  </svg>
                  Edit this page
                </a>
              )}
              {lastUpdated && (
                <span>Last updated: <time>{lastUpdated}</time></span>
              )}
            </footer>
          )}
        </article>
      </main>

      <!-- Table of Contents (xl screens only, compact) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden xl:block w-[160px] shrink-0 pl-4">
          <div class="sticky top-[80px] max-h-[calc(100vh-100px)] overflow-y-auto overscroll-contain py-8">
            <TableOfContents headings={tocHeadings} />
          </div>
        </aside>
      )}
    </div>
  </div>

  <Footer />
  <CookieConsent />

  <!-- Mobile drawer script -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const toggle = document.getElementById('grove-sidebar-toggle');
      const drawer = document.getElementById('grove-sidebar-drawer');
      if (!toggle || !drawer) return;

      function openDrawer() {
        drawer!.classList.remove('hidden');
        drawer!.setAttribute('aria-hidden', 'false');
        toggle!.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        drawer!.classList.add('hidden');
        drawer!.setAttribute('aria-hidden', 'true');
        toggle!.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', openDrawer);

      drawer.querySelectorAll('[data-close-drawer]').forEach((el) => {
        el.addEventListener('click', closeDrawer);
      });

      drawer.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeDrawer);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !drawer.classList.contains('hidden')) {
          closeDrawer();
        }
      });
    });
  </script>

  <!-- Cal.com Embed (for Book a Demo in nav) -->
  <script is:inline>
    (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", "servantium-introduction", {origin:"https://app.cal.com"});
    Cal.ns["servantium-introduction"]("ui", {
      "cssVarsPerTheme": { "light": {"cal-brand":"#00C26D"}, "dark": {"cal-brand":"#00C26D"} },
      "hideEventTypeDetails": false, "layout": "month_view"
    });
  </script>
</body>
</html>

<style>
  /* ── Prose typography ─────────────────────────────── */

  /* Headings */
  .grove-prose :global(h1) {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 1rem;
  }

  .grove-prose :global(h2) {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-cloud-grey);
    scroll-margin-top: 5rem;
  }

  .grove-prose :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .grove-prose :global(h3) {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-ink);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    scroll-margin-top: 5rem;
  }

  .grove-prose :global(h4) {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  /* Body text */
  .grove-prose :global(p) {
    color: var(--color-ink-light);
    font-size: 0.9375rem; /* 15px — slightly smaller for dense docs */
    line-height: 1.8;
    margin-bottom: 1.125rem;
  }

  /* Links */
  .grove-prose :global(a) {
    color: var(--color-green);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: var(--color-pale-green);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }

  .grove-prose :global(a:hover) {
    text-decoration-color: var(--color-green);
  }

  /* Lists */
  .grove-prose :global(ul),
  .grove-prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--color-ink-light);
    font-size: 1rem;
    line-height: 1.75;
  }

  .grove-prose :global(ul) {
    list-style-type: disc;
  }

  .grove-prose :global(ol) {
    list-style-type: decimal;
  }

  .grove-prose :global(li) {
    margin-bottom: 0.35rem;
  }

  .grove-prose :global(li > ul),
  .grove-prose :global(li > ol) {
    margin-top: 0.35rem;
    margin-bottom: 0;
  }

  /* Inline code */
  .grove-prose :global(code) {
    font-size: 0.875em;
    background: var(--color-mist-grey);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-ink);
    font-weight: 500;
  }

  /* Code blocks */
  .grove-prose :global(pre) {
    background: #1e293b;
    color: #e2e8f0;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    line-height: 1.7;
    border: 1px solid var(--color-cloud-grey);
  }

  .grove-prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
    font-weight: 400;
    border-radius: 0;
  }

  /* Blockquotes */
  .grove-prose :global(blockquote) {
    border-left: 3px solid var(--color-green);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .grove-prose :global(blockquote p) {
    color: var(--color-ink-muted);
  }

  /* Horizontal rules */
  .grove-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-cloud-grey);
    margin: 2.5rem 0;
  }

  /* Tables */
  .grove-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    border: 1px solid var(--color-cloud-grey);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .grove-prose :global(thead) {
    background: var(--color-mist-grey);
  }

  .grove-prose :global(th) {
    text-align: left;
    font-weight: 600;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-cloud-grey);
    color: var(--color-ink);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .grove-prose :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-cloud-grey);
    color: var(--color-ink-light);
  }

  .grove-prose :global(tbody tr:nth-child(even)) {
    background: var(--color-mist-grey);
  }

  .grove-prose :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  /* Images */
  .grove-prose :global(img) {
    max-width: 100%;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    border: 1px solid var(--color-cloud-grey);
  }

  /* Strong */
  .grove-prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* Anchored headings: offset for fixed nav */
  .grove-prose :global(h2[id]),
  .grove-prose :global(h3[id]),
  .grove-prose :global(h4[id]) {
    scroll-margin-top: 6rem;
  }

  /* Anchor link hover styling */
  .grove-prose :global(h2 a),
  .grove-prose :global(h3 a),
  .grove-prose :global(h4 a) {
    color: inherit;
    text-decoration: none;
  }

  .grove-prose :global(h2 a:hover),
  .grove-prose :global(h3 a:hover),
  .grove-prose :global(h4 a:hover) {
    color: var(--color-green);
  }
</style>
