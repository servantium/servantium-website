---
/**
 * ReleaseTimeline — Vertical timeline for release notes.
 * Green line on left with date dots, cards on right.
 * Supports client-side filtering by repo (Website / App / All).
 */
interface ReleaseEntry {
  id: string;
  title: string;
  description?: string;
  date?: string;
  version?: string;
  repo?: string;
  badge?: { text: string; variant: string };
}

interface Props {
  entries: ReleaseEntry[];
  showFilter?: boolean;
}

const { entries, showFilter = true } = Astro.props;
const hasMultipleRepos = new Set(entries.map(e => e.repo).filter(Boolean)).size > 1;
---

{entries.length === 0 ? (
  <p class="text-sm text-slate-400 italic">No release notes yet.</p>
) : (
  <div>
    {/* Repo filter tabs — only show if there are entries from multiple repos */}
    {showFilter && hasMultipleRepos && (
      <div class="release-filter flex gap-1 mb-6 bg-[var(--color-mist-grey)] rounded-lg p-1 w-fit">
        <button class="release-filter-btn active" data-filter="all">All</button>
        <button class="release-filter-btn" data-filter="servantium-website">Website</button>
        <button class="release-filter-btn" data-filter="servantium">App</button>
      </div>
    )}

    {/* Always show filter if only one repo, just as static label */}
    {showFilter && !hasMultipleRepos && entries[0]?.repo && (
      <div class="flex gap-1 mb-6">
        <span class="text-xs font-semibold text-[var(--color-ink-muted)] bg-[var(--color-mist-grey)] rounded-lg px-3 py-1.5">
          {entries[0].repo === 'servantium-website' ? 'Website' : 'App'} releases
        </span>
      </div>
    )}

    <div class="release-timeline relative">
      {/* Timeline line */}
      <div class="absolute left-3 top-2 bottom-2 w-px bg-[var(--color-pale-green)]" aria-hidden="true"></div>

      <div class="space-y-8">
        {entries.map((entry, i) => {
          const dateStr = entry.date
            ? new Date(entry.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
            : '';
          const repoLabel = entry.repo === 'servantium-website' ? 'Website' : entry.repo === 'servantium' ? 'App' : '';

          return (
            <div class="release-entry relative pl-10" data-repo={entry.repo || ''}>
              {/* Timeline dot */}
              <div class:list={[
                'absolute left-1.5 top-1.5 size-3.5 rounded-full border-2 border-white',
                i === 0 ? 'bg-[var(--color-green)]' : 'bg-[var(--color-pale-green)]'
              ]} aria-hidden="true"></div>

              {/* Card — no border, clean background on hover */}
              <a
                href={`/help/${entry.id}/`}
                class="group block rounded-lg p-5 transition-all duration-200 hover:bg-[var(--color-mist-grey)] hover:-translate-y-0.5"
                style="transition-timing-function: var(--ease-out)"
              >
                {/* Date + version + repo */}
                <div class="flex items-center gap-3 mb-2 flex-wrap">
                  {entry.version && (
                    <span class="inline-flex items-center rounded-full bg-[var(--color-soft-mint)] px-2.5 py-0.5 text-xs font-semibold text-[var(--color-green)]">
                      {entry.version}
                    </span>
                  )}
                  {entry.badge && (
                    <span class:list={[
                      'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium',
                      entry.badge.variant === 'success' ? 'bg-green-50 text-green-700' :
                      entry.badge.variant === 'caution' ? 'bg-amber-50 text-amber-700' :
                      entry.badge.variant === 'danger' ? 'bg-red-50 text-red-700' :
                      'bg-slate-100 text-slate-600'
                    ]}>
                      {entry.badge.text}
                    </span>
                  )}
                  {dateStr && (
                    <time class="text-xs text-slate-400">{dateStr}</time>
                  )}
                  {repoLabel && (
                    <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wide">{repoLabel}</span>
                  )}
                </div>

                {/* Title */}
                <h3 class="text-base font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors mb-1">
                  {entry.title}
                </h3>

                {/* Description */}
                {entry.description && (
                  <p class="text-sm text-slate-500 line-clamp-2 mb-2">
                    {entry.description}
                  </p>
                )}

                <span class="text-xs font-medium text-[var(--color-green)]">
                  Read more &rarr;
                </span>
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </div>
)}

<style>
  .release-filter-btn {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    border: none;
    background: transparent;
    color: var(--color-ink-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .release-filter-btn:hover {
    color: var(--color-ink);
  }
  .release-filter-btn.active {
    background: white;
    color: var(--color-ink);
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
  }
</style>

<script>
  function initReleaseFilter() {
    const buttons = document.querySelectorAll('.release-filter-btn');
    const entries = document.querySelectorAll('.release-entry');
    if (!buttons.length || !entries.length) return;

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter || 'all';

        // Update active state
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Show/hide entries
        entries.forEach(entry => {
          const repo = (entry as HTMLElement).dataset.repo || '';
          if (filter === 'all' || repo === filter) {
            (entry as HTMLElement).style.display = '';
          } else {
            (entry as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReleaseFilter);
  } else {
    initReleaseFilter();
  }
  document.addEventListener('astro:page-load', initReleaseFilter);
</script>
