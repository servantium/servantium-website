---
import { docsNav } from '@/data/docs-nav';
import type { DocsNavSection, DocsNavItem } from '@/data/docs-nav';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

function isActive(slug: string | undefined): boolean {
  if (!slug) return false;
  return currentSlug === slug;
}

function sectionContainsActive(section: DocsNavSection): boolean {
  const items = section.items || [];
  return items.some((item) => isActive(item.slug));
}
---

<nav aria-label="Documentation" class="space-y-1">
  {docsNav.map((section, sectionIndex) => {
    const items = section.items || [];
    const hasActive = sectionContainsActive(section);
    const isAutogenerate = !!section.autogenerate;
    const shouldCollapse = section.collapsed && !hasActive;

    return (
      <div class:list={[sectionIndex > 0 && 'mt-8']}>
        {items.length > 0 ? (
          <details open={!shouldCollapse}>
            <summary class="grove-sidebar-summary flex cursor-pointer select-none list-none items-center gap-1.5 py-1 text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-slate-400 transition-colors hover:text-slate-600">
              <svg class="grove-sidebar-chevron size-3 shrink-0 text-slate-300 transition-transform duration-150" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              {section.label}
            </summary>
            <ul class="mt-1 space-y-px" role="list">
              {items.map((item) => {
                const active = isActive(item.slug);
                return (
                  <li>
                    <a
                      href={`/help/${item.slug}/`}
                      class:list={[
                        'block rounded-r-md border-l-2 py-1.5 pl-4 pr-2 text-sm leading-snug transition-colors duration-100',
                        active
                          ? 'border-green bg-soft-mint font-semibold text-green'
                          : 'border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-slate-900',
                      ]}
                      aria-current={active ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        ) : isAutogenerate ? (
          <>
            <div class="flex items-center gap-1.5 py-1 text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-slate-400">
              <svg class="size-3 shrink-0 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              {section.label}
            </div>
            <p class="mt-1 pl-[1.125rem] text-xs italic text-slate-400">
              Auto-generated from {section.autogenerate}/
            </p>
          </>
        ) : null}
      </div>
    );
  })}
</nav>

<style>
  /* Rotate chevron when details is open */
  details[open] > .grove-sidebar-summary .grove-sidebar-chevron {
    transform: rotate(90deg);
  }
  /* Hide default marker in all browsers */
  .grove-sidebar-summary::-webkit-details-marker {
    display: none;
  }
</style>
