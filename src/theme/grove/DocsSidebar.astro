---
import type { DocsNavSection, DocsNavItem } from '@/data/docs-nav';

interface Props {
  currentSlug: string;
  nav: DocsNavSection[];
  autogeneratedItems?: Record<string, DocsNavItem[]>;
}

const { currentSlug, nav, autogeneratedItems = {} } = Astro.props;

function isActive(slug: string | undefined): boolean {
  if (!slug) return false;
  return currentSlug === slug;
}

function sectionContainsActive(section: DocsNavSection): boolean {
  const items = section.autogenerate
    ? autogeneratedItems[section.autogenerate] || []
    : section.items || [];
  return items.some((item) => isActive(item.slug));
}
---

<nav aria-label="Documentation" class="grove-sidebar">
  {nav.map((section) => {
    const items = section.autogenerate
      ? autogeneratedItems[section.autogenerate] || []
      : section.items || [];
    const hasActive = sectionContainsActive(section);
    const shouldCollapse = section.collapsed && !hasActive;

    return (
      <div class="mb-6">
        {items.length > 0 && (
          <details open={!shouldCollapse}>
            <summary class="flex cursor-pointer select-none list-none items-center gap-1.5 text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-ink-muted mb-2 hover:text-ink transition-colors">
              <svg class="grove-sidebar-chevron size-3.5 shrink-0 text-ink-muted/60 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
              {section.label}
            </summary>
            <ul class="mt-1 space-y-0.5 border-l border-cloud-grey ml-[5px] pl-0" role="list">
              {items.map((item) => {
                const active = isActive(item.slug);
                return (
                  <li>
                    <a
                      href={`/help/${item.slug}/`}
                      class:list={[
                        'block py-1.5 pl-4 pr-2 text-[0.9375rem] leading-snug transition-colors rounded-r-md -ml-px border-l-2',
                        active
                          ? 'border-green text-green bg-soft-mint font-medium'
                          : 'border-transparent text-ink-muted hover:text-ink hover:border-cloud-grey hover:bg-mist-grey',
                      ]}
                      aria-current={active ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </details>
        )}
      </div>
    );
  })}
</nav>

<style>
  /* Rotate chevron when details is open */
  details[open] > summary .grove-sidebar-chevron {
    transform: rotate(90deg);
  }
  /* Hide default marker in all browsers */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
