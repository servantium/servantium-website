---
/**
 * DocsSearch -- Pagefind search UI for Grove documentation.
 * Lazy-loads Pagefind JS on first interaction (click or Cmd+K).
 */
---

<div class="docs-search-wrapper">
  <button
    id="docs-search-trigger"
    type="button"
    class="flex w-full items-center gap-2.5 rounded-lg border border-cloud-grey bg-white px-3 py-2 text-sm text-ink-muted transition-all duration-150 hover:border-slate-300 hover:shadow-sm focus:outline-none focus:ring-2 focus:ring-green focus:ring-offset-1"
    aria-label="Search documentation"
  >
    <svg class="size-4 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <span class="flex-1 text-left text-slate-400">Search docs...</span>
    <kbd class="hidden items-center gap-0.5 rounded bg-mist-grey px-1.5 py-0.5 font-mono text-[0.6875rem] text-slate-400 sm:inline-flex">
      <span class="text-xs">&#8984;</span>K
    </kbd>
  </button>

  <div id="docs-search-container" class="fixed inset-0 z-[10000] hidden items-start justify-center bg-black/50 pt-[15vh] backdrop-blur-sm">
    <div class="mx-4 w-full max-w-2xl overflow-hidden rounded-xl bg-white shadow-2xl" id="docs-search-modal">
      <div id="docs-search-pagefind"></div>
    </div>
  </div>
</div>

<script is:inline>
  function initDocsSearch() {
    const trigger = document.getElementById('docs-search-trigger');
    const container = document.getElementById('docs-search-container');
    const pagefindEl = document.getElementById('docs-search-pagefind');
    let pagefindLoaded = false;

    async function openSearch() {
      if (!container || !pagefindEl) return;
      container.classList.remove('hidden');
      container.classList.add('flex');
      document.body.style.overflow = 'hidden';

      if (!pagefindLoaded) {
        try {
          // Load Pagefind CSS
          if (!document.querySelector('link[href="/pagefind/pagefind-ui.css"]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = '/pagefind/pagefind-ui.css';
            document.head.appendChild(link);
          }
          // Load Pagefind UI as script (it's an IIFE, not an ES module)
          await new Promise(function(resolve, reject) {
            if (window.PagefindUI) { resolve(); return; }
            var script = document.createElement('script');
            script.src = '/pagefind/pagefind-ui.js';
            script.onload = resolve;
            script.onerror = reject;
            document.head.appendChild(script);
          });
          new window.PagefindUI({
            element: pagefindEl,
            showSubResults: true,
            showImages: false,
            resetStyles: true,
            bundlePath: '/pagefind/',
          });
          pagefindLoaded = true;
        } catch (e) {
          pagefindEl.innerHTML = '<p class="p-6 text-center text-sm text-ink-muted">Search index not available. Try after a full build.</p>';
        }
      }

      setTimeout(() => {
        const input = pagefindEl.querySelector('input');
        if (input) input.focus();
      }, 100);
    }

    function closeSearch() {
      if (!container) return;
      container.classList.add('hidden');
      container.classList.remove('flex');
      document.body.style.overflow = '';
    }

    trigger?.addEventListener('click', openSearch);

    container?.addEventListener('click', (e) => {
      if (e.target === container) closeSearch();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && container && !container.classList.contains('hidden')) {
        closeSearch();
      }
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (container?.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }
    });
  }
  // Initialize on both DOMContentLoaded and astro:page-load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDocsSearch);
  } else {
    initDocsSearch();
  }
  document.addEventListener('astro:page-load', initDocsSearch);
</script>

<style is:global>
  /* Pagefind UI overrides */
  .pagefind-ui__search-input {
    font-family: var(--font-body) !important;
    border-color: var(--color-cloud-grey) !important;
    border-radius: 0.5rem !important;
    padding: 0.75rem 1rem !important;
    font-size: 1rem !important;
  }
  .pagefind-ui__search-input:focus {
    border-color: var(--color-green) !important;
    box-shadow: 0 0 0 3px rgba(0, 194, 109, 0.15) !important;
    outline: none !important;
  }
  .pagefind-ui__result-link {
    color: var(--color-green) !important;
    font-weight: 500 !important;
  }
  .pagefind-ui__result-link:hover {
    color: var(--color-green-hover) !important;
  }
  .pagefind-ui__message {
    font-family: var(--font-body) !important;
    color: var(--color-ink-muted) !important;
  }
</style>
