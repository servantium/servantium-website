---
/**
 * BlogSearch -- Pagefind search UI for the blog listing.
 * Lazy-loads Pagefind JS on first interaction (click or Cmd+K).
 * Follows the same pattern as DocsSearch.
 */
---

<div class="blog-search-wrapper mb-6">
  <button
    id="blog-search-trigger"
    type="button"
    class="flex w-full max-w-md items-center gap-2.5 rounded-xl border border-[var(--color-cloud-grey)]
           bg-white px-4 py-2.5 text-sm text-[var(--color-ink-muted)]
           transition-all duration-150
           hover:border-[var(--color-green)]/40 hover:shadow-sm
           focus:outline-none focus:ring-2 focus:ring-[var(--color-green)] focus:ring-offset-1"
    aria-label="Search articles"
  >
    <svg class="size-4 shrink-0 text-[var(--color-ink-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <span class="flex-1 text-left text-[var(--color-ink-muted)]/60">Search articles...</span>
    <kbd class="hidden items-center gap-0.5 rounded-md bg-[var(--color-mist-grey)] px-1.5 py-0.5 font-mono text-[0.6875rem] text-[var(--color-ink-muted)] sm:inline-flex">
      <span class="text-xs">&#8984;</span>K
    </kbd>
  </button>

  {/* Search modal overlay */}
  <div id="blog-search-container" class="fixed inset-0 z-[10000] hidden items-start justify-center bg-black/50 pt-[15vh] backdrop-blur-sm">
    <div class="mx-4 w-full max-w-2xl overflow-hidden rounded-xl bg-white shadow-2xl" id="blog-search-modal">
      <div id="blog-search-pagefind"></div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const trigger = document.getElementById('blog-search-trigger');
    const container = document.getElementById('blog-search-container');
    const pagefindEl = document.getElementById('blog-search-pagefind');
    let pagefindLoaded = false;

    async function openSearch() {
      if (!container || !pagefindEl) return;
      container.classList.remove('hidden');
      container.classList.add('flex');
      document.body.style.overflow = 'hidden';

      if (!pagefindLoaded) {
        try {
          const pagefind = await import('/pagefind/pagefind-ui.js');
          new pagefind.PagefindUI({
            element: pagefindEl,
            showSubResults: true,
            showImages: false,
            resetStyles: true,
          });
          pagefindLoaded = true;
        } catch (e) {
          pagefindEl.innerHTML =
            '<p class="p-6 text-center text-sm text-[var(--color-ink-muted)]">Search index not available. Try after a full build.</p>';
        }
      }

      setTimeout(() => {
        const input = pagefindEl.querySelector('input');
        if (input) input.focus();
      }, 100);
    }

    function closeSearch() {
      if (!container) return;
      container.classList.add('hidden');
      container.classList.remove('flex');
      document.body.style.overflow = '';
    }

    trigger?.addEventListener('click', openSearch);

    container?.addEventListener('click', (e) => {
      if (e.target === container) closeSearch();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && container && !container.classList.contains('hidden')) {
        closeSearch();
      }
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (container?.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }
    });
  });
</script>

<style is:global>
  /* Pagefind UI overrides for blog search */
  #blog-search-pagefind .pagefind-ui__search-input {
    font-family: var(--font-body) !important;
    border-color: var(--color-cloud-grey) !important;
    border-radius: 0.5rem !important;
    padding: 0.75rem 1rem !important;
    font-size: 1rem !important;
  }
  #blog-search-pagefind .pagefind-ui__search-input:focus {
    border-color: var(--color-green) !important;
    box-shadow: 0 0 0 3px rgba(0, 194, 109, 0.15) !important;
    outline: none !important;
  }
  #blog-search-pagefind .pagefind-ui__result-link {
    color: var(--color-green) !important;
    font-weight: 500 !important;
  }
  #blog-search-pagefind .pagefind-ui__result-link:hover {
    color: var(--color-green-hover) !important;
  }
  #blog-search-pagefind .pagefind-ui__message {
    font-family: var(--font-body) !important;
    color: var(--color-ink-muted) !important;
  }
</style>
