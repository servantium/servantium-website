---
/**
 * BlogSearch -- Pagefind search UI wrapper for blog pages.
 * Opens a full-page modal with Pagefind UI, pre-filtered to Blog results.
 */
import SearchModal from '@/components/SearchModal.astro';
---

<div class="mb-6 w-full">
  <SearchModal
    label="Search blog posts"
    placeholder="Search blog posts..."
    triggerVariant="full"
    defaultFilter="Blog"
    sections={["Resources", "Blog"]}
  />
</div>
