---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  category: string;
  image?: string;
  imageAlt?: string;
  slug: string;
  readingTime?: string;
  tags?: string[];
}

const {
  title,
  description,
  date,
  author,
  category,
  image,
  imageAlt,
  slug,
  readingTime,
  tags = [],
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="blog-card @container group block no-underline text-inherit rounded-xl border border-cloud-grey overflow-hidden
         transition-[transform,box-shadow] duration-300 ease-[var(--ease-bounce)]
         hover:-translate-y-1 hover:shadow-lg"
  data-category={category}
  data-tags={tags.join(',')}
>
  {image && (
    <div class="overflow-hidden h-52">
      <Image
        src={image}
        alt={imageAlt || title}
        width={800}
        height={450}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 ease-[var(--ease-out)]
               group-hover:scale-[1.04]"
      />
    </div>
  )}

  <div class="p-5 @sm:p-6 flex flex-col gap-2">
    <span
      class="inline-block self-start rounded-full bg-green/10 px-3 py-0.5
             text-xs font-semibold uppercase tracking-wider text-green"
    >
      {category}
    </span>

    <h3
      class="font-[family-name:var(--font-display)] text-lg @sm:text-xl leading-snug text-ink
             line-clamp-2 m-0"
    >
      {title}
    </h3>

    <p class="text-sm text-ink-muted leading-relaxed line-clamp-3 m-0">
      {description}
    </p>

    <div class="flex items-center gap-2 text-xs text-ink-muted mt-2 pt-3 border-t border-cloud-grey">
      <span class="font-medium text-ink-light">{author}</span>
      <span class="opacity-40">&middot;</span>
      <time datetime={date}>{formattedDate}</time>
      {readingTime && (
        <>
          <span class="opacity-40">&middot;</span>
          <span>{readingTime}</span>
        </>
      )}
    </div>
  </div>
</a>
