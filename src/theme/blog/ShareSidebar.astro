---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;

const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
const twitterUrl = `https://x.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const emailUrl = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`Check out this article: ${url}`)}`;
---

{/* ── Desktop: fixed left sidebar ── */}
<aside
  class="share-sidebar
         hidden md:flex fixed left-4 lg:left-8 top-1/2 -translate-y-1/2 z-40
         flex-col gap-3"
  aria-label="Share this article"
>
  <a
    href={linkedInUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn inline-flex items-center justify-center w-10 h-10 rounded-full
           bg-white border border-cloud-grey text-ink-muted shadow-sm
           hover:text-green hover:border-green hover:shadow-md
           transition-all duration-200"
    aria-label="Share on LinkedIn"
  >
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>

  <a
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn inline-flex items-center justify-center w-10 h-10 rounded-full
           bg-white border border-cloud-grey text-ink-muted shadow-sm
           hover:text-green hover:border-green hover:shadow-md
           transition-all duration-200"
    aria-label="Share on X"
  >
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>

  <button
    type="button"
    class="share-copy-btn inline-flex items-center justify-center w-10 h-10 rounded-full
           bg-white border border-cloud-grey text-ink-muted shadow-sm
           hover:text-green hover:border-green hover:shadow-md
           transition-all duration-200"
    data-url={url}
    aria-label="Copy link"
  >
    <svg class="share-copy-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
    </svg>
    <svg class="share-check-icon w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
    </svg>
  </button>
</aside>

{/* ── Mobile: fixed bottom bar ── */}
<div
  class="share-bottom-bar
         flex md:hidden fixed bottom-0 inset-x-0 z-40
         bg-white/95 backdrop-blur-sm border-t border-cloud-grey
         items-center justify-center gap-4 px-4 py-3"
  aria-label="Share this article"
>
  <a
    href={linkedInUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center w-10 h-10 rounded-full
           bg-mist-grey text-ink-muted hover:text-green transition-colors duration-200"
    aria-label="Share on LinkedIn"
  >
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>

  <a
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center w-10 h-10 rounded-full
           bg-mist-grey text-ink-muted hover:text-green transition-colors duration-200"
    aria-label="Share on X"
  >
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>

  <button
    type="button"
    class="share-copy-btn-mobile inline-flex items-center justify-center w-10 h-10 rounded-full
           bg-mist-grey text-ink-muted hover:text-green transition-colors duration-200"
    data-url={url}
    aria-label="Copy link"
  >
    <svg class="share-copy-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
    </svg>
    <svg class="share-check-icon w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
    </svg>
  </button>
</div>

<script>
  function initShareButtons() {
    function handleCopy(btn: HTMLButtonElement) {
      const url = btn.dataset.url;
      if (!url) return;

      const linkIcon = btn.querySelector('.share-copy-icon') as HTMLElement;
      const checkIcon = btn.querySelector('.share-check-icon') as HTMLElement;

      navigator.clipboard.writeText(url).then(() => {
        linkIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        btn.classList.add('text-green', 'border-green');

        setTimeout(() => {
          linkIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
          btn.classList.remove('text-green', 'border-green');
        }, 2000);
      });
    }

    document.querySelectorAll<HTMLButtonElement>('.share-copy-btn, .share-copy-btn-mobile').forEach((btn) => {
      btn.addEventListener('click', () => handleCopy(btn));
    });
  }

  document.addEventListener('astro:page-load', initShareButtons);
  if (!document.querySelector('[name="astro-view-transitions"]')) {
    initShareButtons();
  }
</script>
