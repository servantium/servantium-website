<script>
  function initShareButtons() {
    function handleCopy(btn: HTMLButtonElement) {
      const url = btn.dataset.url;
      if (!url) return;

      const linkIcon = btn.querySelector('.share-copy-icon') as HTMLElement;
      const checkIcon = btn.querySelector('.share-check-icon') as HTMLElement;

      navigator.clipboard.writeText(url).then(() => {
        linkIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        btn.classList.add('text-[var(--color-green)]', 'border-[var(--color-green)]');

        setTimeout(() => {
          linkIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
          btn.classList.remove('text-[var(--color-green)]', 'border-[var(--color-green)]');
        }, 2000);
      });
    }

    document.querySelectorAll<HTMLButtonElement>('.share-copy-btn, .share-copy-btn-mobile').forEach((btn) => {
      btn.addEventListener('click', () => handleCopy(btn));
    });

    // Desktop "more" expand/collapse with dots/close icon toggle
    const moreBtn = document.querySelector<HTMLButtonElement>('.share-more-btn');
    const extraPanel = document.querySelector<HTMLElement>('.share-extra');
    const dotsIcon = moreBtn?.querySelector<HTMLElement>('.share-dots-icon');
    const closeIcon = moreBtn?.querySelector<HTMLElement>('.share-close-icon');

    if (moreBtn && extraPanel && dotsIcon && closeIcon) {
      moreBtn.addEventListener('click', () => {
        const isHidden = extraPanel.classList.contains('hidden');
        extraPanel.classList.toggle('hidden', !isHidden);
        extraPanel.classList.toggle('flex', isHidden);
        moreBtn.setAttribute('aria-expanded', String(isHidden));

        // Swap between dots and close icons
        dotsIcon.classList.toggle('hidden', isHidden);
        closeIcon.classList.toggle('hidden', !isHidden);

        // Update aria-label
        moreBtn.setAttribute('aria-label', isHidden ? 'Close share options' : 'More share options');
      });
    }
  }

  document.addEventListener('astro:page-load', initShareButtons);
  if (!document.querySelector('[name="astro-view-transitions"]')) {
    initShareButtons();
  }
</script>
