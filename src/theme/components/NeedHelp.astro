---
/**
 * NeedHelp -- "Need more help?" CTA with warm gradient background.
 */
---

<section class="relative overflow-hidden rounded-2xl p-10 text-center mt-12" style="background: linear-gradient(135deg, #E8FBF1 0%, #F0FDFA 40%, #EDE9FE 100%);">
  {/* Decorative shapes */}
  <div class="absolute top-[-40px] left-[-40px] w-[160px] h-[160px] rounded-full" style="background: rgba(0,194,109,0.08);" aria-hidden="true"></div>
  <div class="absolute bottom-[-60px] right-[-60px] w-[200px] h-[200px] rounded-full" style="background: rgba(124,58,237,0.06);" aria-hidden="true"></div>
  <div class="absolute top-[30%] right-[15%] w-[80px] h-[80px] rounded-full" style="background: rgba(76,130,167,0.06);" aria-hidden="true"></div>

  {/* Icon */}
  <div class="relative mx-auto mb-4 flex size-14 items-center justify-center rounded-full bg-white shadow-md">
    <svg class="size-7 text-[var(--color-green)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10" />
      <circle cx="12" cy="12" r="4" />
      <line x1="4.93" y1="4.93" x2="9.17" y2="9.17" />
      <line x1="14.83" y1="14.83" x2="19.07" y2="19.07" />
      <line x1="14.83" y1="9.17" x2="19.07" y2="4.93" />
      <line x1="4.93" y1="19.07" x2="9.17" y2="14.83" />
    </svg>
  </div>

  <h2 class="relative font-display text-xl font-semibold text-[var(--color-ink)] mb-2">Need more help?</h2>
  <p class="relative text-sm text-[var(--color-ink-muted)] mb-6">Our support team is available to assist you.</p>

  <a
    href="mailto:hello@servantium.com"
    class="relative inline-flex items-center gap-2 rounded-full bg-[var(--color-green)] px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-green-hover)] shadow-md"
  >
    Contact Support
  </a>
</section>
