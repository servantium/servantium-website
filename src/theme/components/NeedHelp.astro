---
/**
 * NeedHelp -- "Need more help?" CTA card for the bottom of help articles.
 */
---

<section class="rounded-xl bg-[var(--color-mist-grey)] p-8 text-center mt-12">
  {/* Life-ring / support icon */}
  <div class="mx-auto mb-4 flex size-12 items-center justify-center rounded-full bg-white shadow-sm">
    <svg class="size-6 text-[var(--color-green)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10" />
      <circle cx="12" cy="12" r="4" />
      <line x1="4.93" y1="4.93" x2="9.17" y2="9.17" />
      <line x1="14.83" y1="14.83" x2="19.07" y2="19.07" />
      <line x1="14.83" y1="9.17" x2="19.07" y2="4.93" />
      <line x1="4.93" y1="19.07" x2="9.17" y2="14.83" />
    </svg>
  </div>

  <h2 class="font-display text-lg font-semibold text-[var(--color-ink)] mb-2">Need more help?</h2>
  <p class="text-sm text-[var(--color-ink-muted)] mb-5">Our support team is available to assist you.</p>

  <a
    href="mailto:hello@servantium.com"
    class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-green)] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-green-hover)]"
  >
    Contact Support
  </a>
</section>
