---
/**
 * OpenInAI — "Discuss with AI" buttons for help docs and blog posts.
 * Opens the article content in ChatGPT, Claude, or Gemini.
 * Supports AEO strategy by driving content into AI assistants.
 */
interface Props {
  title: string;
  url: string;
  summary?: string;
}

const { title, url, summary } = Astro.props;

const prompt = encodeURIComponent(
  `I'm reading this Servantium article: "${title}". ${summary ? `Summary: ${summary}. ` : ''}Full article: ${url}\n\nHelp me understand how this applies to my professional services business.`
);

const chatgptUrl = `https://chat.openai.com/?q=${prompt}`;
const claudeUrl = `https://claude.ai/new?q=${prompt}`;
const geminiUrl = `https://gemini.google.com/app?q=${prompt}`;
---

<div class="flex items-center gap-2 mt-4">
  <span class="text-[11px] font-medium text-slate-400 uppercase tracking-wider">Discuss with</span>
  <a
    href={chatgptUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1 rounded-md border border-slate-200 px-2 py-1 text-[11px] font-medium text-slate-500 no-underline transition-all duration-150 hover:border-[#10a37f] hover:text-[#10a37f] hover:shadow-sm"
    aria-label="Discuss in ChatGPT"
  >
    <svg class="size-3" viewBox="0 0 24 24" fill="currentColor"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
    ChatGPT
  </a>
  <a
    href={claudeUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1 rounded-md border border-slate-200 px-2 py-1 text-[11px] font-medium text-slate-500 no-underline transition-all duration-150 hover:border-[#d97706] hover:text-[#d97706] hover:shadow-sm"
    aria-label="Discuss in Claude"
  >
    <svg class="size-3" viewBox="0 0 24 24" fill="currentColor"><path d="M4.709 15.955l4.72-2.756.08-.046 2.691-1.571 2.527-1.476.081-.047 4.72-2.756c.278-.163.557.163.394.442l-2.756 4.72-.047.08-1.571 2.691-1.476 2.527-.046.081-2.756 4.72c-.163.278-.605.278-.768 0L4.315 16.397c-.163-.279.116-.605.394-.442z"/></svg>
    Claude
  </a>
  <a
    href={geminiUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1 rounded-md border border-slate-200 px-2 py-1 text-[11px] font-medium text-slate-500 no-underline transition-all duration-150 hover:border-[#4285f4] hover:text-[#4285f4] hover:shadow-sm"
    aria-label="Discuss in Gemini"
  >
    <svg class="size-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.352 0 0 5.352 0 12s5.352 12 12 12 12-5.352 12-12S18.648 0 12 0zm0 3.6c2.124 0 4.044.78 5.544 2.052L12 12l5.544 6.348A8.34 8.34 0 0 1 12 20.4c-4.632 0-8.4-3.768-8.4-8.4S7.368 3.6 12 3.6z"/></svg>
    Gemini
  </a>
</div>
