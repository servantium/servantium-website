---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  variant?: 'floating' | 'peeking' | 'waving' | 'searching' | 'cowboy' | 'detective' | 'chef' | 'captain' | 'professor' | 'accountant' | 'controller' | 'explorer';
  animate?: boolean;
  class?: string;
}

const {
  size = 'md',
  variant = 'floating',
  animate = true,
  class: className = '',
} = Astro.props;

const sizes = {
  sm: 32,
  md: 64,
  lg: 120,
};

const px = sizes[size];
---

<div
  class:list={[
    'astronaut-mascot',
    `astronaut-${size}`,
    `astronaut-${variant}`,
    { 'astronaut-animated': animate },
    className,
  ]}
  style={`width: ${px}px; height: ${px}px;`}
  aria-hidden="true"
>
  {variant === 'floating' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm -->
      <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
    </svg>
  )}

  {variant === 'peeking' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Only upper half visible — peeking from an edge -->
      <!-- Helmet -->
      <circle cx="50" cy="50" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="52" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- One hand gripping edge -->
      <rect x="15" y="72" width="14" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <rect x="71" y="72" width="14" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="25" x2="50" y2="16" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="14" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 45 Q42 40 48 42" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Body hint at bottom -->
      <rect x="35" y="72" width="30" height="28" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
    </svg>
  )}

  {variant === 'waving' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm (down) -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm (waving up!) -->
      <rect x="68" y="48" width="8" height="22" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2" transform="rotate(-20 72 59)"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
    </svg>
  )}

  {variant === 'searching' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="45" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="45" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="30" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="55" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm (holding magnifying glass handle) -->
      <rect x="62" y="55" width="8" height="20" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2" transform="rotate(30 66 65)"/>
      <!-- Magnifying glass -->
      <circle cx="80" cy="38" r="12" stroke="#0D0D0D" stroke-width="2.5" fill="none"/>
      <circle cx="80" cy="38" r="10" stroke="#00C26D" stroke-width="1" fill="#00C26D" fill-opacity="0.1"/>
      <line x1="72" y1="47" x2="66" y2="55" stroke="#0D0D0D" stroke-width="2.5" stroke-linecap="round"/>
      <!-- Right arm down -->
      <rect x="15" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="45" y1="15" x2="45" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="45" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M33 35 Q37 30 43 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
    </svg>
  )}

  {variant === 'cowboy' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm -->
      <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Cowboy hat brim -->
      <ellipse cx="50" cy="18" rx="30" ry="6" fill="#8B6914" stroke="#6B4F10" stroke-width="1.5"/>
      <!-- Hat crown -->
      <path d="M35 18 Q42 2 50 5 Q58 2 65 18" fill="#A0781C" stroke="#8B6914" stroke-width="1.5"/>
      <!-- Lasso in right hand -->
      <circle class="cowboy-lasso" cx="78" cy="65" r="8" fill="none" stroke="#C4A35A" stroke-width="2"/>
    </svg>
  )}

  {variant === 'detective' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm -->
      <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Deerstalker cap -->
      <path d="M30 25 Q40 15 50 18 Q60 15 70 25" fill="#5C4033" stroke="#3D2B1F" stroke-width="1.5"/>
      <path d="M32 25 L28 30 M68 25 L72 30" stroke="#5C4033" stroke-width="2" stroke-linecap="round"/>
      <!-- Big magnifying glass -->
      <g class="detective-glass">
        <circle cx="25" cy="55" r="12" fill="none" stroke="#C0C0C0" stroke-width="2.5"/>
        <line x1="33" y1="63" x2="42" y2="72" stroke="#C0C0C0" stroke-width="3" stroke-linecap="round"/>
        <circle cx="25" cy="55" r="12" fill="rgba(173,216,230,0.2)"/>
      </g>
    </svg>
  )}

  {variant === 'chef' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm -->
      <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Chef hat -->
      <ellipse cx="50" cy="22" rx="18" ry="6" fill="white" stroke="#E1E3E6" stroke-width="1"/>
      <rect x="36" y="8" width="28" height="16" rx="8" fill="white" stroke="#E1E3E6" stroke-width="1"/>
      <circle cx="42" cy="6" r="6" fill="white" stroke="#E1E3E6" stroke-width="1"/>
      <circle cx="50" cy="4" r="6" fill="white" stroke="#E1E3E6" stroke-width="1"/>
      <circle cx="58" cy="6" r="6" fill="white" stroke="#E1E3E6" stroke-width="1"/>
      <!-- Spatula -->
      <g class="chef-spatula">
        <line x1="72" y1="60" x2="72" y2="80" stroke="#8B6914" stroke-width="2.5" stroke-linecap="round"/>
        <rect x="68" y="54" width="8" height="8" rx="1" fill="#C0C0C0" stroke="#A0A0A0" stroke-width="1"/>
      </g>
    </svg>
  )}

  {variant === 'captain' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm -->
      <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Captain cap -->
      <ellipse cx="50" cy="22" rx="22" ry="5" fill="#1a1a3e" stroke="#0D0D2B" stroke-width="1"/>
      <path d="M32 22 Q35 12 50 10 Q65 12 68 22" fill="#1a1a3e" stroke="#0D0D2B" stroke-width="1"/>
      <!-- Cap badge -->
      <circle cx="50" cy="20" r="4" fill="#FFD700" stroke="#DAA520" stroke-width="0.5"/>
      <!-- Telescope -->
      <g class="captain-telescope">
        <rect x="65" y="58" width="20" height="6" rx="3" fill="#8B6914" stroke="#6B4F10" stroke-width="1"/>
        <rect x="82" y="57" width="6" height="8" rx="2" fill="#A0781C"/>
      </g>
    </svg>
  )}

  {variant === 'professor' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm -->
      <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Mortarboard -->
      <polygon points="30,20 50,12 70,20 50,28" fill="#1a1a3e" stroke="#0D0D2B" stroke-width="1"/>
      <rect x="46" y="14" width="8" height="8" fill="#1a1a3e"/>
      <!-- Tassel -->
      <line x1="62" y1="20" x2="72" y2="28" stroke="#FFD700" stroke-width="1.5"/>
      <circle cx="72" cy="29" r="2" fill="#FFD700"/>
      <!-- Glasses on visor -->
      <circle cx="43" cy="42" r="4" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
      <circle cx="57" cy="42" r="4" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
      <line x1="47" y1="42" x2="53" y2="42" stroke="rgba(255,255,255,0.4)" stroke-width="0.8"/>
      <!-- Book -->
      <g class="professor-book">
        <rect x="20" y="62" width="14" height="10" rx="1" fill="#4C82A7" stroke="#3a6a8c" stroke-width="1"/>
        <line x1="27" y1="62" x2="27" y2="72" stroke="white" stroke-width="0.5"/>
      </g>
    </svg>
  )}

  {variant === 'accountant' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body (slightly more formal, upright posture) -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm (holding briefcase) -->
      <rect x="20" y="65" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Right arm -->
      <rect x="62" y="70" width="18" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Glasses on visor -->
      <rect x="40" y="39" width="8" height="6" rx="1" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="0.8"/>
      <rect x="52" y="39" width="8" height="6" rx="1" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="0.8"/>
      <line x1="48" y1="42" x2="52" y2="42" stroke="rgba(255,255,255,0.4)" stroke-width="0.6"/>
      <!-- Briefcase -->
      <g class="accountant-briefcase">
        <rect x="10" y="70" width="16" height="12" rx="2" fill="#8B6914" stroke="#6B4F10" stroke-width="1.5"/>
        <rect x="14" y="68" width="8" height="3" rx="1.5" fill="none" stroke="#6B4F10" stroke-width="1.5"/>
        <line x1="18" y1="74" x2="18" y2="78" stroke="#DAA520" stroke-width="1"/>
        <circle cx="18" cy="78" r="1" fill="#DAA520"/>
      </g>
      <!-- Ledger/clipboard in right hand -->
      <g class="accountant-ledger">
        <rect x="76" y="64" width="10" height="14" rx="1" fill="white" stroke="#A0A0A0" stroke-width="1"/>
        <line x1="78" y1="68" x2="84" y2="68" stroke="#E1E3E6" stroke-width="0.5"/>
        <line x1="78" y1="70" x2="84" y2="70" stroke="#E1E3E6" stroke-width="0.5"/>
        <line x1="78" y1="72" x2="82" y2="72" stroke="#00C26D" stroke-width="0.5"/>
        <line x1="78" y1="74" x2="84" y2="74" stroke="#E1E3E6" stroke-width="0.5"/>
      </g>
    </svg>
  )}

  {variant === 'controller' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
      <circle cx="50" cy="40" r="25" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Visor -->
      <ellipse cx="50" cy="42" rx="15" ry="12" fill="#00C26D" opacity="0.8"/>
      <!-- Body -->
      <rect x="35" y="60" width="30" height="25" rx="8" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Backpack -->
      <rect x="60" y="62" width="12" height="20" rx="3" fill="white" stroke="#0D0D0D" stroke-width="2"/>
      <!-- Left arm (extended outward, directing) -->
      <rect x="12" y="60" width="24" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2" transform="rotate(-15, 24, 64)"/>
      <!-- Right arm (extended outward, directing) -->
      <rect x="64" y="60" width="24" height="8" rx="4" fill="white" stroke="#0D0D0D" stroke-width="2" transform="rotate(15, 76, 64)"/>
      <!-- Antenna -->
      <line x1="50" y1="15" x2="50" y2="8" stroke="#6b6b6b" stroke-width="1.5" fill="none"/>
      <circle cx="50" cy="6" r="3" fill="#00C26D"/>
      <!-- Helmet reflection -->
      <path d="M38 35 Q42 30 48 32" stroke="white" stroke-width="1.5" fill="none" opacity="0.5"/>
      <!-- Hi-vis vest stripes on body -->
      <line x1="38" y1="65" x2="62" y2="65" stroke="#FFB02E" stroke-width="2" opacity="0.9"/>
      <line x1="38" y1="80" x2="62" y2="80" stroke="#FFB02E" stroke-width="2" opacity="0.9"/>
      <!-- Orange signal wand (left hand) -->
      <g class="controller-wand-left">
        <line x1="8" y1="50" x2="8" y2="62" stroke="#6b6b6b" stroke-width="2" stroke-linecap="round"/>
        <rect x="4" y="44" width="8" height="8" rx="1" fill="#FF6B35" stroke="#E55A2B" stroke-width="1" opacity="0.9"/>
      </g>
      <!-- Clipboard (right hand) -->
      <g class="controller-clipboard">
        <rect x="86" y="52" width="10" height="14" rx="1" fill="#F5F6F7" stroke="#A0A0A0" stroke-width="1"/>
        <rect x="89" y="50" width="4" height="3" rx="1" fill="#A0A0A0"/>
        <line x1="88" y1="56" x2="94" y2="56" stroke="#E1E3E6" stroke-width="0.5"/>
        <line x1="88" y1="58" x2="94" y2="58" stroke="#E1E3E6" stroke-width="0.5"/>
        <line x1="88" y1="60" x2="92" y2="60" stroke="#00C26D" stroke-width="0.8"/>
        <line x1="88" y1="62" x2="94" y2="62" stroke="#E1E3E6" stroke-width="0.5"/>
      </g>
    </svg>
  )}

  {variant === 'explorer' && (
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Helmet -->
