---
/**
 * CopyForAI -- Mintlify-style "Copy for AI" button.
 * Copies a clean text representation of the article content to clipboard.
 */

interface Props {
  title: string;
  section?: string;
  url?: string;
}

const { title, section, url } = Astro.props;
---

<button
  class="copy-for-ai-btn inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg border border-[var(--color-cloud-grey)] text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] hover:border-[var(--color-ink-muted)] transition-colors cursor-pointer bg-white"
  data-title={title}
  data-section={section}
  data-url={url}
  type="button"
  aria-label="Copy article content for AI"
>
  {/* Clipboard + sparkle icon */}
  <svg class="size-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
    <rect x="8" y="2" width="8" height="4" rx="1" ry="1" />
  </svg>
  <svg class="size-3 shrink-0 -ml-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 2l1.09 3.26L16.36 6.5l-3.27 1.09L12 10.85l-1.09-3.26L7.64 6.5l3.27-1.09L12 2zm6 8l.72 2.17L20.89 13l-2.17.72L18 15.89l-.72-2.17L15.11 13l2.17-.72L18 10zm-12 2l.72 2.17L8.89 15l-2.17.72L6 17.89l-.72-2.17L3.11 15l2.17-.72L6 12z" />
  </svg>
  <span class="copy-for-ai-label">Copy for AI</span>
</button>

<script is:inline>
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.copy-for-ai-btn');
    if (!btn) return;

    var title = btn.getAttribute('data-title') || '';
    var section = btn.getAttribute('data-section') || '';
    var url = btn.getAttribute('data-url') || '';

    // Find the article content
    var content = document.querySelector('.grove-prose') || document.querySelector('.blog-content');
    if (!content) return;

    // Clone and clean
    var clone = content.cloneNode(true);
    var removeTags = clone.querySelectorAll('nav, aside, script, style, .copy-for-ai-btn');
    removeTags.forEach(function(el) { el.remove(); });

    // Convert headings to markdown-style
    var headings = clone.querySelectorAll('h1, h2, h3, h4, h5, h6');
    headings.forEach(function(h) {
      var level = parseInt(h.tagName.charAt(1), 10);
      var prefix = '';
      for (var i = 0; i < level; i++) prefix += '#';
      var text = h.textContent.trim();
      var placeholder = document.createTextNode('\n' + prefix + ' ' + text + '\n');
      h.replaceWith(placeholder);
    });

    // Build header
    var header = '# ' + title + '\n';
    if (section) header += 'Section: ' + section + '\n';
    if (url) header += 'URL: ' + url + '\n';
    header += '\n';

    // Get text
    var bodyText = clone.textContent
      .replace(/\n{3,}/g, '\n\n')
      .trim();

    var fullText = header + bodyText;

    // Copy to clipboard
    navigator.clipboard.writeText(fullText).then(function() {
      var label = btn.querySelector('.copy-for-ai-label');
      if (label) {
        label.textContent = 'Copied!';
        setTimeout(function() {
          label.textContent = 'Copy for AI';
        }, 2000);
      }
    });
  });
</script>
