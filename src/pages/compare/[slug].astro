---
import ResourceLayout from '@/layouts/ResourceLayout.astro';
import { getCollection, render } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';

export async function getStaticPaths() {
  const items = filterByStatus(await getCollection('comparisons', ({ data }) => !data.draft));
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { title, description, kind, competitor, verdict, matrix, updated, date } = item.data;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Compare', href: '/compare/' },
  { label: kind === 'competitor' ? (competitor || title) : 'Category', },
];

const metaLine = `Last updated: ${updated || date}`;
---

<ResourceLayout
  title={title}
  description={description}
  badge={kind === 'competitor' ? 'Comparison' : 'Category comparison'}
  badgeColor="#8B5CF6"
  breadcrumbs={breadcrumbs}
  meta={metaLine}
  activePage="resources"
>
  <div slot="aside">
    {verdict && (
      <div class="verdict">
        <div class="verdict-label">Our honest take</div>
        <p>{verdict}</p>
      </div>
    )}

    {matrix && matrix.length > 0 && (
      <div class="matrix">
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th>Servantium</th>
              <th>{competitor || 'Other'}</th>
            </tr>
          </thead>
          <tbody>
            {matrix.map((row: { feature: string; servantium: string; other: string; winner?: string }) => (
              <tr>
                <td>{row.feature}</td>
                <td class={row.winner === 'servantium' ? 'win' : ''}>{row.servantium}</td>
                <td class={row.winner === 'other' ? 'win' : ''}>{row.other}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <Content />
</ResourceLayout>

<style>
  .verdict {
    padding: 1.5rem 1.75rem;
    background: var(--color-mist-grey);
    border-left: 4px solid var(--color-green);
    border-radius: 8px;
    margin-bottom: 1.75rem;
  }
  .verdict-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-green);
    margin-bottom: 0.5rem;
  }
  .verdict p { font-size: 1.05rem; color: var(--color-ink); line-height: 1.55; margin: 0; }
  .matrix { margin-bottom: 1.75rem; overflow-x: auto; }
  .matrix table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .matrix th, .matrix td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-cloud-grey);
    text-align: left;
  }
  .matrix th {
    font-weight: 600;
    color: var(--color-ink-muted);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  .matrix td.win {
    background: var(--color-soft-mint);
    font-weight: 600;
  }
</style>
