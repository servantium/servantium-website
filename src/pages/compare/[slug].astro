---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('comparisons', ({ data }) => !data.draft);
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { title, description, kind, competitor, verdict, matrix, updated, date } = item.data;
---

<BaseLayout>
  <SEO
    slot="head"
    title={`${title} — Servantium`}
    description={description}
    ogType="article"
  />

  <article class="compare-article">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/compare/">Compare</a>
        <span>›</span>
        <span>{kind === 'competitor' ? competitor : 'Category'}</span>
      </nav>

      <header class="compare-header">
        <div class="badge">{kind === 'competitor' ? 'Competitor comparison' : 'Category comparison'}</div>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
        <div class="updated">Last updated: {updated || date}</div>
      </header>

      {verdict && (
        <div class="verdict">
          <div class="verdict-label">Our honest take</div>
          <p>{verdict}</p>
        </div>
      )}

      {matrix && matrix.length > 0 && (
        <div class="matrix">
          <table>
            <thead>
              <tr>
                <th>Feature</th>
                <th>Servantium</th>
                <th>{competitor || 'Other'}</th>
              </tr>
            </thead>
            <tbody>
              {matrix.map(row => (
                <tr>
                  <td>{row.feature}</td>
                  <td class={row.winner === 'servantium' ? 'win' : ''}>{row.servantium}</td>
                  <td class={row.winner === 'other' ? 'win' : ''}>{row.other}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <div class="compare-content prose">
        <Content />
      </div>

      <div class="cta-box">
        <h2>See it for yourself</h2>
        <p>Book a 15-minute demo. We'll show you the engagement lifecycle end-to-end and you can decide.</p>
        <button class="btn btn-primary" data-cal-link="christopher-veale/servantium-introduction?duration=15" data-cal-namespace="servantium-introduction" data-cal-config='{"layout":"month_view"}'>Book a demo</button>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .compare-article { padding: 7rem 0 5rem; }
  .container { max-width: 820px; margin: 0 auto; padding: 0 var(--space-lg); }
  .breadcrumbs { display: flex; gap: 0.5rem; font-size: 0.85rem; color: var(--color-ink-muted); margin-bottom: 1.5rem; }
  .breadcrumbs a { color: var(--color-green); text-decoration: none; }
  .compare-header { margin-bottom: 2rem; }
  .badge { display: inline-block; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-green); background: var(--color-soft-mint); padding: 0.35rem 0.75rem; border-radius: 100px; margin-bottom: 1rem; }
  .compare-header h1 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 500; line-height: 1.15; letter-spacing: -0.02em; color: var(--color-ink); margin-bottom: 1rem; }
  .lede { font-size: 1.15rem; color: var(--color-ink-light); line-height: 1.55; margin-bottom: 0.75rem; }
  .updated { font-size: 0.8rem; color: var(--color-ink-muted); }
  .verdict { padding: 1.5rem 1.75rem; background: var(--color-mist-grey); border-left: 4px solid var(--color-green); border-radius: 8px; margin-bottom: 2.5rem; }
  .verdict-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-green); margin-bottom: 0.5rem; }
  .verdict p { font-size: 1.05rem; color: var(--color-ink); line-height: 1.55; margin: 0; }
  .matrix { margin-bottom: 2.5rem; overflow-x: auto; }
  .matrix table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .matrix th, .matrix td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-cloud-grey); text-align: left; }
  .matrix th { font-weight: 600; color: var(--color-ink-muted); text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.1em; }
  .matrix td.win { background: var(--color-soft-mint); font-weight: 600; }
  .compare-content { font-size: 1.05rem; line-height: 1.7; color: var(--color-ink-light); }
  .compare-content :global(h2) { font-family: var(--font-display); font-size: 1.5rem; margin: 2rem 0 0.75rem; color: var(--color-ink); }
  .compare-content :global(h3) { font-family: var(--font-display); font-size: 1.2rem; margin: 1.5rem 0 0.5rem; color: var(--color-ink); }
  .compare-content :global(ul) { padding-left: 1.25rem; margin: 1rem 0; }
  .compare-content :global(li) { margin: 0.4rem 0; }
  .compare-content :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
  .compare-content :global(th), .compare-content :global(td) { padding: 0.65rem 0.85rem; border-bottom: 1px solid var(--color-cloud-grey); text-align: left; }
  .cta-box { margin-top: 3rem; padding: 2.5rem; background: var(--color-deep-forest); color: var(--color-white); border-radius: 14px; text-align: center; }
  .cta-box h2 { font-family: var(--font-display); font-size: 1.75rem; font-weight: 500; color: var(--color-white); margin-bottom: 0.5rem; }
  .cta-box p { color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; }
</style>
