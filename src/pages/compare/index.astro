---
import ResourceIndexPage from '@/components/ResourceIndexPage.astro';
import { getCollection } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';
import { comparisonsToTiles } from '@/lib/resourceTiles';

const items = filterByStatus((await getCollection('comparisons', ({ data }) => !data.draft)))
  .sort((a, b) => a.data.order - b.data.order);
const tiles = comparisonsToTiles(items as any);
---

<ResourceIndexPage
  seoTitle="Comparisons | Servantium vs Alternatives"
  seoDescription="Honest comparisons of Servantium against the tools you're probably evaluating. Where they're better, where we are."
  eyebrow="Honest comparisons, no spin"
  h1="How Servantium compares"
  lede="Side-by-side looks at Servantium and the categories you're weighing. We'll tell you where the others are better. so you can make the right call."
  crumbLabel="Comparisons"
  tiles={tiles}
  emptyMessage="No comparisons published yet. coming soon."
  searchId="rix-search-compare"
/>
