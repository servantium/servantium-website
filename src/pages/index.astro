---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import '@/styles/home.css';
import HeroMockup from '@/components/HeroMockup.astro';
import CalBooker from '@/components/CalBooker.tsx';

const jsonLd = [
  {
    "@type": "Organization",
    "@id": "https://servantium.com/#organization",
    "name": "Servantium",
    "url": "https://servantium.com",
    "logo": { "@type": "ImageObject", "url": "https://servantium.com/logo.png" },
    "description": "The CPQ and engagement management platform built for professional services firms.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1111B S Governors Ave STE 48074",
      "addressLocality": "Dover",
      "addressRegion": "DE",
      "postalCode": "19904",
      "addressCountry": "US"
    },
    "email": "hello@servantium.com",
    "sameAs": []
  },
  {
    "@type": "SoftwareApplication",
    "@id": "https://servantium.com/#software",
    "name": "Servantium",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Configure-Price-Quote (CPQ) and Professional Services Automation (PSA) platform.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Contact for pricing" },
    "provider": { "@id": "https://servantium.com/#organization" },
    "featureList": ["Engagement scoping and pricing", "Proposal generation", "Resource planning", "Project delivery tracking", "AI-powered automation"]
  },
  {
    "@type": "WebSite",
    "@id": "https://servantium.com/#website",
    "url": "https://servantium.com",
    "name": "Servantium",
    "publisher": { "@id": "https://servantium.com/#organization" }
  }
];
---

<BaseLayout activePage="home">
  <SEO
    slot="head"
    title="Professional Services CPQ & Engagement Management Platform | Servantium"
    description="Servantium is the professional services CPQ and engagement management platform. Define, price, sell, and deliver services with institutional memory built in."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Homepage content ported from index.html — page-specific sections below -->
  <!-- For the prototype, this is the content between <main> tags from the original -->

  <section class="hero">
    <div class="container">
      <div class="hero-content" id="hero-content">
        <div class="hero-text">
          <div class="hero-eyebrow">The Agentic Services Platform</div>
          <h1>The operating system for<br /><em>your </em><span class="hero-rotating" id="hero-rotate-a"><span class="hero-rotating-inner"><span class="hero-rotating-word active">firm.</span><span class="hero-rotating-word">team.</span><span class="hero-rotating-word">clients.</span><span class="hero-rotating-word">growth.</span></span></span></h1>
          <p class="hero-description">
            Scope, price, deliver, and learn from every engagement. Servantium is the agentic platform that turns your operational knowledge into a compounding advantage.
          </p>
          <div class="hero-ctas">
            <a href="#contact" class="btn btn-primary">Schedule a Call</a>
            <a href="/platform" class="btn btn-secondary">Explore the Platform</a>
          </div>
        </div>
        <HeroMockup />
      </div>
    </div>
    <!-- Logo bar at bottom of hero viewport -->
    <div class="logo-bar-inner">
      <div class="logo-bar-label">Trusted by innovative services teams</div>
      <div class="logo-bar-scroll">
        <div class="logo-bar-track">
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="problem" id="problem">
    <div class="container">
      <div class="problem-content">
        <div class="problem-header" data-animate="fade-up">
          <h2>The Problem</h2>
          <p>
            Services businesses are fundamentally disadvantaged because their offerings are
            implicit, tribal, and fragmented—rather than encoded in systems that remember and improve. <strong>Let's fix that.</strong>
          </p>
        </div>
        <div class="problem-stats">
          <div class="stat-card" data-animate="fade-up" data-delay="0">
            <div class="stat-number">68.9%</div>
            <div class="stat-label">Billable Utilization</div>
            <div class="stat-description">Below the 75% threshold needed for healthy margins</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/03/18/the-truth-about-billable-utilization/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="150">
            <div class="stat-number">1 in 4</div>
            <div class="stat-label">Projects Delivered Late</div>
            <div class="stat-description">On-time delivery has fallen to 73.4%, the lowest in five years</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="300">
            <div class="stat-number">20%</div>
            <div class="stat-label">Hit Profit Margin Targets</div>
            <div class="stat-description">Only 1 in 5 firms consistently achieve their project profit goals</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="450">
            <div class="stat-number">-4.6%</div>
            <div class="stat-label">Revenue Growth Decline</div>
            <div class="stat-description">Year-over-year revenue growth has turned negative</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="core-concept" id="concept" data-animate="fade-up">
    <div class="container">
      <div class="concept-header">
        <h2>Engagement Management for Professional Services</h2>
        <p class="text-large">
          Everything in Servantium revolves around the Engagement: a living record that evolves
          from first conversation through delivery and into organizational memory.
        </p>
      </div>

      <!-- Journey Map: Desktop (horizontal) -->
      <div class="journey-map" id="journey-map">
        <svg class="journey-svg journey-svg--desktop" viewBox="0 0 960 200" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <defs>
            <linearGradient id="journeyGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#00C26D" />
              <stop offset="50%" stop-color="#26A899" />
              <stop offset="100%" stop-color="#4C82A7" />
            </linearGradient>
            <filter id="glowFilter">
              <feGaussianBlur stdDeviation="4" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>
          <!-- Background path (track) -->
          <path class="journey-track" d="M 60,100 C 140,40 220,40 300,100 C 380,160 460,160 540,100 C 620,40 700,40 780,100 C 820,120 860,130 900,110" fill="none" stroke="var(--color-cloud-grey)" stroke-width="4" stroke-linecap="round" />
          <!-- Animated path (draws in) -->
          <path class="journey-path" id="journey-path-desktop" d="M 60,100 C 140,40 220,40 300,100 C 380,160 460,160 540,100 C 620,40 700,40 780,100 C 820,120 860,130 900,110" fill="none" stroke="url(#journeyGrad)" stroke-width="4" stroke-linecap="round" />
          <!-- Waypoints -->
          <g class="journey-waypoint" data-stage="0">
            <circle cx="60" cy="100" r="22" fill="white" stroke="var(--color-servantium-green)" stroke-width="3" class="waypoint-ring" />
            <text x="60" y="105" text-anchor="middle" fill="var(--color-ink)" font-size="14" font-weight="600" font-family="var(--font-display)">1</text>
            <text x="60" y="140" text-anchor="middle" fill="var(--color-ink-muted)" font-size="11" font-weight="600" letter-spacing="0.05em">Discovery</text>
          </g>
          <g class="journey-waypoint" data-stage="1">
            <circle cx="236" cy="56" r="22" fill="white" stroke="var(--color-deep-teal)" stroke-width="3" class="waypoint-ring" />
            <text x="236" y="61" text-anchor="middle" fill="var(--color-ink)" font-size="14" font-weight="600" font-family="var(--font-display)">2</text>
            <text x="236" y="96" text-anchor="middle" fill="var(--color-ink-muted)" font-size="11" font-weight="600" letter-spacing="0.05em">Estimation</text>
          </g>
          <g class="journey-waypoint" data-stage="2">
            <circle cx="420" cy="140" r="22" fill="white" stroke="var(--color-slate-blue)" stroke-width="3" class="waypoint-ring" />
            <text x="420" y="145" text-anchor="middle" fill="var(--color-ink)" font-size="14" font-weight="600" font-family="var(--font-display)">3</text>
            <text x="420" y="175" text-anchor="middle" fill="var(--color-ink-muted)" font-size="11" font-weight="600" letter-spacing="0.05em">Proposal</text>
          </g>
          <g class="journey-waypoint" data-stage="3">
            <circle cx="600" cy="140" r="22" fill="white" stroke="var(--color-amber)" stroke-width="3" class="waypoint-ring" />
            <text x="600" y="145" text-anchor="middle" fill="var(--color-ink)" font-size="14" font-weight="600" font-family="var(--font-display)">4</text>
            <text x="600" y="175" text-anchor="middle" fill="var(--color-ink-muted)" font-size="11" font-weight="600" letter-spacing="0.05em">Contract</text>
          </g>
          <g class="journey-waypoint" data-stage="4">
            <circle cx="780" cy="60" r="22" fill="white" stroke="var(--color-coral)" stroke-width="3" class="waypoint-ring" />
            <text x="780" y="65" text-anchor="middle" fill="var(--color-ink)" font-size="14" font-weight="600" font-family="var(--font-display)">5</text>
            <text x="780" y="96" text-anchor="middle" fill="var(--color-ink-muted)" font-size="11" font-weight="600" letter-spacing="0.05em">Delivery</text>
          </g>
          <g class="journey-waypoint" data-stage="5">
            <circle cx="900" cy="110" r="22" fill="white" stroke="var(--color-slate)" stroke-width="3" class="waypoint-ring" />
            <text x="900" y="115" text-anchor="middle" fill="var(--color-ink)" font-size="14" font-weight="600" font-family="var(--font-display)">6</text>
            <text x="900" y="148" text-anchor="middle" fill="var(--color-ink-muted)" font-size="11" font-weight="600" letter-spacing="0.05em">Learning</text>
          </g>
        </svg>

        <!-- Journey Map: Mobile (vertical) -->
        <div class="journey-vertical" id="journey-vertical">
          <div class="journey-vertical-line"></div>
          <div class="journey-vertical-line-fill" id="journey-vertical-fill"></div>
          {[
            { num: 1, name: 'Discovery', color: 'var(--color-servantium-green)' },
            { num: 2, name: 'Estimation', color: 'var(--color-deep-teal)' },
            { num: 3, name: 'Proposal', color: 'var(--color-slate-blue)' },
            { num: 4, name: 'Contract', color: 'var(--color-amber)' },
            { num: 5, name: 'Delivery', color: 'var(--color-coral)' },
            { num: 6, name: 'Learning', color: 'var(--color-slate)' },
          ].map((stage, i) => (
            <button class={`journey-vpoint${i === 0 ? ' active' : ''}`} data-stage={i} type="button" aria-label={`${stage.name} phase`}>
              <div class="journey-vpoint-circle" style={`border-color: ${stage.color}`}>
                <span class="journey-vpoint-num">{stage.num}</span>
              </div>
              <span class="journey-vpoint-label">{stage.name}</span>
            </button>
          ))}
        </div>

        <!-- Detail Panel -->
        <div class="journey-detail" id="journey-detail">
          <div class="journey-detail-image">
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&h=400&fit=crop" alt="" id="journey-detail-img" loading="lazy" />
          </div>
          <div class="journey-detail-content">
            <h3 class="journey-detail-title" id="journey-detail-title">Discovery</h3>
            <p class="journey-detail-text" id="journey-detail-text">Understand client needs, pain points, and desired outcomes.</p>
            <ul class="journey-detail-features" id="journey-detail-features">
              <li>Structured intake and needs assessment</li>
              <li>Pain point and outcome mapping</li>
              <li>Context capture for downstream decisions</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq" id="faq">
    <div class="container">
      <div class="faq-header">
        <h2>Frequently Asked Questions</h2>
        <p class="text-large">
          Everything you need to know about Servantium and how it transforms professional services operations.
        </p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What is Servantium?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Servantium is an operating system for professional services businesses. It's a unified platform that formalizes how services are defined, priced, sold, activated, and delivered—creating a single system of record for every engagement.</p>
              <p>Unlike traditional PSA tools that focus on time tracking and billing, Servantium captures the complete engagement lifecycle from initial discovery through delivery and learning.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            How is Servantium different from traditional PSA software?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Traditional PSA software typically bolts project management onto sales tools. Servantium takes a fundamentally different approach:</p>
              <ul>
                <li><strong>Not a generic CRM</strong> — Purpose-built for services</li>
                <li><strong>Not a spreadsheet replacement</strong> — Structure that turns implicit knowledge into explicit, compounding primitives</li>
                <li><strong>Not a static proposal generator</strong> — Living documents connected to your service definitions</li>
                <li><strong>Not PSA bolted onto sales</strong> — An integrated system where sales, delivery, and learning share context</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What types of businesses use Servantium?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Servantium is built for professional services firms that deliver repeatable (but customizable) engagements: consulting firms, implementation teams, managed services providers, agencies, and technical services firms.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            How does Servantium handle AI and automation?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>We believe structure precedes automation. AI in Servantium learns from your encoded patterns. Human judgment remains sovereign—technology amplifies expertise but doesn't replace the relationships that make services businesses work.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Is my data secure?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Yes. Your engagement data, pricing information, and client details are encrypted at rest and in transit. Enterprise customers can discuss additional security requirements including data residency and compliance needs.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" id="contact">
    <div class="container">
      <div class="cta-header">
        <h3 style="font-family: var(--font-display); font-size: 1.75rem; margin-bottom: 0.5rem; color: var(--color-white);">Ready to Encode Your Services?</h3>
        <p>
          We're working with a small number of services firms who believe their
          operational knowledge deserves better than spreadsheets and tribal memory.
        </p>
      </div>
      <div class="cta-grid">
        <div class="cta-column" style="border-radius: 8px; padding: 1rem;">
          <div class="cta-column-header">
            <h3>Schedule a Demo</h3>
            <p>Book an intro call to see Servantium in action</p>
          </div>
          <div class="cal-embed-container">
            <CalBooker client:visible calLink="christopher-veale/servantium-introduction" />
          </div>
        </div>
        <div class="cta-column" style="border-radius: 8px; padding: 1rem;">
          <div class="cta-column-header">
            <h3>Send a Message</h3>
            <p>Prefer to write? We'll get back to you within 24 hours</p>
          </div>
          <form class="contact-form" id="contact-form">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name" style="padding: 0.5rem 0.75rem; font-size: 0.9rem;" />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="you@company.com" style="padding: 0.5rem 0.75rem; font-size: 0.9rem;" />
            </div>
            <div class="form-group form-group-message">
              <label for="message">Message</label>
              <textarea id="message" name="message" required placeholder="Tell us about your services business and what you're looking for..." style="padding: 0.5rem 0.75rem; font-size: 0.9rem; min-height: 80px;"></textarea>
            </div>
            <button type="submit" class="form-submit" id="form-submit" style="padding: 0.625rem; font-size: 0.9rem;">Send Message</button>
            <div class="form-status" id="form-status"></div>
            <div class="form-success-overlay" id="form-success-overlay">
              <div class="form-success-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <h4>Message Sent</h4>
              <p>Thanks for reaching out! We'll be in touch within 24 hours.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-question').forEach(function(button) {
    button.addEventListener('click', function() {
      const item = this.parentElement;
      const isActive = item?.classList.contains('active');
      document.querySelectorAll('.faq-item').forEach(function(otherItem) {
        otherItem.classList.remove('active');
        otherItem.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
      });
      if (!isActive) {
        item?.classList.add('active');
        this.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Contact Form Submission
  const contactForm = document.getElementById('contact-form');
  const formStatus = document.getElementById('form-status');
  const formSubmit = document.getElementById('form-submit');
  const formSuccessOverlay = document.getElementById('form-success-overlay');

  contactForm?.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (formSubmit) {
      formSubmit.disabled = true;
      formSubmit.textContent = 'Sending...';
    }
    if (formStatus) {
      formStatus.className = 'form-status';
      formStatus.style.display = 'none';
    }
    const formData = {
      name: (document.getElementById('name') as HTMLInputElement)?.value,
      email: (document.getElementById('email') as HTMLInputElement)?.value,
      message: (document.getElementById('message') as HTMLTextAreaElement)?.value
    };
    try {
      const response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });
      if (response.ok) {
        formSuccessOverlay?.classList.add('active');
        contactForm.reset();
        setTimeout(() => formSuccessOverlay?.classList.remove('active'), 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      if (formStatus) {
        formStatus.className = 'form-status error';
        formStatus.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        formStatus.style.display = 'block';
      }
    } finally {
      if (formSubmit) {
        formSubmit.disabled = false;
        formSubmit.textContent = 'Send Message';
      }
    }
  });

  // Hero rotating words
  document.querySelectorAll('.hero-rotating').forEach(function(container) {
    const words = container.querySelectorAll('.hero-rotating-word');
    if (words.length < 2) return;
    let idx = 0;
    setInterval(function() {
      words[idx].classList.remove('active');
      words[idx].classList.add('exit');
      const prevIdx = idx;
      idx = (idx + 1) % words.length;
      words[idx].classList.remove('exit');
      words[idx].classList.add('active');
      setTimeout(() => words[prevIdx].classList.remove('exit'), 700);
    }, 3500);
  });

  // Section fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('section').forEach(section => {
    section.style.opacity = '0';
    section.style.transform = 'translateY(24px)';
    section.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
    observer.observe(section);
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Cal.com inline embed now handled by React CalBooker atom (client:visible)

  // Journey Map interactive
  const journeyStages = [
    {
      title: 'Discovery',
      text: 'Understand client needs, pain points, and desired outcomes.',
      features: ['Structured intake and needs assessment', 'Pain point and outcome mapping', 'Context capture for downstream decisions'],
      image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&h=400&fit=crop',
    },
    {
      title: 'Estimation',
      text: 'Transform discovery into structured scope and pricing.',
      features: ['Service definition templates', 'Historical data-driven pricing', 'Effort and resource modeling'],
      image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&h=400&fit=crop',
    },
    {
      title: 'Proposal',
      text: 'Generate proposals from your service architecture.',
      features: ['Auto-generated scope documents', 'Pricing tied to service definitions', 'Branded deliverable templates'],
      image: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&h=400&fit=crop',
    },
    {
      title: 'Contract',
      text: 'Win the deal, assign the team, activate the engagement.',
      features: ['Deal-to-delivery handoff', 'Automatic resource alignment', 'Timeline and milestone activation'],
      image: 'https://images.unsplash.com/photo-1552581234-26160f608093?w=800&h=400&fit=crop',
    },
    {
      title: 'Delivery',
      text: 'Execute with real-time visibility into progress and margin.',
      features: ['Live utilization tracking', 'Margin and burn-rate dashboards', 'Milestone and deliverable management'],
      image: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=400&fit=crop',
    },
    {
      title: 'Learning',
      text: 'Extract patterns and feed insights back into service definitions.',
      features: ['Engagement retrospectives', 'Pattern recognition across projects', 'Service definition refinement'],
      image: 'https://images.unsplash.com/photo-1531545514256-b1400bc00f31?w=800&h=400&fit=crop',
    },
  ];

  let activeStage = 0;
  const detailTitle = document.getElementById('journey-detail-title');
  const detailText = document.getElementById('journey-detail-text');
  const detailFeatures = document.getElementById('journey-detail-features');
  const detailImg = document.getElementById('journey-detail-img') as HTMLImageElement | null;
  const detailPanel = document.getElementById('journey-detail');

  function setJourneyStage(index: number) {
    if (index === activeStage && detailPanel?.classList.contains('visible')) return;
    activeStage = index;
    const stage = journeyStages[index];

    // Fade out then update
    detailPanel?.classList.remove('visible');
    setTimeout(() => {
      if (detailTitle) detailTitle.textContent = stage.title;
      if (detailText) detailText.textContent = stage.text;
      if (detailFeatures) {
        detailFeatures.innerHTML = stage.features.map(f => `<li>${f}</li>`).join('');
      }
      if (detailImg) detailImg.src = stage.image;
      detailPanel?.classList.add('visible');
    }, 200);

    // Update desktop SVG waypoints
    document.querySelectorAll('.journey-waypoint').forEach((wp, i) => {
      wp.classList.toggle('active', i === index);
    });
    // Update mobile vertical waypoints
    document.querySelectorAll('.journey-vpoint').forEach((vp, i) => {
      vp.classList.toggle('active', i === index);
    });
  }

  // Desktop SVG waypoint click/hover
  document.querySelectorAll('.journey-waypoint').forEach(wp => {
    wp.addEventListener('click', () => {
      const idx = parseInt(wp.getAttribute('data-stage') || '0');
      setJourneyStage(idx);
    });
    wp.addEventListener('mouseenter', () => {
      const idx = parseInt(wp.getAttribute('data-stage') || '0');
      setJourneyStage(idx);
    });
    // Make SVG groups focusable/clickable
    wp.setAttribute('role', 'button');
    wp.setAttribute('tabindex', '0');
    wp.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        const idx = parseInt(wp.getAttribute('data-stage') || '0');
        setJourneyStage(idx);
      }
    });
  });

  // Mobile vertical waypoint click
  document.querySelectorAll('.journey-vpoint').forEach(vp => {
    vp.addEventListener('click', () => {
      const idx = parseInt(vp.getAttribute('data-stage') || '0');
      setJourneyStage(idx);
    });
  });

  // Path draw animation via IntersectionObserver
  const journeyMap = document.getElementById('journey-map');
  if (journeyMap) {
    const pathEl = document.getElementById('journey-path-desktop') as SVGPathElement | null;
    const vertFill = document.getElementById('journey-vertical-fill');
    let journeyAnimated = false;

    const journeyObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !journeyAnimated) {
          journeyAnimated = true;

          // Animate desktop SVG path
          if (pathEl) {
            const len = pathEl.getTotalLength();
            pathEl.style.strokeDasharray = `${len}`;
            pathEl.style.strokeDashoffset = `${len}`;
            pathEl.style.transition = 'stroke-dashoffset 2s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
            requestAnimationFrame(() => { pathEl.style.strokeDashoffset = '0'; });
          }

          // Animate mobile vertical line fill
          if (vertFill) {
            vertFill.style.transition = 'height 2s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
            requestAnimationFrame(() => { vertFill.style.height = '100%'; });
          }

          // Stagger waypoint fade-in (desktop)
          document.querySelectorAll('.journey-waypoint').forEach((wp, i) => {
            (wp as SVGGElement).style.opacity = '0';
            (wp as SVGGElement).style.transition = `opacity 0.5s ease ${i * 300}ms`;
            setTimeout(() => { (wp as SVGGElement).style.opacity = '1'; }, 50);
          });

          // Stagger waypoint fade-in (mobile)
          document.querySelectorAll('.journey-vpoint').forEach((vp, i) => {
            (vp as HTMLElement).style.opacity = '0';
            (vp as HTMLElement).style.transition = `opacity 0.5s ease ${i * 300}ms`;
            setTimeout(() => { (vp as HTMLElement).style.opacity = '1'; }, 50);
          });

          // Show detail panel after first waypoint appears
          setTimeout(() => { detailPanel?.classList.add('visible'); }, 400);
        }
      });
    }, { threshold: 0.2 });

    journeyObserver.observe(journeyMap);
  }

  // Initialize first stage
  setJourneyStage(0);
</script>

<!-- Scroll-triggered animations for homepage -->
<script is:inline>
  function initScrollAnimations() {
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var elements = document.querySelectorAll('[data-animate]');
    if (elements.length === 0) return;

    if (prefersReduced) {
      elements.forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    // Set initial hidden state
    elements.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.6s cubic-bezier(0.16,1,0.3,1)';
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var delay = parseInt(el.getAttribute('data-delay') || '0');
          setTimeout(function() {
            el.style.opacity = '1';
            el.style.transform = 'none';
          }, delay);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    elements.forEach(function(el) { observer.observe(el); });
  }
  // Fire on both DOMContentLoaded (dev) and astro:page-load (production with View Transitions)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }
  document.addEventListener('astro:page-load', initScrollAnimations);
</script>
