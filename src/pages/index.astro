---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import '@/styles/home.css';
import HeroMockup from '@/components/HeroMockup.astro';
import CalBooker from '@/components/CalBooker.tsx';

const jsonLd = [
  {
    "@type": "Organization",
    "@id": "https://servantium.com/#organization",
    "name": "Servantium",
    "url": "https://servantium.com",
    "logo": { "@type": "ImageObject", "url": "https://servantium.com/logo.png" },
    "description": "The CPQ and engagement management platform built for professional services firms.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1111B S Governors Ave STE 48074",
      "addressLocality": "Dover",
      "addressRegion": "DE",
      "postalCode": "19904",
      "addressCountry": "US"
    },
    "email": "hello@servantium.com",
    "sameAs": []
  },
  {
    "@type": "SoftwareApplication",
    "@id": "https://servantium.com/#software",
    "name": "Servantium",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Configure-Price-Quote (CPQ) and Professional Services Automation (PSA) platform.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Contact for pricing" },
    "provider": { "@id": "https://servantium.com/#organization" },
    "featureList": ["Engagement scoping and pricing", "Proposal generation", "Resource planning", "Project delivery tracking", "AI-powered automation"]
  },
  {
    "@type": "WebSite",
    "@id": "https://servantium.com/#website",
    "url": "https://servantium.com",
    "name": "Servantium",
    "publisher": { "@id": "https://servantium.com/#organization" }
  }
];
---

<BaseLayout activePage="home">
  <SEO
    slot="head"
    title="Professional Services CPQ & Engagement Management Platform | Servantium"
    description="Servantium is the professional services CPQ and engagement management platform. Define, price, sell, and deliver services with institutional memory built in."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Homepage content ported from index.html — page-specific sections below -->
  <!-- For the prototype, this is the content between <main> tags from the original -->

  <section class="hero">
    <div class="container">
      <div class="hero-content" id="hero-content">
        <div class="hero-text">
          <div class="hero-eyebrow">The Agentic Services Platform</div>
          <h1>The operating system for<br /><em>your </em><span class="hero-rotating" id="hero-rotate-a"><span class="hero-rotating-inner"><span class="hero-rotating-word active">firm.</span><span class="hero-rotating-word">team.</span><span class="hero-rotating-word">clients.</span><span class="hero-rotating-word">growth.</span></span></span></h1>
          <p class="hero-description">
            Scope, price, deliver, and learn from every engagement. Servantium is the agentic platform that turns your operational knowledge into a compounding advantage.
          </p>
          <div class="hero-ctas">
            <a href="#contact" class="btn btn-primary">Schedule a Call</a>
            <a href="/platform" class="btn btn-secondary">Explore the Platform</a>
          </div>
        </div>
        <HeroMockup />
      </div>
    </div>
    <!-- Logo bar at bottom of hero viewport -->
    <div class="logo-bar-inner">
      <div class="logo-bar-label">Trusted by innovative services teams</div>
      <div class="logo-bar-scroll">
        <div class="logo-bar-track">
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="problem" id="problem">
    <div class="container">
      <div class="problem-content">
        <div class="problem-header" data-animate="fade-up">
          <h2>The Problem</h2>
          <p>
            Services businesses are fundamentally disadvantaged because their offerings are
            implicit, tribal, and fragmented—rather than encoded in systems that remember and improve. <strong>Let's fix that.</strong>
          </p>
        </div>
        <div class="problem-stats">
          <div class="stat-card" data-animate="fade-up" data-delay="0">
            <div class="stat-number">68.9%</div>
            <div class="stat-label">Billable Utilization</div>
            <div class="stat-description">Below the 75% threshold needed for healthy margins</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/03/18/the-truth-about-billable-utilization/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="150">
            <div class="stat-number">1 in 4</div>
            <div class="stat-label">Projects Delivered Late</div>
            <div class="stat-description">On-time delivery has fallen to 73.4%, the lowest in five years</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="300">
            <div class="stat-number">20%</div>
            <div class="stat-label">Hit Profit Margin Targets</div>
            <div class="stat-description">Only 1 in 5 firms consistently achieve their project profit goals</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="450">
            <div class="stat-number">-4.6%</div>
            <div class="stat-label">Revenue Growth Decline</div>
            <div class="stat-description">Year-over-year revenue growth has turned negative</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Winding Road Engagement Journey -->
  <section class="journey-section" id="concept">
    <div class="journey-sticky">
      <div class="journey-inner">
        <div class="journey-header">
          <h2>The Engagement Journey</h2>
          <p class="text-large">
            Every engagement follows a path. Servantium turns that path into a system that remembers, learns, and improves.
          </p>
        </div>

        <!-- Desktop: Bird's-eye winding road SVG -->
        <div class="journey-road-wrap" id="journey-road-wrap">
          <svg viewBox="0 0 1200 500" class="journey-road-svg" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
            <!-- Road surface (wide grey path) -->
            <path class="road-surface-path"
              d="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"
              stroke="#e2e8f0" stroke-width="44" fill="none" stroke-linecap="round" stroke-linejoin="round"/>

            <!-- Road edge lines for depth -->
            <path d="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"
              stroke="#cbd5e1" stroke-width="46" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
            <path d="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"
              stroke="#e2e8f0" stroke-width="40" fill="none" stroke-linecap="round" stroke-linejoin="round"/>

            <!-- Center dashed line -->
            <path d="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"
              stroke="white" stroke-width="2" fill="none" stroke-dasharray="12 8" stroke-linecap="round"/>

            <!-- Green progress line (animated via stroke-dashoffset) -->
            <path id="road-progress"
              d="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"
              stroke="#00C26D" stroke-width="4" fill="none" stroke-linecap="round"/>

            <!-- Green glow behind progress line -->
            <path id="road-progress-glow"
              d="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"
              stroke="#00C26D" stroke-width="12" fill="none" stroke-linecap="round" opacity="0.25"/>

            <!-- Green particles flowing along the path -->
            <circle r="4" fill="#00C26D" opacity="0.7">
              <animateMotion dur="6s" repeatCount="indefinite" begin="0s"
                path="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"/>
            </circle>
            <circle r="3" fill="#00C26D" opacity="0.5">
              <animateMotion dur="6s" repeatCount="indefinite" begin="-2s"
                path="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"/>
            </circle>
            <circle r="3.5" fill="#00C26D" opacity="0.6">
              <animateMotion dur="6s" repeatCount="indefinite" begin="-4s"
                path="M 50,400 C 200,400 250,100 400,100 C 550,100 500,400 700,400 C 850,400 900,100 1050,150 L 1150,150"/>
            </circle>

            <!-- Stop 1: Discovery -->
            <g class="road-stop" data-stop="0">
              <circle cx="50" cy="400" r="22" fill="white" stroke="#d1d5db" stroke-width="3" class="stop-ring"/>
              <circle cx="50" cy="400" r="22" fill="none" stroke="#00C26D" stroke-width="3" class="stop-ring-active" opacity="0"/>
              <text x="50" y="405" text-anchor="middle" font-size="14" font-weight="700" fill="#9ca3af" class="stop-num" font-family="Source Sans 3, sans-serif">1</text>
              <text x="50" y="440" text-anchor="middle" font-size="13" font-weight="600" fill="#6b7280" class="stop-label" font-family="Source Sans 3, sans-serif">Discovery</text>
            </g>

            <!-- Stop 2: Estimation -->
            <g class="road-stop" data-stop="1">
              <circle cx="400" cy="100" r="22" fill="white" stroke="#d1d5db" stroke-width="3" class="stop-ring"/>
              <circle cx="400" cy="100" r="22" fill="none" stroke="#4C82A7" stroke-width="3" class="stop-ring-active" opacity="0"/>
              <text x="400" y="105" text-anchor="middle" font-size="14" font-weight="700" fill="#9ca3af" class="stop-num" font-family="Source Sans 3, sans-serif">2</text>
              <text x="400" y="72" text-anchor="middle" font-size="13" font-weight="600" fill="#6b7280" class="stop-label" font-family="Source Sans 3, sans-serif">Estimation</text>
            </g>

            <!-- Stop 3: Proposal -->
            <g class="road-stop" data-stop="2">
              <circle cx="700" cy="400" r="22" fill="white" stroke="#d1d5db" stroke-width="3" class="stop-ring"/>
              <circle cx="700" cy="400" r="22" fill="none" stroke="#FFB02E" stroke-width="3" class="stop-ring-active" opacity="0"/>
              <text x="700" y="405" text-anchor="middle" font-size="14" font-weight="700" fill="#9ca3af" class="stop-num" font-family="Source Sans 3, sans-serif">3</text>
              <text x="700" y="440" text-anchor="middle" font-size="13" font-weight="600" fill="#6b7280" class="stop-label" font-family="Source Sans 3, sans-serif">Proposal</text>
            </g>

            <!-- Stop 4: Delivery -->
            <g class="road-stop" data-stop="3">
              <circle cx="1050" cy="150" r="22" fill="white" stroke="#d1d5db" stroke-width="3" class="stop-ring"/>
              <circle cx="1050" cy="150" r="22" fill="none" stroke="#26A899" stroke-width="3" class="stop-ring-active" opacity="0"/>
              <text x="1050" y="155" text-anchor="middle" font-size="14" font-weight="700" fill="#9ca3af" class="stop-num" font-family="Source Sans 3, sans-serif">4</text>
              <text x="1050" y="122" text-anchor="middle" font-size="13" font-weight="600" fill="#6b7280" class="stop-label" font-family="Source Sans 3, sans-serif">Delivery</text>
            </g>

            <!-- Stop 5: Learning -->
            <g class="road-stop" data-stop="4">
              <circle cx="1150" cy="150" r="22" fill="white" stroke="#d1d5db" stroke-width="3" class="stop-ring"/>
              <circle cx="1150" cy="150" r="22" fill="none" stroke="#8B5CF6" stroke-width="3" class="stop-ring-active" opacity="0"/>
              <text x="1150" y="155" text-anchor="middle" font-size="14" font-weight="700" fill="#9ca3af" class="stop-num" font-family="Source Sans 3, sans-serif">5</text>
              <text x="1150" y="122" text-anchor="middle" font-size="13" font-weight="600" fill="#6b7280" class="stop-label" font-family="Source Sans 3, sans-serif">Learning</text>
            </g>
          </svg>
        </div>

        <!-- Detail panel below the road -->
        <div class="journey-detail-panel" id="journey-detail-panel">
          <div class="journey-detail-inner">
            <div class="journey-detail-header">
              <span class="journey-detail-number" id="journey-detail-number">1</span>
              <h3 class="journey-detail-title" id="journey-detail-title">Discovery</h3>
            </div>
            <p class="journey-detail-desc" id="journey-detail-desc">Understand what your client actually needs. Capture context from every conversation, not just action items.</p>
            <div class="journey-detail-features" id="journey-detail-features">
              <span>Engagement workspace</span>
              <span>AI note parsing</span>
              <span>Similar matching</span>
              <span>Service catalog</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile: Vertical road layout -->
    <div class="journey-mobile" id="journey-mobile">
      <div class="journey-mobile-header">
        <h2>The Engagement Journey</h2>
        <p class="text-large">
          Every engagement follows a path. Servantium turns that path into a system that remembers, learns, and improves.
        </p>
      </div>
      <div class="journey-mobile-road">
        <div class="journey-mobile-line"></div>

        <div class="journey-mobile-stop">
          <div class="journey-mobile-pin" style="background: #00C26D;"><span>1</span></div>
          <div class="journey-mobile-content">
            <strong>Discovery</strong>
            <p>Understand what your client actually needs. Capture context from every conversation, not just action items.</p>
            <div class="journey-mobile-features">
              <span>Engagement workspace</span>
              <span>AI note parsing</span>
              <span>Similar matching</span>
              <span>Service catalog</span>
            </div>
          </div>
        </div>

        <div class="journey-mobile-stop">
          <div class="journey-mobile-pin" style="background: #4C82A7;"><span>2</span></div>
          <div class="journey-mobile-content">
            <strong>Estimation</strong>
            <p>Build pricing that reflects reality, not guesswork. Every estimate draws from what you've actually delivered before.</p>
            <div class="journey-mobile-features">
              <span>Quote builder</span>
              <span>Grouped sections</span>
              <span>Margin calculator</span>
              <span>AI generation</span>
            </div>
          </div>
        </div>

        <div class="journey-mobile-stop">
          <div class="journey-mobile-pin" style="background: #FFB02E;"><span>3</span></div>
          <div class="journey-mobile-content">
            <strong>Proposal</strong>
            <p>Generate proposals that reflect your real service architecture. Scope, pricing, and deliverables flow from your estimation work.</p>
            <div class="journey-mobile-features">
              <span>Document generation</span>
              <span>Template system</span>
              <span>PDF export</span>
              <span>Client review</span>
            </div>
          </div>
        </div>

        <div class="journey-mobile-stop">
          <div class="journey-mobile-pin" style="background: #26A899;"><span>4</span></div>
          <div class="journey-mobile-content">
            <strong>Delivery</strong>
            <p>Execute with real-time visibility. Know who's doing what, when, and whether you're on track before it's too late.</p>
            <div class="journey-mobile-features">
              <span>Resource planning</span>
              <span>Capacity tracking</span>
              <span>Utilization metrics</span>
              <span>Progress monitoring</span>
            </div>
          </div>
        </div>

        <div class="journey-mobile-stop">
          <div class="journey-mobile-pin" style="background: #8B5CF6;"><span>5</span></div>
          <div class="journey-mobile-content">
            <strong>Learning</strong>
            <p>Every engagement makes the next one better. Your firm gets smarter automatically.</p>
            <div class="journey-mobile-features">
              <span>Institutional memory</span>
              <span>Note embeddings</span>
              <span>Learning catalog</span>
              <span>Vector search</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ── Winding Road Engagement Journey ── */
    .journey-section {
      position: relative;
      min-height: 180vh;
      background: var(--color-white, #fff);
    }

    .journey-sticky {
      position: sticky;
      top: 4rem;
      height: calc(100vh - 5rem);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .journey-inner {
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .journey-header {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 2rem;
    }
    .journey-header h2 {
      margin-bottom: 0.75rem;
    }

    /* SVG Road */
    .journey-road-wrap {
      position: relative;
      max-width: 1000px;
      margin: 0 auto;
    }
    .journey-road-svg {
      width: 100%;
      height: auto;
      display: block;
    }

    /* Stop markers */
    .road-stop {
      cursor: pointer;
      transition: filter 0.4s ease;
    }
    .road-stop .stop-ring {
      transition: stroke 0.3s ease, opacity 0.3s ease;
    }
    .road-stop .stop-ring-active {
      transition: opacity 0.4s ease;
    }
    .road-stop .stop-num {
      transition: fill 0.3s ease;
    }
    .road-stop .stop-label {
      transition: fill 0.3s ease;
    }
    .road-stop.active .stop-ring {
      opacity: 0;
    }
    .road-stop.active .stop-ring-active {
      opacity: 1;
    }
    .road-stop.active {
      filter: drop-shadow(0 0 12px rgba(0, 194, 109, 0.5));
    }
    /* Per-stop active glow colors */
    .road-stop[data-stop="0"].active { filter: drop-shadow(0 0 12px rgba(0, 194, 109, 0.6)); }
    .road-stop[data-stop="1"].active { filter: drop-shadow(0 0 12px rgba(76, 130, 167, 0.6)); }
    .road-stop[data-stop="2"].active { filter: drop-shadow(0 0 12px rgba(255, 176, 46, 0.6)); }
    .road-stop[data-stop="3"].active { filter: drop-shadow(0 0 12px rgba(38, 168, 153, 0.6)); }
    .road-stop[data-stop="4"].active { filter: drop-shadow(0 0 12px rgba(139, 92, 246, 0.6)); }

    /* Detail panel */
    .journey-detail-panel {
      max-width: 640px;
      margin: 1.5rem auto 0;
      background: var(--color-mint-tint, #F3FCF8);
      border-radius: 12px;
      padding: 1.5rem 2rem;
      border: 1px solid var(--color-cloud-grey, #E1E3E6);
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.35s ease, transform 0.35s ease;
    }
    .journey-detail-panel.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .journey-detail-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .journey-detail-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      min-width: 32px;
      border-radius: 50%;
      background: #00C26D;
      color: white;
      font-weight: 700;
      font-size: 14px;
      font-family: var(--font-body, 'Source Sans 3', sans-serif);
      transition: background 0.3s ease;
    }
    .journey-detail-title {
      font-family: var(--font-display, 'Playfair Display', serif);
      font-size: 1.4rem;
      margin: 0;
      color: var(--color-ink, #0D0D0D);
      transition: color 0.3s ease;
    }
    .journey-detail-desc {
      color: var(--color-ink-light, #3d3d3d);
      line-height: 1.7;
      font-size: 1rem;
      margin-bottom: 0.75rem;
    }
    .journey-detail-features {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .journey-detail-features span {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.85rem;
      color: var(--color-ink-light, #3d3d3d);
      background: white;
      border: 1px solid var(--color-cloud-grey, #E1E3E6);
      border-radius: 6px;
      padding: 0.3rem 0.65rem;
    }
    .journey-detail-features span::before {
      content: '';
      display: inline-block;
      width: 12px;
      height: 12px;
      background: url("data:image/svg+xml,%3Csvg viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16.7 5.3a1 1 0 010 1.4l-8 8a1 1 0 01-1.4 0l-4-4a1 1 0 111.4-1.4L8 12.6l7.3-7.3a1 1 0 011.4 0z' fill='%2300C26D'/%3E%3C/svg%3E") no-repeat center;
      background-size: contain;
      flex-shrink: 0;
    }

    /* ── Mobile vertical layout ── */
    .journey-mobile {
      display: none;
      padding: 4rem 0 3rem;
    }
    .journey-mobile-header {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 2.5rem;
      padding: 0 1.5rem;
    }
    .journey-mobile-header h2 {
      margin-bottom: 0.75rem;
    }
    .journey-mobile-road {
      position: relative;
      max-width: 560px;
      margin: 0 auto;
      padding-left: 56px;
      padding-right: 1rem;
    }
    .journey-mobile-line {
      position: absolute;
      left: 30px;
      top: 12px;
      bottom: 12px;
      width: 4px;
      background: linear-gradient(to bottom, #00C26D, #4C82A7, #FFB02E, #26A899, #8B5CF6);
      border-radius: 2px;
    }
    .journey-mobile-stop {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem 0;
      position: relative;
    }
    .journey-mobile-pin {
      width: 40px;
      height: 40px;
      min-width: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 14px;
      margin-left: -28px;
      z-index: 2;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
      font-family: var(--font-body, 'Source Sans 3', sans-serif);
    }
    .journey-mobile-content {
      flex: 1;
    }
    .journey-mobile-content strong {
      display: block;
      font-size: 1.1rem;
      color: var(--color-ink, #0D0D0D);
      margin-bottom: 0.25rem;
    }
    .journey-mobile-content p {
      font-size: 0.9rem;
      color: var(--color-ink-light, #3d3d3d);
      line-height: 1.6;
      margin: 0 0 0.5rem;
    }
    .journey-mobile-features {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }
