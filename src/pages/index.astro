</BaseLayout>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-question').forEach(function(button) {
    button.addEventListener('click', function() {
      const item = this.parentElement;
      const isActive = item?.classList.contains('active');
      document.querySelectorAll('.faq-item').forEach(function(otherItem) {
        otherItem.classList.remove('active');
        otherItem.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
      });
      if (!isActive) {
        item?.classList.add('active');
        this.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Contact Form Submission
  const contactForm = document.getElementById('contact-form');
  const formStatus = document.getElementById('form-status');
  const formSubmit = document.getElementById('form-submit');
  const formSuccessOverlay = document.getElementById('form-success-overlay');

  contactForm?.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (formSubmit) {
      formSubmit.disabled = true;
      formSubmit.textContent = 'Sending...';
    }
    if (formStatus) {
      formStatus.className = 'form-status';
      formStatus.style.display = 'none';
    }
    const formData = {
      name: (document.getElementById('name') as HTMLInputElement)?.value,
      email: (document.getElementById('email') as HTMLInputElement)?.value,
      message: (document.getElementById('message') as HTMLTextAreaElement)?.value
    };
    try {
      const response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });
      if (response.ok) {
        formSuccessOverlay?.classList.add('active');
        contactForm.reset();
        setTimeout(() => formSuccessOverlay?.classList.remove('active'), 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      if (formStatus) {
        formStatus.className = 'form-status error';
        formStatus.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        formStatus.style.display = 'block';
      }
    } finally {
      if (formSubmit) {
        formSubmit.disabled = false;
        formSubmit.textContent = 'Send Message';
      }
    }
  });

  // Hero rotating words
  document.querySelectorAll('.hero-rotating').forEach(function(container) {
    const words = container.querySelectorAll('.hero-rotating-word');
    if (words.length < 2) return;
    let idx = 0;
    setInterval(function() {
      words[idx].classList.remove('active');
      words[idx].classList.add('exit');
      const prevIdx = idx;
      idx = (idx + 1) % words.length;
      words[idx].classList.remove('exit');
      words[idx].classList.add('active');
      setTimeout(() => words[prevIdx].classList.remove('exit'), 700);
    }, 3500);
  });

  // Section fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('section').forEach(section => {
    section.style.opacity = '0';
    section.style.transform = 'translateY(24px)';
    section.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
    observer.observe(section);
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Cal.com inline embed now handled by React CalBooker atom (client:visible)
</script>

<!-- Scroll-triggered animations for homepage -->
<script is:inline>
  function initScrollAnimations() {
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var elements = document.querySelectorAll('[data-animate]');
    if (elements.length === 0) return;

    if (prefersReduced) {
      elements.forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    // Set initial hidden state
    elements.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.6s cubic-bezier(0.16,1,0.3,1)';
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var delay = parseInt(el.getAttribute('data-delay') || '0');
          setTimeout(function() {
            el.style.opacity = '1';
            el.style.transform = 'none';
          }, delay);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    elements.forEach(function(el) { observer.observe(el); });
  }
  // Fire on both DOMContentLoaded (dev) and astro:page-load (production with View Transitions)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }
  document.addEventListener('astro:page-load', initScrollAnimations);
</script>

<!-- 3D Road scroll interaction -->
<script is:inline>
  function initRoadAnimation() {
    var roadSection = document.querySelector('.road-section');
    var markers = document.querySelectorAll('.stage-marker');
    var mobileStages = document.querySelectorAll('.road-mobile-stage');
    var detailPanel = document.getElementById('road-detail-panel');
    var detailTitle = document.getElementById('road-detail-title');
    var detailDesc = document.getElementById('road-detail-desc');
    var detailFeatures = document.getElementById('road-detail-features');

    if (!roadSection) return;

    var roadStages = [
      { title: 'Discovery', color: '#00C26D', desc: 'Understand client needs, pain points, and desired outcomes before a single line item is written.', features: ['Structured intake and needs assessment', 'Pain point and outcome mapping', 'Context capture for downstream decisions', 'Similar engagement matching'] },
      { title: 'Estimation', color: '#4C82A7', desc: 'Transform discovery into structured scope and pricing, informed by every project your firm has delivered.', features: ['Service definition templates', 'Historical data-driven pricing', 'Effort and resource modeling', 'AI-powered quote generation'] },
      { title: 'Proposal', color: '#FFB02E', desc: 'Generate professional proposals directly from your service architecture and pricing data.', features: ['Auto-generated scope documents', 'Pricing tied to service definitions', 'Branded deliverable templates', 'One-click PDF export'] },
      { title: 'Delivery', color: '#26A899', desc: 'Execute with real-time visibility into progress, margin, and resource utilization.', features: ['Live utilization tracking', 'Margin and burn-rate dashboards', 'Milestone management', 'Cross-engagement visibility'] },
      { title: 'Learning', color: '#9B59B6', desc: 'Every engagement feeds back into your institutional memory, making each future project smarter.', features: ['Engagement retrospectives', 'Pattern recognition across projects', 'Service definition refinement', 'Estimate accuracy tracking'] }
    ];

    var currentStage = -1;

    function setActiveStage(index) {
      if (index === currentStage) return;
      currentStage = index;
      var stage = roadStages[index];

      // Update desktop markers
      markers.forEach(function(m, i) {
        m.classList.toggle('active', i === index);
      });

      // Update mobile stages
      mobileStages.forEach(function(m, i) {
        m.classList.toggle('active', i === index);
      });

      // Update detail panel
      if (detailPanel) {
        detailPanel.classList.remove('visible');
        setTimeout(function() {
          if (detailTitle) { detailTitle.textContent = stage.title; detailTitle.style.color = stage.color; }
          if (detailDesc) detailDesc.textContent = stage.desc;
          if (detailFeatures) {
            detailFeatures.innerHTML = stage.features.map(function(f) { return '<li>' + f + '</li>'; }).join('');
          }
          detailPanel.classList.add('visible');
        }, 180);
      }
    }

    // Click on markers (desktop)
    markers.forEach(function(m, i) {
      m.addEventListener('click', function() { setActiveStage(i); });
    });

    // Click on mobile stages
    mobileStages.forEach(function(m, i) {
      m.addEventListener('click', function() { setActiveStage(i); });
    });

    // Scroll-linked animation
    var animated = false;
    var roadObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !animated) {
          animated = true;
          setActiveStage(0);
          if (detailPanel) {
            setTimeout(function() { detailPanel.classList.add('visible'); }, 500);
          }
        }
      });
    }, { threshold: 0.2 });
    roadObserver.observe(roadSection);

    // Scroll-driven stage progression
    function onScroll() {
      if (!animated) return;
      var rect = roadSection.getBoundingClientRect();
      var progress = 1 - (rect.top / window.innerHeight);
      var clampedProgress = Math.max(0, Math.min(1, progress));
      var activeIndex = Math.min(4, Math.max(0, Math.floor(clampedProgress * 5)));
      setActiveStage(activeIndex);
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // Initialize
    setActiveStage(0);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRoadAnimation);
  } else {
    initRoadAnimation();
  }
  document.addEventListener('astro:page-load', initRoadAnimation);
</script>
