---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import '@/styles/home.css';
import HeroMockup from '@/components/HeroMockup.astro';

import EngagementRoad from '@/theme/widgets/EngagementRoad.astro';

const logos = [
  { src: '/logos/investorflow.svg', alt: 'InvestorFlow' },
  { src: '/logos/compliancelabs.png', alt: 'Compliance Labs' },
  { src: '/logos/e9corporation.png', alt: 'E-9 Corporation', invert: true },
  { src: '/logos/plottlabs.png', alt: 'Plott Labs' },
  { src: '/logos/google-for-startups.svg', alt: 'Google for Startups' },
  { src: '/logos/nvidia-inception.svg', alt: 'NVIDIA Inception Program' },
];

const jsonLd = [
  {
    "@type": "Organization",
    "@id": "https://servantium.com/#organization",
    "name": "Servantium",
    "url": "https://servantium.com",
    "logo": { "@type": "ImageObject", "url": "https://servantium.com/logo.png" },
    "description": "The CPQ and engagement management platform built for professional services firms.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1111B S Governors Ave STE 48074",
      "addressLocality": "Dover",
      "addressRegion": "DE",
      "postalCode": "19904",
      "addressCountry": "US"
    },
    "email": "hello@servantium.com",
    "sameAs": [
      "https://www.linkedin.com/company/servantium"
    ]
  },
  {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Servantium?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Servantium is the single place where you define what you sell, price it, scope it, deliver it, and learn from it. One system for the whole engagement lifecycle. Most tools make you stitch together a CRM, a PSA, spreadsheets, and a document generator. We built one thing that does the job properly."
        }
      },
      {
        "@type": "Question",
        "name": "How is Servantium different from traditional PSA software?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most PSA tools bolt project tracking onto a sales tool and call it a day. Servantium connects the whole chain. Your service definitions feed your estimates, your estimates feed your proposals, your delivery data feeds back into smarter estimates next time. Everything shares context instead of living in silos."
        }
      },
      {
        "@type": "Question",
        "name": "What types of businesses use Servantium?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Consulting firms, implementation teams, MSPs, agencies, and technical services companies. The common thread: you deliver engagements that are roughly repeatable but always a bit different — and you're tired of reinventing the wheel every time."
        }
      },
      {
        "@type": "Question",
        "name": "How does Servantium handle AI and automation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Servantium gives you structured engagement data that AI can actually learn from. Then the automation gets useful — smarter estimates, pattern matching across past work, things that genuinely save time. But we're not pretending AI replaces the humans who do the work."
        }
      },
      {
        "@type": "Question",
        "name": "Is my data secure?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Everything's encrypted at rest and in transit — your engagement data, your pricing, your client details. We take this seriously because we know services firms handle sensitive commercial information."
        }
      }
    ]
  },
  {
    "@type": "SoftwareApplication",
    "@id": "https://servantium.com/#software",
    "name": "Servantium",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Configure-Price-Quote (CPQ) and Professional Services Automation (PSA) platform.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Contact for pricing" },
    "provider": { "@id": "https://servantium.com/#organization" },
    "featureList": ["Engagement scoping and pricing", "Proposal generation", "Resource planning", "Project delivery tracking", "AI-powered automation"]
  },
  {
    "@type": "WebSite",
    "@id": "https://servantium.com/#website",
    "url": "https://servantium.com",
    "name": "Servantium",
    "publisher": { "@id": "https://servantium.com/#organization" }
  }
];
---

<BaseLayout activePage="home">
  <SEO
    slot="head"
    title="Professional Services CPQ & Engagement Management Platform | Servantium"
    description="Servantium is the professional services CPQ and engagement management platform. Define, price, sell, and deliver services with institutional memory built in."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Homepage content ported from index.html — page-specific sections below -->
  <!-- For the prototype, this is the content between <main> tags from the original -->

  <section class="hero">
    <div class="container">
      <div class="hero-content" id="hero-content">
        <div class="hero-text">
          <div class="hero-eyebrow">The Agentic Services Platform</div>
          <h1>The operating system for<br /><em>your </em><span class="hero-rotating" id="hero-rotate-a"><span class="hero-rotating-inner"><span class="hero-rotating-word active">firm.</span><span class="hero-rotating-word">team.</span><span class="hero-rotating-word">clients.</span><span class="hero-rotating-word">growth.</span></span></span></h1>
          <p class="hero-description">
            Scope, price, deliver, and learn from every engagement. Servantium is the agentic platform that turns your operational knowledge into a compounding advantage.
          </p>
          <div class="hero-ctas">
            <a href="#contact" class="btn btn-primary">Schedule a Call</a>
            <a href="/platform" class="btn btn-secondary">Explore the Platform</a>
          </div>
        </div>
        <HeroMockup />
      </div>
    </div>
    <!-- Logo bar at bottom of hero viewport -->
    <div class="logo-bar-inner">
      <div class="logo-bar-label">Customers & Partners</div>
      <div class="logo-bar-scroll">
        <div class="logo-bar-track">
          {/* Two copies for seamless infinite scroll */}
          {[...logos, ...logos].map((logo, i) => (
            <img src={logo.src} alt={logo.alt} class={`logo-bar-img${logo.invert ? ' logo-invert' : ''}`} loading="lazy" aria-hidden={i >= logos.length ? 'true' : undefined} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="problem" id="problem">
    <div class="container">
      <div class="problem-content">
        <div class="problem-header" data-animate="fade-up">
          <h2>The Problem</h2>
          <p>
            Services businesses are fundamentally disadvantaged because their offerings are
            implicit, tribal, and fragmented—rather than encoded in systems that remember and improve. <strong>Let's fix that.</strong>
          </p>
        </div>
        <div class="problem-stats">
          <div class="stat-card" data-animate="fade-up" data-delay="0">
            <div class="stat-number">68.9%</div>
            <div class="stat-label">Billable Utilization</div>
            <div class="stat-description">Below the 75% threshold needed for healthy margins</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/03/18/the-truth-about-billable-utilization/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="150">
            <div class="stat-number">1 in 4</div>
            <div class="stat-label">Projects Delivered Late</div>
            <div class="stat-description">On-time delivery has fallen to 73.4%, the lowest in five years</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="300">
            <div class="stat-number">20%</div>
            <div class="stat-label">Hit Profit Margin Targets</div>
            <div class="stat-description">Only 1 in 5 firms consistently achieve their project profit goals</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="450">
            <div class="stat-number">-4.6%</div>
            <div class="stat-label">Revenue Growth Decline</div>
            <div class="stat-description">Year-over-year revenue growth has turned negative</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement Road Driving Simulator -->
  <div id="concept"></div>
  <EngagementRoad
    title="Engagement Management for Professional Services"
    subtitle="Everything in Servantium revolves around the Engagement — a living record that evolves from first conversation through delivery and into organizational memory."
    stops={[
      { title: 'Discovery', tagline: 'Every conversation is captured context.', description: 'Understand what your client actually needs. Capture context from every conversation, not just action items.', features: ['Engagement workspace', 'AI note parsing', 'Similar matching', 'Service catalog', 'Speech-to-text capture', 'Tag organization'], color: '#00C26D', icon: '\u{1F50D}' },
      { title: 'Estimation', tagline: 'Price from experience, not guesswork.', description: 'Build pricing that reflects reality, not guesswork. Every estimate draws from what you\'ve actually delivered before.', features: ['Quote builder', 'Grouped sections', 'Margin calculator', 'AI generation', 'Discount system', 'Quote templates'], color: '#4C82A7', icon: '\u{1F4CA}' },
      { title: 'Proposal', tagline: 'Documents that write themselves.', description: 'Generate proposals from your real service architecture. Scope, pricing, and deliverables flow from your estimation work.', features: ['Document generation', 'Template system', 'PDF export', 'Client review', 'Adobe merge integration', 'Version history'], color: '#FFB02E', icon: '\u{1F4DD}' },
      { title: 'Delivery', tagline: 'See problems before they become fires.', description: 'Execute with real-time visibility. Know who\'s doing what, when, and whether you\'re on track before it\'s too late.', features: ['Resource planning', 'Capacity tracking', 'Utilization metrics', 'Progress monitoring', 'Interval planning', 'Assignment grid'], color: '#26A899', icon: '\u{1F680}' },
      { title: 'Learning', tagline: 'Your firm gets smarter with every project.', description: 'Every engagement makes the next one better. Your firm gets smarter automatically.', features: ['Institutional memory', 'Note embeddings', 'Learning catalog', 'Vector search', 'Pattern detection', 'Accuracy benchmarks'], color: '#8B5CF6', icon: '\u{1F9E0}' },
    ]}
  />

  <section class="faq" id="faq">
    <div class="container">
      <div class="faq-header">
        <h2>Frequently Asked Questions</h2>
        <p class="text-large">
          Everything you need to know about Servantium and how it transforms professional services operations.
        </p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What is Servantium?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>It's where you run your services business. Servantium is the single place where you define what you sell, price it, scope it, deliver it, and learn from it. One system for the whole engagement lifecycle.</p>
              <p>Most tools make you stitch together a CRM, a PSA, spreadsheets, and a document generator. We built one thing that does the job properly.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            How is Servantium different from traditional PSA software?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Most PSA tools bolt project tracking onto a sales tool and call it a day. You end up with disconnected data everywhere -- your estimates live in spreadsheets, your proposals live in Word docs, and nobody can tell you whether last quarter's projects actually hit their margins.</p>
              <p>Servantium connects the whole chain. Your service definitions feed your estimates, your estimates feed your proposals, your delivery data feeds back into smarter estimates next time. Everything shares context instead of living in silos.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What types of businesses use Servantium?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>If you sell expertise and deliver projects, you're probably a fit. We're talking consulting firms, implementation teams, MSPs, agencies, and technical services companies. The common thread: you deliver engagements that are roughly repeatable but always a bit different -- and you're tired of reinventing the wheel every time.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            How does Servantium handle AI and automation?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Here's the honest version: AI is only as useful as the data you feed it. Most services firms have terrible operational data -- hours billed and revenue, but nothing about what actually happened on the engagement. So their AI tools produce garbage.</p>
              <p>We fix the data problem first. Servantium gives you structured engagement data that AI can actually learn from. Then the automation gets useful -- smarter estimates, pattern matching across past work, things that genuinely save time. But we're not pretending AI replaces the humans who do the work. It won't.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Is my data secure?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Yes. Everything's encrypted at rest and in transit -- your engagement data, your pricing, your client details. We take this seriously because we know services firms handle sensitive commercial information. If you've got specific compliance or data residency requirements, we're happy to have that conversation.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" id="contact">
    <div class="container">
      <div class="cta-header">
        <h2 style="font-family: var(--font-display); font-size: 1.75rem; margin-bottom: 0.5rem; color: var(--color-white);">Ready to Encode Your Services?</h2>
        <p>
          We're working with a small number of services firms who believe their
          operational knowledge deserves better than spreadsheets and tribal memory.
        </p>
      </div>
      <div class="cta-grid">
        <div class="cta-column" style="border-radius: 8px; padding: 1rem;">
          <div class="cta-column-header">
            <h3>Schedule a Demo</h3>
            <p>Book an intro call to see Servantium in action</p>
          </div>
          <div class="cal-embed-container">
            <div id="cal-inline-embed" style="width:100%;height:100%;overflow:scroll;"></div>
          </div>
        </div>
        <div class="cta-column" style="border-radius: 8px; padding: 1rem;">
          <div class="cta-column-header">
            <h3>Send a Message</h3>
            <p>Prefer to write? We'll get back to you within 24 hours</p>
          </div>
          <form class="contact-form" id="contact-form">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name" style="padding: 0.5rem 0.75rem; font-size: 0.9rem;" />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="you@company.com" style="padding: 0.5rem 0.75rem; font-size: 0.9rem;" />
            </div>
            <div class="form-group form-group-message">
              <label for="message">Message</label>
              <textarea id="message" name="message" required placeholder="Tell us about your services business and what you're looking for..." style="padding: 0.5rem 0.75rem; font-size: 0.9rem; min-height: 80px;"></textarea>
            </div>
            <button type="submit" class="form-submit" id="form-submit" style="padding: 0.625rem; font-size: 0.9rem;">Send Message</button>
            <div class="form-status" id="form-status"></div>
            <div class="form-success-overlay" id="form-success-overlay">
              <div class="form-success-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <h4>Message Sent</h4>
              <p>Thanks for reaching out! We'll be in touch within 24 hours.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-question').forEach(function(button) {
    button.addEventListener('click', function() {
      const item = this.parentElement;
      const isActive = item?.classList.contains('active');
      document.querySelectorAll('.faq-item').forEach(function(otherItem) {
        otherItem.classList.remove('active');
        otherItem.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
      });
      if (!isActive) {
        item?.classList.add('active');
        this.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Contact Form Submission
  const contactForm = document.getElementById('contact-form');
  const formStatus = document.getElementById('form-status');
  const formSubmit = document.getElementById('form-submit');
  const formSuccessOverlay = document.getElementById('form-success-overlay');

  contactForm?.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (formSubmit) {
      formSubmit.disabled = true;
      formSubmit.textContent = 'Sending...';
    }
    if (formStatus) {
      formStatus.className = 'form-status';
      formStatus.style.display = 'none';
    }
    const formData = {
      name: (document.getElementById('name') as HTMLInputElement)?.value,
      email: (document.getElementById('email') as HTMLInputElement)?.value,
      message: (document.getElementById('message') as HTMLTextAreaElement)?.value
    };
    try {
      const response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });
      if (response.ok) {
        formSuccessOverlay?.classList.add('active');
        contactForm.reset();
        setTimeout(() => formSuccessOverlay?.classList.remove('active'), 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      if (formStatus) {
        formStatus.className = 'form-status error';
        formStatus.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        formStatus.style.display = 'block';
      }
    } finally {
      if (formSubmit) {
        formSubmit.disabled = false;
        formSubmit.textContent = 'Send Message';
      }
    }
  });

  // Hero mockup auto-cycling (rotates through 6 screens)
  (function() {
    const pages = document.querySelectorAll('.mockup-page');
    const dots = document.querySelectorAll('.mockup-auto-dot');
    const navBtns = document.querySelectorAll('.mockup-nav-btn');
    if (pages.length < 2) return;

    const pageOrder = ['notes', 'engagement', 'documents', 'resources', 'dashboard', 'learning'];
    let currentIdx = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    function showPage(idx: number) {
      pages.forEach(p => p.classList.remove('active'));
      dots.forEach(d => d.classList.remove('active'));
      navBtns.forEach(b => b.classList.remove('active'));
      const targetPage = pageOrder[idx];
      const page = document.querySelector(`.mockup-page[data-page="${targetPage}"]`);
      const dot = document.querySelector(`.mockup-auto-dot[data-page="${targetPage}"]`);
      const btn = document.querySelector(`.mockup-nav-btn[data-page="${targetPage}"]`);
      if (page) page.classList.add('active');
      if (dot) dot.classList.add('active');
      if (btn) btn.classList.add('active');
      currentIdx = idx;
    }

    function startAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => {
        showPage((currentIdx + 1) % pageOrder.length);
      }, 5000);
    }

    // Click dots to jump
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const page = dot.getAttribute('data-page') || '';
        const idx = pageOrder.indexOf(page);
        if (idx >= 0) { showPage(idx); startAuto(); }
      });
    });

    // Click nav buttons to jump
    navBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const page = btn.getAttribute('data-page') || '';
        const idx = pageOrder.indexOf(page);
        if (idx >= 0) { showPage(idx); startAuto(); }
      });
    });

    showPage(0);
    startAuto();
  })();

  // Hero rotating words
  document.querySelectorAll('.hero-rotating').forEach(function(container) {
    const words = container.querySelectorAll('.hero-rotating-word');
    if (words.length < 2) return;
    let idx = 0;
    setInterval(function() {
      words[idx].classList.remove('active');
      words[idx].classList.add('exit');
      const prevIdx = idx;
      idx = (idx + 1) % words.length;
      words[idx].classList.remove('exit');
      words[idx].classList.add('active');
      setTimeout(() => words[prevIdx].classList.remove('exit'), 700);
    }, 3500);
  });

  // Section fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('section').forEach(section => {
    // Don't hide sections that are already in the viewport (hero, above-fold)
    var rect = section.getBoundingClientRect();
    if (rect.top < window.innerHeight && rect.bottom > 0) {
      // Already visible - don't hide it
      return;
    }
    section.style.opacity = '0';
    section.style.transform = 'translateY(24px)';
    section.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
    observer.observe(section);
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Cal.com inline embed
  if (window.Cal && window.Cal.ns && window.Cal.ns["servantium-introduction"]) {
    window.Cal.ns["servantium-introduction"]("inline", {
      elementOrSelector: "#cal-inline-embed",
      calLink: "christopher-veale/servantium-introduction",
      config: {layout:"month_view", useSlotsViewOnSmallScreen:"true", theme:"light"},
    });
  }
</script>

<!-- Scroll-triggered animations for homepage -->
<script is:inline>
  function initScrollAnimations() {
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var elements = document.querySelectorAll('[data-animate]');
    if (elements.length === 0) return;

    if (prefersReduced) {
      elements.forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    // Set initial hidden state
    elements.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.6s cubic-bezier(0.16,1,0.3,1)';
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var delay = parseInt(el.getAttribute('data-delay') || '0');
          setTimeout(function() {
            el.style.opacity = '1';
            el.style.transform = 'none';
          }, delay);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    elements.forEach(function(el) { observer.observe(el); });
  }
  // Fire on both DOMContentLoaded (dev) and astro:page-load (production with View Transitions)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }
  document.addEventListener('astro:page-load', initScrollAnimations);
</script>
