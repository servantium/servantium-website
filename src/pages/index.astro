<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-question').forEach(function(button) {
    button.addEventListener('click', function() {
      const item = this.parentElement;
      const isActive = item?.classList.contains('active');
      document.querySelectorAll('.faq-item').forEach(function(otherItem) {
        otherItem.classList.remove('active');
        otherItem.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
      });
      if (!isActive) {
        item?.classList.add('active');
        this.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Contact Form Submission
  const contactForm = document.getElementById('contact-form');
  const formStatus = document.getElementById('form-status');
  const formSubmit = document.getElementById('form-submit');
  const formSuccessOverlay = document.getElementById('form-success-overlay');

  contactForm?.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (formSubmit) {
      formSubmit.disabled = true;
      formSubmit.textContent = 'Sending...';
    }
    if (formStatus) {
      formStatus.className = 'form-status';
      formStatus.style.display = 'none';
    }
    const formData = {
      name: (document.getElementById('name') as HTMLInputElement)?.value,
      email: (document.getElementById('email') as HTMLInputElement)?.value,
      message: (document.getElementById('message') as HTMLTextAreaElement)?.value
    };
    try {
      const response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });
      if (response.ok) {
        formSuccessOverlay?.classList.add('active');
        contactForm.reset();
        setTimeout(() => formSuccessOverlay?.classList.remove('active'), 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      if (formStatus) {
        formStatus.className = 'form-status error';
        formStatus.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        formStatus.style.display = 'block';
      }
    } finally {
      if (formSubmit) {
        formSubmit.disabled = false;
        formSubmit.textContent = 'Send Message';
      }
    }
  });

  // Hero rotating words
  document.querySelectorAll('.hero-rotating').forEach(function(container) {
    const words = container.querySelectorAll('.hero-rotating-word');
    if (words.length < 2) return;
    let idx = 0;
    setInterval(function() {
      words[idx].classList.remove('active');
      words[idx].classList.add('exit');
      const prevIdx = idx;
      idx = (idx + 1) % words.length;
      words[idx].classList.remove('exit');
      words[idx].classList.add('active');
      setTimeout(() => words[prevIdx].classList.remove('exit'), 700);
    }, 3500);
  });

  // Section fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('section').forEach(section => {
    section.style.opacity = '0';
    section.style.transform = 'translateY(24px)';
    section.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
    observer.observe(section);
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      const href = this.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Cal.com inline embed now handled by React CalBooker atom (client:visible)
</script>

<!-- Scroll-triggered animations for homepage -->
<script is:inline>
  function initScrollAnimations() {
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var elements = document.querySelectorAll('[data-animate]');
    if (elements.length === 0) return;

    if (prefersReduced) {
      elements.forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
      return;
    }

    // Set initial hidden state
    elements.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.6s cubic-bezier(0.16,1,0.3,1)';
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var delay = parseInt(el.getAttribute('data-delay') || '0');
          setTimeout(function() {
            el.style.opacity = '1';
            el.style.transform = 'none';
          }, delay);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    elements.forEach(function(el) { observer.observe(el); });
  }
  // Fire on both DOMContentLoaded (dev) and astro:page-load (production with View Transitions)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }
  document.addEventListener('astro:page-load', initScrollAnimations);
</script>

<!-- Winding road scroll interaction -->
<script is:inline>
  function initJourneyRoad() {
    var section = document.querySelector('.journey-section');
    var progressPath = document.getElementById('road-progress');
    var glowPath = document.getElementById('road-progress-glow');
    var stops = document.querySelectorAll('.road-stop');
    var detailPanel = document.getElementById('journey-detail-panel');
    var detailNumber = document.getElementById('journey-detail-number');
    var detailTitle = document.getElementById('journey-detail-title');
    var detailDesc = document.getElementById('journey-detail-desc');
    var detailFeatures = document.getElementById('journey-detail-features');

    if (!section || !progressPath) return;

    // Stage data
    var stages = [
      { title: 'Discovery', color: '#00C26D', num: '1',
        desc: 'Understand what your client actually needs. Capture context from every conversation, not just action items.',
        features: ['Engagement workspace', 'AI note parsing', 'Similar matching', 'Service catalog'] },
      { title: 'Estimation', color: '#4C82A7', num: '2',
        desc: 'Build pricing that reflects reality, not guesswork. Every estimate draws from what you\'ve actually delivered before.',
        features: ['Quote builder', 'Grouped sections', 'Margin calculator', 'AI generation'] },
      { title: 'Proposal', color: '#FFB02E', num: '3',
        desc: 'Generate proposals that reflect your real service architecture. Scope, pricing, and deliverables flow from your estimation work.',
        features: ['Document generation', 'Template system', 'PDF export', 'Client review'] },
      { title: 'Delivery', color: '#26A899', num: '4',
        desc: 'Execute with real-time visibility. Know who\'s doing what, when, and whether you\'re on track before it\'s too late.',
        features: ['Resource planning', 'Capacity tracking', 'Utilization metrics', 'Progress monitoring'] },
      { title: 'Learning', color: '#8B5CF6', num: '5',
        desc: 'Every engagement makes the next one better. Your firm gets smarter automatically.',
        features: ['Institutional memory', 'Note embeddings', 'Learning catalog', 'Vector search'] }
    ];

    // Stop positions along the path as fractions (0-1)
    // These correspond to approximate positions on the cubic bezier path
    var stopPositions = [0.0, 0.22, 0.52, 0.82, 1.0];

    // Get total path length and set up dash animation
    var totalLength = progressPath.getTotalLength();
    progressPath.style.strokeDasharray = totalLength;
    progressPath.style.strokeDashoffset = totalLength;
    if (glowPath) {
      glowPath.style.strokeDasharray = totalLength;
      glowPath.style.strokeDashoffset = totalLength;
    }

    var currentStage = -1;
    var ticking = false;

    function setActiveStage(index) {
      if (index === currentStage) return;
      currentStage = index;
      var stage = stages[index];

      // Update stop markers
      stops.forEach(function(stop, i) {
        var isActive = i <= index;
        var isCurrent = i === index;
        var stopColor = stages[i].color;

        stop.classList.toggle('active', isCurrent);

        // Update number color
        var numEl = stop.querySelector('.stop-num');
        if (numEl) numEl.setAttribute('fill', isActive ? stopColor : '#9ca3af');

        // Update label color
        var labelEl = stop.querySelector('.stop-label');
        if (labelEl) labelEl.setAttribute('fill', isActive ? '#0D0D0D' : '#6b7280');
      });

      // Update detail panel
      if (detailPanel) {
        detailPanel.classList.remove('visible');
        setTimeout(function() {
          if (detailNumber) {
            detailNumber.textContent = stage.num;
            detailNumber.style.background = stage.color;
          }
          if (detailTitle) detailTitle.textContent = stage.title;
          if (detailDesc) detailDesc.textContent = stage.desc;
          if (detailFeatures) {
            detailFeatures.innerHTML = stage.features.map(function(f) {
              return '<span>' + f + '</span>';
            }).join('');
          }
          detailPanel.classList.add('visible');
        }, 150);
      }
    }

    // Click on stops
    stops.forEach(function(stop, i) {
      stop.addEventListener('click', function() { setActiveStage(i); });
    });

    function updateRoad() {
      var rect = section.getBoundingClientRect();
      var sectionHeight = rect.height;
      var scrolled = Math.max(0, -rect.top);
      var progress = Math.min(1, scrolled / (sectionHeight - window.innerHeight));

      // Advance the green progress line
      var offset = totalLength * (1 - progress);
      progressPath.style.strokeDashoffset = offset;
      if (glowPath) glowPath.style.strokeDashoffset = offset;

      // Determine active stop based on progress
      var activeIndex = 0;
      for (var i = 0; i < stopPositions.length; i++) {
        if (progress >= stopPositions[i] - 0.05) {
          activeIndex = i;
        }
      }
      setActiveStage(activeIndex);
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(updateRoad);
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // Initialize: show first stage
    setActiveStage(0);
    updateRoad();

    // Show detail panel once section is visible
    var journeyObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && detailPanel) {
          setTimeout(function() { detailPanel.classList.add('visible'); }, 300);
          journeyObserver.unobserve(section);
        }
      });
    }, { threshold: 0.1 });
    journeyObserver.observe(section);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initJourneyRoad);
  } else {
    initJourneyRoad();
  }
  document.addEventListener('astro:page-load', initJourneyRoad);
</script>
