---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import '@/styles/home.css';
import HeroMockup from '@/components/HeroMockup.astro';
import CalBooker from '@/components/CalBooker.tsx';

const jsonLd = [
  {
    "@type": "Organization",
    "@id": "https://servantium.com/#organization",
    "name": "Servantium",
    "url": "https://servantium.com",
    "logo": { "@type": "ImageObject", "url": "https://servantium.com/logo.png" },
    "description": "The CPQ and engagement management platform built for professional services firms.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1111B S Governors Ave STE 48074",
      "addressLocality": "Dover",
      "addressRegion": "DE",
      "postalCode": "19904",
      "addressCountry": "US"
    },
    "email": "hello@servantium.com",
    "sameAs": []
  },
  {
    "@type": "SoftwareApplication",
    "@id": "https://servantium.com/#software",
    "name": "Servantium",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Configure-Price-Quote (CPQ) and Professional Services Automation (PSA) platform.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Contact for pricing" },
    "provider": { "@id": "https://servantium.com/#organization" },
    "featureList": ["Engagement scoping and pricing", "Proposal generation", "Resource planning", "Project delivery tracking", "AI-powered automation"]
  },
  {
    "@type": "WebSite",
    "@id": "https://servantium.com/#website",
    "url": "https://servantium.com",
    "name": "Servantium",
    "publisher": { "@id": "https://servantium.com/#organization" }
  }
];
---

<BaseLayout activePage="home">
  <SEO
    slot="head"
    title="Professional Services CPQ & Engagement Management Platform | Servantium"
    description="Servantium is the professional services CPQ and engagement management platform. Define, price, sell, and deliver services with institutional memory built in."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Homepage content ported from index.html — page-specific sections below -->
  <!-- For the prototype, this is the content between <main> tags from the original -->

  <section class="hero">
    <div class="container">
      <div class="hero-content" id="hero-content">
        <div class="hero-text">
          <div class="hero-eyebrow">The Agentic Services Platform</div>
          <h1>The operating system for<br /><em>your </em><span class="hero-rotating" id="hero-rotate-a"><span class="hero-rotating-inner"><span class="hero-rotating-word active">firm.</span><span class="hero-rotating-word">team.</span><span class="hero-rotating-word">clients.</span><span class="hero-rotating-word">growth.</span></span></span></h1>
          <p class="hero-description">
            Scope, price, deliver, and learn from every engagement. Servantium is the agentic platform that turns your operational knowledge into a compounding advantage.
          </p>
          <div class="hero-ctas">
            <a href="#contact" class="btn btn-primary">Schedule a Call</a>
            <a href="/platform" class="btn btn-secondary">Explore the Platform</a>
          </div>
        </div>
        <HeroMockup />
      </div>
    </div>
    <!-- Logo bar at bottom of hero viewport -->
    <div class="logo-bar-inner">
      <div class="logo-bar-label">Trusted by innovative services teams</div>
      <div class="logo-bar-scroll">
        <div class="logo-bar-track">
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
          <div class="logo-placeholder"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="problem" id="problem">
    <div class="container">
      <div class="problem-content">
        <div class="problem-header" data-animate="fade-up">
          <h2>The Problem</h2>
          <p>
            Services businesses are fundamentally disadvantaged because their offerings are
            implicit, tribal, and fragmented—rather than encoded in systems that remember and improve. <strong>Let's fix that.</strong>
          </p>
        </div>
        <div class="problem-stats">
          <div class="stat-card" data-animate="fade-up" data-delay="0">
            <div class="stat-number">68.9%</div>
            <div class="stat-label">Billable Utilization</div>
            <div class="stat-description">Below the 75% threshold needed for healthy margins</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/03/18/the-truth-about-billable-utilization/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="150">
            <div class="stat-number">1 in 4</div>
            <div class="stat-label">Projects Delivered Late</div>
            <div class="stat-description">On-time delivery has fallen to 73.4%, the lowest in five years</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="300">
            <div class="stat-number">20%</div>
            <div class="stat-label">Hit Profit Margin Targets</div>
            <div class="stat-description">Only 1 in 5 firms consistently achieve their project profit goals</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
          <div class="stat-card" data-animate="fade-up" data-delay="450">
            <div class="stat-number">-4.6%</div>
            <div class="stat-label">Revenue Growth Decline</div>
            <div class="stat-description">Year-over-year revenue growth has turned negative</div>
            <div class="stat-source"><a href="https://spiresearch.com/2025/02/12/the-18th-annual-professional-services-maturity-benchmark-report-is-out-now/" target="_blank">SPI Research 2025</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3D Road Workflow Visualization -->
  <section class="road-section" id="concept" data-animate="fade-up">
    <div class="container">
      <div class="road-header">
        <h2>The Engagement Journey</h2>
        <p class="text-large">
          Every engagement follows a path. Servantium turns that path into a system that remembers, learns, and improves.
        </p>
      </div>

      <!-- Desktop: 3D Perspective Road -->
      <div class="road-viewport" id="road-viewport">
        <div class="road-container">
          <div class="road-surface">
            <div class="road-center-line"></div>
            <!-- Green particles flowing along the road -->
            <div class="road-particle" style="animation-delay: 0s;"></div>
            <div class="road-particle" style="animation-delay: 0.5s;"></div>
            <div class="road-particle" style="animation-delay: 1.0s;"></div>
            <div class="road-particle" style="animation-delay: 1.5s;"></div>
            <div class="road-particle" style="animation-delay: 2.0s;"></div>
            <div class="road-particle" style="animation-delay: 2.5s;"></div>

            <!-- Stage markers along the road -->
            <div class="stage-marker" data-stage="1">
              <div class="stage-pin" style="background: #00C26D;">
                <span class="stage-pin-num">1</span>
              </div>
              <div class="stage-pin-label">Discovery</div>
              <div class="stage-sparkle"></div>
            </div>
            <div class="stage-marker" data-stage="2">
              <div class="stage-pin" style="background: #4C82A7;">
                <span class="stage-pin-num">2</span>
              </div>
              <div class="stage-pin-label">Estimation</div>
              <div class="stage-sparkle"></div>
            </div>
            <div class="stage-marker" data-stage="3">
              <div class="stage-pin" style="background: #FFB02E;">
                <span class="stage-pin-num">3</span>
              </div>
              <div class="stage-pin-label">Proposal</div>
              <div class="stage-sparkle"></div>
            </div>
            <div class="stage-marker" data-stage="4">
              <div class="stage-pin" style="background: #26A899;">
                <span class="stage-pin-num">4</span>
              </div>
              <div class="stage-pin-label">Delivery</div>
              <div class="stage-sparkle"></div>
            </div>
            <div class="stage-marker" data-stage="5">
              <div class="stage-pin" style="background: #9B59B6;">
                <span class="stage-pin-num">5</span>
              </div>
              <div class="stage-pin-label">Learning</div>
              <div class="stage-sparkle"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile: Vertical road -->
      <div class="road-mobile" id="road-mobile">
        <div class="road-mobile-line"></div>
        <div class="road-mobile-stage" data-stage="1">
          <div class="road-mobile-pin" style="background: #00C26D;"><span>1</span></div>
          <div class="road-mobile-info">
            <strong>Discovery</strong>
            <span>Understand client needs</span>
          </div>
        </div>
        <div class="road-mobile-stage" data-stage="2">
          <div class="road-mobile-pin" style="background: #4C82A7;"><span>2</span></div>
          <div class="road-mobile-info">
            <strong>Estimation</strong>
            <span>Build informed pricing</span>
          </div>
        </div>
        <div class="road-mobile-stage" data-stage="3">
          <div class="road-mobile-pin" style="background: #FFB02E;"><span>3</span></div>
          <div class="road-mobile-info">
            <strong>Proposal</strong>
            <span>Generate winning proposals</span>
          </div>
        </div>
        <div class="road-mobile-stage" data-stage="4">
          <div class="road-mobile-pin" style="background: #26A899;"><span>4</span></div>
          <div class="road-mobile-info">
            <strong>Delivery</strong>
            <span>Execute with visibility</span>
          </div>
        </div>
        <div class="road-mobile-stage" data-stage="5">
          <div class="road-mobile-pin" style="background: #9B59B6;"><span>5</span></div>
          <div class="road-mobile-info">
            <strong>Learning</strong>
            <span>Compound your knowledge</span>
          </div>
        </div>
      </div>

      <!-- Detail panel below the road -->
      <div class="road-detail-panel" id="road-detail-panel">
        <div class="road-detail-inner">
          <h3 class="road-detail-title" id="road-detail-title" style="color: #00C26D;">Discovery</h3>
          <p class="road-detail-desc" id="road-detail-desc">Understand client needs, pain points, and desired outcomes before a single line item is written.</p>
          <ul class="road-detail-features" id="road-detail-features">
            <li>Structured intake and needs assessment</li>
            <li>Pain point and outcome mapping</li>
            <li>Context capture for downstream decisions</li>
            <li>Similar engagement matching</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ── 3D Road Visualization ── */
    .road-section {
      padding: 4rem 0 3rem;
      background: var(--color-white);
    }
    .road-header {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 2.5rem;
    }
    .road-header h2 {
      margin-bottom: 0.75rem;
    }

    /* Desktop road viewport */
    .road-viewport {
      position: relative;
      height: 500px;
      perspective: 800px;
      overflow: hidden;
      background: linear-gradient(to bottom, #f0f9f4 0%, white 100%);
      border-radius: 16px;
      margin: 0 auto;
      max-width: 800px;
    }
    .road-container {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }
    .road-surface {
      position: relative;
      width: 300px;
      height: 600px;
      background: #2d2d3d;
      clip-path: polygon(35% 0%, 65% 0%, 100% 100%, 0% 100%);
      transform: rotateX(55deg);
      transform-origin: center bottom;
      transition: transform 0.1s linear;
    }

    /* Dashed center line */
    .road-center-line {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 4px;
      margin-left: -2px;
      background: repeating-linear-gradient(to bottom, white 0px, white 20px, transparent 20px, transparent 40px);
      animation: roadLineScroll 2s linear infinite;
      opacity: 0.7;
    }
    @keyframes roadLineScroll {
      to { transform: translateY(40px); }
    }

    /* Green flowing particles */
    .road-particle {
      position: absolute;
      left: 50%;
      margin-left: -3px;
      width: 6px;
      height: 6px;
      background: #00C26D;
      border-radius: 50%;
      box-shadow: 0 0 8px #00C26D, 0 0 16px rgba(0, 194, 109, 0.3);
      animation: particleFlow 3s linear infinite;
      z-index: 3;
    }
    @keyframes particleFlow {
      0% { top: 0; opacity: 0; transform: scale(0.5); }
      10% { opacity: 1; transform: scale(0.6); }
      90% { opacity: 1; transform: scale(1.2); }
      100% { top: 100%; opacity: 0; transform: scale(1.4); }
    }

    /* Stage markers positioned along the road */
    .stage-marker {
      position: absolute;
      left: 50%;
      z-index: 4;
      display: flex;
      flex-direction: column;
      align-items: center;
      transition: transform 0.4s var(--ease-spring, cubic-bezier(0.16, 1, 0.3, 1)), opacity 0.3s ease;
    }
    .stage-marker[data-stage="1"] { top: 8%; transform: translateX(-50%) scale(0.5); }
    .stage-marker[data-stage="2"] { top: 24%; transform: translateX(-50%) scale(0.6); }
    .stage-marker[data-stage="3"] { top: 42%; transform: translateX(-50%) scale(0.75); }
    .stage-marker[data-stage="4"] { top: 62%; transform: translateX(-50%) scale(0.88); }
    .stage-marker[data-stage="5"] { top: 80%; transform: translateX(-50%) scale(1.0); }

    .stage-marker.active .stage-pin {
      box-shadow: 0 0 20px rgba(0, 194, 109, 0.6), 0 0 40px rgba(0, 194, 109, 0.2);
      transform: scale(1.15);
    }
    .stage-marker.active .stage-sparkle {
      opacity: 1;
    }

    .stage-pin {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 14px;
      font-family: var(--font-body, 'Source Sans 3', sans-serif);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
      transition: box-shadow 0.3s ease, transform 0.3s ease;
      cursor: pointer;
    }
    .stage-pin-num {
      line-height: 1;
    }
    .stage-pin-label {
      margin-top: 4px;
      font-size: 10px;
      font-weight: 600;
      color: white;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
      white-space: nowrap;
      letter-spacing: 0.03em;
    }

    /* Sparkle effect on active markers */
    .stage-sparkle {
      position: absolute;
      top: -4px;
      left: 50%;
      margin-left: -20px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 2px solid rgba(0, 194, 109, 0.4);
      opacity: 0;
      animation: sparkle 2s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes sparkle {
      0%, 100% { transform: scale(0.8); opacity: 0; }
      50% { transform: scale(1.5); opacity: 0.6; }
    }

    /* Detail panel below the road */
    .road-detail-panel {
      max-width: 600px;
      margin: 2rem auto 0;
      background: var(--color-mint-tint, #F3FCF8);
      border-radius: 12px;
      padding: 2rem;
      border: 1px solid var(--color-cloud-grey, #E1E3E6);
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.35s ease, transform 0.35s ease;
    }
    .road-detail-panel.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .road-detail-title {
      font-family: var(--font-display, 'Playfair Display', serif);
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
      transition: color 0.3s ease;
    }
    .road-detail-desc {
      color: var(--color-ink-light, #3d3d3d);
      line-height: 1.7;
      font-size: 1.05rem;
      margin-bottom: 1rem;
    }
    .road-detail-features {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.4rem 1.5rem;
    }
    .road-detail-features li {
      position: relative;
      padding-left: 1.4rem;
      font-size: 0.9rem;
      color: var(--color-ink-light, #3d3d3d);
      line-height: 1.5;
    }
    .road-detail-features li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.5em;
      width: 14px;
      height: 14px;
      background: url("data:image/svg+xml,%3Csvg viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16.7 5.3a1 1 0 010 1.4l-8 8a1 1 0 01-1.4 0l-4-4a1 1 0 111.4-1.4L8 12.6l7.3-7.3a1 1 0 011.4 0z' fill='%2300C26D'/%3E%3C/svg%3E") no-repeat center;
      background-size: contain;
    }

    /* Mobile vertical road */
    .road-mobile {
      display: none;
      position: relative;
      padding-left: 60px;
    }
    .road-mobile-line {
      position: absolute;
      left: 24px;
      top: 0;
      bottom: 0;
      width: 4px;
      background: linear-gradient(to bottom, #00C26D, #4C82A7, #FFB02E, #26A899, #9B59B6);
      border-radius: 2px;
    }
    .road-mobile-stage {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem 0;
      position: relative;
      cursor: pointer;
      transition: opacity 0.3s ease;
    }
    .road-mobile-stage.active .road-mobile-pin {
      box-shadow: 0 0 12px rgba(0, 194, 109, 0.5);
      transform: scale(1.1);
    }
    .road-mobile-pin {
      width: 40px;
      height: 40px;
      min-width: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 14px;
      margin-left: -32px;
      z-index: 2;
      transition: box-shadow 0.3s ease, transform 0.3s ease;
    }
    .road-mobile-info {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .road-mobile-info strong {
      font-size: 1rem;
      color: var(--color-ink, #0D0D0D);
    }
    .road-mobile-info span {
      font-size: 0.85rem;
      color: var(--color-ink-muted, #6b6b6b);
    }

    @media (max-width: 768px) {
      .road-viewport { display: none; }
      .road-mobile { display: block; }
      .road-detail-features { grid-template-columns: 1fr; }
    }

    @media (prefers-reduced-motion: reduce) {
      .road-center-line,
      .road-particle,
      .stage-sparkle {
        animation: none !important;
      }
    }
  </style>

  <section class="faq" id="faq">
    <div class="container">
      <div class="faq-header">
        <h2>Frequently Asked Questions</h2>
        <p class="text-large">
          Everything you need to know about Servantium and how it transforms professional services operations.
        </p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What is Servantium?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Servantium is an operating system for professional services businesses. It's a unified platform that formalizes how services are defined, priced, sold, activated, and delivered—creating a single system of record for every engagement.</p>
              <p>Unlike traditional PSA tools that focus on time tracking and billing, Servantium captures the complete engagement lifecycle from initial discovery through delivery and learning.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            How is Servantium different from traditional PSA software?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Traditional PSA software typically bolts project management onto sales tools. Servantium takes a fundamentally different approach:</p>
              <ul>
                <li><strong>Not a generic CRM</strong> — Purpose-built for services</li>
                <li><strong>Not a spreadsheet replacement</strong> — Structure that turns implicit knowledge into explicit, compounding primitives</li>
                <li><strong>Not a static proposal generator</strong> — Living documents connected to your service definitions</li>
                <li><strong>Not PSA bolted onto sales</strong> — An integrated system where sales, delivery, and learning share context</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What types of businesses use Servantium?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Servantium is built for professional services firms that deliver repeatable (but customizable) engagements: consulting firms, implementation teams, managed services providers, agencies, and technical services firms.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            How does Servantium handle AI and automation?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>We believe structure precedes automation. AI in Servantium learns from your encoded patterns. Human judgment remains sovereign—technology amplifies expertise but doesn't replace the relationships that make services businesses work.</p>
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Is my data secure?
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>Yes. Your engagement data, pricing information, and client details are encrypted at rest and in transit. Enterprise customers can discuss additional security requirements including data residency and compliance needs.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" id="contact">
