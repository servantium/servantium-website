---
/**
 * Preview 2: Verdant/Tailwind login — uses our design system.
 * Full Tailwind utilities, Verdant tokens, Astronaut component.
 */
import '@/theme/verdant.css';
import '@/styles/global.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';
import Astronaut from '@/theme/components/Astronaut.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In — Servantium</title>
</head>
<body class="min-h-screen flex bg-white">

  <!-- Left: Immersive brand panel -->
  <div class="hidden lg:flex w-[48%] min-h-screen flex-col justify-between relative overflow-hidden" style="background: linear-gradient(160deg, #00C26D 0%, #037A47 40%, #023E25 100%);">

    {/* Decorative orbs */}
    <div class="absolute top-[-10%] right-[-15%] w-[50%] h-[50%] rounded-full" style="background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 65%);" aria-hidden="true"></div>
    <div class="absolute bottom-[-5%] left-[-10%] w-[35%] h-[35%] rounded-full" style="background: radial-gradient(circle, rgba(54,217,147,0.15) 0%, transparent 60%);" aria-hidden="true"></div>

    {/* Floating stars */}
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[12%] left-[18%] w-[3px] h-[3px] bg-white rounded-full opacity-40 animate-pulse"></div>
      <div class="absolute top-[28%] right-[22%] w-[2px] h-[2px] bg-white rounded-full opacity-30" style="animation: pulse 3s ease-in-out 0.8s infinite;"></div>
      <div class="absolute top-[55%] left-[12%] w-[3px] h-[3px] bg-white rounded-full opacity-35" style="animation: pulse 3s ease-in-out 1.5s infinite;"></div>
      <div class="absolute bottom-[30%] right-[18%] w-[2px] h-[2px] bg-white rounded-full opacity-25" style="animation: pulse 3s ease-in-out 0.3s infinite;"></div>
      <div class="absolute top-[38%] left-[32%] w-[2px] h-[2px] bg-white rounded-full opacity-20" style="animation: pulse 3s ease-in-out 2s infinite;"></div>
    </div>

    {/* Top: Logo */}
    <div class="relative z-10 p-8">
      <img src="/logo.png" alt="Servantium" class="h-8 object-contain" style="filter: brightness(0) invert(1);" />
    </div>

    {/* Center: Message + Astronaut */}
    <div class="relative z-10 flex-1 flex flex-col items-center justify-center px-8">
      <h2 class="font-[family-name:var(--font-display)] text-[2.5rem] leading-[1.2] font-medium text-center mb-4" style="color: #ffffff; text-shadow: 0 2px 12px rgba(0,0,0,0.15);">
        The operating system<br/>for your clients.
      </h2>
      <p class="text-center max-w-xs leading-relaxed" style="color: rgba(255,255,255,0.75); font-size: 1.05rem;">
        Scope, price, deliver, and learn from every engagement.
      </p>

      <div class="mt-8">
        <Astronaut size="lg" variant="waving" animate={true} />
      </div>
    </div>

    {/* Bottom: Testimonial or social proof */}
    <div class="relative z-10 p-8">
      <div class="rounded-xl p-4" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(8px);">
        <p class="text-sm italic leading-relaxed" style="color: rgba(255,255,255,0.8);">
          "Servantium changed how we scope and price engagements. We went from guessing to knowing."
        </p>
        <div class="flex items-center gap-2 mt-3">
          <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold" style="background: rgba(255,255,255,0.2); color: white;">β</div>
          <div>
            <span class="text-xs font-medium" style="color: rgba(255,255,255,0.9);">Beta Customer</span>
            <span class="text-xs block" style="color: rgba(255,255,255,0.5);">Professional Services Firm</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right: Form panel -->
  <div class="flex-1 min-h-screen flex flex-col justify-center items-center px-6 py-8 lg:px-12">
    <div class="w-full max-w-[380px]">

      {/* Mobile logo (hidden on desktop) */}
      <div class="lg:hidden flex items-center justify-center mb-8">
        <img src="/logo.png" alt="Servantium" class="h-8 object-contain" />
      </div>

      {/* Header */}
      <div class="mb-8">
        <h1 class="font-[family-name:var(--font-display)] text-[1.875rem] font-medium text-[var(--color-ink)] leading-tight">
          Welcome back
        </h1>
        <p class="mt-1.5 text-[var(--color-ink-muted)] text-[0.95rem]">
          Sign in to continue to Servantium
        </p>
      </div>

      {/* Form */}
      <form class="space-y-5">
        <div>
          <label for="email2" class="block text-sm font-semibold text-[var(--color-ink-light)] mb-1.5">Email address</label>
          <input
            type="email"
            id="email2"
            placeholder="you@company.com"
            class="w-full px-4 py-3 text-[0.95rem] rounded-xl border border-[var(--color-cloud-grey)] bg-white text-[var(--color-ink)] placeholder-slate-400 outline-none transition-all duration-200 focus:border-[var(--color-green)] focus:ring-2 focus:ring-[var(--color-green)]/15"
          />
        </div>

        <div>
          <label for="password2" class="block text-sm font-semibold text-[var(--color-ink-light)] mb-1.5">Password</label>
          <input
            type="password"
            id="password2"
            placeholder="Enter your password"
            class="w-full px-4 py-3 text-[0.95rem] rounded-xl border border-[var(--color-cloud-grey)] bg-white text-[var(--color-ink)] placeholder-slate-400 outline-none transition-all duration-200 focus:border-[var(--color-green)] focus:ring-2 focus:ring-[var(--color-green)]/15"
          />
        </div>

        <div class="flex items-center justify-between text-sm">
          <label class="flex items-center gap-2 text-[var(--color-ink-light)] cursor-pointer">
            <input type="checkbox" class="w-4 h-4 rounded border-[var(--color-cloud-grey)] accent-[var(--color-green)]" />
            Remember me
          </label>
          <a href="#" class="font-medium text-[var(--color-green)] no-underline hover:text-[var(--color-green-hover)] transition-colors">
            Forgot password?
          </a>
        </div>

        <button
          type="submit"
          class="w-full py-3 rounded-xl font-semibold text-white text-[0.95rem] transition-all duration-200 hover:shadow-lg active:scale-[0.98]"
          style="background: var(--color-green); color: #ffffff;"
          onmouseover="this.style.background='var(--color-green-hover)'"
          onmouseout="this.style.background='var(--color-green)'"
        >
          Sign In
        </button>

        {/* Divider */}
        <div class="flex items-center gap-3">
          <div class="flex-1 h-px bg-[var(--color-cloud-grey)]"></div>
          <span class="text-xs text-slate-400">or continue with</span>
          <div class="flex-1 h-px bg-[var(--color-cloud-grey)]"></div>
        </div>

        {/* Google SSO */}
        <button
          type="button"
          class="w-full py-2.5 rounded-xl border border-[var(--color-cloud-grey)] bg-white text-[var(--color-ink-light)] text-[0.95rem] font-medium flex items-center justify-center gap-3 transition-all duration-200 hover:bg-[var(--color-mist-grey)] hover:border-slate-300"
        >
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        </button>
      </form>

      {/* Footer */}
      <p class="mt-8 text-center text-sm text-[var(--color-ink-muted)]">
        Don't have an account?
        <a href="#" class="font-semibold text-[var(--color-green)] no-underline hover:text-[var(--color-green-hover)] transition-colors ml-1">Sign up</a>
      </p>
    </div>
  </div>

</body>
</html>
