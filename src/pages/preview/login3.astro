---
/**
 * Preview 3: Flutter firebase_ui_auth SignInScreen re-skin.
 * Simulates what the actual Flutter sign-in screen would look like
 * using firebase_ui_auth's headerBuilder, sideBuilder, and footerBuilder.
 *
 * This preview mimics Flutter's Material Design constraints while
 * applying Servantium/Verdant branding. Max can reference this 1:1.
 *
 * FLUTTER MAPPING:
 * - Left green panel = sideBuilder (only shows on wide screens)
 * - Form area = firebase_ui_auth's built-in form (email + password fields)
 * - Header above form = headerBuilder
 * - Footer below form = footerBuilder
 * - Green theme = ThemeData colorScheme with seedColor 0xFF00C26D
 */
import '@/theme/verdant.css';
import '@/styles/global.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';
import Astronaut from '@/theme/components/Astronaut.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In — Servantium (Flutter Preview)</title>
  <style>
    /* Simulate Flutter's Material Design system */
    body { margin: 0; font-family: 'Source Sans 3', sans-serif; min-height: 100vh; display: flex; background: #fafafa; }

    /* ── sideBuilder ── (Flutter: only renders on constraints.maxWidth > 800) */
    .flutter-side-builder {
      width: 480px;
      min-height: 100vh;
      background: linear-gradient(160deg, #00C26D 0%, #037A47 40%, #023E25 100%);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 48px;
      position: relative;
      overflow: hidden;
    }

    @media (max-width: 800px) {
      .flutter-side-builder { display: none; }
    }

    .flutter-side-builder .orb {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 65%);
    }
    .flutter-side-builder .orb-1 { top: -10%; right: -15%; width: 50%; height: 50%; }
    .flutter-side-builder .orb-2 { bottom: -5%; left: -10%; width: 35%; height: 35%; }

    .side-content { position: relative; z-index: 1; text-align: center; }
    .side-logo { height: 44px; filter: brightness(0) invert(1); margin-bottom: 32px; }
    .side-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 500; color: #fff; line-height: 1.25; margin-bottom: 12px; }
    .side-subtitle { font-size: 1rem; color: rgba(255,255,255,0.75); max-width: 280px; line-height: 1.6; }
    .side-astronaut { margin-top: 40px; }
    .side-testimonial {
      margin-top: 48px;
      padding: 16px 20px;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(8px);
      border-radius: 12px;
      text-align: left;
      max-width: 300px;
    }
    .side-testimonial p { font-size: 0.85rem; color: rgba(255,255,255,0.8); font-style: italic; line-height: 1.5; margin: 0 0 8px; }
    .side-testimonial .author { font-size: 0.75rem; color: rgba(255,255,255,0.6); }

    /* ── Main form area ── (Flutter: Scaffold body with centered card) */
    .flutter-form-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 32px 24px;
    }

    /* Flutter SignInScreen renders form inside a ConstrainedBox maxWidth ~400 */
    .flutter-form-card {
      width: 100%;
      max-width: 380px;
    }

    /* ── headerBuilder ── */
    .flutter-header-builder {
      text-align: center;
      margin-bottom: 32px;
    }
    .flutter-header-builder .mobile-logo { display: none; height: 32px; margin-bottom: 24px; }
    @media (max-width: 800px) {
      .flutter-header-builder .mobile-logo { display: inline-block; }
    }
    .flutter-header-builder h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 500;
      color: #0D0D0D;
      margin: 0 0 4px;
    }
    .flutter-header-builder p {
      font-size: 0.95rem;
      color: #6b6b6b;
      margin: 0;
    }

    /* ── Firebase UI Auth form fields (simulated) ── */
    /* Flutter: These are rendered by EmailAuthProvider automatically */
    .firebase-form { display: flex; flex-direction: column; gap: 16px; }

    .firebase-field label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: #3d3d3d;
      margin-bottom: 6px;
      letter-spacing: 0.02em;
    }

    .firebase-field input {
      width: 100%;
      padding: 12px 16px;
      font-size: 0.95rem;
      font-family: 'Source Sans 3', sans-serif;
      border: 1.5px solid #E1E3E6;
      border-radius: 10px;
      background: #fff;
      color: #0D0D0D;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      box-sizing: border-box;
    }

    .firebase-field input:focus {
      border-color: #00C26D;
      box-shadow: 0 0 0 3px rgba(0, 194, 109, 0.12);
    }

    .firebase-field input::placeholder { color: #9ca3af; }

    /* Flutter: password visibility toggle */
    .password-wrapper { position: relative; }
    .password-wrapper input { padding-right: 44px; }
    .password-toggle {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: #9ca3af;
      padding: 4px;
    }
    .password-toggle:hover { color: #3d3d3d; }

    /* Flutter: ElevatedButton with Material theme */
    .firebase-submit {
      width: 100%;
      padding: 14px;
      font-size: 0.95rem;
      font-weight: 600;
      font-family: 'Source Sans 3', sans-serif;
      color: #ffffff;
      background: #00C26D;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      margin-top: 4px;
    }
    .firebase-submit:hover { background: #00A95E; }
    .firebase-submit:active { transform: scale(0.98); }

    /* Forgot password link */
    .forgot-link {
      text-align: right;
      margin-top: -8px;
    }
    .forgot-link a {
      font-size: 0.85rem;
      color: #00C26D;
      text-decoration: none;
      font-weight: 500;
    }
    .forgot-link a:hover { color: #00A95E; }

    /* Divider */
    .auth-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 8px 0;
      color: #9ca3af;
      font-size: 0.8rem;
    }
    .auth-divider::before, .auth-divider::after { content: ''; flex: 1; height: 1px; background: #E1E3E6; }

    /* Google button */
    .google-btn {
      width: 100%;
      padding: 11px;
      font-size: 0.9rem;
      font-family: 'Source Sans 3', sans-serif;
      color: #3d3d3d;
      background: #fff;
      border: 1.5px solid #E1E3E6;
      border-radius: 10px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: border-color 0.2s, background 0.2s;
      font-weight: 500;
    }
    .google-btn:hover { border-color: #d1d5db; background: #f9fafb; }

    /* ── footerBuilder ── */
    .flutter-footer-builder {
      text-align: center;
      margin-top: 28px;
      font-size: 0.9rem;
      color: #6b6b6b;
    }
    .flutter-footer-builder a {
      color: #00C26D;
      text-decoration: none;
      font-weight: 600;
    }
    .flutter-footer-builder a:hover { color: #00A95E; }

    /* ── Code annotations (visible on hover) ── */
    .code-note {
      position: absolute;
      top: 4px;
      right: 4px;
      background: rgba(0,0,0,0.7);
      color: #22c55e;
      font-size: 9px;
      font-family: monospace;
      padding: 2px 6px;
      border-radius: 4px;
      opacity: 0;
      transition: opacity 0.2s;
      pointer-events: none;
      z-index: 100;
      white-space: nowrap;
    }
    *:hover > .code-note { opacity: 1; }
    [data-flutter] { position: relative; }

    /* Astronaut costumes */
    .costume-carousel {
      margin-top: 32px;
      position: relative;
      width: 100%;
      max-width: 260px;
      height: 100px;
    }
    .costume-carousel .costume {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      opacity: 0;
      transition: opacity 0.6s ease;
      color: rgba(255,255,255,0.85);
      font-size: 0.85rem;
      text-align: center;
    }
    .costume-carousel .costume.active { opacity: 1; }
    .costume-icon { font-size: 2.5rem; line-height: 1; }
    .costume-label { font-weight: 600; font-size: 0.8rem; color: rgba(255,255,255,0.7); }
  </style>
</head>
<body>

  <!-- sideBuilder: only on wide screens (Flutter: constraints.maxWidth > 800) -->
  <div class="flutter-side-builder" data-flutter="sideBuilder">
    <span class="code-note">sideBuilder(context, constraints)</span>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="side-content">
      <img src="/logo.png" alt="Servantium" class="side-logo" />
      <div class="side-title">The operating system<br/>for your clients.</div>
      <div class="side-subtitle">Scope, price, deliver, and learn from every engagement.</div>
      <div class="side-astronaut">
        <Astronaut size="lg" variant="waving" animate={true} />
      </div>
      <div class="side-testimonial">
        <p>"Servantium changed how we scope engagements. We went from guessing to knowing."</p>
        <span class="author">— Beta Customer, Professional Services</span>
      </div>
      <div class="costume-carousel" aria-hidden="true">
        <div class="costume active" data-costume="0">
          <span class="costume-icon">&#x1F468;&#x200D;&#x1F680;</span>
          <span class="costume-label">The Explorer</span>
        </div>
        <div class="costume" data-costume="1">
          <span class="costume-icon">&#x1F9D1;&#x200D;&#x1F52C;</span>
          <span class="costume-label">The Analyst</span>
        </div>
        <div class="costume" data-costume="2">
          <span class="costume-icon">&#x1F9D1;&#x200D;&#x1F4BB;</span>
          <span class="costume-label">The Architect</span>
        </div>
        <div class="costume" data-costume="3">
          <span class="costume-icon">&#x1F9D1;&#x200D;&#x1F3EB;</span>
          <span class="costume-label">The Mentor</span>
        </div>
        <div class="costume" data-costume="4">
          <span class="costume-icon">&#x1F9D1;&#x200D;&#x1F3A8;</span>
          <span class="costume-label">The Designer</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Main form area (Flutter: Scaffold body) -->
  <div class="flutter-form-area">
    <div class="flutter-form-card">

      <!-- headerBuilder -->
      <div class="flutter-header-builder" data-flutter="headerBuilder">
        <span class="code-note">headerBuilder(context, constraints, shrinkOffset)</span>
        <img src="/logo.png" alt="Servantium" class="mobile-logo" />
        <h1>Welcome back</h1>
        <p>Sign in to continue to Servantium</p>
      </div>

      <!-- Firebase UI Auth form (auto-rendered by EmailAuthProvider) -->
      <form class="firebase-form" data-flutter="EmailAuthProvider auto-rendered form">
        <span class="code-note">EmailAuthProvider() — auto-rendered fields</span>

        <div class="firebase-field">
          <label for="email3">Email</label>
          <input type="email" id="email3" placeholder="you@company.com" />
        </div>

        <div class="firebase-field">
          <label for="password3">Password</label>
          <div class="password-wrapper">
            <input type="password" id="password3" placeholder="Enter your password" />
            <button type="button" class="password-toggle" aria-label="Toggle password visibility">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <div class="forgot-link">
          <a href="#">Forgot password?</a>
        </div>

        <button type="submit" class="firebase-submit">Sign In</button>

        <div class="auth-divider">or</div>

        <button type="button" class="google-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        </button>
      </form>

      <!-- footerBuilder -->
      <div class="flutter-footer-builder" data-flutter="footerBuilder">
        <span class="code-note">footerBuilder(context, auth)</span>
        Don't have an account? <a href="#">Contact us</a>
      </div>

    </div>
  </div>

  <script>
    (function() {
      var costumes = document.querySelectorAll('.costume-carousel .costume');
      if (!costumes.length) return;
      var current = 0;
      setInterval(function() {
        costumes[current].classList.remove('active');
        current = (current + 1) % costumes.length;
        costumes[current].classList.add('active');
      }, 4000);
    })();
  </script>
</body>
</html>
