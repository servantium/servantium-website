---
/**
 * Login screen design reference for Flutter firebase_ui_auth SignInScreen.
 *
 * FLUTTER MAPPING:
 * - Left green panel = sideBuilder (only shows on wide screens)
 * - Form area = firebase_ui_auth's built-in form (email + password fields)
 * - Header above form = headerBuilder
 * - Footer below form = footerBuilder
 * - Green theme = ThemeData colorScheme with seedColor 0xFF00C26D
 */
import '@/theme/verdant.css';
import '@/styles/global.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/500.css';
import '@fontsource/source-sans-3/600.css';
import Astronaut from '@/theme/components/Astronaut.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In — Servantium</title>
  <style>
    body { margin: 0; font-family: 'Source Sans 3', sans-serif; min-height: 100vh; display: flex; background: #fafafa; }

    /* ── Side panel ── */
    .side-panel {
      width: 45%;
      min-width: 400px;
      max-width: 720px;
      min-height: 100vh;
      background: linear-gradient(160deg, #00C26D 0%, #037A47 40%, #023E25 100%);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 48px 40px;
      position: relative;
      overflow: hidden;
      box-sizing: border-box;
    }

    @media (max-width: 800px) {
      .side-panel { display: none; }
    }

    .side-panel .orb {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 65%);
    }
    .side-panel .orb-1 { top: -10%; right: -15%; width: 50%; height: 50%; }
    .side-panel .orb-2 { bottom: -5%; left: -10%; width: 35%; height: 35%; }

    .side-content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      width: 100%;
      max-width: 420px;
      gap: 0;
    }

    .side-logo { height: 48px; filter: brightness(0) invert(1); margin-bottom: 32px; }

    .side-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.1rem;
      font-weight: 500;
      color: #fff;
      line-height: 1.3;
      margin: 0 0 12px;
    }

    .side-subtitle {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.75);
      line-height: 1.65;
      margin: 0 0 28px;
      max-width: 380px;
    }

    /* Astronaut carousel */
    .astronaut-carousel {
      position: relative;
      width: 140px;
      height: 170px;
      margin-bottom: 28px;
    }
    .astronaut-carousel .astro-slide {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      opacity: 0;
      transform: scale(0.85);
      transition: opacity 0.6s ease, transform 0.5s ease;
    }
    .astronaut-carousel .astro-slide.active { opacity: 1; transform: scale(1); }
    .astro-icon { width: 120px; height: 120px; filter: drop-shadow(0 4px 16px rgba(0,0,0,0.2)); }
    .astro-label { font-weight: 600; font-size: 0.8rem; color: rgba(255,255,255,0.6); letter-spacing: 0.02em; }

    /* Testimonial */
    .side-quote {
      padding: 20px 24px;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(8px);
      border-radius: 12px;
      text-align: left;
      width: 100%;
      max-width: 380px;
    }
    .side-quote p {
      font-size: 0.9rem;
      color: rgba(255,255,255,0.88);
      font-style: italic;
      line-height: 1.6;
      margin: 0 0 8px;
    }
    .side-quote .attribution {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.55);
    }

    /* ── Form area ── */
    .form-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 32px 24px;
    }

    .form-card {
      width: 100%;
      max-width: 380px;
    }

    /* Header */
    .form-header {
      text-align: center;
      margin-bottom: 32px;
    }
    .form-header .mobile-logo { display: none; height: 32px; margin-bottom: 24px; }
    @media (max-width: 800px) {
      .form-header .mobile-logo { display: inline-block; }
    }
    .form-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 500;
      color: #0D0D0D;
      margin: 0 0 4px;
    }
    .form-header p {
      font-size: 0.95rem;
      color: #6b6b6b;
      margin: 0;
    }

    /* Form fields */
    .login-form { display: flex; flex-direction: column; gap: 16px; }

    .field label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: #3d3d3d;
      margin-bottom: 6px;
      letter-spacing: 0.02em;
    }

    .field input {
      width: 100%;
      padding: 12px 16px;
      font-size: 0.95rem;
      font-family: 'Source Sans 3', sans-serif;
      border: 1.5px solid #E1E3E6;
      border-radius: 10px;
      background: #fff;
      color: #0D0D0D;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      box-sizing: border-box;
    }

    .field input:focus {
      border-color: #00C26D;
      box-shadow: 0 0 0 3px rgba(0, 194, 109, 0.12);
    }

    .field input::placeholder { color: #9ca3af; }

    .password-wrapper { position: relative; }
    .password-wrapper input { padding-right: 44px; }
    .password-toggle {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: #9ca3af;
      padding: 4px;
    }
    .password-toggle:hover { color: #3d3d3d; }

    .submit-btn {
      width: 100%;
      padding: 14px;
      font-size: 0.95rem;
      font-weight: 600;
      font-family: 'Source Sans 3', sans-serif;
      color: #ffffff;
      background: #00C26D;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      margin-top: 4px;
    }
    .submit-btn:hover { background: #00A95E; }
    .submit-btn:active { transform: scale(0.98); }

    .forgot-link {
      text-align: right;
      margin-top: -8px;
    }
    .forgot-link a {
      font-size: 0.85rem;
      color: #00C26D;
      text-decoration: none;
      font-weight: 500;
    }
    .forgot-link a:hover { color: #00A95E; }

    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 8px 0;
      color: #9ca3af;
      font-size: 0.8rem;
    }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #E1E3E6; }

    .google-btn {
      width: 100%;
      padding: 11px;
      font-size: 0.9rem;
      font-family: 'Source Sans 3', sans-serif;
      color: #3d3d3d;
      background: #fff;
      border: 1.5px solid #E1E3E6;
      border-radius: 10px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: border-color 0.2s, background 0.2s;
      font-weight: 500;
    }
    .google-btn:hover { border-color: #d1d5db; background: #f9fafb; }

    .form-footer {
      text-align: center;
      margin-top: 28px;
      font-size: 0.9rem;
      color: #6b6b6b;
    }
    .form-footer a {
      color: #00C26D;
      text-decoration: none;
      font-weight: 600;
    }
    .form-footer a:hover { color: #00A95E; }
  </style>
</head>
<body>

  <!-- Side panel (sideBuilder) -->
  <div class="side-panel">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="side-content">
      <img src="/logo.png" alt="Servantium" class="side-logo" />
      <div class="side-title">The operating system for services teams.</div>
      <div class="side-subtitle">Your hub to scope, price, deliver and learn from every project.</div>
      <div class="astronaut-carousel" aria-hidden="true">
        <div class="astro-slide active" data-slide="0">
          <div class="astro-icon"><Astronaut size="lg" variant="waving" animate={true} /></div>
        </div>
        <div class="astro-slide" data-slide="1">
          <div class="astro-icon"><Astronaut size="lg" variant="cowboy" animate={true} /></div>
        </div>
        <div class="astro-slide" data-slide="2">
          <div class="astro-icon"><Astronaut size="lg" variant="detective" animate={true} /></div>
        </div>
        <div class="astro-slide" data-slide="3">
          <div class="astro-icon"><Astronaut size="lg" variant="captain" animate={true} /></div>
        </div>
        <div class="astro-slide" data-slide="4">
          <div class="astro-icon"><Astronaut size="lg" variant="professor" animate={true} /></div>
        </div>
      </div>
      <div class="side-quote">
        <p>"Servantium makes turning around quotes and invoices faster than ever."</p>
        <span class="attribution">— Business Development, Federal Services</span>
      </div>
    </div>
  </div>

  <!-- Form area -->
  <div class="form-area">
    <div class="form-card">

      <div class="form-header">
        <img src="/logo.png" alt="Servantium" class="mobile-logo" />
        <h1>Welcome back</h1>
        <p>Sign in to continue to Servantium</p>
      </div>

      <form class="login-form">
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" placeholder="you@company.com" />
        </div>

        <div class="field">
          <label for="password">Password</label>
          <div class="password-wrapper">
            <input type="password" id="password" placeholder="Enter your password" />
            <button type="button" class="password-toggle" aria-label="Toggle password visibility">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <div class="forgot-link">
          <a href="#">Forgot password?</a>
        </div>

        <button type="submit" class="submit-btn">Sign In</button>

        <div class="divider">or</div>

        <button type="button" class="google-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        </button>
      </form>

      <div class="form-footer">
        Don't have an account? <a href="#">Contact us</a>
      </div>

    </div>
  </div>

  <script>
    (function() {
      var slides = document.querySelectorAll('.astronaut-carousel .astro-slide');
      if (!slides.length) return;
      var current = 0;
      setInterval(function() {
        slides[current].classList.remove('active');
        current = (current + 1) % slides.length;
        slides[current].classList.add('active');
      }, 4000);
    })();
  </script>
</body>
</html>
