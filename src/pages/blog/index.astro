---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import BlogCard from '@/theme/blog/BlogCard.astro';
import BlogFilters from '@/theme/blog/BlogFilters.astro';
import PageReveal from '@/theme/components/PageReveal.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category))].sort();
const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))].sort();
---

<BaseLayout activePage="blog">
  <SEO
    slot="head"
    title="Blog — Servantium"
    description="Insights on professional services, engagement management, and building the operational infrastructure services businesses deserve."
    ogType="website"
  />

  <!-- Blog Hero -->
  <PageReveal>
    <section class="bg-gradient-to-b from-[var(--color-soft-mint)] to-white pt-32 pb-12 md:pt-36 md:pb-16">
      <div class="mx-auto max-w-[var(--content-width)] px-6 text-center">
        <h1 data-reveal="1" class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-medium text-[var(--color-ink)] mb-4">
          Blog
        </h1>
        <p data-reveal="2" class="text-lg text-[var(--color-ink-muted)] max-w-2xl mx-auto leading-relaxed">
          Insights on professional services, engagement management, and building the operational infrastructure services businesses deserve.
        </p>
      </div>
    </section>
  </PageReveal>

  <!-- Filters + Grid -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-[var(--content-width)] px-6">
      <BlogFilters categories={categories} tags={allTags} />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-10" id="blog-grid">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            author={post.data.author}
            category={post.data.category}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            slug={post.id}
            readingTime={post.data.readingTime}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- RSS Link -->
  <section class="pb-16 text-center">
    <a href="/rss.xml" class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-green)] transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 11a9 9 0 0 1 9 9"></path>
        <path d="M4 4a16 16 0 0 1 16 16"></path>
        <circle cx="5" cy="19" r="1"></circle>
      </svg>
      Subscribe via RSS
    </a>
  </section>
</BaseLayout>
