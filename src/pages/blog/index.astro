---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import { getCollection } from 'astro:content';
import { authors } from '@/data/authors';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout activePage="blog">
  <SEO
    slot="head"
    title="Blog — Servantium"
    description="Insights on professional services CPQ, engagement management, and building operational infrastructure for services businesses."
  />

  <section class="blog-hero">
    <div class="container">
      <h1>Blog</h1>
      <p class="text-large">Insights on professional services, engagement management, and building the operational infrastructure services businesses deserve.</p>
    </div>
  </section>

  <section class="blog-grid-section">
    <div class="container">
      <div class="blog-grid">
        {posts.map(post => {
          const authorData = authors[post.data.author];
          const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
          return (
            <a href={`/blog/${post.id}`} class="blog-card">
              {post.data.image && (
                <div class="blog-card-image">
                  <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
                </div>
              )}
              <div class="blog-card-content">
                <span class="blog-card-category">{post.data.category}</span>
                <h3 class="blog-card-title">{post.data.title}</h3>
                <p class="blog-card-excerpt">{post.data.description}</p>
                <div class="blog-card-meta">
                  <span>{authorData?.name || post.data.author}</span>
                  <span class="blog-card-dot">&middot;</span>
                  <span>{formattedDate}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding: 8rem 0 3rem;
    background: linear-gradient(180deg, var(--color-soft-mint) 0%, var(--color-white) 100%);
    text-align: center;
  }
  .blog-hero h1 { margin-bottom: 1rem; }
  .blog-hero .text-large { max-width: 700px; margin: 0 auto; }

  .blog-grid-section { padding: var(--space-xl) 0 var(--space-3xl); }
  .blog-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-lg);
  }
  .blog-card {
    text-decoration: none; color: inherit; border-radius: 12px;
    border: 1px solid var(--color-cloud-grey); overflow: hidden;
    transition: all 0.25s ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .blog-card-image { height: 200px; overflow: hidden; }
  .blog-card-image img { width: 100%; height: 100%; object-fit: cover; }
  .blog-card-content { padding: var(--space-md); }
  .blog-card-category {
    color: var(--color-servantium-green); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.75rem;
  }
  .blog-card-title {
    font-family: var(--font-display); font-size: 1.25rem;
    margin: 0.5rem 0; line-height: 1.3;
  }
  .blog-card-excerpt { font-size: 0.95rem; color: var(--color-ink-muted); line-height: 1.6; }
  .blog-card-meta {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.85rem; color: var(--color-ink-muted); margin-top: 1rem;
  }
  .blog-card-dot { opacity: 0.5; }

  @media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
