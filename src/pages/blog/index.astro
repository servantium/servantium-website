---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import PageReveal from '@/theme/components/PageReveal.astro';
import FeaturedPost from '@/theme/blog/FeaturedPost.astro';
import BubbleGrid from '@/theme/blog/BubbleGrid.astro';
import BlogSearch from '@/theme/blog/BlogSearch.astro';
import { getCollection } from 'astro:content';
import { authors } from '@/data/authors';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category))].sort();

// Split posts for featured section
const featuredPost = posts[0];
const bubblePosts = posts.slice(1, 3);
const gridPosts = posts.slice(3);

// Prepare featured post data
const featuredAuthorData = authors[featuredPost.data.author];
const bubblePostsData = bubblePosts.map(p => ({
  title: p.data.title,
  description: p.data.description,
  date: p.data.date,
  author: p.data.author,
  authorData: authors[p.data.author],
  category: p.data.category,
  image: p.data.image,
  imageAlt: p.data.imageAlt,
  slug: p.id,
  readingTime: p.data.readingTime,
}));
---

<BaseLayout activePage="blog">
  <SEO
    slot="head"
    title="Blog — Servantium"
    description="Insights on professional services, engagement management, and building the operational infrastructure services businesses deserve."
    ogType="website"
  />

  {/* -- Hero Section — Servantium green background -- */}
  <section class="relative overflow-hidden pt-24 pb-4 md:pt-28 md:pb-6" style="background: linear-gradient(135deg, var(--color-green) 0%, var(--color-forest) 100%);">
    <div class="relative mx-auto max-w-[var(--content-width)] px-6 text-center">
      <h1
        class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-[3.25rem] font-medium mb-3 leading-[1.15] tracking-[-0.02em]"
        style="color: #ffffff; text-shadow: 0 2px 8px rgba(0,0,0,0.15);"
      >
        Insights for Services Leaders
      </h1>
      <p
        class="text-lg md:text-xl max-w-2xl mx-auto leading-relaxed"
        style="color: rgba(255,255,255,0.9);"
      >
        Strategy, operations, and the infrastructure modern services businesses deserve.
      </p>
    </div>
  </section>

  {/* -- Search + Filters — tight below hero -- */}
  <section class="py-1">
    <div class="mx-auto max-w-[var(--content-width)] px-6">
      <div
        class="blog-filters flex gap-2.5 overflow-x-auto pb-1 scrollbar-none
               [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
        role="tablist"
        aria-label="Filter by category"
      >
        <button
          type="button"
          class="filter-cat is-active whitespace-nowrap rounded-full px-5 py-2 text-sm font-semibold
                 transition-all duration-200 ease-[var(--ease-out)]
                 bg-[var(--color-green)] text-white shadow-[0_2px_8px_rgba(0,194,109,0.25)]"
          data-category="all"
          role="tab"
          aria-selected="true"
        >
          All
        </button>

        {categories.map((cat) => (
          <button
            type="button"
            class="filter-cat whitespace-nowrap rounded-full px-5 py-2 text-sm font-semibold
                   transition-all duration-200 ease-[var(--ease-out)]
                   bg-white border border-[var(--color-cloud-grey)] text-[var(--color-ink-muted)]
                   hover:border-[var(--color-green)] hover:text-[var(--color-green)]"
            data-category={cat}
            role="tab"
            aria-selected="false"
          >
            {cat}
          </button>
        ))}
      </div>
      <div class="mt-3">
        <BlogSearch />
      </div>
    </div>
  </section>

  {/* -- Featured Section -- */}
  <section class="pb-0">
    <div class="mx-auto max-w-[var(--content-width)] px-6">

      {/* -- Featured Post (latest) -- */}
      <div class="featured-section mb-3" data-featured-category={featuredPost.data.category}>
        <FeaturedPost
          title={featuredPost.data.title}
          description={featuredPost.data.description}
          date={featuredPost.data.date}
          author={featuredPost.data.author}
          authorData={featuredAuthorData}
          category={featuredPost.data.category}
          image={featuredPost.data.image}
          imageAlt={featuredPost.data.imageAlt}
          slug={featuredPost.id}
          readingTime={featuredPost.data.readingTime}
        />
      </div>

      {/* -- Bubble Grid (posts 2-3) -- */}
      <div class="bubble-section mb-4" data-bubble-categories={bubblePosts.map(p => p.data.category).join(',')}>
        <BubbleGrid posts={bubblePostsData} />
      </div>

      {/* -- Post Count + Sort -- */}
      <h2 class="sr-only">All Articles</h2>
      <div class="flex items-center justify-between mb-3">
        <p class="text-sm text-[var(--color-ink-muted)]" id="blog-post-count">
          {posts.length} {posts.length === 1 ? 'article' : 'articles'}
        </p>
        <div class="flex items-center gap-2">
          <label for="blog-sort" class="text-xs text-[var(--color-ink-muted)]">Sort by:</label>
          <select
            id="blog-sort"
            class="text-xs bg-white border border-[var(--color-cloud-grey)] rounded-lg px-2.5 py-1.5 text-[var(--color-ink-light)] focus:border-[var(--color-green)] focus:ring-1 focus:ring-[var(--color-green)] focus:outline-none cursor-pointer"
          >
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
            <option value="title">Title A-Z</option>
          </select>
        </div>
      </div>

      {/* -- Card Grid (remaining posts) -- */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7" id="blog-grid">
        {gridPosts.map((post, i) => {
          const authorData = authors[post.data.author];
          const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });

          return (
            <a
              href={`/blog/${post.id}`}
              class="blog-card group relative flex flex-col rounded-2xl border border-[var(--color-cloud-grey)]
                     bg-white overflow-hidden no-underline text-inherit
                     transition-[transform,box-shadow] duration-300 ease-[var(--ease-bounce)]
                     hover:-translate-y-1.5 hover:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.12)]"
              data-category={post.data.category}
              data-tags={(post.data.tags || []).join(',')}
              data-date={post.data.date}
              data-title={post.data.title}
              data-page-item
              data-animate
              style={`--stagger: ${Math.min(i, 8) * 80}ms`}
            >
              {/* Card Image */}
              {post.data.image && (
                <div class="relative overflow-hidden aspect-[16/9]">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-600 ease-[var(--ease-out)]
                           group-hover:scale-105"
                  />
                  {/* Gradient overlay at bottom of image */}
                  <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-t from-black/10 to-transparent pointer-events-none" aria-hidden="true"></div>
                </div>
              )}

              {/* Card Content */}
              <div class="flex flex-col flex-1 p-5 sm:p-6 gap-3">
                {/* Category Badge */}
                <span
                  class="inline-block self-start rounded-full bg-[var(--color-green)]/10 px-3 py-0.5
                         text-[0.6875rem] font-semibold uppercase tracking-wider text-[var(--color-green)]"
                >
                  {post.data.category}
                </span>

                {/* Title */}
                <h3
                  class="font-[family-name:var(--font-display)] text-lg sm:text-xl leading-snug
                         text-[var(--color-ink)] line-clamp-2 m-0 tracking-[-0.01em]"
                >
                  {post.data.title}
                </h3>

                {/* Description */}
                <p class="text-sm text-[var(--color-ink-muted)] leading-relaxed line-clamp-3 m-0 flex-1">
                  {post.data.description}
                </p>

                {/* Author + Date Footer */}
                <div class="flex items-center gap-3 pt-4 mt-auto border-t border-[var(--color-cloud-grey)]/60">
                  {authorData?.image && (
                    <img
                      src={authorData.image}
                      alt={authorData.name}
                      class="w-8 h-8 rounded-full object-cover ring-2 ring-white"
                      loading="lazy"
                    />
                  )}
                  <div class="flex flex-col min-w-0">
                    <span class="text-xs font-medium text-[var(--color-ink-light)] truncate">
                      {authorData?.name || post.data.author}
                    </span>
                    <div class="flex items-center gap-1.5 text-[0.6875rem] text-[var(--color-ink-muted)]">
                      <time datetime={post.data.date}>{formattedDate}</time>
                      {post.data.readingTime && (
                        <>
                          <span class="opacity-40" aria-hidden="true">&middot;</span>
                          <span>{post.data.readingTime}</span>
                        </>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      {/* -- Pagination Controls -- */}
      <nav id="blog-pagination" class="flex items-center justify-center gap-2 mt-10 mb-6" aria-label="Blog pagination" role="navigation">
      </nav>

      {/* -- Empty State -- */}
      <div id="blog-empty" class="hidden py-20 text-center">
        <p class="text-lg text-[var(--color-ink-muted)]">No articles match this filter.</p>
        <button
          type="button"
          id="blog-clear-filter"
          class="mt-4 text-sm font-semibold text-[var(--color-green)] hover:underline"
        >
          Show all articles
        </button>
      </div>
    </div>
  </section>

  {/* -- RSS Footer -- */}
  <section class="pb-20 text-center">
    <a
      href="/rss.xml"
      class="inline-flex items-center gap-2.5 text-sm font-medium text-[var(--color-ink-muted)]
             hover:text-[var(--color-green)] transition-colors duration-200"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 11a9 9 0 0 1 9 9"></path>
        <path d="M4 4a16 16 0 0 1 16 16"></path>
        <circle cx="5" cy="19" r="1"></circle>
      </svg>
      Subscribe via RSS
    </a>
  </section>
</BaseLayout>

<style>
  /* -- Scroll-triggered card entrance -- */
  [data-animate] {
    opacity: 1; /* visible by default */
    transform: none;
    transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-spring);
  }
  [data-animate].is-animating {
    opacity: 0;
    transform: translateY(24px);
  }
  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* -- Filter transition for cards -- */
  .blog-card {
    transition: transform 0.3s var(--ease-bounce),
                box-shadow 0.3s var(--ease-out),
                opacity 0.25s ease;
  }
  .blog-card.is-hiding {
    opacity: 0;
    transform: scale(0.96);
  }

  /* -- Active filter pill -- */
  .filter-cat.is-active {
    background: var(--color-green) !important;
    color: white !important;
    border-color: var(--color-green) !important;
    box-shadow: 0 2px 8px rgba(0, 194, 109, 0.25);
  }

  /* -- Duration utility Tailwind doesn't have by default -- */
  .duration-600 {
    transition-duration: 600ms;
  }
</style>

<script>
  function initBlogListing() {
    const grid = document.getElementById('blog-grid');
    const cards = grid?.querySelectorAll<HTMLElement>('.blog-card');
    const catButtons = document.querySelectorAll<HTMLButtonElement>('.filter-cat');
    const emptyState = document.getElementById('blog-empty');
    const clearBtn = document.getElementById('blog-clear-filter');
    const postCount = document.getElementById('blog-post-count');
    const paginationNav = document.getElementById('blog-pagination');

    // Featured section elements
    const featuredSection = document.querySelector<HTMLElement>('.featured-section');
    const bubbleSection = document.querySelector<HTMLElement>('.bubble-section');

    if (!grid || !cards) return;

    let currentCategory = 'all';
    let currentPage = 1;
    const POSTS_PER_PAGE = 12;

    // -- Scroll-triggered reveal --
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );

    function observeCards() {
      cards.forEach((card, i) => {
        if (card.style.display !== 'none') {
          if (i >= 3) {
            card.classList.add('is-animating');
            observer.observe(card);
          }
        }
      });
    }

    // -- Pagination helpers --
    function getFilteredCards(): HTMLElement[] {
      return Array.from(cards).filter((card) => {
        const cardCat = card.dataset.category || '';
        return currentCategory === 'all' || cardCat === currentCategory;
      });
    }

    function applyPagination() {
      const filtered = getFilteredCards();
      const totalPages = Math.max(1, Math.ceil(filtered.length / POSTS_PER_PAGE));

      if (currentPage > totalPages) currentPage = totalPages;

      const startIdx = (currentPage - 1) * POSTS_PER_PAGE;
      const endIdx = startIdx + POSTS_PER_PAGE;

      // Hide all cards first, then show only those matching filter + page
      cards.forEach((card) => {
        card.style.display = 'none';
      });

      filtered.forEach((card, i) => {
        card.style.display = (i >= startIdx && i < endIdx) ? '' : 'none';
      });

      // Count featured/bubble posts too for the article count
      let totalVisible = filtered.length;
      if (featuredSection && featuredSection.style.display !== 'none') totalVisible++;
      if (bubbleSection && bubbleSection.style.display !== 'none') {
        const bubbleCats = (bubbleSection.dataset.bubbleCategories || '').split(',');
        totalVisible += bubbleCats.filter(c => currentCategory === 'all' || c === currentCategory).length;
      }

      if (postCount) {
        postCount.textContent = `${totalVisible} ${totalVisible === 1 ? 'article' : 'articles'}`;
      }

      // Empty state
      if (emptyState) {
        emptyState.classList.toggle('hidden', totalVisible > 0);
      }
      grid.classList.toggle('hidden', filtered.length === 0);

      // Update URL
      const url = new URL(window.location.href);
      if (currentPage > 1) {
        url.searchParams.set('page', String(currentPage));
      } else {
        url.searchParams.delete('page');
      }
      if (currentCategory !== 'all') {
        url.searchParams.set('category', currentCategory);
      } else {
        url.searchParams.delete('category');
      }
      history.replaceState(null, '', url.toString());

      renderPagination(totalPages);

      // Re-trigger entrance animations for newly visible cards
      filtered.slice(startIdx, endIdx).forEach((card) => {
        card.classList.remove('is-visible', 'is-animating');
        requestAnimationFrame(() => {
          card.classList.add('is-animating');
          observer.observe(card);
        });
      });
    }

    function renderPagination(totalPages: number) {
      if (!paginationNav) return;

      if (totalPages <= 1) {
        paginationNav.innerHTML = '';
        return;
      }

      const btnBase = 'inline-flex items-center justify-center min-w-[2.5rem] h-10 px-3 rounded-lg text-sm font-medium transition-all duration-200';
      const btnNormal = `${btnBase} border border-[var(--color-cloud-grey)] bg-white text-[var(--color-ink-light)] hover:border-[var(--color-green)] hover:text-[var(--color-green)]`;
      const btnActive = `${btnBase} bg-[var(--color-green)] text-white shadow-[0_2px_8px_rgba(0,194,109,0.25)]`;
      const btnDisabled = `${btnBase} border border-[var(--color-cloud-grey)] bg-[var(--color-mist-grey)] text-[var(--color-ink-muted)] opacity-50 cursor-not-allowed`;

      let html = '';

      // Previous button
      html += `<button type="button" data-page="${currentPage - 1}" class="${currentPage === 1 ? btnDisabled : btnNormal}" ${currentPage === 1 ? 'disabled' : ''} aria-label="Previous page">&lsaquo; Prev</button>`;

      // Page numbers with ellipsis
      const pages: (number | string)[] = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) pages.push(i);
      } else {
        pages.push(1);
        if (currentPage > 3) pages.push('...');
        const start = Math.max(2, currentPage - 1);
        const end = Math.min(totalPages - 1, currentPage + 1);
        for (let i = start; i <= end; i++) pages.push(i);
        if (currentPage < totalPages - 2) pages.push('...');
        pages.push(totalPages);
      }

      for (const p of pages) {
        if (p === '...') {
          html += `<span class="inline-flex items-center justify-center min-w-[2.5rem] h-10 text-sm text-[var(--color-ink-muted)]">...</span>`;
        } else {
          const isActive = p === currentPage;
          html += `<button type="button" data-page="${p}" class="${isActive ? btnActive : btnNormal}" ${isActive ? 'aria-current="page"' : ''} aria-label="Page ${p}">${p}</button>`;
        }
      }

      // Next button
      html += `<button type="button" data-page="${currentPage + 1}" class="${currentPage === totalPages ? btnDisabled : btnNormal}" ${currentPage === totalPages ? 'disabled' : ''} aria-label="Next page">Next &rsaquo;</button>`;

      paginationNav.innerHTML = html;

      // Bind click events
      paginationNav.querySelectorAll<HTMLButtonElement>('button[data-page]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const page = parseInt(btn.dataset.page || '1', 10);
          if (page >= 1 && page <= totalPages) {
            currentPage = page;
            applyPagination();
            grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }

    // -- Category filtering --
    function filterCards(category: string) {
      currentCategory = category;
      currentPage = 1;

      // Update button styles
      catButtons.forEach((btn) => {
        const isActive = btn.dataset.category === category;
        btn.classList.toggle('is-active', isActive);
        btn.setAttribute('aria-selected', String(isActive));

        if (isActive) {
          btn.className = btn.className
            .replace(/bg-white\s*/g, '')
            .replace(/border\s+border-\[var\(--color-cloud-grey\)\]/g, '')
            .replace(/text-\[var\(--color-ink-muted\)\]/g, '')
            .replace(/hover:border-\[var\(--color-green\)\]/g, '')
            .replace(/hover:text-\[var\(--color-green\)\]/g, '');
        }
      });

      // Show/hide featured section based on category
      if (featuredSection) {
        const featuredCat = featuredSection.dataset.featuredCategory;
        featuredSection.style.display = (category === 'all' || featuredCat === category) ? '' : 'none';
      }
      if (bubbleSection) {
        const bubbleCats = (bubbleSection.dataset.bubbleCategories || '').split(',');
        const anyMatch = category === 'all' || bubbleCats.includes(category);
        bubbleSection.style.display = anyMatch ? '' : 'none';
      }

      applyPagination();
    }

    // -- Event listeners --
    catButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterCards(btn.dataset.category || 'all');
      });
    });

    clearBtn?.addEventListener('click', () => {
      filterCards('all');
    });

    // -- Sort dropdown --
    const sortSelect = document.getElementById('blog-sort') as HTMLSelectElement | null;
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        const gridEl = document.getElementById('blog-grid');
        if (!gridEl) return;
        const cardEls = Array.from(gridEl.children) as HTMLElement[];
        cardEls.sort((a, b) => {
          const dateA = a.getAttribute('data-date') || '';
          const dateB = b.getAttribute('data-date') || '';
          const titleA = a.getAttribute('data-title') || '';
          const titleB = b.getAttribute('data-title') || '';
          switch (sortSelect.value) {
            case 'oldest': return dateA.localeCompare(dateB);
            case 'title': return titleA.localeCompare(titleB);
            default: return dateB.localeCompare(dateA);
          }
        });
        cardEls.forEach(card => gridEl.appendChild(card));
        currentPage = 1;
        applyPagination();
      });
    }

    // -- Apply initial state from URL --
    const params = new URLSearchParams(window.location.search);
    const initialCat = params.get('category') || 'all';
    const initialPage = parseInt(params.get('page') || '1', 10);
    currentPage = initialPage > 0 ? initialPage : 1;

    if (initialCat !== 'all') {
      filterCards(initialCat);
    } else {
      applyPagination();
    }
  }

  // Fire on both DOMContentLoaded (dev) and astro:page-load (prod with View Transitions)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBlogListing);
  } else {
    initBlogListing();
  }
  document.addEventListener('astro:page-load', initBlogListing);
</script>
