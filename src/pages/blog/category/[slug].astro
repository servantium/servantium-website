---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import { getCollection } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';

export async function getStaticPaths() {
  const posts = filterByStatus(await getCollection('blog', ({ data }) => !data.draft));
  const categories = [...new Set(posts.map((p) => p.data.category))];

  return categories.map((category) => {
    const slug = category.toLowerCase().replace(/\s+/g, '-');
    const filteredPosts = posts
      .filter((p) => p.data.category === category)
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

    return {
      params: { slug },
      props: { category, posts: filteredPosts },
    };
  });
}

const { category, posts } = Astro.props;
---

<BaseLayout activePage="blog">
  <SEO
    slot="head"
    title={`${category} — Servantium Blog`}
    description={`${category} insights on professional services, engagement management, and operational infrastructure.`}
    ogType="website"
  />

  <!-- Blog Hero -->
  <section class="bg-gradient-to-b from-[var(--color-soft-mint)] to-white py-16 md:py-20">
    <div class="mx-auto max-w-[var(--content-width)] px-6 text-center">
      <a href="/blog/" class="inline-flex items-center gap-1 text-sm text-[var(--color-green)] hover:text-[var(--color-green-hover)] mb-4 transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        All Posts
      </a>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-medium text-[var(--color-ink)] mb-4">
        {category}
      </h1>
      <p class="text-lg text-[var(--color-ink-muted)] max-w-xl mx-auto">
        {posts.length} article{posts.length !== 1 ? 's' : ''} on {category.toLowerCase()}.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16">
    <div class="mx-auto max-w-[var(--content-width)] px-6">
      <h2 class="sr-only">Articles in {category}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group block rounded-xl border border-[var(--color-cloud-grey)] overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
            style="transition-timing-function: var(--ease-out)"
          >
            {post.data.image && (
              <div class="overflow-hidden aspect-[16/9]">
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt || post.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                  style="transition-timing-function: var(--ease-out)"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6">
              <span class="inline-block text-xs font-semibold uppercase tracking-wider text-[var(--color-green)] mb-2">
                {post.data.category}
              </span>
              <h3 class="font-[family-name:var(--font-display)] text-lg font-medium text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors mb-2 line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-[var(--color-ink-muted)] line-clamp-3 mb-4">
                {post.data.description}
              </p>
              <div class="flex items-center gap-2 text-xs text-[var(--color-ink-muted)]">
                <span>{post.data.author}</span>
                <span>·</span>
                <time>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
