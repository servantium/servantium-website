---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import { getCollection } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((author) => ({
    params: { slug: author.id },
    props: { author },
  }));
}

const { author } = Astro.props;
const { name, role, avatar, linkedin, bio } = author.data;

// Get all non-draft posts by this author
const allPosts = filterByStatus(await getCollection('blog', ({ data }) => !data.draft));
const authorPosts = allPosts
  .filter((post) => post.data.author === author.id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout activePage="blog">
  <SEO
    slot="head"
    title={`${name} — Servantium Blog`}
    description={bio || `Articles by ${name}, ${role}`}
    ogType="profile"
  />

  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6">
      <!-- Author Header -->
      <div class="flex flex-col items-center text-center mb-16">
        <img
          src={avatar}
          alt={name}
          width="120"
          height="120"
          class="w-30 h-30 rounded-full object-cover mb-6 shadow-lg"
        />
        <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-medium text-[var(--color-ink)] mb-2">
          {name}
        </h1>
        <p class="text-lg text-[var(--color-ink-muted)] mb-4">{role}</p>
        {bio && (
          <p class="text-[var(--color-ink-light)] max-w-xl leading-relaxed mb-6">{bio}</p>
        )}
        {linkedin && (
          <a
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-[var(--color-green)] hover:text-[var(--color-green-hover)] font-medium transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Connect on LinkedIn
          </a>
        )}
      </div>

      <!-- Posts by Author -->
      <h2 class="font-[family-name:var(--font-display)] text-2xl md:text-3xl font-medium text-[var(--color-ink)] mb-8">
        Articles by {name.split(' ')[0]}
      </h2>

      {authorPosts.length === 0 ? (
        <p class="text-[var(--color-ink-muted)]">No published articles yet.</p>
      ) : (
        <div class="grid gap-8">
          {authorPosts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="group block rounded-xl border border-[var(--color-cloud-grey)] p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-green)]"
              style={`transition-timing-function: var(--ease-out)`}
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <span class="inline-block text-xs font-semibold uppercase tracking-wider text-[var(--color-green)] mb-2">
                    {post.data.category}
                  </span>
                  <h3 class="font-[family-name:var(--font-display)] text-xl font-medium text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors mb-2">
                    {post.data.title}
                  </h3>
                  <p class="text-[var(--color-ink-muted)] line-clamp-2 mb-3">
                    {post.data.description}
                  </p>
                  <div class="flex items-center gap-3 text-sm text-[var(--color-ink-muted)]">
                    <time>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                    {post.data.readingTime && (
                      <>
                        <span>·</span>
                        <span>{post.data.readingTime}</span>
                      </>
                    )}
                  </div>
                </div>
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt=""
                    class="w-24 h-24 rounded-lg object-cover flex-shrink-0 hidden sm:block"
                    loading="lazy"
                  />
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
