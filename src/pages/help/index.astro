---
import DocsLayout from '@/theme/grove/DocsLayout.astro';
import { getCollection } from 'astro:content';

// Get all docs
const allDocs = await getCollection('docs');

// Get featured docs for "What's New" section
const featuredDocs = allDocs
  .filter((doc) => doc.data.featured === true);

// Hardcoded defaults for What's New cards (used to fill remaining slots if < 8 featured)
const defaultWhatsNew = [
  { href: '/help/guides/engagements/', label: 'Engagement Workspace', version: 'v1.0', date: 'March 2026' },
  { href: '/help/guides/quotes-pricing/', label: 'AI Quote Generation', version: 'v1.0', date: 'March 2026' },
  { href: '/help/guides/ai-features/', label: 'Similar Matching', version: 'v1.0', date: 'March 2026' },
  { href: '/help/guides/resource-planning/', label: 'Resource Planning', version: 'v1.0', date: 'March 2026' },
  { href: '/help/guides/documents/', label: 'Document Generation', version: 'v1.0', date: 'March 2026' },
  { href: '/help/guides/notes-ai/', label: 'Note Intelligence', version: 'v1.0', date: 'March 2026' },
  { href: '/help/guides/quotes-pricing/', label: 'Service Catalog', version: 'v1.0', date: 'March 2026' },
  { href: '/help/guides/ai-features/', label: 'Institutional Memory', version: 'v1.0', date: 'March 2026' },
];

// Build the What's New items: featured docs first, then fill with defaults
const featuredItems = featuredDocs.map((doc) => ({
  href: `/help/${doc.id}/`,
  label: doc.data.featuredLabel || doc.data.title,
  version: 'v1.0',
  date: doc.data.date ? new Date(doc.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : 'March 2026',
  fromDoc: true,
}));

const remainingSlots = Math.max(0, 8 - featuredItems.length);
const whatsNewItems = [...featuredItems, ...defaultWhatsNew.slice(0, remainingSlots)];

// Get release notes for "Latest Updates" timeline
const releaseNotes = allDocs
  .filter((doc) => doc.id.startsWith('release-notes/'))
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);
---

