---
import DocsLayout from '@/theme/grove/DocsLayout.astro';
import { getCollection } from 'astro:content';

// Get latest release note for "What's New" card
const allDocs = await getCollection('docs');
const latestRelease = allDocs
  .filter((doc) => doc.id.startsWith('release-notes/'))
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  })[0];

const latestDate = latestRelease?.data.date
  ? new Date(latestRelease.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : '';
---

<DocsLayout
  title="Help Center"
  description="Help docs, guides, and release notes for Servantium."
  headings={[
    { depth: 2, slug: 'quick-links', text: 'Quick Links' },
    { depth: 2, slug: 'whats-new', text: "What's New" },
    { depth: 2, slug: 'browse-docs', text: 'Browse Documentation' },
    { depth: 2, slug: 'need-help', text: 'Need Help?' },
  ]}
  currentSlug="getting-started"
>
  <p class="text-slate-500 mb-10 text-[15px] leading-relaxed">
    Everything you need to get started with Servantium. Browse the documentation, watch tutorials, or check out what's new.
  </p>

  <!-- Quick Links — colorful cards like Tailwind docs -->
  <h2 id="quick-links" class="sr-only">Quick Links</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12 not-prose">
    <!-- Documentation — Green -->
    <a href="/help/quick-start/" class="group relative overflow-hidden rounded-xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg bg-gradient-to-br from-[var(--color-green)] to-[var(--color-forest)] text-white no-underline" style="transition-timing-function: var(--ease-out)">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-8 translate-x-8" aria-hidden="true"></div>
      <svg class="size-8 mb-3 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
      <h3 class="text-base font-bold text-white mb-1">Documentation</h3>
      <p class="text-sm text-white/80 mb-3">Browse the complete guide to get started with Servantium.</p>
      <span class="text-xs font-semibold text-white/90 group-hover:text-white transition-colors">Get started &rarr;</span>
    </a>

    <!-- Video Tutorials — Slate Blue -->
    <div class="group relative overflow-hidden rounded-xl p-6 bg-gradient-to-br from-[var(--color-slate-blue)] to-[#3a6d8c] text-white opacity-80">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-8 translate-x-8" aria-hidden="true"></div>
      <svg class="size-8 mb-3 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
      <h3 class="text-base font-bold text-white mb-1">Video Tutorials</h3>
      <p class="text-sm text-white/70 mb-3">Watch screencasts to learn Servantium visually.</p>
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold bg-white/20 rounded-full px-2.5 py-0.5 text-white/90">Coming soon</span>
    </div>

    <!-- Release Notes — Amber -->
    <a href="/help/release-notes/" class="group relative overflow-hidden rounded-xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg bg-gradient-to-br from-[var(--color-amber)] to-[#e09a00] text-white no-underline" style="transition-timing-function: var(--ease-out)">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-8 translate-x-8" aria-hidden="true"></div>
      <svg class="size-8 mb-3 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <h3 class="text-base font-bold text-white mb-1">Release Notes</h3>
      <p class="text-sm text-white/80 mb-3">See what's new, improved, and fixed in each release.</p>
      <span class="text-xs font-semibold text-white/90 group-hover:text-white transition-colors">View changelog &rarr;</span>
    </a>

    <!-- Blog — Deep Teal -->
    <a href="/blog/" class="group relative overflow-hidden rounded-xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg bg-gradient-to-br from-[var(--color-deep-teal)] to-[#1d8a7c] text-white no-underline" style="transition-timing-function: var(--ease-out)">
      <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-8 translate-x-8" aria-hidden="true"></div>
      <svg class="size-8 mb-3 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
      <h3 class="text-base font-bold text-white mb-1">Blog & Insights</h3>
      <p class="text-sm text-white/80 mb-3">Strategy, operations, and services infrastructure articles.</p>
      <span class="text-xs font-semibold text-white/90 group-hover:text-white transition-colors">Read articles &rarr;</span>
    </a>
  </div>

  <!-- What's New -->
  <h2 id="whats-new">What's New in Servantium</h2>

  {latestRelease ? (
    <a
      href={`/help/${latestRelease.id}/`}
      class="group block rounded-xl border-l-4 border-[var(--color-green)] bg-[var(--color-mint-tint)] p-6 mb-10 transition-all duration-200 hover:shadow-md hover:bg-[var(--color-soft-mint)]"
    >
      <div class="flex items-center gap-3 mb-2">
        {latestRelease.data.version && (
          <span class="inline-flex items-center rounded-full bg-[var(--color-green)] px-2.5 py-0.5 text-xs font-bold text-white">
            {latestRelease.data.version}
          </span>
        )}
        {latestDate && <time class="text-xs text-slate-500">{latestDate}</time>}
      </div>
      <h3 class="text-lg font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors mb-1">
        {latestRelease.data.title}
      </h3>
      {latestRelease.data.description && (
        <p class="text-sm text-slate-500 line-clamp-2 mb-2">{latestRelease.data.description}</p>
      )}
      <span class="text-sm font-medium text-[var(--color-green)]">Read the full release notes &rarr;</span>
    </a>
  ) : (
    <p class="text-sm text-slate-400 italic mb-10">No releases yet.</p>
  )}

  <!-- Browse Documentation -->
  <h2 id="browse-docs">Browse Documentation</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
    <a href="/help/quick-start/" class="group block rounded-lg border border-[var(--color-cloud-grey)] p-4 transition-all duration-150 hover:border-[var(--color-green)] hover:shadow-sm">
      <h3 class="text-sm font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors">Quick Start</h3>
      <p class="mt-1 text-xs text-slate-500">Get up and running in minutes</p>
    </a>
    <a href="/help/key-concepts/" class="group block rounded-lg border border-[var(--color-cloud-grey)] p-4 transition-all duration-150 hover:border-[var(--color-green)] hover:shadow-sm">
      <h3 class="text-sm font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors">Key Concepts</h3>
      <p class="mt-1 text-xs text-slate-500">Engagements, quotes, resources, and lifecycle</p>
    </a>
    <a href="/help/guides/engagements/" class="group block rounded-lg border border-[var(--color-cloud-grey)] p-4 transition-all duration-150 hover:border-[var(--color-green)] hover:shadow-sm">
      <h3 class="text-sm font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors">Guides</h3>
      <p class="mt-1 text-xs text-slate-500">Deep dives into every feature</p>
    </a>
    <a href="/help/release-notes/" class="group block rounded-lg border border-[var(--color-cloud-grey)] p-4 transition-all duration-150 hover:border-[var(--color-green)] hover:shadow-sm">
      <h3 class="text-sm font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors">Release Notes</h3>
      <p class="mt-1 text-xs text-slate-500">Changelog and what's new</p>
    </a>
  </div>

  <!-- Need Help -->
  <h2 id="need-help">Need Help?</h2>
  <div class="space-y-3">
    <a href="/help/support/contact/" class="group flex items-center justify-between rounded-lg border border-[var(--color-cloud-grey)] p-4 transition-all duration-150 hover:border-[var(--color-green)] hover:shadow-sm">
      <div>
        <h3 class="text-sm font-semibold text-[var(--color-ink)]">Contact Support</h3>
        <p class="mt-0.5 text-xs text-slate-500">We typically respond within 24 hours</p>
      </div>
      <svg class="size-4 text-slate-300 group-hover:text-[var(--color-green)] transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
    <a href="/help/support/faq/" class="group flex items-center justify-between rounded-lg border border-[var(--color-cloud-grey)] p-4 transition-all duration-150 hover:border-[var(--color-green)] hover:shadow-sm">
      <div>
        <h3 class="text-sm font-semibold text-[var(--color-ink)]">FAQ</h3>
        <p class="mt-0.5 text-xs text-slate-500">Common questions answered</p>
      </div>
      <svg class="size-4 text-slate-300 group-hover:text-[var(--color-green)] transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</DocsLayout>
