              <rect x="36" y="62" width="48" height="8" rx="4" fill="rgba(255,255,255,0.15)" />
              <rect x="36" y="80" width="52" height="8" rx="4" fill="rgba(255,255,255,0.15)" />
              <rect x="36" y="98" width="44" height="8" rx="4" fill="rgba(255,255,255,0.12)" />
              <rect x="36" y="116" width="56" height="8" rx="4" fill="rgba(255,255,255,0.12)" />
              <rect x="36" y="134" width="40" height="8" rx="4" fill="rgba(255,255,255,0.1)" />
              <rect x="36" y="152" width="50" height="8" rx="4" fill="rgba(255,255,255,0.1)" />
              <!-- Active indicator -->
              <rect x="32" y="42" width="3" height="12" rx="1.5" fill="rgba(255,255,255,0.5)" />
              <!-- Content area -->
              <rect x="120" y="24" width="208" height="184" rx="8" fill="rgba(255,255,255,0.07)" />
              <!-- Content title -->
              <rect x="140" y="44" width="120" height="12" rx="4" fill="rgba(255,255,255,0.25)" />
              <!-- Content lines -->
              <rect x="140" y="72" width="168" height="6" rx="3" fill="rgba(255,255,255,0.15)" />
              <rect x="140" y="86" width="152" height="6" rx="3" fill="rgba(255,255,255,0.12)" />
              <rect x="140" y="100" width="160" height="6" rx="3" fill="rgba(255,255,255,0.12)" />
              <!-- Bullet points -->
              <circle cx="148" cy="125" r="3" fill="rgba(255,255,255,0.2)" />
              <rect x="158" y="122" width="120" height="6" rx="3" fill="rgba(255,255,255,0.12)" />
              <circle cx="148" cy="141" r="3" fill="rgba(255,255,255,0.2)" />
              <rect x="158" y="138" width="108" height="6" rx="3" fill="rgba(255,255,255,0.12)" />
              <circle cx="148" cy="157" r="3" fill="rgba(255,255,255,0.2)" />
              <rect x="158" y="154" width="132" height="6" rx="3" fill="rgba(255,255,255,0.12)" />
              <!-- Code block -->
              <rect x="140" y="174" width="168" height="24" rx="6" fill="rgba(255,255,255,0.1)" />
              <rect x="152" y="183" width="80" height="6" rx="3" fill="rgba(255,255,255,0.2)" />
            </svg>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-20 hidden sm:block" style="background: linear-gradient(to top, #023E25, transparent);" aria-hidden="true"></div>
      </div>
    </section>

    <!-- Card 2 — Explore AI features (blue) -->
    <section class="flex min-h-[280px]">
      <div class="w-full relative text-white overflow-hidden rounded-3xl flex shadow-lg">
        <div class="w-full flex md:flex-col bg-gradient-to-br from-[#4C82A7] to-[#1d3f5c]">
          <div class="sm:max-w-sm sm:flex-none md:w-auto md:flex-auto flex flex-col items-start relative z-10 p-6 xl:p-8">
            <h2 class="text-xl font-semibold mb-2" style="color:#fff; text-shadow: 0 1px 3px rgba(0,0,0,0.3);">Explore AI features</h2>
            <p class="font-medium mb-4 text-sm" style="color: rgba(255,255,255,0.85); text-shadow: 0 1px 2px rgba(0,0,0,0.2);">Discover how AI powers similar matching, quote generation, and institutional memory.</p>
            <a class="mt-auto bg-white/20 hover:bg-white/30 transition-colors duration-200 rounded-xl font-semibold py-2 px-4 inline-flex text-sm no-underline" style="color:#fff;" href="/help/guides/ai-features/">Explore AI</a>
          </div>
          <div class="relative md:pl-6 xl:pl-8 hidden sm:block" aria-hidden="true">
