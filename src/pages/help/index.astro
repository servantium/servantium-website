              <line x1="112" y1="76" x2="176" y2="36" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
              <line x1="240" y1="140" x2="176" y2="180" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
