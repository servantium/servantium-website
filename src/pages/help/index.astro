              <circle cx="100" cy="60" r="14" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" />
              <circle cx="260" cy="56" r="14" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" />
              <circle cx="80" cy="140" r="12" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.18)" stroke-width="1.5" />
              <circle cx="276" cy="136" r="12" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.18)" stroke-width="1.5" />
              <circle cx="140" cy="176" r="10" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
              <circle cx="220" cy="180" r="10" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
              <circle cx="56" cy="96" r="8" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.12)" stroke-width="1" />
              <circle cx="304" cy="92" r="8" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.12)" stroke-width="1" />
              <!-- Connection lines -->
              <line x1="176" y1="100" x2="100" y2="60" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
              <line x1="176" y1="100" x2="260" y2="56" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
              <line x1="176" y1="100" x2="80" y2="140" stroke="rgba(255,255,255,0.12)" stroke-width="1" />
              <line x1="176" y1="100" x2="276" y2="136" stroke="rgba(255,255,255,0.12)" stroke-width="1" />
              <line x1="176" y1="100" x2="140" y2="176" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
              <line x1="176" y1="100" x2="220" y2="180" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
              <line x1="100" y1="60" x2="56" y2="96" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
              <line x1="260" y1="56" x2="304" y2="92" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
              <line x1="80" y1="140" x2="140" y2="176" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
              <line x1="276" y1="136" x2="220" y2="180" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
              <line x1="100" y1="60" x2="80" y2="140" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
              <line x1="260" y1="56" x2="276" y2="136" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
              <!-- Sparkle shapes -->
              <path d="M176 80 L178 88 L186 90 L178 92 L176 100 L174 92 L166 90 L174 88 Z" fill="rgba(255,255,255,0.3)" />
              <path d="M120 40 L121 44 L125 45 L121 46 L120 50 L119 46 L115 45 L119 44 Z" fill="rgba(255,255,255,0.2)" />
              <path d="M240 170 L241 174 L245 175 L241 176 L240 180 L239 176 L235 175 L239 174 Z" fill="rgba(255,255,255,0.2)" />
              <!-- Center dot highlight -->
              <circle cx="176" cy="100" r="5" fill="rgba(255,255,255,0.3)" />
            </svg>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-20 hidden sm:block" style="background: linear-gradient(to top, #1d3f5c, transparent);" aria-hidden="true"></div>
      </div>
    </section>

    <!-- Card 3 — Watch the screencasts (amber) -->
    <section class="flex min-h-[280px]">
      <div class="w-full relative text-white overflow-hidden rounded-3xl flex shadow-lg">
        <div class="w-full flex md:flex-col bg-gradient-to-br from-[#e09a00] to-[#8B6100]">
          <div class="sm:max-w-sm sm:flex-none md:w-auto md:flex-auto flex flex-col items-start relative z-10 p-6 xl:p-8">
            <h2 class="text-xl font-semibold mb-2" style="color:#fff; text-shadow: 0 1px 3px rgba(0,0,0,0.3);">Watch the screencasts</h2>
            <p class="font-medium mb-4 text-sm" style="color: rgba(255,255,255,0.85); text-shadow: 0 1px 2px rgba(0,0,0,0.2);">Learn more about Servantium directly from the team.</p>
            <span class="mt-auto bg-white/20 rounded-xl font-semibold py-2 px-4 inline-flex text-sm opacity-50 cursor-default" style="color:#fff;">Coming soon</span>
          </div>
          <div class="relative md:pl-6 xl:pl-8 hidden sm:block" aria-hidden="true">
            <!-- SVG: Abstract video player -->
            <svg viewBox="0 0 352 232" class="w-full" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Main video player -->
              <rect x="40" y="24" width="272" height="160" rx="12" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
              <!-- Play button -->
              <circle cx="176" cy="94" r="28" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.25)" stroke-width="1.5" />
              <polygon points="168,80 168,108 192,94" fill="rgba(255,255,255,0.3)" />
              <!-- Progress bar background -->
              <rect x="56" y="168" width="240" height="6" rx="3" fill="rgba(255,255,255,0.1)" />
              <!-- Progress bar fill -->
              <rect x="56" y="168" width="96" height="6" rx="3" fill="rgba(255,255,255,0.25)" />
              <!-- Progress dot -->
              <circle cx="152" cy="171" r="5" fill="rgba(255,255,255,0.35)" />
              <!-- Thumbnail strip -->
              <rect x="40" y="196" width="60" height="36" rx="6" fill="rgba(255,255,255,0.1)" />
              <rect x="40" y="196" width="60" height="36" rx="6" stroke="rgba(255,255,255,0.2)" stroke-width="1" />
              <!-- Thumbnail play icon -->
              <polygon points="65,208 65,222 77,215" fill="rgba(255,255,255,0.2)" />
              <rect x="110" y="196" width="60" height="36" rx="6" fill="rgba(255,255,255,0.08)" />
              <polygon points="135,208 135,222 147,215" fill="rgba(255,255,255,0.15)" />
              <rect x="180" y="196" width="60" height="36" rx="6" fill="rgba(255,255,255,0.08)" />
              <polygon points="205,208 205,222 217,215" fill="rgba(255,255,255,0.15)" />
              <rect x="250" y="196" width="60" height="36" rx="6" fill="rgba(255,255,255,0.06)" />
              <polygon points="275,208 275,222 287,215" fill="rgba(255,255,255,0.12)" />
            </svg>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-20 hidden sm:block" style="background: linear-gradient(to top, #8B6100, transparent);" aria-hidden="true"></div>
      </div>
    </section>

  </div>

  <!-- ═══════════════════════════════════════════════════
       SECTION 4: "What's new in Servantium" feature cards
       ═══════════════════════════════════════════════════ -->
  <div class="not-prose mb-6">
    <h2 id="whats-new" class="font-display text-[1.35rem] font-semibold leading-tight tracking-tight text-[var(--color-ink)] mb-4 scroll-mt-24">
      What's new in Servantium
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

      {whatsNewItems.map((item, i) => (
        <a href={item.href} class="group rounded-xl p-4 no-underline [text-decoration:none] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg" style={`background: ${gradientPalette[i % gradientPalette.length]};`}>
          <span class="block text-sm font-bold text-white [text-decoration:none]">{item.label}</span>
          <span class="block text-xs mt-1" style="color: rgba(255,255,255,0.7);">{item.version}</span>
        </a>
      ))}

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       SECTION 5: Latest Updates timeline
       ═══════════════════════════════════════════════════ -->
  <div class="not-prose">
    <div class="flex items-center justify-between mb-4">
      <h2 id="latest-updates" class="font-display text-[1.35rem] font-semibold leading-tight tracking-tight text-[var(--color-ink)] scroll-mt-24">
        Latest Updates
      </h2>
      <a href="/help/release-notes/" class="text-sm font-medium text-[var(--color-green)] no-underline [text-decoration:none] hover:underline transition-colors">
        View all updates &rarr;
      </a>
    </div>

    {releaseNotes.length === 0 ? (
      <p class="text-sm text-[var(--color-ink-muted)] italic">No release notes yet.</p>
    ) : (
      <div class="relative pl-8">
        <!-- Timeline vertical line -->
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-[var(--color-pale-green)]" aria-hidden="true"></div>

        <div class="space-y-8">
          {releaseNotes.map((entry, i) => {
            const dateStr = entry.data.date
              ? new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
              : '';
            const dotColor = entry.data.repo === 'servantium-website' ? '#4C82A7' : 'var(--color-green)';

            return (
              <div class="relative">
                <!-- Timeline dot (green=servantium, blue=website) -->
                <div class="absolute -left-8 top-1 flex items-center justify-center">
                  <div class="size-3.5 rounded-full border-2 border-white" style={`background-color: ${i === 0 ? dotColor : (entry.data.repo === 'servantium-website' ? 'rgba(76,130,167,0.4)' : 'var(--color-pale-green)')};`} aria-hidden="true"></div>
                </div>

                <!-- Entry content -->
                <div class="pb-1">
                  {dateStr && (
                    <time class="text-xs font-medium text-[var(--color-ink-muted)] mb-1 block">{dateStr}</time>
                  )}
                  <a href={`/help/${entry.id}/`} class="group no-underline [text-decoration:none]">
                    <h3 class="text-[15px] font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors mb-1 no-underline [text-decoration:none]">
                      {entry.data.title}
                    </h3>
                    {entry.data.description && (
                      <p class="text-sm text-[var(--color-ink-muted)] line-clamp-2 mb-1.5 no-underline [text-decoration:none]">
                        {entry.data.description}
                      </p>
                    )}
                    <span class="text-xs font-medium text-[var(--color-green)] no-underline [text-decoration:none]">
                      Read more &rarr;
                    </span>
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>

</DocsLayout>
