---
import DocsLayout from '@/theme/grove/DocsLayout.astro';
import { getCollection } from 'astro:content';

// Get all docs
const allDocs = await getCollection('docs');

// Get featured docs for "What's New" section
const featuredDocs = allDocs
  .filter((doc) => doc.data.featured === true);

// Gradient palette for What's New cards
const gradientPalette = [
  'linear-gradient(135deg, #00C26D, #023E25)',       // green
  'linear-gradient(135deg, #4C82A7, #1d3f5c)',       // blue
  'linear-gradient(135deg, #26A899, #0f4f47)',       // teal
  'linear-gradient(135deg, #e09a00, #8B6100)',       // amber
  'linear-gradient(135deg, #FF5C70, #a8293a)',       // coral
  'linear-gradient(135deg, #6366F1, #3730A3)',       // slate-blue
  'linear-gradient(135deg, #059669, #064E3B)',       // forest
  'linear-gradient(135deg, #10B981, #047857)',       // emerald
];

// Hardcoded defaults for What's New cards (used to fill remaining slots if < 8 featured)
const defaultWhatsNew = [
  { href: '/help/guides/engagements/', label: 'Engagement Workspace', version: 'v1.0' },
  { href: '/help/guides/quotes-pricing/', label: 'AI Quote Generation', version: 'v1.0' },
  { href: '/help/guides/ai-features/', label: 'Similar Matching', version: 'v1.0' },
  { href: '/help/guides/resource-planning/', label: 'Resource Planning', version: 'v1.0' },
  { href: '/help/guides/documents/', label: 'Document Generation', version: 'v1.0' },
  { href: '/help/guides/notes-ai/', label: 'Note Intelligence', version: 'v1.0' },
  { href: '/help/guides/quotes-pricing/', label: 'Service Catalog', version: 'v1.0' },
  { href: '/help/guides/ai-features/', label: 'Institutional Memory', version: 'v1.0' },
];

// Build the What's New items: featured docs first, then fill with defaults
const featuredItems = featuredDocs.map((doc) => ({
  href: `/help/${doc.id}/`,
  label: doc.data.featuredLabel || doc.data.title,
  version: 'v1.0',
  fromDoc: true,
}));

const remainingSlots = Math.max(0, 8 - featuredItems.length);
const whatsNewItems = [...featuredItems, ...defaultWhatsNew.slice(0, remainingSlots)];

// Get release notes for "Latest Updates" timeline
const releaseNotes = allDocs
  .filter((doc) => doc.id.startsWith('release-notes/'))
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);
---

<DocsLayout
  title="Help Center"
  description="Help docs, guides, and release notes for Servantium."
  headings={[]}
  currentSlug="getting-started"
>
  <!-- ═══════════════════════════════════════════════════
       SECTION 2: Hero title + subtitle
       ═══════════════════════════════════════════════════ -->
  <div class="not-prose mb-4">
    <h2 id="getting-started" class="font-display text-[1.75rem] font-semibold leading-tight tracking-tight text-[var(--color-ink)] sm:text-[2rem] mb-2 scroll-mt-24">
      Getting started with Servantium
