              <!-- Thumbnail row -->
              <rect x="48" y="188" width="56" height="36" rx="8" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.18)" stroke-width="1" />
              <polygon points="71,200 71,214 83,207" fill="rgba(255,255,255,0.25)" />
              <rect x="114" y="188" width="56" height="36" rx="8" fill="rgba(255,255,255,0.08)" />
              <polygon points="137,200 137,214 149,207" fill="rgba(255,255,255,0.18)" />
              <rect x="180" y="188" width="56" height="36" rx="8" fill="rgba(255,255,255,0.06)" />
              <polygon points="203,200 203,214 215,207" fill="rgba(255,255,255,0.14)" />
              <rect x="246" y="188" width="56" height="36" rx="8" fill="rgba(255,255,255,0.04)" />
