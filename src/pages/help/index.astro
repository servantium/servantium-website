  </div>

  <!-- ═══════════════════════════════════════════════════
       SECTION 4: "What's new in Servantium" feature cards
       ═══════════════════════════════════════════════════ -->
  <div class="not-prose mt-6 mb-4">
    <h2 id="whats-new" class="font-display text-xl font-semibold leading-tight tracking-tight text-[var(--color-ink)] mb-3 scroll-mt-24">
      What's new in Servantium
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3">

      {whatsNewItems.map((item, i) => {
        const cardGradients = [
          { from: '#059669', to: '#047857' },
          { from: '#2563EB', to: '#1D4ED8' },
          { from: '#0D9488', to: '#0F766E' },
          { from: '#D97706', to: '#B45309' },
          { from: '#E11D48', to: '#BE123C' },
          { from: '#7C3AED', to: '#6D28D9' },
          { from: '#10B981', to: '#059669' },
          { from: '#475569', to: '#334155' },
        ];
        const icons = [
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>`,
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>`,
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
          `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
        ];
        const gradient = cardGradients[i % cardGradients.length];
        const icon = icons[i % icons.length];

        return (
          <a href={item.href} class="group relative rounded-2xl overflow-hidden min-h-[160px] no-underline [text-decoration:none] transition-all duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col justify-end p-4 pb-3" style={`background: linear-gradient(145deg, ${gradient.from}, ${gradient.to});`}>
            {/* Decorative blob */}
            <div class="absolute top-[-20px] right-[-20px] w-[90px] h-[90px] rounded-full" style="background: rgba(255,255,255,0.12);" aria-hidden="true"></div>
            {/* Icon centered in upper half */}
            <span class="absolute top-5 right-4 opacity-50 [text-decoration:none]" style="color: #fff;" set:html={icon} />
            {/* Label and version at bottom */}
            <span class="block text-sm font-semibold leading-tight mb-1 [text-decoration:none]" style="color: #fff;">{item.label}</span>
            <span class="block text-[11px] font-medium [text-decoration:none]" style="color: rgba(255,255,255,0.7);">{item.version} &middot; {item.date || 'March 2026'}</span>
          </a>
        );
      })}

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       SECTION 5: Latest Updates timeline
       ═══════════════════════════════════════════════════ -->
  <div class="not-prose mt-8 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 id="latest-updates" class="font-display text-xl font-semibold leading-tight tracking-tight text-[var(--color-ink)] scroll-mt-24">
        Latest Updates
      </h2>
      <a href="/help/release-notes/" class="text-sm font-medium text-[var(--color-green)] no-underline [text-decoration:none] hover:underline transition-colors">
        View all updates &rarr;
      </a>
    </div>

    {/* Filter chips */}
    <div class="release-filter flex gap-1 mb-6 bg-[var(--color-mist-grey)] rounded-lg p-1 w-fit">
      <button class="release-filter-btn active" data-filter="all">All</button>
      <button class="release-filter-btn" data-filter="servantium-website">Website</button>
      <button class="release-filter-btn" data-filter="servantium">App</button>
    </div>

    {releaseNotes.length === 0 ? (
      <p class="text-sm text-[var(--color-ink-muted)] italic">No release notes yet.</p>
    ) : (
      <div class="relative pl-8">
        <!-- Timeline vertical line -->
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-[var(--color-pale-green)]" aria-hidden="true"></div>

        <div class="space-y-6">
          {releaseNotes.map((entry, i) => {
            const dateStr = entry.data.date
              ? new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
              : '';
            const dotColor = entry.data.repo === 'servantium-website' ? '#4C82A7' : 'var(--color-green)';

            return (
              <div class="relative timeline-entry" data-repo={entry.data.repo || ''} data-animate="fade-up" data-delay={String(i * 150)} style="opacity:0; transform:translateY(20px);">
                <!-- Timeline dot (green=servantium, blue=website) -->
                <div class="absolute -left-8 top-1 flex items-center justify-center">
                  <div class="size-3.5 rounded-full border-2 border-white" style={`background-color: ${i === 0 ? dotColor : (entry.data.repo === 'servantium-website' ? 'rgba(76,130,167,0.4)' : 'var(--color-pale-green)')};`} aria-hidden="true"></div>
                </div>

                <!-- Entry content -->
                <div class="pb-1">
                  {dateStr && (
                    <time class="text-xs font-medium text-[var(--color-ink-muted)] mb-1 block">{dateStr}</time>
                  )}
                  <a href={`/help/${entry.id}/`} class="group no-underline [text-decoration:none]" style="text-decoration:none;">
                    <h3 class="text-[15px] font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors mb-1 no-underline [text-decoration:none]" style="text-decoration:none;">
                      {entry.data.title}
                    </h3>
                    {entry.data.description && (
                      <p class="text-sm text-[var(--color-ink-muted)] line-clamp-2 mb-1.5 no-underline [text-decoration:none]" style="text-decoration:none;">
                        {entry.data.description}
                      </p>
                    )}
                    <span class="text-xs font-medium text-[var(--color-green)] no-underline [text-decoration:none]" style="text-decoration:none;">
                      Read more &rarr;
                    </span>
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>

  <!-- Filter chip styles -->
  <style>
    .release-filter-btn {
      font-size: 0.75rem;
      font-weight: 600;
      padding: 0.375rem 0.75rem;
      border-radius: 0.375rem;
      border: none;
      background: transparent;
      color: var(--color-ink-muted);
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .release-filter-btn:hover {
      color: var(--color-ink);
    }
    .release-filter-btn.active {
      background: white;
      color: var(--color-ink);
      box-shadow: 0 1px 2px rgba(0,0,0,0.06);
    }
  </style>

  <!-- Filter chip interaction -->
  <script>
    function initUpdateFilter() {
      const buttons = document.querySelectorAll('.release-filter .release-filter-btn');
      const entries = document.querySelectorAll('.timeline-entry[data-repo]');
      if (!buttons.length || !entries.length) return;

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = (btn as HTMLElement).dataset.filter || 'all';

          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          entries.forEach(entry => {
            const repo = (entry as HTMLElement).dataset.repo || '';
            if (filter === 'all' || repo === filter) {
              (entry as HTMLElement).style.display = '';
            } else {
              (entry as HTMLElement).style.display = 'none';
            }
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initUpdateFilter);
    } else {
      initUpdateFilter();
    }
    document.addEventListener('astro:page-load', initUpdateFilter);
  </script>

  <!-- Timeline scroll unfurl animation -->
  <script>
    function initTimelineAnimation() {
      const entries = document.querySelectorAll('[data-animate="fade-up"]');
      if (!entries.length) return;

      const observer = new IntersectionObserver(
        (items) => {
          items.forEach((item) => {
            if (item.isIntersecting) {
              const el = item.target as HTMLElement;
              const delay = parseInt(el.dataset.delay || '0', 10);
              setTimeout(() => {
                el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
              }, delay);
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
      );

      entries.forEach((entry) => observer.observe(entry));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTimelineAnimation);
    } else {
      initTimelineAnimation();
    }
    document.addEventListener('astro:page-load', initTimelineAnimation);
  </script>

</DocsLayout>
