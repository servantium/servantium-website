    <!-- Card 1 — Read the docs (green) -->
    <section class="flex min-h-[280px]">
      <div class="w-full relative text-white overflow-hidden rounded-3xl flex shadow-lg">
        <div class="w-full flex md:flex-col bg-gradient-to-br from-[#00A95E] to-[#023E25]">
