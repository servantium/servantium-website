            <span class="flex items-center justify-center w-10 h-10 rounded-xl mb-3 [text-decoration:none]" style={`color: ${style.iconColor}; background: white; box-shadow: 0 1px 3px ${style.iconColor}20;`} set:html={icon} />
            <span class="block text-[13px] font-semibold leading-tight mb-1.5 [text-decoration:none]" style={`color: ${style.color};`}>{item.label}</span>
            <span class="block text-[11px] font-medium [text-decoration:none]" style={`color: ${style.iconColor}; opacity: 0.7;`}>{item.version} &middot; {item.date || 'March 2026'}</span>
          </a>
        );
      })}

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       SECTION 5: Latest Updates timeline
       ═══════════════════════════════════════════════════ -->
  <div class="not-prose mt-2 mb-2">
    <div class="flex items-center justify-between mb-3">
      <h2 id="latest-updates" class="font-display text-[1.35rem] font-semibold leading-tight tracking-tight text-[var(--color-ink)] scroll-mt-24">
        Latest Updates
      </h2>
      <a href="/help/release-notes/" class="text-sm font-medium text-[var(--color-green)] no-underline [text-decoration:none] hover:underline transition-colors">
        View all updates &rarr;
      </a>
    </div>

    {releaseNotes.length === 0 ? (
      <p class="text-sm text-[var(--color-ink-muted)] italic">No release notes yet.</p>
    ) : (
      <div class="relative pl-8">
        <!-- Timeline vertical line -->
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-[var(--color-pale-green)]" aria-hidden="true"></div>

        <div class="space-y-8">
          {releaseNotes.map((entry, i) => {
            const dateStr = entry.data.date
              ? new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
              : '';
            const dotColor = entry.data.repo === 'servantium-website' ? '#4C82A7' : 'var(--color-green)';

            return (
              <div class="relative timeline-entry" data-animate="fade-up" data-delay={String(i * 150)} style="opacity:0; transform:translateY(20px);">
                <!-- Timeline dot (green=servantium, blue=website) -->
                <div class="absolute -left-8 top-1 flex items-center justify-center">
                  <div class="size-3.5 rounded-full border-2 border-white" style={`background-color: ${i === 0 ? dotColor : (entry.data.repo === 'servantium-website' ? 'rgba(76,130,167,0.4)' : 'var(--color-pale-green)')};`} aria-hidden="true"></div>
                </div>

                <!-- Entry content -->
                <div class="pb-1">
                  {dateStr && (
                    <time class="text-xs font-medium text-[var(--color-ink-muted)] mb-1 block">{dateStr}</time>
                  )}
                  <a href={`/help/${entry.id}/`} class="group no-underline [text-decoration:none]" style="text-decoration:none;">
                    <h3 class="text-[15px] font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-green)] transition-colors mb-1 no-underline [text-decoration:none]" style="text-decoration:none;">
                      {entry.data.title}
                    </h3>
                    {entry.data.description && (
                      <p class="text-sm text-[var(--color-ink-muted)] line-clamp-2 mb-1.5 no-underline [text-decoration:none]" style="text-decoration:none;">
                        {entry.data.description}
                      </p>
                    )}
                    <span class="text-xs font-medium text-[var(--color-green)] no-underline [text-decoration:none]" style="text-decoration:none;">
                      Read more &rarr;
                    </span>
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>

  <!-- Timeline scroll unfurl animation -->
  <script>
    function initTimelineAnimation() {
      const entries = document.querySelectorAll('[data-animate="fade-up"]');
      if (!entries.length) return;

      const observer = new IntersectionObserver(
        (items) => {
          items.forEach((item) => {
            if (item.isIntersecting) {
              const el = item.target as HTMLElement;
              const delay = parseInt(el.dataset.delay || '0', 10);
              setTimeout(() => {
                el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
              }, delay);
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
      );

      entries.forEach((entry) => observer.observe(entry));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTimelineAnimation);
    } else {
      initTimelineAnimation();
    }
    document.addEventListener('astro:page-load', initTimelineAnimation);
  </script>

</DocsLayout>
