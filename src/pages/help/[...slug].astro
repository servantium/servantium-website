---
import DocsLayout from '@/theme/grove/DocsLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');

  return docs.map((doc) => {
    const slug = doc.id === 'index' ? undefined : doc.id;
    return {
      params: { slug },
      props: { entry: doc },
    };
  });
}

const { entry } = Astro.props;

// Astro 6: use the top-level render() function from astro:content
const { Content, headings } = await render(entry);

const title = entry.data.title;
const description = entry.data.description || '';
const currentSlug = entry.id === 'index' ? 'getting-started' : entry.id;
---

<DocsLayout
  title={title}
  description={description}
  headings={headings}
  currentSlug={currentSlug}
>
  <Content />
</DocsLayout>
