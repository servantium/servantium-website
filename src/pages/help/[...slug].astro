---
import DocsLayout from '@/theme/grove/DocsLayout.astro';
import { getCollection, render } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';
import { docsNav } from '@/data/docs-nav';

export async function getStaticPaths() {
  const docs = filterByStatus(await getCollection('docs'));

  // Build a flat ordered list of all nav slugs for prev/next calculation
  const flatNavSlugs: { label: string; slug: string }[] = [];
  for (const section of docsNav) {
    if (section.items) {
      for (const item of section.items) {
        if (item.slug) {
          flatNavSlugs.push({ label: item.label, slug: item.slug });
        }
      }
    }
  }

  // Filter out index — handled by /help/index.astro
  return docs.filter((doc) => doc.id !== 'index').map((doc) => {
    const slug = doc.id;
    const currentSlug = doc.id;

    // Find prev/next in the flat nav order
    const currentIndex = flatNavSlugs.findIndex((item) => item.slug === currentSlug);
    const prev = currentIndex > 0 ? flatNavSlugs[currentIndex - 1] : null;
    const next = currentIndex >= 0 && currentIndex < flatNavSlugs.length - 1
      ? flatNavSlugs[currentIndex + 1]
      : null;

    return {
      params: { slug },
      props: { entry: doc, prev, next },
    };
  });
}

interface PaginationLink {
  label: string;
  slug: string;
}

const { entry, prev, next } = Astro.props as {
  entry: any;
  prev: PaginationLink | null;
  next: PaginationLink | null;
};

const { Content, headings } = await render(entry);

const title = entry.data.title;
const description = entry.data.description || '';
const currentSlug = entry.id === 'index' ? 'getting-started' : entry.id;
---

<DocsLayout
  title={title}
  description={description}
  headings={headings}
  currentSlug={currentSlug}
  prev={prev}
  next={next}
>
  <Content />
</DocsLayout>
