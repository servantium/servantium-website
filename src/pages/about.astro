---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import Astronaut from '@/theme/components/Astronaut.astro';

// Brandfetch Logo Link API
const bf = import.meta.env.BRAND_FETCH ? `?c=${import.meta.env.BRAND_FETCH}` : '';
const bfLogo = (domain: string) => `https://cdn.brandfetch.io/${domain}${bf}`;

const jsonLd = {
  "@type": "AboutPage",
  "mainEntity": {
    "@type": "Organization",
    "@id": "https://servantium.com/#organization",
    "name": "Servantium",
    "url": "https://servantium.com",
    "logo": { "@type": "ImageObject", "url": "https://servantium.com/logo.png" },
    "description": "The CPQ and engagement management platform built for professional services firms.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1111B S Governors Ave STE 48074",
      "addressLocality": "Dover",
      "addressRegion": "DE",
      "postalCode": "19904",
      "addressCountry": "US"
    },
    "email": "hello@servantium.com",
    "founder": [
      { "@type": "Person", "name": "Christopher Veale", "jobTitle": "Co-founder & CEO" },
      { "@type": "Person", "name": "Maxwell Friel", "jobTitle": "Co-founder & CTO" }
    ]
  }
};
---

<BaseLayout activePage="about">
  <SEO
    slot="head"
    title="About Servantium — The Founders & Our Mission"
    description="Servantium was founded to give services businesses the operational infrastructure they deserve. Meet the founders and learn why we're building the operating system for professional services."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="relative overflow-hidden pt-40 pb-20" style="background: linear-gradient(160deg, #F3FCF8 0%, #fff 40%, #E8FBF1 100%);">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #00C26D 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="container relative z-10">
      <div class="max-w-4xl mx-auto flex items-start gap-12">
        <div class="flex-1" data-animate="fade-up">
          <span class="inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-green)] mb-6">About Servantium</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-medium leading-[1.1] mb-6" style="font-family: var(--font-display);">
            We're building the infrastructure services businesses have always needed
          </h1>
          <p class="text-lg md:text-xl text-[var(--color-ink-muted)] leading-relaxed max-w-2xl">
            With 15+ years each in professional services leadership, we've lived every problem Servantium solves. We built this platform because services businesses deserve real infrastructure, not workarounds.
          </p>
        </div>
        <div class="hidden lg:block flex-shrink-0 mt-8" data-animate="fade-up" data-delay="200">
          <Astronaut size="lg" variant="searching" animate={true} />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ STORY ═══════════════════ -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-medium mb-12" style="font-family: var(--font-display);" data-animate="fade-up">The story behind Servantium</h2>

        <div class="story-prose" data-animate="fade-up" data-delay="100">
          <p>
            <strong>We've spent 15+ years each leading <span class="highlight-word">professional services</span> organizations,</strong> building delivery teams, running complex engagements, and implementing enterprise platforms across life sciences, legal tech, and regulated industries. We've held VP and Director-level roles where we owned the outcomes, managed global teams, and watched the same problems repeat at every company we touched.
          </p>
          <p>
            The pattern never changed. Talented consultants pricing engagements from memory. Scope changes communicated over Slack but never making it to the contract. Delivery teams rebuilding what someone else already built last quarter because nobody wrote it down in a place the next team could find.
          </p>
        </div>

        <blockquote class="pull-quote" data-animate="fade-up">
          <p>Product companies don't have this problem. Every feature, every price change, every customer interaction feeds back into the system. Services businesses deserve the same loop.</p>
        </blockquote>

        <div class="story-prose" data-animate="fade-up">
          <p>
            We'd seen the PSA tools. They track hours. They don't capture the reasoning behind a scope decision or the lessons from a delivery that went sideways. We'd seen the CRMs. They track deals. They lose the thread the moment a deal becomes a project.
          </p>
          <p>
            What nobody had built was the <span class="highlight-word">connective tissue</span>: a system that carries context from the first client conversation through scoping, pricing, delivery, and back into the next engagement. A system that actually remembers.
          </p>
        </div>

        <blockquote class="pull-quote" data-animate="fade-up">
          <p>We didn't want to build another tool that bends to chaos. We wanted to build one that creates structure.</p>
        </blockquote>

        <div class="story-prose" data-animate="fade-up">
          <p>
            The name comes from <em class="latin-word highlight-word">servare</em>, the Latin root meaning to serve, protect, and preserve, fused with <em class="latin-word highlight-word">-ium</em>, the suffix for foundational elements. Like titanium or platinum, Servantium is infrastructure: strong, enduring, and built to last.
          </p>
          <p>
            We're building an <span class="highlight-word">operating system</span> for services firms. Not a dashboard. Not a time tracker. A system that encodes how your firm works, so it can work better every time.
          </p>
        </div>

        <blockquote class="pull-quote" data-animate="fade-up">
          <p>Technology should amplify human expertise, not replace human judgment. Services are relationships. We're just giving them better memory.</p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ FOUNDERS ═══════════════════ -->
  <section class="py-20 md:py-28" style="background: var(--color-mist-grey, #F5F6F7);">
    <div class="container">
      <div class="text-center max-w-xl mx-auto mb-16" data-animate="fade-up">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-green)] mb-4">Leadership</span>
        <h2 class="text-3xl md:text-4xl font-medium mb-4" style="font-family: var(--font-display);">Meet the founders</h2>
        <p class="text-lg text-[var(--color-ink-muted)]">
          15+ years each in professional services leadership. One on the business side, one on the technology side.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Christopher -->
        <div data-animate="fade-up">
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="aspect-[4/3] bg-gradient-to-br from-[#023E25] to-[#037A47] overflow-hidden">
              <img src="/christopher-veale.png" alt="Christopher Veale" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6 md:p-8">
              <h3 class="text-xl font-medium mb-1" style="font-family: var(--font-display);">Christopher Veale</h3>
              <div class="text-sm font-medium text-[var(--color-green)] mb-4">Co-founder & CEO</div>
              <p class="text-[0.92rem] text-[var(--color-ink-muted)] leading-relaxed mb-3">
                Christopher is a services industry executive with 15+ years of experience building and scaling professional services organizations. He has led engagement delivery, customer success, and go-to-market operations across life sciences, legal technology, and enterprise SaaS, managing global teams and owning P&L responsibility at every stage.
              </p>
              <p class="text-[0.92rem] text-[var(--color-ink-muted)] leading-relaxed mb-5">
                His career has been defined by one question: how do you take what the best people in a firm know and turn it into a system the whole organization can use? Servantium is the answer he's been building toward for over a decade.
              </p>
              <!-- Links + logos -->
              <div class="flex items-center gap-4 flex-wrap">
                <a href="https://linkedin.com/in/christopher-veale" class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-green)] transition-colors" target="_blank" rel="noopener noreferrer">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
                <div class="flex items-center gap-3 ml-auto">
                  <img src={bfLogo('drexel.edu')} alt="Drexel" class="h-5 w-auto" loading="lazy" />
                  <img src={bfLogo('veeva.com')} alt="Veeva" class="h-5 w-auto" loading="lazy" />
                  <img src={bfLogo('tetrascience.com')} alt="TetraScience" class="h-5 w-auto" loading="lazy" />
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Maxwell -->
        <div data-animate="fade-up" data-delay="150">
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="aspect-[4/3] bg-gradient-to-br from-[#023E25] to-[#037A47] overflow-hidden">
              <img src="/maxwell-friel.png" alt="Maxwell Friel" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6 md:p-8">
              <h3 class="text-xl font-medium mb-1" style="font-family: var(--font-display);">Maxwell Friel</h3>
              <div class="text-sm font-medium text-[var(--color-green)] mb-4">Co-founder & CTO</div>
              <p class="text-[0.92rem] text-[var(--color-ink-muted)] leading-relaxed mb-3">
                Maxwell is a technology executive and platform architect with 15+ years of experience designing and delivering enterprise software in regulated industries. He has led platform architecture, built delivery organizations from scratch, and held VP-level roles spanning engineering and services, giving him a rare perspective that bridges both sides of the build-and-deliver equation.
              </p>
              <p class="text-[0.92rem] text-[var(--color-ink-muted)] leading-relaxed mb-5">
                He brings deep technical expertise in AI, Python, and cloud architecture alongside hands-on experience running the services teams that implement what engineering builds. Currently pursuing his M.S. in Artificial Intelligence at Drexel University, he's building the platform he wished he'd had at every previous company.
              </p>
              <!-- Links + logos -->
              <div class="flex items-center gap-4 flex-wrap">
                <a href="https://linkedin.com/in/maxwell-friel-2bb02b30" class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-green)] transition-colors" target="_blank" rel="noopener noreferrer">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn
                </a>
                <div class="flex items-center gap-3 ml-auto">
                  <img src={bfLogo('drexel.edu')} alt="Drexel" class="h-5 w-auto" loading="lazy" />
                  <img src={bfLogo('veeva.com')} alt="Veeva" class="h-5 w-auto" loading="lazy" />
                  <img src="/optin_inc_logo.jpeg" alt="Optin" class="h-5 w-auto" loading="lazy" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ VISION ═══════════════════ -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center" data-animate="fade-up">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-green)] mb-4">Our Vision</span>
        <p class="text-xl md:text-2xl text-[var(--color-ink)] leading-relaxed" style="font-family: var(--font-display);">
          Build the system that turns a services firm's knowledge into a lasting advantage. Help every team scope faster, price smarter, deliver better, and never lose what they've learned.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ VALUES ═══════════════════ -->
  <section class="py-20 md:py-28 overflow-hidden" style="background: var(--color-mist-grey, #F5F6F7);">
    <div class="container">
      <div class="text-center max-w-xl mx-auto mb-16" data-animate="fade-up">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-green)] mb-4">Our Values</span>
        <h2 class="text-3xl md:text-4xl font-medium mb-4" style="font-family: var(--font-display);">How we operate</h2>
        <p class="text-lg text-[var(--color-ink-muted)]">
          The principles that drive every decision we make.
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-0">
        <!-- Startup Speed -->
        <div class="value-pillar" data-animate="fade-up">
          <div class="value-number">01</div>
          <div class="value-divider"></div>
          <div class="value-icon-wrap">
            <svg viewBox="0 0 40 40" fill="none" class="w-10 h-10">
              <path d="M20 6L10 22h8l-2 12 12-16h-8l2-12z" fill="#00C26D" opacity="0.15" stroke="#00C26D" stroke-width="2" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="value-content">
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-display);">Startup Speed</h3>
            <p class="text-[var(--color-ink-muted)] leading-relaxed">Ship fast, iterate faster. We move at startup pace while delivering enterprise reliability. Every week matters. Every release should make the product meaningfully better than it was on Friday.</p>
          </div>
        </div>

        <!-- Customer First -->
        <div class="value-pillar" data-animate="fade-up" data-delay="150">
          <div class="value-number">02</div>
          <div class="value-divider"></div>
          <div class="value-icon-wrap">
            <svg viewBox="0 0 40 40" fill="none" class="w-10 h-10">
              <circle cx="20" cy="14" r="8" fill="#00C26D" opacity="0.15" stroke="#00C26D" stroke-width="2"/>
              <path d="M8 34c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="#00C26D" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="value-content">
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-display);">Customer First</h3>
            <p class="text-[var(--color-ink-muted)] leading-relaxed">Every feature we build solves a real problem for a real customer. No vanity features. No building because a competitor has it. We talk to customers constantly and let their workflows shape our roadmap.</p>
          </div>
        </div>

        <!-- Relentless Iteration -->
        <div class="value-pillar" data-animate="fade-up" data-delay="300">
          <div class="value-number">03</div>
          <div class="value-divider"></div>
          <div class="value-icon-wrap">
            <svg viewBox="0 0 40 40" fill="none" class="w-10 h-10">
              <!-- Stacked layers rising up -->
              <rect x="8" y="28" width="24" height="4" rx="2" fill="#00C26D" opacity="0.2"/>
              <rect x="8" y="20" width="24" height="4" rx="2" fill="#00C26D" opacity="0.4"/>
              <rect x="8" y="12" width="24" height="4" rx="2" fill="#00C26D" opacity="0.7"/>
              <path d="M20 4l4 6H16l4-6z" fill="#00C26D"/>
            </svg>
          </div>
          <div class="value-content">
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-display);">Relentless Iteration</h3>
            <p class="text-[var(--color-ink-muted)] leading-relaxed">We treat feedback as a gift. Every conversation shapes the product. We're never done improving. The version you see today is the worst version of Servantium you'll ever use.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════ CTA ═══════════════════ -->
  <section class="relative overflow-hidden py-20 md:py-24" style="background: linear-gradient(135deg, #00C26D 0%, #037A47 50%, #023E25 100%);">
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full opacity-10" style="background: radial-gradient(circle, white, transparent 70%);"></div>
    <div class="container relative z-10">
      <div class="max-w-2xl mx-auto text-center">
        <div class="hidden md:flex justify-center mb-8" data-animate="fade-up">
          <Astronaut size="lg" variant="captain" animate={true} />
        </div>
        <h2 class="text-3xl md:text-4xl font-medium text-white mb-4" style="font-family: var(--font-display);" data-animate="fade-up">Join our founding partners</h2>
        <p class="text-lg text-white/70 mb-8 max-w-lg mx-auto" data-animate="fade-up" data-delay="100">
          We're working with a small number of services firms who believe their operational knowledge deserves better than spreadsheets and tribal memory.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-animate="fade-up" data-delay="200">
          <button
            class="px-8 py-3.5 bg-white text-[var(--color-green)] font-semibold rounded-xl hover:bg-white/90 transition-colors text-sm cursor-pointer"
            data-cal-link="christopher-veale/servantium-introduction?duration=15"
            data-cal-namespace="servantium-introduction"
            data-cal-config='{"layout":"month_view"}'
          >Book a Demo</button>
          <button
            class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors text-sm cursor-pointer bg-transparent"
            onclick="openContactModal()"
          >Send a Message</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Modal (reuse pattern from platform page) -->
  <div class="contact-modal-overlay" id="contact-modal" aria-hidden="true">
    <div class="contact-modal">
      <button class="contact-modal-close" aria-label="Close" onclick="closeContactModal()">&times;</button>
      <h2 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 0.25rem;">Get in touch</h2>
      <p style="color: var(--color-ink-muted); margin-bottom: 1.5rem; font-size: 0.95rem;">Tell us about your firm and we'll reach out within 24 hours.</p>
      <form class="contact-modal-form" id="about-contact-form">
        <input type="text" name="name" placeholder="Your name" required>
        <input type="email" name="email" placeholder="Work email" required>
        <textarea name="message" placeholder="Tell us about your firm and what you're looking for..." rows="4"></textarea>
        <button type="submit" class="contact-submit-btn" id="about-contact-submit">Send Message</button>
      </form>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Scroll highlight words ── */
  .highlight-word {
    transition: color 0.4s ease, background-color 0.4s ease;
    border-radius: 2px;
    padding: 0 2px;
  }
  .highlight-word.highlighted {
    color: #00C26D;
  }

  /* ── Story prose ── */
  .story-prose {
    font-size: 1.1rem;
    line-height: 1.85;
    color: var(--color-ink-muted, #6b6b6b);
  }
  .story-prose p { margin-bottom: 1.5rem; }
  .story-prose strong { color: var(--color-ink, #0D0D0D); font-weight: 500; }

  /* ── Pull quotes ── */
  .pull-quote {
    position: relative;
    margin: 2.5rem 0;
    padding: 1rem 0 1rem 1.5rem;
    border-left: 4px solid var(--color-green, #00C26D);
    background: var(--color-mint-tint, #F3FCF8);
    border-radius: 0 8px 8px 0;
  }
  .pull-quote p {
    font-family: var(--font-body, 'Source Sans 3', sans-serif);
    font-size: 1.05rem;
    font-weight: 500;
    font-style: normal;
    line-height: 1.6;
    color: var(--color-ink, #0D0D0D);
    margin: 0;
  }

  /* ── Latin easter egg ── */
  .latin-word {
    font-style: italic;
    transition: text-shadow 0.3s ease, color 0.3s ease;
    cursor: default;
  }
  .latin-word:hover {
    color: var(--color-green, #00C26D);
    text-shadow: 0 0 12px rgba(0, 194, 109, 0.3);
  }

  /* ── Value pillars ── */
  .value-pillar {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6);
  }
  .value-pillar:last-child { border-bottom: none; }
  .value-number {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--color-green, #00C26D);
    opacity: 0.2;
    line-height: 1;
    flex-shrink: 0;
    width: 50px;
    padding-top: 6px;
  }
  .value-divider {
    width: 2px;
    align-self: stretch;
    background: var(--color-green, #00C26D);
    border-radius: 1px;
    flex-shrink: 0;
  }
  .value-icon-wrap {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 6px;
  }
  .value-content { flex: 1; padding-top: 4px; }

  /* ── Contact modal ── */
  .contact-modal-overlay { position: fixed; inset: 0; z-index: 10000; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
  .contact-modal-overlay.open { opacity: 1; pointer-events: auto; }
  .contact-modal { background: white; border-radius: 16px; padding: 2.5rem; width: 90%; max-width: 480px; position: relative; transform: translateY(20px) scale(0.97); transition: transform 0.3s ease; box-shadow: 0 25px 60px rgba(0,0,0,0.15); }
  .contact-modal-overlay.open .contact-modal { transform: translateY(0) scale(1); }
  .contact-modal-close { position: absolute; top: 16px; right: 20px; background: none; border: none; font-size: 1.5rem; color: #999; cursor: pointer; line-height: 1; }
  .contact-modal-close:hover { color: #333; }
  .contact-modal-form input, .contact-modal-form textarea { display: block; width: 100%; padding: 0.75rem 1rem; border: 1px solid #E1E3E6; border-radius: 8px; font-family: inherit; font-size: 0.95rem; margin-bottom: 0.75rem; transition: border-color 0.2s; box-sizing: border-box; }
  .contact-modal-form input:focus, .contact-modal-form textarea:focus { outline: none; border-color: #00C26D; }
  .contact-submit-btn { display: block; width: 100%; padding: 0.85rem; font-size: 1rem; font-weight: 600; font-family: inherit; color: #fff; background: #00C26D; border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s; }
  .contact-submit-btn:hover { background: #00A95E; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pull-quote { margin-left: 0; }
    .pull-quote p { font-size: 1.2rem; }
    .value-number { display: none; }
    .value-pillar { gap: 1rem; }
  }
</style>

<script is:inline>
  // Contact modal
  function openContactModal() {
    var modal = document.getElementById('contact-modal');
    if (modal) { modal.classList.add('open'); modal.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
  }
  function closeContactModal() {
    var modal = document.getElementById('contact-modal');
    if (modal) { modal.classList.remove('open'); modal.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }
  }
  document.getElementById('contact-modal')?.addEventListener('click', function(e) { if (e.target === this) closeContactModal(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeContactModal(); });

  // Contact form submit
  document.getElementById('about-contact-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('about-contact-submit');
    btn.disabled = true; btn.textContent = 'Sending...';
    try {
      var response = await fetch('https://contact.servantium.com/', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: this.querySelector('[name="name"]').value,
          email: this.querySelector('[name="email"]').value,
          message: this.querySelector('[name="message"]').value
        })
      });
      if (response.ok) { btn.textContent = 'Sent!'; btn.style.background = '#037A47'; setTimeout(closeContactModal, 2000); }
      else throw new Error();
    } catch(err) { btn.textContent = 'Error — try hello@servantium.com'; btn.style.background = '#FF5C70'; }
    finally { setTimeout(function() { btn.disabled = false; btn.textContent = 'Send Message'; btn.style.background = ''; }, 3000); }
  });

  // Scroll reveal
  document.addEventListener('DOMContentLoaded', function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var elements = document.querySelectorAll('[data-animate]');
    elements.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      var delay = parseInt(el.getAttribute('data-delay') || '0');
      el.style.transition = 'opacity 0.7s cubic-bezier(0.25,0.46,0.45,0.94) ' + delay + 'ms, transform 0.7s cubic-bezier(0.16,1,0.3,1) ' + delay + 'ms';
    });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) { entry.target.style.opacity = '1'; entry.target.style.transform = 'none'; observer.unobserve(entry.target); }
      });
    }, { threshold: 0.05, rootMargin: '0px 0px -20px 0px' });
    elements.forEach(function(el) {
      // Immediately reveal elements already in viewport
      var rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        var delay = parseInt(el.getAttribute('data-delay') || '0');
        setTimeout(function() { el.style.opacity = '1'; el.style.transform = 'none'; }, delay);
      } else {
        observer.observe(el);
      }
    });

    // Highlight words on scroll
    var highlightWords = document.querySelectorAll('.highlight-word');
    if (highlightWords.length) {
      var highlightObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('highlighted');
            highlightObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40% 0px' });
      highlightWords.forEach(function(el) { highlightObserver.observe(el); });
    }
  });
</script>
