---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import Astronaut from '@/theme/components/Astronaut.astro';

const jsonLd = {
  "@type": "AboutPage",
  "mainEntity": {
    "@type": "Organization",
    "@id": "https://servantium.com/#organization",
    "name": "Servantium",
    "url": "https://servantium.com",
    "logo": { "@type": "ImageObject", "url": "https://servantium.com/logo.png" },
    "description": "The CPQ and engagement management platform built for professional services firms.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1111B S Governors Ave STE 48074",
      "addressLocality": "Dover",
      "addressRegion": "DE",
      "postalCode": "19904",
      "addressCountry": "US"
    },
    "email": "hello@servantium.com",
    "founder": [
      { "@type": "Person", "name": "Christopher Veale", "jobTitle": "Co-founder & CEO" },
      { "@type": "Person", "name": "Maxwell Friel", "jobTitle": "Co-founder & CTO" }
    ]
  }
};
---

<BaseLayout activePage="about">
  <SEO
    slot="head"
    title="About Servantium — The Founders & Our Mission"
    description="Servantium was founded to give services businesses the operational infrastructure they deserve. Meet the founders and learn why we're building the operating system for professional services."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- ════════════════════════════════════════════════════
       HERO — gradient mesh + astronaut
       ════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden pt-40 pb-24" style="background: linear-gradient(160deg, #F3FCF8 0%, #fff 40%, #E8FBF1 100%);">
    <!-- Decorative mesh dots -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #00C26D 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="container relative z-10">
      <div class="max-w-4xl mx-auto flex items-start gap-12">
        <div class="flex-1" data-animate="fade-up">
          <span class="inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-green)] mb-6">About Servantium</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-medium leading-[1.1] mb-6" style="font-family: var(--font-display);">
            We're building the infrastructure services businesses have always needed
          </h1>
          <p class="text-lg md:text-xl text-[var(--color-ink-muted)] leading-relaxed max-w-2xl">
            Services businesses have real products — they just lack the systems to define, price, and deliver them consistently. We're here to change that.
          </p>
        </div>
        <div class="hidden lg:block flex-shrink-0 mt-8" data-animate="fade-up" data-delay="200">
          <Astronaut size="lg" variant="searching" animate={true} />
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════
       STORY — editorial layout with pull quotes
       ════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-medium mb-10" style="font-family: var(--font-display);" data-animate="fade-up">The story behind Servantium</h2>

        <div class="story-prose" data-animate="fade-up" data-delay="100">
          <p>
            <strong>We've spent 15 years each in the trenches of professional services</strong> — running consulting organizations, managing complex engagements, and building products in regulated industries. We've seen firsthand how talented teams struggle with the same problems over and over again.
          </p>
          <p>
            Pricing decisions made in isolation. Scope changes that never made it to the contract. Delivery teams reinventing the wheel because lessons from past projects lived only in people's heads. We saw how much margin leaked through the cracks of disconnected systems.
          </p>
        </div>

        <!-- Pull quote 1 -->
        <blockquote class="pull-quote" data-animate="fade-up">
          <p>Product companies don't have these problems. Services businesses deserve the same advantage.</p>
        </blockquote>

        <div class="story-prose" data-animate="fade-up">
          <p>
            Product companies have systems that remember everything: every price change, every customer interaction, every feature update feeds back into better decisions. We knew that same compounding loop was possible for services — if someone built the right foundation.
          </p>
          <p>
            So we built Servantium. Not another tool that bends to chaos, but a system that creates structure. A single source of truth for how services are sold, priced, contracted, and delivered.
          </p>
        </div>

        <!-- Pull quote 2 -->
        <blockquote class="pull-quote" data-animate="fade-up">
          <p>Structure before automation. AI only works when built on organized foundations.</p>
        </blockquote>

        <div class="story-prose" data-animate="fade-up">
          <p>
            The name fuses <em class="latin-word">servare</em>, the Latin root meaning to serve, protect, and preserve, with <em class="latin-word">-ium</em>, the suffix used for foundational elements. Like titanium or platinum, Servantium is meant to be essential infrastructure: strong, enduring, and built to last.
          </p>
          <p>
            An operating system that gives services businesses the operational discipline traditionally reserved for product companies — without sacrificing the flexibility and human expertise that makes services work.
          </p>
        </div>

        <!-- Pull quote 3 -->
        <blockquote class="pull-quote" data-animate="fade-up">
          <p>Technology should amplify human expertise, not replace human judgment.</p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════
       FOUNDERS — clean cards, green accent, human bios
       ════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28" style="background: var(--color-mist-grey, #F5F6F7);">
    <div class="container">
      <div class="text-center max-w-xl mx-auto mb-16" data-animate="fade-up">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-green)] mb-4">Leadership</span>
        <h2 class="text-3xl md:text-4xl font-medium mb-4" style="font-family: var(--font-display);">Meet the founders</h2>
        <p class="text-lg text-[var(--color-ink-muted)]">
          Two operators who've lived the problems Servantium solves.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Christopher -->
        <div class="founder-card group" data-animate="fade-up">
          <div class="h-1 bg-[var(--color-green)] rounded-t-2xl"></div>
          <div class="bg-white rounded-b-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="aspect-[4/3] bg-gradient-to-br from-[#023E25] to-[#037A47] flex items-center justify-center overflow-hidden">
              <img src="/christopher-veale.png" alt="Christopher Veale" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6 md:p-8">
              <h3 class="text-xl font-medium mb-1" style="font-family: var(--font-display);">Christopher Veale</h3>
              <div class="text-sm font-medium text-[var(--color-green)] mb-4">Co-founder & CEO</div>
              <p class="text-[0.92rem] text-[var(--color-ink-muted)] leading-relaxed mb-4">
                15 years building and scaling professional services organizations. Specializes in the intersection of product thinking and service delivery — turning operational chaos into repeatable systems.
              </p>
              <a href="https://linkedin.com/in/christopher-veale" class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-green)] transition-colors" target="_blank">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            </div>
          </div>
        </div>

        <!-- Maxwell -->
        <div class="founder-card group" data-animate="fade-up" data-delay="150">
          <div class="h-1 bg-[var(--color-slate-blue,#4C82A7)] rounded-t-2xl"></div>
          <div class="bg-white rounded-b-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="aspect-[4/3] bg-gradient-to-br from-[#023E25] to-[#037A47] flex items-center justify-center overflow-hidden">
              <img src="/maxwell-friel.png" alt="Maxwell Friel" class="w-full h-full object-cover object-top" />
            </div>
            <div class="p-6 md:p-8">
              <h3 class="text-xl font-medium mb-1" style="font-family: var(--font-display);">Maxwell Friel</h3>
              <div class="text-sm font-medium text-[var(--color-slate-blue,#4C82A7)] mb-4">Co-founder & CTO</div>
              <p class="text-[0.92rem] text-[var(--color-ink-muted)] leading-relaxed mb-4">
                15 years building enterprise software in regulated industries. Solution architect turned CTO — brings deep insight into what services organizations actually need and what they don't.
              </p>
              <a href="https://linkedin.com/in/maxwell-friel-2bb02b30" class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-green)] transition-colors" target="_blank">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════
       VALUES — horizontal pillars with custom SVG icons
       ════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white overflow-hidden">
    <div class="container">
      <div class="text-center max-w-xl mx-auto mb-16" data-animate="fade-up">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-green)] mb-4">Our Values</span>
        <h2 class="text-3xl md:text-4xl font-medium mb-4" style="font-family: var(--font-display);">How we operate</h2>
        <p class="text-lg text-[var(--color-ink-muted)]">
          The principles that guide everything we build.
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-0">
        <!-- Value 1: Clarity -->
        <div class="value-pillar" data-animate="fade-up">
          <div class="value-number">01</div>
          <div class="value-divider"></div>
          <div class="value-icon-wrap">
            <svg viewBox="0 0 48 48" fill="none" class="w-10 h-10">
              <!-- Clarity: clean geometric prism refracting light -->
              <path d="M24 4L40 38H8L24 4Z" stroke="#00C26D" stroke-width="2" fill="none"/>
              <line x1="24" y1="38" x2="24" y2="4" stroke="#00C26D" stroke-width="1" opacity="0.3"/>
              <line x1="16" y1="21" x2="32" y2="21" stroke="#00C26D" stroke-width="1" opacity="0.3"/>
              <circle cx="24" cy="22" r="3" fill="#00C26D" opacity="0.2"/>
              <circle cx="24" cy="22" r="1.5" fill="#00C26D"/>
              <!-- Light rays emerging -->
              <line x1="36" y1="30" x2="44" y2="26" stroke="#00C26D" stroke-width="1.5" opacity="0.5" stroke-linecap="round"/>
              <line x1="36" y1="34" x2="44" y2="34" stroke="#00C26D" stroke-width="1.5" opacity="0.4" stroke-linecap="round"/>
              <line x1="36" y1="38" x2="42" y2="42" stroke="#00C26D" stroke-width="1.5" opacity="0.3" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="value-content">
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-display);">Clarity</h3>
            <p class="text-[var(--color-ink-muted)] leading-relaxed">Your services are a product. Define them like one. Simple, understandable systems beat complex ones — if you can't explain it, you can't trust it.</p>
          </div>
        </div>

        <!-- Value 2: Compounding -->
        <div class="value-pillar" data-animate="fade-up" data-delay="150">
          <div class="value-number">02</div>
          <div class="value-divider"></div>
          <div class="value-icon-wrap">
            <svg viewBox="0 0 48 48" fill="none" class="w-10 h-10">
              <!-- Compounding: ascending spiral growth -->
              <path d="M8 40C8 40 12 32 18 28C24 24 20 18 26 14C32 10 28 6 36 4" stroke="#00C26D" stroke-width="2" fill="none" stroke-linecap="round"/>
              <circle cx="8" cy="40" r="2" fill="#00C26D" opacity="0.3"/>
              <circle cx="18" cy="28" r="2.5" fill="#00C26D" opacity="0.4"/>
              <circle cx="26" cy="14" r="3" fill="#00C26D" opacity="0.6"/>
              <circle cx="36" cy="4" r="3.5" fill="#00C26D"/>
              <!-- Growth arrows -->
              <path d="M34 8L36 4L40 6" stroke="#00C26D" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="value-content">
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-display);">Compounding</h3>
            <p class="text-[var(--color-ink-muted)] leading-relaxed">Every engagement should make the next one better. We build systems that remember, learn, and improve — turning institutional knowledge into a compounding advantage.</p>
          </div>
        </div>

        <!-- Value 3: Craft -->
        <div class="value-pillar" data-animate="fade-up" data-delay="300">
          <div class="value-number">03</div>
          <div class="value-divider"></div>
          <div class="value-icon-wrap">
            <svg viewBox="0 0 48 48" fill="none" class="w-10 h-10">
              <!-- Craft: precision compass/tool -->
              <circle cx="24" cy="24" r="18" stroke="#00C26D" stroke-width="1.5" fill="none" opacity="0.2"/>
              <circle cx="24" cy="24" r="12" stroke="#00C26D" stroke-width="1.5" fill="none" opacity="0.3"/>
              <circle cx="24" cy="24" r="2" fill="#00C26D"/>
              <!-- Compass needle -->
              <line x1="24" y1="24" x2="24" y2="8" stroke="#00C26D" stroke-width="2" stroke-linecap="round"/>
              <line x1="24" y1="24" x2="36" y2="32" stroke="#00C26D" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              <!-- Precision marks -->
              <line x1="24" y1="6" x2="24" y2="9" stroke="#00C26D" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="42" y1="24" x2="39" y2="24" stroke="#00C26D" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="24" y1="42" x2="24" y2="39" stroke="#00C26D" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="6" y1="24" x2="9" y2="24" stroke="#00C26D" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="value-content">
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-display);">Craft</h3>
            <p class="text-[var(--color-ink-muted)] leading-relaxed">Software should earn its place in your workflow. We sweat the details — day-one usability, thoughtful defaults, and interfaces that respect your time. No bloat, no vanity features.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════
       CTA — green gradient + Cal.com
       ════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden py-20 md:py-24" style="background: linear-gradient(135deg, #00C26D 0%, #037A47 50%, #023E25 100%);">
    <!-- Decorative orb -->
    <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full opacity-10" style="background: radial-gradient(circle, white, transparent 70%);"></div>

    <div class="container relative z-10">
      <div class="max-w-2xl mx-auto text-center">
        <div class="hidden md:flex justify-center mb-8" data-animate="fade-up">
          <Astronaut size="lg" variant="captain" animate={true} />
        </div>
        <h2 class="text-3xl md:text-4xl font-medium text-white mb-4" style="font-family: var(--font-display);" data-animate="fade-up">Join our founding partners</h2>
        <p class="text-lg text-white/70 mb-8 max-w-lg mx-auto" data-animate="fade-up" data-delay="100">
          We're working with a small number of services firms who believe their operational knowledge deserves better than spreadsheets and tribal memory.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-animate="fade-up" data-delay="200">
          <button
            class="px-8 py-3.5 bg-white text-[var(--color-green)] font-semibold rounded-xl hover:bg-white/90 transition-colors text-sm"
            data-cal-link="christopher-veale/servantium-introduction?duration=15"
            data-cal-namespace="servantium-introduction"
            data-cal-config='{"layout":"month_view"}'
          >Book a Demo</button>
          <a href="mailto:hello@servantium.com" class="px-8 py-3.5 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors text-sm no-underline">
            hello@servantium.com
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Story prose ── */
  .story-prose {
    font-size: 1.1rem;
    line-height: 1.85;
    color: var(--color-ink-muted, #6b6b6b);
  }
  .story-prose p {
    margin-bottom: 1.5rem;
  }
  .story-prose strong {
    color: var(--color-ink, #0D0D0D);
    font-weight: 500;
  }

  /* ── Pull quotes — editorial accent ── */
  .pull-quote {
    position: relative;
    margin: 3rem 0 3rem -2rem;
    padding: 0 0 0 2rem;
    border-left: 3px solid var(--color-green, #00C26D);
  }
  .pull-quote p {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 1.5rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.4;
    color: var(--color-ink, #0D0D0D);
    margin: 0;
  }

  /* ── Latin easter egg ── */
  .latin-word {
    font-style: italic;
    transition: text-shadow 0.3s ease, color 0.3s ease;
    cursor: default;
  }
  .latin-word:hover {
    color: var(--color-green, #00C26D);
    text-shadow: 0 0 12px rgba(0, 194, 109, 0.3);
  }

  /* ── Value pillars ── */
  .value-pillar {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6);
  }
  .value-pillar:last-child {
    border-bottom: none;
  }
  .value-number {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--color-ink, #0D0D0D);
    opacity: 0.08;
    line-height: 1;
    flex-shrink: 0;
    width: 50px;
    padding-top: 2px;
  }
  .value-divider {
    width: 2px;
    align-self: stretch;
    background: var(--color-green, #00C26D);
    border-radius: 1px;
    flex-shrink: 0;
    opacity: 0.4;
  }
  .value-icon-wrap {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 2px;
  }
  .value-content {
    flex: 1;
    padding-top: 2px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .pull-quote {
      margin-left: 0;
    }
    .pull-quote p {
      font-size: 1.25rem;
    }
    .value-number {
      display: none;
    }
    .value-pillar {
      gap: 1rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // Scroll reveal
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var elements = document.querySelectorAll('[data-animate]');
    elements.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      var delay = parseInt(el.getAttribute('data-delay') || '0');
      el.style.transition = 'opacity 0.7s cubic-bezier(0.25,0.46,0.45,0.94) ' + delay + 'ms, transform 0.7s cubic-bezier(0.16,1,0.3,1) ' + delay + 'ms';
    });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'none';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    elements.forEach(function(el) { observer.observe(el); });
  });
</script>
