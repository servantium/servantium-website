---
import ResourceLayout from '@/layouts/ResourceLayout.astro';
import { getCollection, render } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';

export async function getStaticPaths() {
  const items = filterByStatus(await getCollection('customers', ({ data }) => data.published));
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { name, industry, logo, metrics, quote, quoteAuthor, quoteRole } = item.data;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/resources/' },
  { label: 'Customer Stories', href: '/resources/customers/' },
  { label: name },
];
---

<ResourceLayout
  title={name}
  description={quote || `How ${name} runs engagements on Servantium.`}
  badge={industry}
  badgeColor="#FF5C70"
  breadcrumbs={breadcrumbs}
  activePage="resources"
>
  <div slot="aside">
    {logo && <img src={logo} alt={`${name} logo`} class="customer-logo" />}

    {metrics && metrics.length > 0 && (
      <div class="metrics-row">
        {metrics.map((m: { label: string; value: string }) => (
          <div class="metric">
            <div class="metric-value">{m.value}</div>
            <div class="metric-label">{m.label}</div>
          </div>
        ))}
      </div>
    )}

    {quote && (
      <blockquote class="pull-quote">
        <p>"{quote}"</p>
        {(quoteAuthor || quoteRole) && (
          <footer>— {quoteAuthor}{quoteRole && `, ${quoteRole}`}</footer>
        )}
      </blockquote>
    )}
  </div>

  <Content />
</ResourceLayout>

<style>
  .customer-logo { max-height: 56px; width: auto; margin-bottom: 1.5rem; }
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .metric {
    padding: 1.25rem;
    background: var(--color-mist-grey);
    border-radius: 12px;
    text-align: center;
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-green);
  }
  .metric-label { font-size: 0.85rem; color: var(--color-ink-muted); margin-top: 0.25rem; }
  .pull-quote {
    border-left: 3px solid var(--color-green);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0 2rem;
    font-size: 1.15rem;
    color: var(--color-ink-light);
    font-style: italic;
    background: var(--color-mint-tint);
    border-radius: 0 12px 12px 0;
  }
  .pull-quote footer { font-size: 0.9rem; color: var(--color-ink-muted); margin-top: 0.5rem; font-style: normal; }
</style>
