---
import ResourceLayout from '@/layouts/ResourceLayout.astro';
import LeadMagnetForm from '@/components/LeadMagnetForm.astro';
import { getCollection, render } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';

export async function getStaticPaths() {
  const items = filterByStatus(await getCollection('resources', ({ data }) =>
    !data.draft && data.type !== 'calculator'
  ));
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { title, description, type, delivery, fileUrl, readingTime } = item.data;

const typeLabelMap: Record<string, string> = {
  template: 'Template',
  guide: 'Guide',
  playbook: 'Playbook',
  ebook: 'Ebook',
  checklist: 'Checklist',
};

// Index page a resource should breadcrumb back to
const indexMap: Record<string, { label: string; href: string }> = {
  template: { label: 'Templates', href: '/resources/templates/' },
  guide: { label: 'Guides & Playbooks', href: '/resources/guides/' },
  playbook: { label: 'Guides & Playbooks', href: '/resources/guides/' },
  ebook: { label: 'Guides & Playbooks', href: '/resources/guides/' },
  checklist: { label: 'Checklists', href: '/resources/checklists/' },
};

const parent = indexMap[type] || { label: 'Resources', href: '/resources/' };
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Resources', href: '/resources/' },
  { label: parent.label, href: parent.href },
  { label: title },
];
---

<ResourceLayout
  title={title}
  description={description}
  badge={typeLabelMap[type] || type}
  breadcrumbs={breadcrumbs}
  meta={readingTime}
  activePage="resources"
>
  {delivery === 'gated' && fileUrl && (
    <div slot="aside">
      <LeadMagnetForm
        resourceTitle={title}
        fileUrl={fileUrl}
        resourceId={item.id}
      />
    </div>
  )}

  <Content />
</ResourceLayout>
