---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import ResourceIcon from '@/chrome/ResourceIcons.astro';
import SearchModal from '@/components/SearchModal.astro';
import { getCollection } from 'astro:content';
import { filterByStatus } from '@/lib/content-filter';

// ── Data ────────────────────────────────────────────────────────────
const rawResources = filterByStatus((await getCollection('resources', ({ data }) => !data.draft)))
  .sort((a, b) => a.data.order - b.data.order);

const customers = filterByStatus((await getCollection('customers', ({ data }) => data.published)))
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

const blogPosts = filterByStatus((await getCollection('blog', ({ data }) => !data.draft)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const comparisons = filterByStatus((await getCollection('comparisons', ({ data }) => !data.draft)))
  .sort((a, b) => a.data.order - b.data.order);

// ── Unified card model — everything is a "tile" on the wall ────────
interface Tile {
  href: string;
  kind: 'calculator' | 'template' | 'guide' | 'playbook' | 'customer' | 'blog' | 'comparison';
  type: string;
  title: string;
  description: string;
  date?: string;
  featured?: boolean;
  readingTime?: string;
  category?: string;
  size?: 'hero' | 'wide' | 'normal';
  cover?: string;
}

const resourceTiles: Tile[] = rawResources.map(r => {
  const isCalc = r.data.type === 'calculator';
  return {
    href: isCalc
      ? (r.data.toolUrl || `/resources/calculators/${r.id}/`)
      : `/resources/templates/${r.id}/`,
    kind: r.data.type as Tile['kind'],
    type: r.data.type,
    title: r.data.title,
    description: r.data.description,
    date: r.data.date,
    featured: r.data.featured,
    readingTime: r.data.readingTime,
  };
});

const blogTiles: Tile[] = blogPosts.map(p => ({
  href: `/blog/${p.id}/`,
  kind: 'blog',
  type: 'article',
  title: p.data.title,
  description: p.data.description,
  date: p.data.date,
  category: p.data.category,
  readingTime: p.data.readingTime,
  cover: p.data.image,
}));

const customerTiles: Tile[] = customers.map(c => ({
  href: `/resources/customers/${c.id}/`,
  kind: 'customer',
  type: 'customer story',
  title: c.data.name,
  description: c.data.quote || `How ${c.data.name} runs engagements on Servantium.`,
  category: c.data.industry,
}));

const comparisonTiles: Tile[] = comparisons.map(c => ({
  href: `/compare/${c.id}/`,
  kind: 'comparison',
  type: c.data.kind === 'competitor' ? 'comparison' : 'category',
  title: c.data.title,
  description: c.data.tagline || c.data.description,
  date: c.data.date,
}));

// Featured row — 3-7 varying-sized cards, blog-style.
// Picks: first featured playbook/guide, then any featured resources,
// then the most recent blog post, then highest-signal comparisons.
const featuredSeeds: Tile[] = [];
const seen = new Set<string>();
const pushFeatured = (t?: Tile) => {
  if (!t || seen.has(t.href) || featuredSeeds.length >= 5) return;
  seen.add(t.href);
  featuredSeeds.push(t);
};
pushFeatured(resourceTiles.find(t => t.featured && (t.kind === 'playbook' || t.kind === 'guide')));
pushFeatured(resourceTiles.find(t => t.kind === 'playbook'));
resourceTiles.filter(t => t.featured).forEach(pushFeatured);
pushFeatured(blogTiles[0]);
pushFeatured(comparisonTiles[0]);
pushFeatured(resourceTiles.find(t => t.kind === 'calculator'));
pushFeatured(resourceTiles.find(t => t.kind === 'template'));

const featuredTiles = featuredSeeds;
const featuredHref = new Set(featuredTiles.map(t => t.href));

// Everything else in the wall
const wallTiles: Tile[] = [
  ...resourceTiles.filter(t => !featuredHref.has(t.href)),
  ...comparisonTiles.filter(t => !featuredHref.has(t.href)),
  ...customerTiles,
  ...blogTiles.filter(t => !featuredHref.has(t.href)),
];

// Filter chips for the toolbar
const filters = [
  { id: 'all', label: 'All' },
  { id: 'calculator', label: 'Calculators' },
  { id: 'template', label: 'Templates' },
  { id: 'guide,playbook', label: 'Guides & Playbooks' },
  { id: 'comparison', label: 'Comparisons' },
  { id: 'customer', label: 'Customer Stories' },
  { id: 'blog', label: 'Blog' },
];

// Icon per kind — single SVG glyph system (no emojis)
const kindMeta: Record<string, { icon: string; label: string; color: string; cover: string }> = {
  calculator:  { icon: 'calculator', label: 'Calculator',     color: '#FFB02E', cover: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&h=400&fit=crop' },
  template:    { icon: 'template',   label: 'Template',       color: '#4C82A7', cover: 'https://images.unsplash.com/photo-1586281380349-632531db7ed4?w=800&h=400&fit=crop' },
  guide:       { icon: 'guide',      label: 'Guide',          color: '#26A899', cover: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&h=400&fit=crop' },
  playbook:    { icon: 'playbook',   label: 'Playbook',       color: '#26A899', cover: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=400&fit=crop' },
  customer:    { icon: 'customer',   label: 'Customer story', color: '#FF5C70', cover: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=800&h=400&fit=crop' },
  blog:        { icon: 'blog',       label: 'Blog',           color: '#00C26D', cover: 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=800&h=400&fit=crop' },
  comparison:  { icon: 'comparison', label: 'Comparison',     color: '#8B5CF6', cover: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=400&fit=crop' },
  ebook:       { icon: 'ebook',      label: 'Ebook',          color: '#26A899', cover: 'https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?w=800&h=400&fit=crop' },
  checklist:   { icon: 'checklist',  label: 'Checklist',      color: '#00C26D', cover: 'https://images.unsplash.com/photo-1484480974693-6ca0a78fb36b?w=800&h=400&fit=crop' },
};
---

<BaseLayout activePage="resources">
  <SEO
    slot="head"
    title="Resources | Servantium"
    description="Templates, calculators, playbooks, customer stories, and comparisons for professional services teams. Free to use. Built from real engagement operations experience."
    ogType="website"
  />

  <!-- ══════════════════════════════════════════════════════════════
       HERO — big featured tile, Carta-style split card
       ══════════════════════════════════════════════════════════════ -->
  <section class="r-hero">
    <div class="r-hero-bg" aria-hidden="true">
      <div class="r-hero-blob r-hero-blob--1"></div>
      <div class="r-hero-blob r-hero-blob--2"></div>
      <div class="r-hero-grid-overlay"></div>
    </div>
    <div class="r-container r-hero-inner">
      <div class="r-hero-head">
        <div class="r-eyebrow r-eyebrow--light">
          <span class="r-eyebrow-dot"></span>
          The Resources Hub
        </div>
        <h1>Real tools for services teams.</h1>
        <p class="r-lede">
          Templates, calculators, playbooks, comparisons, and writing — built for teams that scope projects, price them, and deliver them. Free to use. No signup required.
        </p>

        <div class="r-hero-stats">
          <div class="r-hero-stat">
            <div class="r-hero-stat-num">{resourceTiles.filter(t => t.kind === 'template').length + resourceTiles.filter(t => t.kind === 'calculator').length}+</div>
            <div class="r-hero-stat-label">Templates &amp; tools</div>
          </div>
          <div class="r-hero-stat-divider"></div>
          <div class="r-hero-stat">
            <div class="r-hero-stat-num">{blogTiles.length}+</div>
            <div class="r-hero-stat-label">Strategy essays</div>
          </div>
          <div class="r-hero-stat-divider"></div>
          <div class="r-hero-stat">
            <div class="r-hero-stat-num">{comparisons.length + customers.length}</div>
            <div class="r-hero-stat-label">Comparisons &amp; stories</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       FILTER TOOLBAR — sticky, pill-style
       ══════════════════════════════════════════════════════════════ -->
  <div class="r-toolbar">
    <div class="r-container">
      <div class="r-filters" role="tablist" aria-label="Filter resources">
        {filters.map((f, i) => (
          <button
            type="button"
            class={`r-filter${i === 0 ? ' active' : ''}`}
            data-filter={f.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >{f.label}</button>
        ))}
      </div>
      <div class="r-toolbar-search">
        <SearchModal label="Search every resource" placeholder="Search templates, guides, comparisons, blog..." triggerVariant="full" />
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       FEATURED ROW — 3-5 varying-sized cards, blog-style mosaic
       ══════════════════════════════════════════════════════════════ -->
  {featuredTiles.length > 0 && (
    <section class="r-featured">
      <div class="r-container">
        <div class="r-featured-head">
          <h2>Featured</h2>
          <p>Our highest-signal picks right now.</p>
        </div>
        <div class={`r-featured-grid r-featured-grid--${featuredTiles.length}`}>
          {featuredTiles.map((t, i) => {
            const m = kindMeta[t.kind] || { icon: '•', label: t.type, color: '#6b6b6b', cover: '' };
            const cover = t.cover || m.cover;
            return (
              <a
                href={t.href}
                class={`r-feat r-feat--${i}`}
                style={`--tile-accent: ${m.color}; --tile-cover: url('${cover}');`}
              >
                <div class="r-feat-image" aria-hidden="true"></div>
                <div class="r-feat-overlay" aria-hidden="true"></div>
                <div class="r-feat-body">
                  <span class="r-feat-chip">
                    <ResourceIcon name={m.icon as any} size={14} />
                    {m.label}
                  </span>
                  <h3 class="r-feat-title">{t.title}</h3>
                  <p class="r-feat-desc">{t.description}</p>
                  <div class="r-feat-meta">
                    {t.category && <span>{t.category}</span>}
                    {t.readingTime && <span>{t.readingTime}</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════════════════════════
       CONTENT WALL — dense grid, mixed tile sizes
       ══════════════════════════════════════════════════════════════ -->
  <section class="r-wall">
    <div class="r-container">
      <div class="r-grid" id="resourceGrid">
        {wallTiles.map((t, i) => {
          const m = kindMeta[t.kind] || { icon: '•', label: t.type, color: '#6b6b6b', cover: '' };
          const cover = t.cover || m.cover;
          // Deterministic "artsy" variation — seeded by title hash so the same tile
          // always gets the same treatment build-to-build.
          const hash = Array.from(t.title).reduce((a, c) => (a * 31 + c.charCodeAt(0)) | 0, 7);
          const n = Math.abs(hash);
          // Size rhythm: 1/6 tall, 1/6 wide, rest normal. Blogs always normal for density.
          const tall = (t.kind !== 'blog') && (n % 11 === 0);
          const wide = (t.kind !== 'blog') && !tall && (n % 7 === 3);
          const multi = tall || wide;
          // Style rhythm: 60% image, 25% gradient, 15% solid accent — but ANY
          // tile bigger than one cell ALWAYS gets an image (visual anchors).
          const styleRoll = n % 20;
          const variant = multi ? 'image' : (styleRoll < 12 ? 'image' : styleRoll < 17 ? 'gradient' : 'solid');
          // Rotation: tiny jitter for playful feel (max ±1deg)
          const rot = ((n % 5) - 2) * 0.25;
          return (
            <a
              href={t.href}
              class={`r-tile r-tile--${variant}${wide ? ' r-tile--wide' : ''}${tall ? ' r-tile--tall' : ''}`}
              data-kind={t.kind}
              style={`--tile-accent: ${m.color}; --tile-cover: url('${cover}'); --tile-rot: ${rot}deg;`}
            >
              <div class="r-tile-image" aria-hidden="true"></div>
              <div class="r-tile-chip">
                <span class="r-tile-chip-icon"><ResourceIcon name={m.icon as any} size={14} /></span>
                {m.label}
              </div>
              <div class="r-tile-info">
                <h3 class="r-tile-title">{t.title}</h3>
                <p class="r-tile-desc">{t.description}</p>
                <div class="r-tile-meta">
                  {t.category && <span class="r-tile-category">{t.category}</span>}
                  {t.readingTime && <span>{t.readingTime}</span>}
                  {t.date && !t.readingTime && (
                    <span>{new Date(t.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <nav id="resourcePagination" class="r-pagination" aria-label="Resources pagination" role="navigation"></nav>

      <div class="r-empty" id="resourceEmpty" hidden>
        <p>No resources in this category yet. Try another filter, or <a href="/resources/">see everything</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function() {
    var grid = document.getElementById('resourceGrid');
    var empty = document.getElementById('resourceEmpty');
    var paginationNav = document.getElementById('resourcePagination');
    if (!grid) return;
    var buttons = document.querySelectorAll('.r-filter');
    var tiles = Array.prototype.slice.call(grid.querySelectorAll('.r-tile'));
    var featuredSection = document.querySelector('.r-featured');

    var currentFilter = 'all';
    var currentPage = 1;
    var TILES_PER_PAGE = 36;

    function getFilteredTiles() {
      return tiles.filter(function(tile) {
        var kind = tile.getAttribute('data-kind') || '';
        return currentFilter === 'all' || currentFilter.split(',').indexOf(kind) !== -1;
      });
    }

    function applyPagination() {
      var filtered = getFilteredTiles();
      var totalPages = Math.max(1, Math.ceil(filtered.length / TILES_PER_PAGE));
      if (currentPage > totalPages) currentPage = totalPages;

      var startIdx = (currentPage - 1) * TILES_PER_PAGE;
      var endIdx = startIdx + TILES_PER_PAGE;

      // Hide everything first
      tiles.forEach(function(tile) { tile.style.display = 'none'; });

      // Show only filtered tiles on the current page
      filtered.forEach(function(tile, i) {
        tile.style.display = (i >= startIdx && i < endIdx) ? '' : 'none';
      });

      if (empty) empty.hidden = filtered.length !== 0;

      renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
      if (!paginationNav) return;
      if (totalPages <= 1) { paginationNav.innerHTML = ''; return; }

      var html = '';

      // Previous
      html += '<button type="button" data-page="' + (currentPage - 1) + '" class="r-page-btn"' + (currentPage === 1 ? ' disabled' : '') + ' aria-label="Previous page">&lsaquo; Prev</button>';

      // Page numbers
      var pages = [];
      if (totalPages <= 7) {
        for (var i = 1; i <= totalPages; i++) pages.push(i);
      } else {
        pages.push(1);
        if (currentPage > 3) pages.push('...');
        var start = Math.max(2, currentPage - 1);
        var end = Math.min(totalPages - 1, currentPage + 1);
        for (var j = start; j <= end; j++) pages.push(j);
        if (currentPage < totalPages - 2) pages.push('...');
        pages.push(totalPages);
      }

      for (var k = 0; k < pages.length; k++) {
        var p = pages[k];
        if (p === '...') {
          html += '<span class="r-page-ellipsis">...</span>';
        } else {
          var isActive = p === currentPage;
          html += '<button type="button" data-page="' + p + '" class="r-page-btn' + (isActive ? ' r-page-btn--active' : '') + '"' + (isActive ? ' aria-current="page"' : '') + ' aria-label="Page ' + p + '">' + p + '</button>';
        }
      }

      // Next
      html += '<button type="button" data-page="' + (currentPage + 1) + '" class="r-page-btn"' + (currentPage === totalPages ? ' disabled' : '') + ' aria-label="Next page">Next &rsaquo;</button>';

      paginationNav.innerHTML = html;

      // Bind clicks
      var btns = paginationNav.querySelectorAll('button[data-page]');
      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var page = parseInt(btn.getAttribute('data-page') || '1', 10);
          if (page >= 1 && page <= totalPages) {
            currentPage = page;
            applyPagination();
            grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var filter = btn.getAttribute('data-filter') || 'all';
        currentFilter = filter;
        currentPage = 1;

        buttons.forEach(function(b) {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        // Hide featured mosaic when any filter other than "all" is active
        if (featuredSection) {
          featuredSection.hidden = filter !== 'all';
        }
        // Collapse artsy tall/wide variants into plain cells when filtering
        grid.classList.toggle('r-grid--flat', filter !== 'all');

        applyPagination();
      });
    });

    // Initial render with pagination
    applyPagination();
  })();
</script>

<style>
  /* ── Shared container ─────────────────────────────────────────── */
  .r-container {
    max-width: var(--content-width, 1180px);
    margin: 0 auto;
    padding: 0 var(--space-lg, 2.5rem);
  }

  /* ── Hero ─────────────────────────────────────────────────────── */
  .r-hero {
    position: relative;
    padding: 8rem 0 3rem;
    background: linear-gradient(135deg, #023E25 0%, #015c38 55%, #00C26D 100%);
    color: #ffffff;
    overflow: hidden;
    isolation: isolate;
  }
  .r-hero-inner { position: relative; z-index: 2; }
  .r-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .r-hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
  }
  .r-hero-blob--1 {
    width: 560px; height: 560px;
    top: -180px; right: -140px;
    background: radial-gradient(circle, #00C26D 0%, transparent 70%);
  }
  .r-hero-blob--2 {
    width: 480px; height: 480px;
    bottom: -200px; left: -120px;
    background: radial-gradient(circle, #26A899 0%, transparent 70%);
  }
  .r-hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
  }
  .r-hero-head { text-align: center; max-width: 820px; margin: 0 auto 2.5rem; }
  .r-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-green, #00C26D);
    margin-bottom: 1rem;
  }
  .r-eyebrow--light {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(6px);
    padding: 0.45rem 0.9rem;
    border-radius: 100px;
  }
  .r-eyebrow-dot {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #00C26D;
    box-shadow: 0 0 0 4px rgba(0, 194, 109, 0.22);
    animation: rHeroPulse 2s ease-in-out infinite;
  }
  @keyframes rHeroPulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(0, 194, 109, 0.22); }
    50% { box-shadow: 0 0 0 8px rgba(0, 194, 109, 0.08); }
  }
  .r-hero-head h1 {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
  }
  .r-lede {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 auto 2rem;
    max-width: 640px;
  }
  .r-hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 1.75rem;
    padding: 1rem 1.75rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    border-radius: 14px;
  }
  .r-hero-stat { text-align: center; }
  .r-hero-stat-num {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 0.35rem;
  }
  .r-hero-stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.7);
    white-space: nowrap;
  }
  .r-hero-stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255, 255, 255, 0.2);
  }
  @media (max-width: 640px) {
    .r-hero-stats { gap: 1rem; padding: 0.75rem 1rem; flex-wrap: wrap; justify-content: center; }
    .r-hero-stat-divider { display: none; }
  }
  .r-hero-card {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 0;
    background: var(--color-deep-forest, #023E25);
    color: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 30px 80px rgba(2, 62, 37, 0.2);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .r-hero-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 40px 100px rgba(2, 62, 37, 0.28);
  }
  .r-hero-card-text { padding: 3rem; display: flex; flex-direction: column; justify-content: center; }
  .r-hero-card-type {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-green, #00C26D);
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .r-hero-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
