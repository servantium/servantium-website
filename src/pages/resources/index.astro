---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import ResourceIcon from '@/components/ResourceIcons.astro';
import SearchModal from '@/components/SearchModal.astro';
import { getCollection } from 'astro:content';

// ── Data ────────────────────────────────────────────────────────────
const rawResources = (await getCollection('resources', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const customers = (await getCollection('customers', ({ data }) => data.published))
  .sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const comparisons = (await getCollection('comparisons', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

// ── Unified card model — everything is a "tile" on the wall ────────
interface Tile {
  href: string;
  kind: 'calculator' | 'template' | 'guide' | 'playbook' | 'customer' | 'blog' | 'comparison';
  type: string;
  title: string;
  description: string;
  date?: string;
  featured?: boolean;
  readingTime?: string;
  category?: string;
  size?: 'hero' | 'wide' | 'normal';
}

const resourceTiles: Tile[] = rawResources.map(r => {
  const isCalc = r.data.type === 'calculator';
  return {
    href: isCalc
      ? (r.data.toolUrl || `/resources/calculators/${r.id}/`)
      : `/resources/templates/${r.id}/`,
    kind: r.data.type as Tile['kind'],
    type: r.data.type,
    title: r.data.title,
    description: r.data.description,
    date: r.data.date,
    featured: r.data.featured,
    readingTime: r.data.readingTime,
  };
});

const blogTiles: Tile[] = blogPosts.map(p => ({
  href: `/blog/${p.id}/`,
  kind: 'blog',
  type: 'article',
  title: p.data.title,
  description: p.data.description,
  date: p.data.date,
  category: p.data.category,
  readingTime: p.data.readingTime,
}));

const customerTiles: Tile[] = customers.map(c => ({
  href: `/resources/customers/${c.id}/`,
  kind: 'customer',
  type: 'customer story',
  title: c.data.name,
  description: c.data.quote || `How ${c.data.name} runs engagements on Servantium.`,
  category: c.data.industry,
}));

const comparisonTiles: Tile[] = comparisons.map(c => ({
  href: `/compare/${c.id}/`,
  kind: 'comparison',
  type: c.data.kind === 'competitor' ? 'comparison' : 'category',
  title: c.data.title,
  description: c.data.tagline || c.data.description,
  date: c.data.date,
}));

// The hero featured tile (first featured resource, or first playbook)
const heroTile: Tile | undefined =
  resourceTiles.find(t => t.featured && (t.kind === 'playbook' || t.kind === 'guide')) ||
  resourceTiles.find(t => t.kind === 'playbook') ||
  resourceTiles[0];

// Everything else in the wall
const wallTiles: Tile[] = [
  ...resourceTiles.filter(t => t !== heroTile),
  ...comparisonTiles,
  ...customerTiles,
  ...blogTiles,
];

// Filter chips for the toolbar
const filters = [
  { id: 'all', label: 'All' },
  { id: 'calculator', label: 'Calculators' },
  { id: 'template', label: 'Templates' },
  { id: 'guide,playbook', label: 'Guides & Playbooks' },
  { id: 'comparison', label: 'Comparisons' },
  { id: 'customer', label: 'Customer Stories' },
  { id: 'blog', label: 'Blog' },
];

// Icon per kind — single SVG glyph system (no emojis)
const kindMeta: Record<string, { icon: string; label: string; color: string; cover: string }> = {
  calculator:  { icon: 'calculator', label: 'Calculator',     color: '#FFB02E', cover: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&h=400&fit=crop' },
  template:    { icon: 'template',   label: 'Template',       color: '#4C82A7', cover: 'https://images.unsplash.com/photo-1586281380349-632531db7ed4?w=800&h=400&fit=crop' },
  guide:       { icon: 'guide',      label: 'Guide',          color: '#26A899', cover: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=800&h=400&fit=crop' },
  playbook:    { icon: 'playbook',   label: 'Playbook',       color: '#26A899', cover: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=400&fit=crop' },
  customer:    { icon: 'customer',   label: 'Customer story', color: '#FF5C70', cover: 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=800&h=400&fit=crop' },
  blog:        { icon: 'blog',       label: 'Article',        color: '#00C26D', cover: 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=800&h=400&fit=crop' },
  comparison:  { icon: 'comparison', label: 'Comparison',     color: '#8B5CF6', cover: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=400&fit=crop' },
  ebook:       { icon: 'ebook',      label: 'Ebook',          color: '#26A899', cover: 'https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?w=800&h=400&fit=crop' },
  checklist:   { icon: 'checklist',  label: 'Checklist',      color: '#00C26D', cover: 'https://images.unsplash.com/photo-1484480974693-6ca0a78fb36b?w=800&h=400&fit=crop' },
};
---

<BaseLayout activePage="resources">
  <SEO
    slot="head"
    title="Resources | Servantium"
    description="Templates, calculators, playbooks, customer stories, comparisons, and blog posts for professional services firms. Free, practical, and built from real engagement operations experience."
    ogType="website"
  />

  <!-- ══════════════════════════════════════════════════════════════
       HERO — big featured tile, Carta-style split card
       ══════════════════════════════════════════════════════════════ -->
  <section class="r-hero">
    <div class="r-hero-bg" aria-hidden="true">
      <div class="r-hero-blob r-hero-blob--1"></div>
      <div class="r-hero-blob r-hero-blob--2"></div>
      <div class="r-hero-grid-overlay"></div>
    </div>
    <div class="r-container r-hero-inner">
      <div class="r-hero-head">
        <div class="r-eyebrow r-eyebrow--light">
          <span class="r-eyebrow-dot"></span>
          The Resources Hub
        </div>
        <h1>Real tools for real services firms.</h1>
        <p class="r-lede">
          Templates, pricing calculators, playbooks, customer stories, and op-eds.
          All in one place. Free. Practical. Built from the trenches.
        </p>

        <div class="r-hero-stats">
          <div class="r-hero-stat">
            <div class="r-hero-stat-num">{resourceTiles.filter(t => t.kind === 'template').length + resourceTiles.filter(t => t.kind === 'calculator').length}+</div>
            <div class="r-hero-stat-label">Templates &amp; tools</div>
          </div>
          <div class="r-hero-stat-divider"></div>
          <div class="r-hero-stat">
            <div class="r-hero-stat-num">{blogTiles.length}+</div>
            <div class="r-hero-stat-label">Strategy essays</div>
          </div>
          <div class="r-hero-stat-divider"></div>
          <div class="r-hero-stat">
            <div class="r-hero-stat-num">{comparisons.length + customers.length}</div>
            <div class="r-hero-stat-label">Comparisons &amp; stories</div>
          </div>
        </div>
      </div>

      <div class="r-hero-search">
        <SearchModal label="Search every resource" placeholder="Search templates, guides, comparisons, blog..." triggerVariant="full" />
      </div>

      {heroTile && (
        <a class="r-hero-card" href={heroTile.href}>
          <div class="r-hero-card-text">
            <div class="r-hero-card-type">
              <span class="r-hero-card-icon" aria-hidden="true">
                <ResourceIcon name={(kindMeta[heroTile.kind]?.icon || 'guide') as any} size={18} />
              </span>
              Featured · {kindMeta[heroTile.kind]?.label || heroTile.type}
            </div>
            <h2>{heroTile.title}</h2>
            <p>{heroTile.description}</p>
            {heroTile.readingTime && <span class="r-hero-card-meta">{heroTile.readingTime}</span>}
            <span class="r-hero-card-cta">Read the playbook →</span>
          </div>
          <div class="r-hero-card-visual" aria-hidden="true">
            {/* Abstract connected-nodes diagram — our own SVG, no emojis, no stock art */}
            <svg viewBox="0 0 340 280" xmlns="http://www.w3.org/2000/svg" class="r-hero-visual-svg">
              <defs>
                <linearGradient id="rheroGrad" x1="0" x2="1" y1="0" y2="1">
                  <stop offset="0" stop-color="#00C26D" stop-opacity="0.6"/>
                  <stop offset="1" stop-color="#00C26D" stop-opacity="0.05"/>
                </linearGradient>
              </defs>
              {/* Connecting lines */}
              <g stroke="rgba(255,255,255,0.25)" stroke-width="1.5" fill="none">
                <line x1="80" y1="70" x2="170" y2="140"/>
                <line x1="260" y1="70" x2="170" y2="140"/>
                <line x1="80" y1="210" x2="170" y2="140"/>
                <line x1="260" y1="210" x2="170" y2="140"/>
                <line x1="170" y1="40" x2="170" y2="140"/>
                <line x1="170" y1="240" x2="170" y2="140"/>
              </g>
              {/* Outer nodes */}
              <circle cx="80" cy="70" r="22" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <circle cx="260" cy="70" r="22" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <circle cx="80" cy="210" r="22" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <circle cx="260" cy="210" r="22" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <circle cx="170" cy="40" r="16" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <circle cx="170" cy="240" r="16" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              {/* Center node (larger, green accent) */}
              <circle cx="170" cy="140" r="38" fill="url(#rheroGrad)" stroke="#00C26D" stroke-width="2"/>
              <circle cx="170" cy="140" r="6" fill="#00C26D"/>
              {/* Subtle node glyphs */}
              <g fill="rgba(255,255,255,0.6)">
                <rect x="72" y="62" width="16" height="2" rx="1"/>
                <rect x="72" y="68" width="12" height="2" rx="1"/>
                <rect x="72" y="74" width="14" height="2" rx="1"/>
                <rect x="252" y="62" width="16" height="2" rx="1"/>
                <rect x="252" y="68" width="10" height="2" rx="1"/>
                <rect x="252" y="74" width="13" height="2" rx="1"/>
                <rect x="72" y="202" width="16" height="2" rx="1"/>
                <rect x="72" y="208" width="13" height="2" rx="1"/>
                <rect x="72" y="214" width="11" height="2" rx="1"/>
                <rect x="252" y="202" width="14" height="2" rx="1"/>
                <rect x="252" y="208" width="16" height="2" rx="1"/>
                <rect x="252" y="214" width="12" height="2" rx="1"/>
              </g>
            </svg>
          </div>
        </a>
      )}
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       FILTER TOOLBAR — sticky, pill-style
       ══════════════════════════════════════════════════════════════ -->
  <div class="r-toolbar">
    <div class="r-container">
      <div class="r-filters" role="tablist" aria-label="Filter resources">
        {filters.map((f, i) => (
          <button
            type="button"
            class={`r-filter${i === 0 ? ' active' : ''}`}
            data-filter={f.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >{f.label}</button>
        ))}
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       CONTENT WALL — dense grid, mixed tile sizes
       ══════════════════════════════════════════════════════════════ -->
  <section class="r-wall">
    <div class="r-container">
      <div class="r-grid" id="resourceGrid">
        {wallTiles.map((t, i) => {
          const m = kindMeta[t.kind] || { icon: '•', label: t.type, color: '#6b6b6b' };
          // Every 7th non-blog tile gets wide treatment for visual rhythm
          const wide = (i % 7 === 3 && t.kind !== 'blog');
          return (
            <a
              href={t.href}
              class={`r-tile${wide ? ' r-tile--wide' : ''}`}
              data-kind={t.kind}
              style={`--tile-accent: ${m.color}; --tile-cover: url('${m.cover}');`}
            >
              <div class="r-tile-image" aria-hidden="true"></div>
              <div class="r-tile-chip">
                <span class="r-tile-chip-icon"><ResourceIcon name={m.icon as any} size={14} /></span>
                {m.label}
              </div>
              <div class="r-tile-info">
                <h3 class="r-tile-title">{t.title}</h3>
                <p class="r-tile-desc">{t.description}</p>
                <div class="r-tile-meta">
                  {t.category && <span class="r-tile-category">{t.category}</span>}
                  {t.readingTime && <span>{t.readingTime}</span>}
                  {t.date && !t.readingTime && (
                    <span>{new Date(t.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div class="r-empty" id="resourceEmpty" hidden>
        <p>No resources in this category yet. Try another filter, or <a href="/resources/">see everything</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function() {
    var grid = document.getElementById('resourceGrid');
    var empty = document.getElementById('resourceEmpty');
    if (!grid) return;
    var buttons = document.querySelectorAll('.r-filter');
    var tiles = grid.querySelectorAll('.r-tile');

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var filter = btn.getAttribute('data-filter') || 'all';
        buttons.forEach(function(b) {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        var visible = 0;
        tiles.forEach(function(tile) {
          var kind = tile.getAttribute('data-kind') || '';
          var match = filter === 'all' || filter.split(',').indexOf(kind) !== -1;
          tile.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        if (empty) empty.hidden = visible !== 0;
      });
    });
  })();
</script>

<style>
  /* ── Shared container ─────────────────────────────────────────── */
  .r-container {
    max-width: var(--content-width, 1180px);
    margin: 0 auto;
    padding: 0 var(--space-lg, 2.5rem);
  }

  /* ── Hero ─────────────────────────────────────────────────────── */
  .r-hero {
    position: relative;
    padding: 8rem 0 3rem;
    background: linear-gradient(135deg, #023E25 0%, #015c38 55%, #00C26D 100%);
    color: #ffffff;
    overflow: hidden;
    isolation: isolate;
  }
  .r-hero-inner { position: relative; z-index: 2; }
  .r-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .r-hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
  }
  .r-hero-blob--1 {
    width: 560px; height: 560px;
    top: -180px; right: -140px;
    background: radial-gradient(circle, #00C26D 0%, transparent 70%);
  }
  .r-hero-blob--2 {
    width: 480px; height: 480px;
    bottom: -200px; left: -120px;
    background: radial-gradient(circle, #26A899 0%, transparent 70%);
  }
  .r-hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
  }
  .r-hero-head { text-align: center; max-width: 820px; margin: 0 auto 2.5rem; }
  .r-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-green, #00C26D);
    margin-bottom: 1rem;
  }
  .r-eyebrow--light {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(6px);
    padding: 0.45rem 0.9rem;
    border-radius: 100px;
  }
  .r-eyebrow-dot {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #00C26D;
    box-shadow: 0 0 0 4px rgba(0, 194, 109, 0.22);
    animation: rHeroPulse 2s ease-in-out infinite;
  }
  @keyframes rHeroPulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(0, 194, 109, 0.22); }
    50% { box-shadow: 0 0 0 8px rgba(0, 194, 109, 0.08); }
  }
  .r-hero-head h1 {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
  }
  .r-lede {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 auto 2rem;
    max-width: 640px;
  }
  .r-hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 1.75rem;
    padding: 1rem 1.75rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    border-radius: 14px;
  }
  .r-hero-stat { text-align: center; }
  .r-hero-stat-num {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 0.35rem;
  }
  .r-hero-stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.7);
    white-space: nowrap;
  }
  .r-hero-stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255, 255, 255, 0.2);
  }
  @media (max-width: 640px) {
    .r-hero-stats { gap: 1rem; padding: 0.75rem 1rem; flex-wrap: wrap; justify-content: center; }
    .r-hero-stat-divider { display: none; }
  }
  .r-hero-card {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 0;
    background: var(--color-deep-forest, #023E25);
    color: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 30px 80px rgba(2, 62, 37, 0.2);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .r-hero-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 40px 100px rgba(2, 62, 37, 0.28);
  }
  .r-hero-card-text { padding: 3rem; display: flex; flex-direction: column; justify-content: center; }
  .r-hero-card-type {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-green, #00C26D);
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .r-hero-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px; height: 22px;
    color: var(--color-green, #00C26D);
  }
  .r-hero-search { max-width: 560px; margin: 0 auto 3rem; }
  .r-hero-card h2 {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(1.6rem, 2.8vw, 2.25rem);
    font-weight: 500;
    line-height: 1.15;
    color: #ffffff;
    margin: 0 0 0.85rem;
  }
  .r-hero-card p {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    margin: 0 0 1.25rem;
    max-width: 42ch;
  }
  .r-hero-card-meta { font-size: 0.8rem; color: rgba(255, 255, 255, 0.55); margin-bottom: 0.75rem; }
  .r-hero-card-cta {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-green, #00C26D);
  }
  .r-hero-card-visual {
    background: linear-gradient(135deg, rgba(0, 194, 109, 0.25), rgba(0, 194, 109, 0.05));
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    position: relative;
  }
  .r-hero-visual-svg {
    width: 100%;
    max-width: 340px;
    height: auto;
    display: block;
    filter: drop-shadow(0 10px 40px rgba(0, 0, 0, 0.3));
  }
  @media (max-width: 820px) {
    .r-hero-card { grid-template-columns: 1fr; }
    .r-hero-card-text { padding: 2rem; }
    .r-hero-card-visual { min-height: 200px; padding: 2rem; }
  }

  /* ── Sticky filter toolbar ────────────────────────────────────── */
  .r-toolbar {
    position: sticky;
    top: 72px;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--color-cloud-grey, #E1E3E6);
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6);
    padding: 0.9rem 0;
    margin-top: 2rem;
  }
  .r-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .r-filter {
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1.5px solid var(--color-cloud-grey, #E1E3E6);
    border-radius: 100px;
    color: var(--color-ink-light, #3d3d3d);
    cursor: pointer;
