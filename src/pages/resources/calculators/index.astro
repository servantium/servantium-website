---
import ResourceIndexPage from '@/components/ResourceIndexPage.astro';
import { getCollection } from 'astro:content';
import { resourcesToTiles } from '@/lib/resourceTiles';

const items = (await getCollection('resources', ({ data }) => !data.draft && data.type === 'calculator'))
  .sort((a, b) => a.data.order - b.data.order);
const tiles = resourcesToTiles(items as any);
---

<ResourceIndexPage
  seoTitle="Pricing & Ops Calculators | Servantium Resources"
  seoDescription="Free interactive calculators for services firms: fixed-fee pricing, utilization, blended rate, and more. No signup to use."
  eyebrow="Interactive tools"
  h1="Calculators for services firms"
  lede="Built by operators who got tired of doing this math in spreadsheets. Free to use, no signup, no email gate."
  crumbLabel="Calculators"
  tiles={tiles}
  emptyMessage="No calculators published yet. more coming soon."
  searchId="rix-search-calculators"
/>
