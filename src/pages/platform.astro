<style>
  :root {
    --green-500: #00C26D;
    --green-600: #00A95E;
    --green-700: #009657;
    --green-800: #037A47;
    --green-900: #045F37;
    --green-950: #023E25;
    --green-100: #C8F5DE;
    --green-50: #E8FBF1;
    --green-25: #F3FCF8;
    --coral: #FF5C70;
    --slate-blue: #4C82A7;
