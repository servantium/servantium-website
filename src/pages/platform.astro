<script is:inline>
  // Contact Modal
  function openContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    var form = document.getElementById('contact-modal-form');
    var success = document.getElementById('contact-modal-success');
    if (form) form.style.display = '';
    if (success) success.style.display = 'none';
  }
  document.getElementById('contact-modal').addEventListener('click', function(e) {
    if (e.target === this) closeContactModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeContactModal();
  });
  document.getElementById('contact-modal-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('contact-modal-submit');
    var statusEl = document.getElementById('contact-modal-status');
    btn.disabled = true;
    btn.textContent = 'Sending...';
    if (statusEl) { statusEl.className = 'contact-modal-status'; statusEl.style.display = 'none'; }

    var formData = {
      name: this.querySelector('[name="name"]').value,
      email: this.querySelector('[name="email"]').value,
      message: this.querySelector('[name="message"]').value
    };

    try {
      var response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (response.ok) {
        this.style.display = 'none';
        document.getElementById('contact-modal-success').style.display = 'block';
        this.reset();
        setTimeout(closeContactModal, 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch(err) {
      if (statusEl) {
        statusEl.className = 'contact-modal-status error';
        statusEl.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        statusEl.style.display = 'block';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });

  // Scroll reveal for .reveal elements
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var reveals = document.querySelectorAll('.reveal');
    reveals.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.5s cubic-bezier(0.16,1,0.3,1)';
    });
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'none';
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      reveals.forEach(function(el) { observer.observe(el); });
    } else {
      reveals.forEach(function(el) { el.style.opacity = '1'; el.style.transform = 'none'; });
    }
  })();
</script>

<!-- Narrative scroll observer -->
<script is:inline>
  function initNarrative() {
    var mockups = document.querySelectorAll('.narrative-mockup');
    var texts = document.querySelectorAll('.narrative-text');
    var dots = document.querySelectorAll('.narrative-dot');
    var astroVariants = document.querySelectorAll('.astro-variant');
    if (!mockups.length) return;

    var stageColors = [
      'var(--color-green, #00C26D)',
      '#4C82A7',
      '#26A899',
      '#8B5CF6'
    ];

    var currentStage = 0;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var index = parseInt(entry.target.dataset.mockup);
          if (index !== currentStage) {
            // Hide current text, show new
            texts.forEach(function(t) { t.classList.add('hidden'); });
            if (texts[index]) texts[index].classList.remove('hidden');

            // Update dots - active and previous are lit
            dots.forEach(function(d, i) {
              if (i <= index) {
                d.style.background = stageColors[i];
                d.style.boxShadow = '0 0 8px rgba(0,194,109,0.5)';
              } else {
                d.style.background = 'var(--color-cloud-grey, #E1E3E6)';
                d.style.boxShadow = 'none';
              }
            });

            // Switch astronaut costume
            astroVariants.forEach(function(v) { v.classList.add('hidden'); });
            if (astroVariants[index]) astroVariants[index].classList.remove('hidden');

            currentStage = index;
          }
        }
      });
    }, { threshold: 0.5, rootMargin: '-20% 0px -20% 0px' });

    mockups.forEach(function(m) { observer.observe(m); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNarrative);
  } else {
    initNarrative();
  }
  document.addEventListener('astro:page-load', initNarrative);
</script>

<script is:inline>
  function initFeatureTabs() {
    // Tab switching
    function activateTab(tabName) {
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
        if (b.dataset.tab === tabName) {
          b.classList.add('active');
          b.setAttribute('aria-selected', 'true');
        }
      });
      document.querySelectorAll('.tab-panel').forEach(function(p) {
        p.style.display = 'none';
      });
      var panel = document.querySelector('[data-panel="' + tabName + '"]');
      if (panel) panel.style.display = 'block';
    }

    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        activateTab(btn.dataset.tab);
      });
    });

    // "Explore features" links from narrative and compact cards: smooth scroll + activate tab
    document.querySelectorAll('.narrative-link[data-tab], .compact-card[data-tab]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var tabName = this.dataset.tab;
        activateTab(tabName);
        var target = document.getElementById('features');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFeatureTabs);
  } else {
    initFeatureTabs();
  }
  document.addEventListener('astro:page-load', initFeatureTabs);
</script>
