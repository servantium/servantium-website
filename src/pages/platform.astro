  .mock-eng-insight { background: var(--neutral-100); border-radius: 6px; padding: 8px 10px; font-size: 9px; color: var(--slate); border-left: 3px solid var(--green-500); }

  /* Mockup 2: Estimate Table */
  .mock-est { font-size: 9px; }
