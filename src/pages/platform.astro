  .feature-table tbody tr:nth-child(even) {
    background: #F8FAFC;
  }
  .feature-table tbody tr:nth-child(odd) {
    background: white;
  }
  .feature-table tbody tr:not(:last-child) td {
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  /* CTA */
  .platform-cta { padding: 4rem 0; background: var(--green-950); text-align: center; }
  .platform-cta h2 { color: white; margin-bottom: 1rem; }
  .platform-cta > .container > p { font-size: 1.1rem; color: rgba(255,255,255,0.7); margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto; }
  .platform-cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .platform-cta .btn-secondary { border-color: rgba(255,255,255,0.2); color: white; }
  .platform-cta .btn-secondary:hover { border-color: var(--green-500); background: rgba(0, 194, 109, 0.1); }

  /* Contact Modal */
  .contact-modal-overlay { position: fixed; inset: 0; z-index: 10000; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
  .contact-modal-overlay.open { opacity: 1; pointer-events: auto; }
  .contact-modal { background: white; border-radius: 16px; padding: 2.5rem; width: 90%; max-width: 480px; position: relative; transform: translateY(20px) scale(0.97); transition: transform 0.3s ease; box-shadow: 0 25px 60px rgba(0,0,0,0.15); }
  .contact-modal-overlay.open .contact-modal { transform: translateY(0) scale(1); }
  .contact-modal-close { position: absolute; top: 16px; right: 20px; background: none; border: none; font-size: 1.5rem; color: #999; cursor: pointer; line-height: 1; }
  .contact-modal-close:hover { color: #333; }
  .contact-modal h2 { font-family: var(--font-heading, 'Playfair Display', serif); font-size: 1.5rem; margin-bottom: 0.25rem; }
  .contact-modal-form input, .contact-modal-form textarea { display: block; width: 100%; padding: 0.75rem 1rem; border: 1px solid #E1E3E6; border-radius: 8px; font-family: inherit; font-size: 0.95rem; margin-bottom: 0.75rem; transition: border-color 0.2s; }
  .contact-modal-form input:focus, .contact-modal-form textarea:focus { outline: none; border-color: #00C26D; }
  .contact-modal-form .btn { width: 100%; justify-content: center; padding: 0.85rem; font-size: 1rem; }
  .contact-modal-status { font-size: 0.85rem; margin-top: 0.75rem; padding: 0.5rem; border-radius: 6px; text-align: center; }
  .contact-modal-status.error { background: rgba(255,92,112,0.1); color: #cc3344; }
  .contact-modal-success { text-align: center; padding: 2rem 0; }
  .contact-modal-check { width: 56px; height: 56px; border-radius: 50%; background: rgba(0,194,109,0.1); color: #00C26D; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
  .contact-modal-check svg { width: 28px; height: 28px; stroke: #00C26D; }
  .contact-modal-success h3 { font-family: var(--font-heading, 'Playfair Display', serif); margin-bottom: 0.5rem; }
  .contact-modal-success p { color: #6B7280; }

  /* Responsive */
  @media (max-width: 768px) {
    .platform-hero { padding: 7rem 0 3.5rem; }
    .mini-illus { max-width: 100%; }
    .feature-table-wrap { border-radius: 8px; }
    .feature-table td:first-child { white-space: normal; }
    .platform-cta { padding: 3rem 0; }
    .platform-cta-buttons, .hero-buttons { flex-direction: column; align-items: center; }
  }
</style>

<script is:inline>
  // Contact Modal
  function openContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    var form = document.getElementById('contact-modal-form');
    var success = document.getElementById('contact-modal-success');
    if (form) form.style.display = '';
    if (success) success.style.display = 'none';
  }
  document.getElementById('contact-modal').addEventListener('click', function(e) {
    if (e.target === this) closeContactModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeContactModal();
  });
  document.getElementById('contact-modal-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('contact-modal-submit');
    var statusEl = document.getElementById('contact-modal-status');
    btn.disabled = true;
    btn.textContent = 'Sending...';
    if (statusEl) { statusEl.className = 'contact-modal-status'; statusEl.style.display = 'none'; }

    var formData = {
      name: this.querySelector('[name="name"]').value,
      email: this.querySelector('[name="email"]').value,
      message: this.querySelector('[name="message"]').value
    };

    try {
      var response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (response.ok) {
        this.style.display = 'none';
        document.getElementById('contact-modal-success').style.display = 'block';
        this.reset();
        setTimeout(closeContactModal, 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch(err) {
      if (statusEl) {
        statusEl.className = 'contact-modal-status error';
        statusEl.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        statusEl.style.display = 'block';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });

  // Scroll reveal for .reveal elements
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var reveals = document.querySelectorAll('.reveal');
    reveals.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.5s cubic-bezier(0.16,1,0.3,1)';
    });
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'none';
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      reveals.forEach(function(el) { observer.observe(el); });
    } else {
      reveals.forEach(function(el) { el.style.opacity = '1'; el.style.transform = 'none'; });
    }
  })();
</script>

<!-- Narrative panel scroll reveal -->
<script is:inline>
  function initNarrativeReveal() {
    var stages = document.querySelectorAll('.narrative-stage');
    if (!stages.length) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      stages.forEach(function(s) { s.classList.add('visible'); });
      return;
    }
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    stages.forEach(function(s) { observer.observe(s); });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNarrativeReveal);
  } else {
    initNarrativeReveal();
  }
  document.addEventListener('astro:page-load', initNarrativeReveal);
</script>

<script is:inline>
  function initFeatureTabs() {
    // Tab switching
    function activateTab(tabName) {
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
        if (b.dataset.tab === tabName) {
          b.classList.add('active');
          b.setAttribute('aria-selected', 'true');
        }
      });
      document.querySelectorAll('.tab-panel').forEach(function(p) {
        p.style.display = 'none';
      });
      var panel = document.querySelector('[data-panel="' + tabName + '"]');
      if (panel) panel.style.display = 'block';
    }

    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        activateTab(btn.dataset.tab);
      });
    });

    // "Explore features" links from narrative and compact cards: smooth scroll + activate tab
    document.querySelectorAll('.narrative-link[data-tab]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var tabName = this.dataset.tab;
        activateTab(tabName);
        var target = document.getElementById('features');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFeatureTabs);
  } else {
    initFeatureTabs();
  }
  document.addEventListener('astro:page-load', initFeatureTabs);
</script>
