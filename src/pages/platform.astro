---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import IntegrationWall from '@/theme/widgets/IntegrationWall.astro';
import Astronaut from '@/theme/components/Astronaut.astro';

const integrations = [
  { name: 'Salesforce', abbrev: 'SF', color: '#00A1E0', tier: 'live' as const },
  { name: 'Google Workspace', abbrev: 'G', color: '#4285F4', tier: 'live' as const },
  { name: 'CSV Import', abbrev: 'CSV', color: '#00C26D', tier: 'live' as const },
  { name: 'HubSpot', abbrev: 'HS', color: '#FF7A59', tier: 'planned' as const },
  { name: 'Slack', abbrev: 'SL', color: '#4A154B', tier: 'planned' as const },
  { name: 'Teams', abbrev: 'TM', color: '#6264A7', tier: 'planned' as const },
  { name: 'QuickBooks', abbrev: 'QB', color: '#2CA01C', tier: 'planned' as const },
  { name: 'Jira', abbrev: 'JR', color: '#0052CC', tier: 'planned' as const },
  { name: 'Zapier', abbrev: 'ZP', color: '#FF4A00', tier: 'planned' as const },
  { name: 'Xero', abbrev: 'XR', color: '#13B5EA', tier: 'planned' as const },
  { name: 'Dynamics', abbrev: 'DY', color: '#002050', tier: 'planned' as const },
  ...Array.from({ length: 40 }, (_, i) => ({ name: '', abbrev: '+', color: '#94a3b8', tier: 'placeholder' as const })),
];

const jsonLd = {
  "@type": "WebPage",
  "name": "Platform — Professional Services CPQ & Engagement Management",
  "description": "Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory.",
  "url": "https://servantium.com/platform",
  "isPartOf": {
    "@id": "https://servantium.com/#website"
  },
  "about": {
    "@id": "https://servantium.com/#software"
  },
  "publisher": {
    "@id": "https://servantium.com/#organization"
  }
};
---

<BaseLayout activePage="platform">
  <SEO
    slot="head"
    title="Platform — Professional Services CPQ & Engagement Management | Servantium"
    description="Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Section 1: Hero -->
  <section class="platform-hero">
    <div class="container">
      <span class="section-label">The Platform That Remembers</span>
      <h1>Every engagement makes your firm smarter.</h1>
      <p class="platform-hero-desc">Most platforms record what happened. Servantium learns from it. Scope, price, staff, and deliver with a system that compounds your knowledge into a permanent advantage.</p>
      <div class="hero-buttons">
        <button class="btn btn-primary btn-large" data-cal-link="christopher-veale/servantium-introduction?duration=15" data-cal-namespace="servantium-introduction" data-cal-config='{"layout":"month_view"}'>Book a Demo</button>
        <button class="btn btn-secondary btn-large" onclick="openContactModal()">Contact Us</button>
      </div>
    </div>
  </section>

  <!-- Section 2: Narrative Scroll -->
  <section class="narrative-section relative" style="min-height: 300vh;" id="narrative">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex gap-12">

        <!-- LEFT: Sticky text column (desktop) -->
        <div class="w-[40%] hidden lg:block">
          <div class="sticky top-24" style="height: calc(100vh - 8rem);">
            <!-- Progress dots -->
            <div class="absolute left-0 top-1/2 -translate-y-1/2 flex flex-col gap-6">
              <div class="narrative-dot w-2.5 h-2.5 rounded-full bg-[var(--color-green)] shadow-[0_0_8px_rgba(0,194,109,0.5)]" data-dot="0"></div>
              <div class="narrative-dot w-2.5 h-2.5 rounded-full bg-[var(--color-cloud-grey)]" data-dot="1"></div>
              <div class="narrative-dot w-2.5 h-2.5 rounded-full bg-[var(--color-cloud-grey)]" data-dot="2"></div>
              <div class="narrative-dot w-2.5 h-2.5 rounded-full bg-[var(--color-cloud-grey)]" data-dot="3"></div>
            </div>

            <!-- Astronaut -->
            <div class="absolute right-0 bottom-8 narrative-astronaut" data-astro-stage="0">
              <div class="astro-variant" data-astro-variant="0"><Astronaut size="md" variant="searching" /></div>
              <div class="astro-variant hidden" data-astro-variant="1"><Astronaut size="md" variant="floating" /></div>
              <div class="astro-variant hidden" data-astro-variant="2"><Astronaut size="md" variant="waving" /></div>
              <div class="astro-variant hidden" data-astro-variant="3"><Astronaut size="md" variant="peeking" /></div>
            </div>

            <!-- Text panels (only one visible at a time) -->
            <div class="pl-8 flex flex-col justify-center h-full">
              <!-- STAGE 0: Scope -->
              <div class="narrative-text" data-stage="0">
                <p class="text-[var(--color-ink-muted)] leading-relaxed mb-4 text-base italic">
                  Your consultant just landed a new client. She's spending the afternoon digging through Slack, email, and old proposals to piece together how you've handled similar work.
                </p>
                <h3 class="text-2xl md:text-3xl font-medium mb-3" style="font-family: var(--font-display); color: var(--color-ink); border-left: 3px solid var(--color-green); padding-left: 12px;">
                  Scope with confidence
                </h3>
                <p class="text-[var(--color-ink-light)] leading-relaxed mb-4">
                  She opens Similar Engagements and finds 4 comparable projects in seconds. Pricing, delivery outcomes, lessons learned — all there.
                </p>
                <div class="grid grid-cols-2 gap-2 mb-4">
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]">
                    <svg class="w-4 h-4 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Engagement workspace
                  </span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]">
                    <svg class="w-4 h-4 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    AI note parsing
                  </span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]">
                    <svg class="w-4 h-4 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Similar matching
                  </span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]">
                    <svg class="w-4 h-4 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Service catalog
                  </span>
                </div>
                <a href="#features" data-tab="scope" class="narrative-link text-sm font-semibold text-[var(--color-green)] no-underline hover:text-[var(--color-green-hover)]">
                  Explore features ↓
                </a>
              </div>

              <!-- STAGE 1: Price (initially hidden) -->
              <div class="narrative-text hidden" data-stage="1">
                <p class="text-[var(--color-ink-muted)] leading-relaxed mb-4 text-base italic">
                  Building a quote means opening three spreadsheets, guessing at margins, and hoping someone remembers what the last one actually cost to deliver.
                </p>
                <h3 class="text-2xl md:text-3xl font-medium mb-3" style="font-family: var(--font-display); color: var(--color-ink); border-left: 3px solid #4C82A7; padding-left: 12px;">
                  Price with precision
                </h3>
                <p class="text-[var(--color-ink-light)] leading-relaxed mb-4">
                  The quote builder pulls from your learning catalog. Real costs from real projects. AI generates a complete structure from your notes and history.
                </p>
                <div class="grid grid-cols-2 gap-2 mb-4">
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Grouped estimate builder</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Margin analysis</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>AI generation</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Learning catalog</span>
                </div>
                <a href="#features" data-tab="price" class="narrative-link text-sm font-semibold text-[#4C82A7] no-underline hover:opacity-80">Explore features ↓</a>
              </div>

              <!-- STAGE 2: Staff (initially hidden) -->
              <div class="narrative-text hidden" data-stage="2">
                <p class="text-[var(--color-ink-muted)] leading-relaxed mb-4 text-base italic">
                  You just won a big implementation. Now you're trying to figure out who's available without double-booking your best people across five active projects.
                </p>
                <h3 class="text-2xl md:text-3xl font-medium mb-3" style="font-family: var(--font-display); color: var(--color-ink); border-left: 3px solid #26A899; padding-left: 12px;">
                  Staff with clarity
                </h3>
                <p class="text-[var(--color-ink-light)] leading-relaxed mb-4">
                  The resource planner shows real-time capacity across every engagement. Assign the right people based on skills, availability, and track record.
                </p>
                <div class="grid grid-cols-2 gap-2 mb-4">
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Resource plans</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Utilization tracking</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Capacity forecasting</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Skill matching</span>
                </div>
                <a href="#features" data-tab="staff" class="narrative-link text-sm font-semibold text-[#26A899] no-underline hover:opacity-80">Explore features ↓</a>
              </div>

              <!-- STAGE 3: Learn (initially hidden) -->
              <div class="narrative-text hidden" data-stage="3">
                <p class="text-[var(--color-ink-muted)] leading-relaxed mb-4 text-base italic">
                  Your firm completes 200 engagements a year, but each one starts from scratch. When someone leaves, everything they know walks out with them.
                </p>
                <h3 class="text-2xl md:text-3xl font-medium mb-3" style="font-family: var(--font-display); color: var(--color-ink); border-left: 3px solid #8B5CF6; padding-left: 12px;">
                  Learn and improve
                </h3>
                <p class="text-[var(--color-ink-light)] leading-relaxed mb-4">
                  Every engagement feeds the institutional memory. Notes become embeddings. Quotes become catalog items. Outcomes become benchmarks. Your firm compounds knowledge automatically.
                </p>
                <div class="grid grid-cols-2 gap-2 mb-4">
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#8B5CF6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Institutional memory</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#8B5CF6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Note embeddings</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#8B5CF6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Learning catalog</span>
                  <span class="flex items-center gap-2 text-sm text-[var(--color-ink-muted)]"><svg class="w-4 h-4 text-[#8B5CF6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Vector search</span>
                </div>
                <a href="#features" data-tab="learn" class="narrative-link text-sm font-semibold text-[#8B5CF6] no-underline hover:opacity-80">Explore features ↓</a>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Scrolling mockup column -->
        <div class="w-full lg:w-[60%]">

          <!-- Mockup 0: Scope -->
          <div class="narrative-mockup min-h-[75vh] flex items-center" data-mockup="0">
            <!-- Mobile-only text card -->
            <div class="narrative-mobile-card lg:hidden mb-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-2.5 h-2.5 rounded-full bg-[var(--color-green)] shadow-[0_0_8px_rgba(0,194,109,0.5)]"></div>
                <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-ink-muted)]">Stage 1</span>
              </div>
              <p class="text-[var(--color-ink-muted)] leading-relaxed mb-3 text-sm italic">
                Your consultant just landed a new client. She's spending the afternoon digging through Slack, email, and old proposals to piece together how you've handled similar work.
              </p>
              <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display); color: var(--color-ink); border-left: 3px solid var(--color-green); padding-left: 10px;">
                Scope with confidence
              </h3>
              <p class="text-[var(--color-ink-light)] leading-relaxed mb-3 text-sm">
                She opens Similar Engagements and finds 4 comparable projects in seconds. Pricing, delivery outcomes, lessons learned — all there.
              </p>
              <div class="grid grid-cols-2 gap-1.5 mb-3">
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Engagement workspace</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>AI note parsing</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Similar matching</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[var(--color-green)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Service catalog</span>
              </div>
            </div>
            <!-- Mockup -->
            <div class="mini-illus w-full">
              <div class="mock-eng-card">
                <div class="mock-eng-header">
                  <div class="mock-eng-dot"></div>
                  <div class="mock-eng-title">KVWN, Initial Discovery</div>
                </div>
                <div class="mock-eng-keywords">
                  <span class="mock-eng-kw">Salesforce CRM</span>
                  <span class="mock-eng-kw">60 users</span>
                  <span class="mock-eng-kw">Q3 2026</span>
                </div>
                <div class="mock-eng-insight">
                  3 similar engagements found. Avg. 14 weeks, 92% estimate accuracy.
                </div>
              </div>
            </div>
          </div>

          <!-- Mockup 1: Price -->
          <div class="narrative-mockup min-h-[75vh] flex items-center" data-mockup="1">
            <div class="narrative-mobile-card lg:hidden mb-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-2.5 h-2.5 rounded-full bg-[#4C82A7] shadow-[0_0_8px_rgba(76,130,167,0.5)]"></div>
                <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-ink-muted)]">Stage 2</span>
              </div>
              <p class="text-[var(--color-ink-muted)] leading-relaxed mb-3 text-sm italic">
                Building a quote means opening three spreadsheets, guessing at margins, and hoping someone remembers what the last one actually cost to deliver.
              </p>
              <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display); color: var(--color-ink); border-left: 3px solid #4C82A7; padding-left: 10px;">
                Price with precision
              </h3>
              <p class="text-[var(--color-ink-light)] leading-relaxed mb-3 text-sm">
                The quote builder pulls from your learning catalog. Real costs from real projects. AI generates a complete structure from your notes and history.
              </p>
              <div class="grid grid-cols-2 gap-1.5 mb-3">
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Grouped estimate builder</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Margin analysis</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>AI generation</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#4C82A7] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Learning catalog</span>
              </div>
            </div>
            <div class="mini-illus w-full">
              <div class="mock-est">
                <div class="mock-est-header">
                  <span>Item Type</span>
                  <span>Item Name</span>
                  <span>Qty</span>
                  <span>Cost</span>
                  <span>Markup</span>
                  <span>Total</span>
                </div>
                <div class="mock-est-group">
                  <span>Discovery &amp; Requirements</span>
                  <span>$24,000</span>
                  <span>35%</span>
                  <span>$32,400</span>
                </div>
                <div class="mock-est-row">
                  <span><span class="mock-est-badge">Resource</span></span>
                  <span>Sr. Business Analyst</span>
                  <span>120h</span>
                  <span>$12,000</span>
                  <span>35%</span>
                  <span>$16,200</span>
                </div>
                <div class="mock-est-row">
                  <span><span class="mock-est-badge">Resource</span></span>
                  <span>Solutions Architect</span>
                  <span>80h</span>
                  <span>$12,000</span>
                  <span>35%</span>
                  <span>$16,200</span>
                </div>
                <div class="mock-est-total">$167,450</div>
              </div>
            </div>
          </div>

          <!-- Mockup 2: Staff -->
          <div class="narrative-mockup min-h-[75vh] flex items-center" data-mockup="2">
            <div class="narrative-mobile-card lg:hidden mb-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-2.5 h-2.5 rounded-full bg-[#26A899] shadow-[0_0_8px_rgba(38,168,153,0.5)]"></div>
                <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-ink-muted)]">Stage 3</span>
              </div>
              <p class="text-[var(--color-ink-muted)] leading-relaxed mb-3 text-sm italic">
                You just won a big implementation. Now you're trying to figure out who's available without double-booking your best people across five active projects.
              </p>
              <h3 class="text-xl font-medium mb-2" style="font-family: var(--font-display); color: var(--color-ink); border-left: 3px solid #26A899; padding-left: 10px;">
                Staff with clarity
              </h3>
              <p class="text-[var(--color-ink-light)] leading-relaxed mb-3 text-sm">
                The resource planner shows real-time capacity across every engagement. Assign the right people based on skills, availability, and track record.
              </p>
              <div class="grid grid-cols-2 gap-1.5 mb-3">
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Resource plans</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Utilization tracking</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Capacity forecasting</span>
                <span class="flex items-center gap-1.5 text-xs text-[var(--color-ink-muted)]"><svg class="w-3.5 h-3.5 text-[#26A899] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Skill matching</span>
              </div>
            </div>
            <div class="mini-illus w-full">
              <div class="mock-res">
                <div class="mock-res-project">KVWN, Salesforce CRM</div>
                <div class="mock-res-header">
                  <span>Resource</span>
                  <span>Apr</span>
                  <span>May</span>
                  <span>Jun</span>
                  <span>Jul</span>
                </div>
                <div class="mock-res-row">
                  <span><span class="mock-res-name">R. Burgundy</span><br><span class="mock-res-role">Lead</span></span>
                  <span><span class="mock-res-cell normal">72%</span></span>
                  <span><span class="mock-res-cell heavy">88%</span></span>
                  <span><span class="mock-res-cell normal">65%</span></span>
                  <span><span class="mock-res-cell normal">40%</span></span>
                </div>
                <div class="mock-res-row">
                  <span><span class="mock-res-name">B. Fantana</span><br><span class="mock-res-role">Architect</span></span>
                  <span><span class="mock-res-cell normal">60%</span></span>
                  <span><span class="mock-res-cell normal">75%</span></span>
