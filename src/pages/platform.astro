  }
  .narrative-stage.visible {
    opacity: 1;
    transform: none;
  }

  /* Comic panel animations */
  [data-animate] { opacity: 0; transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
  [data-animate="slide-left"] { transform: translateX(-40px); }
  [data-animate="slide-right"] { transform: translateX(40px); }
  [data-animate="fade-up"] { transform: translateY(30px); }
  [data-animate].is-visible { opacity: 1; transform: none; }

  /* Speech bubble tail on setup panels */
  .comic-setup {
    position: relative;
  }
  .comic-setup::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 48px;
    width: 20px;
    height: 20px;
    background: inherit;
    transform: rotate(45deg);
    border-bottom-right-radius: 4px;
    z-index: 1;
  }

  /* Mini Illustrations */
  .mini-illus {
    max-width: 480px;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    overflow: hidden;
    background: white;
    border: 1px solid var(--neutral-300);
    font-family: 'Source Sans 3', sans-serif;
    font-size: 10px;
    color: var(--neutral-900);
    margin: 0 auto;
  }

  /* Mockup 1: Engagement Card */
  .mock-eng-card { padding: 16px; }
  .mock-eng-header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .mock-eng-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green-500); }
