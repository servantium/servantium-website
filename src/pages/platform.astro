  .mock-est-group { display: grid; grid-template-columns: 1fr 0.6fr 0.6fr 0.7fr; padding: 7px 12px; background: rgba(76,130,167,0.06); font-weight: 600; font-size: 9px; color: var(--slate-blue); border-bottom: 1px solid var(--neutral-300); }
  .mock-est-row { display: grid; grid-template-columns: 1fr 1.2fr 0.5fr 0.6fr 0.6fr 0.7fr; padding: 6px 12px; border-bottom: 1px solid rgba(0,0,0,0.04); align-items: center; }
  .mock-est-badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 8px; font-weight: 600; background: rgba(76,130,167,0.1); color: var(--slate-blue); }
