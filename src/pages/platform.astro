---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import IntegrationWall from '@/theme/widgets/IntegrationWall.astro';

const integrations = [
  { name: 'Salesforce', abbrev: 'SF', color: '#00A1E0', tier: 'live' as const },
  { name: 'Google Workspace', abbrev: 'G', color: '#4285F4', tier: 'live' as const },
  { name: 'CSV Import', abbrev: 'CSV', color: '#00C26D', tier: 'live' as const },
  { name: 'HubSpot', abbrev: 'HS', color: '#FF7A59', tier: 'planned' as const },
  { name: 'Slack', abbrev: 'SL', color: '#4A154B', tier: 'planned' as const },
  { name: 'Teams', abbrev: 'TM', color: '#6264A7', tier: 'planned' as const },
  { name: 'QuickBooks', abbrev: 'QB', color: '#2CA01C', tier: 'planned' as const },
  { name: 'Jira', abbrev: 'JR', color: '#0052CC', tier: 'planned' as const },
  { name: 'Zapier', abbrev: 'ZP', color: '#FF4A00', tier: 'planned' as const },
  { name: 'Xero', abbrev: 'XR', color: '#13B5EA', tier: 'planned' as const },
  { name: 'Dynamics', abbrev: 'DY', color: '#002050', tier: 'planned' as const },
  ...Array.from({ length: 40 }, (_, i) => ({ name: '', abbrev: '+', color: '#94a3b8', tier: 'placeholder' as const })),
];

const jsonLd = {
  "@type": "WebPage",
  "name": "Platform — Professional Services CPQ & Engagement Management",
  "description": "Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory.",
  "url": "https://servantium.com/platform",
  "isPartOf": {
    "@id": "https://servantium.com/#website"
  },
  "about": {
    "@id": "https://servantium.com/#software"
  },
  "publisher": {
    "@id": "https://servantium.com/#organization"
  }
};
---

<BaseLayout activePage="platform">
  <SEO
    slot="head"
    title="Platform — Professional Services CPQ & Engagement Management | Servantium"
    description="Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Section 1: Hero -->
  <section class="platform-hero">
    <div class="container">
      <span class="section-label">The Platform That Remembers</span>
      <h1>Every engagement makes your firm smarter.</h1>
      <p class="platform-hero-desc">Most platforms record what happened. Servantium learns from it. Scope, price, staff, and deliver with a system that compounds your knowledge into a permanent advantage.</p>
      <div class="hero-buttons">
        <button class="btn btn-primary btn-large" data-cal-link="christopher-veale/servantium-introduction?duration=15" data-cal-namespace="servantium-introduction" data-cal-config='{"layout":"month_view"}'>Book a Demo</button>
        <button class="btn btn-secondary btn-large" onclick="openContactModal()">Contact Us</button>
      </div>
    </div>
  </section>

  <!-- Section 2: Four Pillars -->

  <!-- Pillar 1: Scope -->
  <section class="pillar-section tinted" id="scope" data-pillar="1" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-narrative">
      <div class="narrative-today">
        <span class="narrative-label">Today</span>
        <p>Your senior consultant just landed a new client. She's spending the afternoon digging through Slack, email, and old proposals to piece together how you've handled similar work.</p>
      </div>
      <div class="narrative-arrow">&rarr;</div>
      <div class="narrative-servantium">
        <span class="narrative-label">With Servantium</span>
        <p>She opens Similar Engagements and finds 4 comparable projects in seconds. Pricing, delivery outcomes, lessons learned — all there.</p>
      </div>
    </div>
    <div class="pillar-grid">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-green">Scope with confidence</h3>
        <p class="pillar-desc">Discovery that captures context, not just notes. Your service catalog gives you the building blocks for every engagement.</p>
        <ul class="pillar-bullets green">
          <li>Engagement workspace</li>
          <li>AI note parsing</li>
          <li>Service catalog library</li>
          <li>Similar engagement matching</li>
        </ul>
        <a class="pillar-guide-link" href="#features" data-tab="scope">Explore features &darr;</a>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-eng-card">
            <div class="mock-eng-header">
              <div class="mock-eng-dot"></div>
              <div class="mock-eng-title">KVWN, Initial Discovery</div>
            </div>
            <div class="mock-eng-keywords">
              <span class="mock-eng-kw">Salesforce CRM</span>
              <span class="mock-eng-kw">60 users</span>
              <span class="mock-eng-kw">Q3 2026</span>
            </div>
            <div class="mock-eng-insight">
              3 similar engagements found. Avg. 14 weeks, 92% estimate accuracy.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 2: Price -->
  <section class="pillar-section" id="price" data-pillar="2" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-narrative">
      <div class="narrative-today">
        <span class="narrative-label">Today</span>
        <p>Building a quote means opening three spreadsheets, guessing at margins, and hoping someone remembers what the last one actually cost to deliver.</p>
      </div>
      <div class="narrative-arrow">&rarr;</div>
      <div class="narrative-servantium">
        <span class="narrative-label">With Servantium</span>
        <p>The quote builder pulls from your learning catalog. Real costs from real projects. AI generates a complete structure from your notes and history.</p>
      </div>
    </div>
    <div class="pillar-grid reversed">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-blue">Price with precision</h3>
        <p class="pillar-desc">Build estimates informed by every project you have ever delivered. Grouped line items, role-based pricing, automatic margin calculations.</p>
        <ul class="pillar-bullets blue">
          <li>Grouped estimate builder</li>
          <li>Role &amp; rate management</li>
          <li>Margin analysis</li>
          <li>One-click proposal generation</li>
        </ul>
        <a class="pillar-guide-link" href="#features" data-tab="price">Explore features &darr;</a>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-est">
            <div class="mock-est-header">
              <span>Item Type</span>
              <span>Item Name</span>
              <span>Qty</span>
              <span>Cost</span>
              <span>Markup</span>
              <span>Total</span>
            </div>
            <div class="mock-est-group">
              <span>Discovery &amp; Requirements</span>
              <span>$24,000</span>
              <span>35%</span>
              <span>$32,400</span>
            </div>
            <div class="mock-est-row">
              <span><span class="mock-est-badge">Resource</span></span>
              <span>Sr. Business Analyst</span>
              <span>120h</span>
              <span>$12,000</span>
              <span>35%</span>
              <span>$16,200</span>
            </div>
            <div class="mock-est-row">
              <span><span class="mock-est-badge">Resource</span></span>
              <span>Solutions Architect</span>
              <span>80h</span>
              <span>$12,000</span>
              <span>35%</span>
              <span>$16,200</span>
            </div>
            <div class="mock-est-total">$167,450</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 3: Staff -->
  <section class="pillar-section tinted" id="staff" data-pillar="3" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-narrative">
      <div class="narrative-today">
        <span class="narrative-label">Today</span>
        <p>You just won a big implementation. Now you're trying to figure out who's available without accidentally double-booking your best people across five active projects.</p>
      </div>
      <div class="narrative-arrow">&rarr;</div>
      <div class="narrative-servantium">
        <span class="narrative-label">With Servantium</span>
        <p>The resource planner shows real-time capacity across every engagement. Assign the right people based on skills, availability, and track record.</p>
      </div>
    </div>
    <div class="pillar-grid">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-teal">Staff with clarity</h3>
        <p class="pillar-desc">See who is available, who is overloaded, and who is perfect for the job. Across every active engagement.</p>
        <ul class="pillar-bullets teal">
          <li>Cross-engagement visibility</li>
          <li>Utilization tracking</li>
          <li>Skill-based matching</li>
          <li>Capacity forecasting</li>
        </ul>
        <a class="pillar-guide-link" href="#features" data-tab="staff">Explore features &darr;</a>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-res">
            <div class="mock-res-project">KVWN, Salesforce CRM</div>
            <div class="mock-res-header">
              <span>Resource</span>
              <span>Apr</span>
              <span>May</span>
              <span>Jun</span>
              <span>Jul</span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">R. Burgundy</span><br><span class="mock-res-role">Lead</span></span>
              <span><span class="mock-res-cell normal">72%</span></span>
              <span><span class="mock-res-cell heavy">88%</span></span>
              <span><span class="mock-res-cell normal">65%</span></span>
              <span><span class="mock-res-cell normal">40%</span></span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">B. Fantana</span><br><span class="mock-res-role">Architect</span></span>
              <span><span class="mock-res-cell normal">60%</span></span>
              <span><span class="mock-res-cell normal">75%</span></span>
              <span><span class="mock-res-cell heavy">90%</span></span>
              <span><span class="mock-res-cell over">105%</span></span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">B. Tamland</span><br><span class="mock-res-role">Developer</span></span>
              <span><span class="mock-res-cell normal">50%</span></span>
              <span><span class="mock-res-cell normal">70%</span></span>
              <span><span class="mock-res-cell heavy">85%</span></span>
              <span><span class="mock-res-cell normal">75%</span></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 4: Learn -->
  <section class="pillar-section" id="learn" data-pillar="4" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-narrative">
      <div class="narrative-today">
        <span class="narrative-label">Today</span>
        <p>Your firm completes 200 engagements a year, but each one starts from scratch. When someone leaves, everything they know walks out with them.</p>
      </div>
      <div class="narrative-arrow">&rarr;</div>
      <div class="narrative-servantium">
        <span class="narrative-label">With Servantium</span>
        <p>Every engagement feeds the institutional memory. Notes become embeddings. Quotes become catalog items. Outcomes become benchmarks. Your firm compounds knowledge automatically.</p>
      </div>
    </div>
    <div class="pillar-grid reversed">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-amber">Learn from everything</h3>
        <p class="pillar-desc">This is what competitors cannot copy. Every delivered engagement feeds back into how you scope, price, and staff the next one.</p>
        <ul class="pillar-bullets amber">
          <li>Delivery variance analysis</li>
          <li>Estimate accuracy tracking</li>
          <li>Pattern detection</li>
          <li>Continuous improvement engine</li>
        </ul>
        <a class="pillar-guide-link" href="#features" data-tab="learn">Explore features &darr;</a>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-learn">
            <div class="mock-learn-title">KVWN, Post-Delivery Analysis</div>
            <div class="mock-learn-metrics">
              <span class="mock-learn-pill green">94% estimate accuracy</span>
              <span class="mock-learn-pill green">8% under budget</span>
              <span class="mock-learn-pill blue">17 weeks actual vs planned</span>
            </div>
            <div class="mock-learn-patterns">
              <div class="mock-learn-patterns-title">Patterns Detected</div>
              <div class="mock-learn-patterns-text">Discovery phases for CRM implementations consistently run 15% under estimate when led by senior analysts. Recommend adjusting catalog effort drivers.</div>
            </div>
            <div class="mock-learn-footer">Feeding insights into <span>Service Catalog</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Integrations — Matrix Wall -->
  <IntegrationWall
    title="Your data flows where it needs to"
    subtitle="Servantium connects with the tools your team already uses. Our REST API and MCP-ready architecture means new integrations take days, not months."
    integrations={integrations}
    capabilities={['Bi-directional sync', 'REST API ready', 'MCP-compatible']}
  />

  <!-- Section 4: Feature Table -->
  <section id="features" class="py-12 bg-white">
    <div class="container">
      <h2 class="text-center mb-8 font-display" style="font-family: var(--font-heading, 'Playfair Display', serif);">Everything under the hood</h2>

      <!-- Tab buttons -->
      <div class="flex justify-center gap-2 mb-8 flex-wrap" role="tablist">
        <button class="tab-btn active" data-tab="scope" role="tab" aria-selected="true">Scope</button>
        <button class="tab-btn" data-tab="price" role="tab" aria-selected="false">Price</button>
        <button class="tab-btn" data-tab="staff" role="tab" aria-selected="false">Staff</button>
        <button class="tab-btn" data-tab="learn" role="tab" aria-selected="false">Learn</button>
      </div>

      <!-- Tab panels -->
      <div class="feature-table-wrap">
        <div class="tab-panel" data-panel="scope">
          <table class="feature-table">
            <thead><tr><th>Feature</th><th>What it does</th></tr></thead>
            <tbody>
              <tr><td>Engagement Workspace</td><td>6-tab workspace: Info, Similars, Notes, Quotes, Documents, Resource Plans</td></tr>
              <tr><td>Similar Matching</td><td>Vector search finds semantically similar past engagements in seconds</td></tr>
              <tr><td>Service Catalog</td><td>Auto-updating catalog of your services, costs, and markups</td></tr>
              <tr><td>AI Context Extraction</td><td>AI reads your notes and populates engagement template fields</td></tr>
              <tr><td>Templates</td><td>Configurable engagement types with custom fields (text, chips, sliders, nested)</td></tr>
              <tr><td>Tags</td><td>Color-coded categories for cross-cutting organization</td></tr>
            </tbody>
          </table>
        </div>

        <div class="tab-panel" data-panel="price" style="display:none;">
          <table class="feature-table">
            <thead><tr><th>Feature</th><th>What it does</th></tr></thead>
            <tbody>
              <tr><td>Quote Builder</td><td>Grouped sections with line items, quantities, costs, and markup percentages</td></tr>
              <tr><td>AI Quote Generation</td><td>Generates complete quote structures from notes and engagement history</td></tr>
              <tr><td>Margin Calculator</td><td>Real-time cost, markup, and margin calculations at item, section, and quote level</td></tr>
              <tr><td>Learning Catalog</td><td>Catalog items auto-update with real pricing from every quote you build</td></tr>
              <tr><td>Discount System</td><td>Quantity-based discounts with configurable thresholds and percentages</td></tr>
              <tr><td>Quote Templates</td><td>Pre-built quote structures with formula evaluation for common project types</td></tr>
            </tbody>
          </table>
        </div>

        <div class="tab-panel" data-panel="staff" style="display:none;">
          <table class="feature-table">
            <thead><tr><th>Feature</th><th>What it does</th></tr></thead>
            <tbody>
              <tr><td>Resource Plans</td><td>Staffing plans linked to engagements with start/end dates and intervals</td></tr>
              <tr><td>Assignment Grid</td><td>Per-period hour assignments across day, week, or month intervals</td></tr>
              <tr><td>Capacity Forecasting</td><td>See capacity, target, projected, and utilization percentage per resource</td></tr>
              <tr><td>Utilization Tracking</td><td>Real-time visibility into who's overloaded and who has bandwidth</td></tr>
              <tr><td>Resource Profiles</td><td>Workspace with Info, Plans, and Capacity tabs for every team member</td></tr>
            </tbody>
          </table>
        </div>

        <div class="tab-panel" data-panel="learn" style="display:none;">
          <table class="feature-table">
            <thead><tr><th>Feature</th><th>What it does</th></tr></thead>
            <tbody>
              <tr><td>Note Embeddings</td><td>Notes automatically converted to vector embeddings for semantic search</td></tr>
              <tr><td>Institutional Memory</td><td>Every engagement feeds a compounding knowledge base your firm keeps forever</td></tr>
              <tr><td>Learning Catalog</td><td>Service catalog auto-updates from real quote data as you deliver work</td></tr>
              <tr><td>Document Versioning</td><td>Full version history of all documents, quotes, and engagement changes</td></tr>
              <tr><td>Speech-to-Text</td><td>Built-in transcription for capturing meeting notes directly in the app</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Final CTA -->
  <section class="platform-cta">
    <div class="container">
      <h2>See it in action.</h2>
      <p>15 minutes. No slides. Just the platform, live.</p>
      <div class="platform-cta-buttons">
        <button class="btn btn-primary btn-large" data-cal-link="christopher-veale/servantium-introduction?duration=15" data-cal-namespace="servantium-introduction" data-cal-config='{"layout":"month_view"}'>Book a Demo</button>
        <button class="btn btn-secondary btn-large" onclick="openContactModal()">Contact Us</button>
      </div>
    </div>
  </section>

  <!-- Contact Modal -->
  <div class="contact-modal-overlay" id="contact-modal" aria-hidden="true">
    <div class="contact-modal">
      <button class="contact-modal-close" aria-label="Close" onclick="closeContactModal()">&times;</button>
      <h2>Get in touch</h2>
      <p style="color:var(--color-ink-muted, #6B7280);margin-bottom:1.5rem;font-size:0.95rem;">Tell us about your firm and we'll reach out within 24 hours.</p>
      <form class="contact-modal-form" id="contact-modal-form">
        <input type="text" name="name" placeholder="Your name" required>
        <input type="email" name="email" placeholder="Work email" required>
        <textarea name="message" placeholder="Tell us about your firm and what you're looking for..." rows="4"></textarea>
        <button type="submit" class="btn btn-primary" id="contact-modal-submit">Send Message</button>
        <div class="contact-modal-status" id="contact-modal-status" style="display:none;"></div>
      </form>
      <div class="contact-modal-success" id="contact-modal-success" style="display:none;">
        <div class="contact-modal-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h3>Message Sent</h3>
        <p>Thanks for reaching out! We'll be in touch within 24 hours.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  :root {
    --green-500: #00C26D;
    --green-600: #00A95E;
    --green-700: #009657;
    --green-800: #037A47;
    --green-900: #045F37;
    --green-950: #023E25;
    --green-100: #C8F5DE;
    --green-50: #E8FBF1;
    --green-25: #F3FCF8;
    --coral: #FF5C70;
    --slate-blue: #4C82A7;
    --amber: #FFB02E;
    --deep-teal: #26A899;
    --slate: #64748B;
    --neutral-25: #FFFFFF;
    --neutral-100: #F5F6F7;
    --neutral-300: #E1E3E6;
    --neutral-700: #64748B;
    --neutral-900: #0D0D0D;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green-600);
    margin-bottom: 1.25rem;
  }
  .section-label::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 2px;
    background: var(--green-500);
  }

  /* Hero */
  .platform-hero {
    padding: 9rem 0 5rem;
    background: linear-gradient(180deg, var(--neutral-25) 0%, var(--green-25) 100%);
    text-align: center;
  }
  .platform-hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 1.25rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .platform-hero-desc {
    max-width: 660px;
    margin: 0 auto 2.5rem;
    font-size: 1.15rem;
    line-height: 1.7;
  }
  .hero-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Pillar Narrative — Today / With Servantium */
  .pillar-narrative {
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
    max-width: 1320px;
    margin: 0 auto 2rem;
    padding: 0 1.5rem;
  }
  .narrative-today, .narrative-servantium {
    flex: 1;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .narrative-today {
    background: var(--neutral-100);
    border-left: 3px solid #cbd5e1;
  }
  .narrative-today p {
    color: #475569;
    margin: 0;
  }
  .narrative-servantium {
    background: var(--green-25);
    border-left: 3px solid var(--green-500);
  }
  .narrative-servantium p {
    font-weight: 500;
    color: #1e293b;
    margin: 0;
  }
  .narrative-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    color: var(--neutral-700);
  }
  .narrative-servantium .narrative-label {
    color: var(--green-600);
  }
  .narrative-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--green-500);
    font-weight: 700;
    flex-shrink: 0;
    width: 32px;
  }

  /* Pillar guide link */
  .pillar-guide-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 1rem;
    color: var(--green-600);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .pillar-guide-link:hover {
    color: var(--green-700);
  }

  /* Four Pillars */
  .pillar-section {
    padding: 4rem 0;
    background: var(--neutral-25);
  }
  .pillar-section.tinted {
    background: #F9FDFB;
  }
  .pillar-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .pillar-grid.reversed .pillar-text { order: 2; }
  .pillar-grid.reversed .pillar-visual { order: 1; }

  .pillar-title {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-left: 12px;
    line-height: 1.3;
  }
  .pillar-title.accent-green { border-left: 4px solid var(--green-500); }
  .pillar-title.accent-blue { border-left: 4px solid var(--slate-blue); }
