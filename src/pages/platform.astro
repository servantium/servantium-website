    font-size: 18px;
    background-image: linear-gradient(135deg, #4285F4 25%, #EA4335 25%, #EA4335 50%, #FBBC05 50%, #FBBC05 75%, #34A853 75%) !important;
    -webkit-background-clip: text !important;
    background-clip: text !important;
    -webkit-text-fill-color: transparent;
  }
  .wave-node-live .wave-node-icon-google {
    box-shadow: 0 0 16px rgba(0, 194, 109, 0.35);
  }

  /* Tier 2: Planned - full color, no glow */
  .wave-node-soon .wave-node-icon {
    background: white;
    border: 1px solid var(--neutral-300);
  }

  /* Tier 3: Placeholder silhouettes */
  .wave-node-placeholder .wave-node-icon-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 14px;
