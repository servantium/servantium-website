---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';

const jsonLd = {
  "@type": "WebPage",
  "name": "Platform — Professional Services CPQ & Engagement Management",
  "description": "Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory.",
  "url": "https://servantium.com/platform",
  "isPartOf": {
    "@id": "https://servantium.com/#website"
  },
  "about": {
    "@id": "https://servantium.com/#software"
  },
  "publisher": {
    "@id": "https://servantium.com/#organization"
  }
};
---

<BaseLayout activePage="platform">
  <SEO
    slot="head"
    title="Platform — Professional Services CPQ & Engagement Management | Servantium"
    description="Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Section 1: Hero -->
  <section class="platform-hero">
    <div class="container">
      <span class="section-label">The Platform That Remembers</span>
      <h1>Every engagement makes your firm smarter.</h1>
      <p class="platform-hero-desc">Most platforms record what happened. Servantium learns from it. Scope, price, staff, and deliver &mdash; with a system that compounds your knowledge into a permanent advantage.</p>
      <div class="hero-buttons">
        <button class="btn btn-primary btn-large" data-cal-link="christopher-veale/servantium-introduction?duration=15" data-cal-namespace="servantium-introduction" data-cal-config='{"layout":"month_view"}'>Book a Demo</button>
        <button class="btn btn-secondary btn-large" onclick="openContactModal()">Contact Us</button>
      </div>
    </div>
  </section>

  <!-- Section 2: Four Pillars -->

  <!-- Pillar 1: Scope -->
  <section class="pillar-section tinted" id="scope" data-animate="fade-up">
    <div class="pillar-grid">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-green">Scope with confidence</h3>
        <p class="pillar-desc">AI-assisted discovery that captures context, not just notes. Your service catalog provides the building blocks for every engagement.</p>
        <ul class="pillar-bullets green">
          <li>Engagement workspace</li>
          <li>AI note parsing</li>
          <li>Service catalog library</li>
          <li>Similar engagement matching</li>
        </ul>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-eng-card">
            <div class="mock-eng-header">
              <div class="mock-eng-dot"></div>
              <div class="mock-eng-title">KVWN &mdash; Initial Discovery</div>
            </div>
            <div class="mock-eng-keywords">
              <span class="mock-eng-kw">Salesforce CRM</span>
              <span class="mock-eng-kw">60 users</span>
              <span class="mock-eng-kw">Q3 2026</span>
            </div>
            <div class="mock-eng-insight">
              3 similar engagements found &mdash; avg. 14 weeks, 92% estimate accuracy
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 2: Price -->
  <section class="pillar-section" id="price" data-animate="fade-up">
    <div class="pillar-grid reversed">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-blue">Price with precision</h3>
        <p class="pillar-desc">Build estimates informed by every project you've ever delivered. Grouped line items, role-based pricing, automatic margin calculations.</p>
        <ul class="pillar-bullets blue">
          <li>Grouped estimate builder</li>
          <li>Role &amp; rate management</li>
          <li>Margin analysis</li>
          <li>One-click proposal generation</li>
        </ul>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-est">
            <div class="mock-est-header">
              <span>Item Type</span>
              <span>Item Name</span>
              <span>Qty</span>
              <span>Cost</span>
              <span>Markup</span>
              <span>Total</span>
            </div>
            <div class="mock-est-group">
              <span>Discovery &amp; Requirements</span>
              <span>$24,000</span>
              <span>35%</span>
              <span>$32,400</span>
            </div>
            <div class="mock-est-row">
              <span><span class="mock-est-badge">Resource</span></span>
              <span>Sr. Business Analyst</span>
              <span>120h</span>
              <span>$12,000</span>
              <span>35%</span>
              <span>$16,200</span>
            </div>
            <div class="mock-est-row">
              <span><span class="mock-est-badge">Resource</span></span>
              <span>Solutions Architect</span>
              <span>80h</span>
              <span>$12,000</span>
              <span>35%</span>
              <span>$16,200</span>
            </div>
            <div class="mock-est-total">$167,450</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 3: Staff -->
  <section class="pillar-section tinted" id="staff" data-animate="fade-up">
    <div class="pillar-grid">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-teal">Staff with clarity</h3>
        <p class="pillar-desc">See who's available, who's overloaded, and who's perfect for the job &mdash; across every active engagement.</p>
        <ul class="pillar-bullets teal">
          <li>Cross-engagement visibility</li>
          <li>Utilization tracking</li>
          <li>Skill-based matching</li>
          <li>Capacity forecasting</li>
        </ul>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-res">
            <div class="mock-res-project">KVWN &mdash; Salesforce CRM</div>
            <div class="mock-res-header">
              <span>Resource</span>
              <span>Apr</span>
              <span>May</span>
              <span>Jun</span>
              <span>Jul</span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">R. Burgundy</span><br><span class="mock-res-role">Lead</span></span>
              <span><span class="mock-res-cell normal">72%</span></span>
              <span><span class="mock-res-cell heavy">88%</span></span>
              <span><span class="mock-res-cell normal">65%</span></span>
              <span><span class="mock-res-cell normal">40%</span></span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">B. Fantana</span><br><span class="mock-res-role">Architect</span></span>
              <span><span class="mock-res-cell normal">60%</span></span>
              <span><span class="mock-res-cell normal">75%</span></span>
              <span><span class="mock-res-cell heavy">90%</span></span>
              <span><span class="mock-res-cell over">105%</span></span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">B. Tamland</span><br><span class="mock-res-role">Developer</span></span>
              <span><span class="mock-res-cell normal">50%</span></span>
              <span><span class="mock-res-cell normal">70%</span></span>
              <span><span class="mock-res-cell heavy">85%</span></span>
              <span><span class="mock-res-cell normal">75%</span></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 4: Learn -->
  <section class="pillar-section" id="learn" data-animate="fade-up">
    <div class="pillar-grid reversed">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-amber">Learn from everything</h3>
        <p class="pillar-desc">This is what competitors can't copy. Every delivered engagement feeds back into how you scope, price, and staff the next one.</p>
        <ul class="pillar-bullets amber">
          <li>Delivery variance analysis</li>
          <li>Estimate accuracy tracking</li>
          <li>Pattern detection</li>
          <li>Continuous improvement engine</li>
        </ul>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-learn">
            <div class="mock-learn-title">KVWN &mdash; Post-Delivery Analysis</div>
            <div class="mock-learn-metrics">
              <span class="mock-learn-pill green">94% estimate accuracy</span>
              <span class="mock-learn-pill green">8% under budget</span>
              <span class="mock-learn-pill blue">17 weeks actual vs planned</span>
            </div>
            <div class="mock-learn-patterns">
              <div class="mock-learn-patterns-title">Patterns Detected</div>
              <div class="mock-learn-patterns-text">Discovery phases for CRM implementations consistently run 15% under estimate when led by senior analysts. Recommend adjusting catalog effort drivers.</div>
            </div>
            <div class="mock-learn-footer">Feeding insights into <span>Service Catalog</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Integrations -->
  <section class="integrations" id="integrations">
    <div class="container">
      <div class="integrations-header reveal">
        <span class="section-label">Integrations</span>
        <h2>Built to connect.</h2>
        <p class="text-large">REST API and MCP Server &mdash; connect anything. Need something we haven't built yet? We build integrations on demand as our ecosystem grows.</p>
      </div>

      <!-- Desktop: Hub and Spoke Constellation -->
      <div class="constellation reveal">
        <!-- Hub -->
        <div class="constellation-hub">
          <img src="/logo.png" alt="Servantium">
        </div>
        <!-- Dotted lines (SVG) -->
        <svg class="constellation-lines" viewBox="0 0 460 460" fill="none">
          <line x1="230" y1="230" x2="230" y2="45" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="230" y1="230" x2="385" y2="90" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="230" y1="230" x2="430" y2="220" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="230" y1="230" x2="385" y2="370" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="230" y1="230" x2="230" y2="415" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="230" y1="230" x2="75" y2="370" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="230" y1="230" x2="30" y2="220" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="230" y1="230" x2="75" y2="90" stroke="#E1E3E6" stroke-width="1" stroke-dasharray="4 4"/>
        </svg>
        <!-- Nodes -->
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#EBF5FF;color:#00A1E0;">sf</div>
          <span class="constellation-name">Salesforce</span>
          <span class="constellation-badge live">Live</span>
        </div>
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#FFF0EB;color:#FF7A59;">H</div>
          <span class="constellation-name">HubSpot</span>
          <span class="constellation-badge soon">Coming Soon</span>
        </div>
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#E8F5E3;color:#2CA01C;">QB</div>
          <span class="constellation-name">QuickBooks</span>
          <span class="constellation-badge soon">Coming Soon</span>
        </div>
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#E8F0FF;color:#0052CC;">J</div>
          <span class="constellation-name">Jira</span>
          <span class="constellation-badge soon">Coming Soon</span>
        </div>
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#F3E8F9;color:#4A154B;">#</div>
          <span class="constellation-name">Slack</span>
          <span class="constellation-badge soon">Coming Soon</span>
        </div>
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#EDEEF8;color:#6264A7;">T</div>
          <span class="constellation-name">Teams</span>
          <span class="constellation-badge soon">Coming Soon</span>
        </div>
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#FFF0E8;color:#FF4A00;">Z</div>
          <span class="constellation-name">Zapier</span>
          <span class="constellation-badge soon">Coming Soon</span>
        </div>
        <div class="constellation-node">
          <div class="constellation-icon" style="background:#E8FBF1;color:#00C26D;">CSV</div>
          <span class="constellation-name">CSV Import</span>
          <span class="constellation-badge live">Live</span>
        </div>
      </div>

      <!-- Mobile: 2x4 Grid -->
      <div class="constellation-mobile reveal">
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#EBF5FF;color:#00A1E0;">sf</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">Salesforce</span>
            <span class="constellation-badge live">Live</span>
          </div>
        </div>
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#E8FBF1;color:#00C26D;">CSV</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">CSV Import</span>
            <span class="constellation-badge live">Live</span>
          </div>
        </div>
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#FFF0EB;color:#FF7A59;">H</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">HubSpot</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#E8F5E3;color:#2CA01C;">QB</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">QuickBooks</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#E8F0FF;color:#0052CC;">J</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">Jira</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#F3E8F9;color:#4A154B;">#</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">Slack</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#EDEEF8;color:#6264A7;">T</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">Teams</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="constellation-mobile-card">
          <div class="constellation-icon" style="background:#FFF0E8;color:#FF4A00;">Z</div>
          <div class="constellation-mobile-info">
            <span class="constellation-name">Zapier</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
      </div>

      <div class="integration-request reveal">
        <a href="/#contact">Request an integration &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Section 4: Feature Matrix -->
  <section class="features-section" id="features">
    <div class="container">
      <div class="features-header reveal">
        <span class="section-label">Features</span>
        <h2>Everything you need.</h2>
      </div>

      <div class="reveal">
        <div class="feature-tabs" role="tablist">
          <button class="feature-tab active" role="tab" aria-selected="true" data-tab="core">Core Platform</button>
          <button class="feature-tab" role="tab" aria-selected="false" data-tab="collab">Collaboration</button>
          <button class="feature-tab" role="tab" aria-selected="false" data-tab="resources">Resources</button>
          <button class="feature-tab" role="tab" aria-selected="false" data-tab="intelligence">Intelligence</button>
          <button class="feature-tab" role="tab" aria-selected="false" data-tab="integrations-tab">Integrations</button>
          <button class="feature-tab" role="tab" aria-selected="false" data-tab="security">Security</button>
        </div>

        <!-- Core Platform -->
        <div class="feature-panel active" id="panel-core" role="tabpanel">
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Engagement workspace</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Service catalog</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Grouped estimate builder</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Role &amp; rate management</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Proposal generation</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Document templates</span><span class="feature-item-badge roadmap">Roadmap</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Client management</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Multi-currency support</span><span class="feature-item-badge roadmap">Roadmap</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Custom fields</span><span class="feature-item-badge live">Live</span></div>
        </div>

        <!-- Collaboration -->
        <div class="feature-panel" id="panel-collab" role="tabpanel">
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Team workspaces</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Real-time editing</span><span class="feature-item-badge roadmap">Roadmap</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Comment threads</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Activity feed</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Email notifications</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Shared dashboards</span><span class="feature-item-badge roadmap">Roadmap</span></div>
        </div>

        <!-- Resources -->
        <div class="feature-panel" id="panel-resources" role="tabpanel">
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Resource planning grid</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Utilization tracking</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Skill-based matching</span><span class="feature-item-badge roadmap">Roadmap</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Capacity forecasting</span><span class="feature-item-badge roadmap">Roadmap</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Cross-engagement view</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Time tracking</span><span class="feature-item-badge roadmap">Roadmap</span></div>
        </div>

        <!-- Intelligence -->
        <div class="feature-panel" id="panel-intelligence" role="tabpanel">
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">AI note parsing</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Similar engagement matching</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Estimate accuracy tracking</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Pattern detection</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Delivery variance analysis</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Margin optimization</span><span class="feature-item-badge roadmap">Roadmap</span></div>
        </div>

        <!-- Integrations -->
        <div class="feature-panel" id="panel-integrations-tab" role="tabpanel">
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Salesforce CRM</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">REST API</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">CSV import/export</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">MCP Server</span><span class="feature-item-badge roadmap">Roadmap</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">HubSpot</span><span class="feature-item-badge roadmap">Roadmap</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Zapier</span><span class="feature-item-badge roadmap">Roadmap</span></div>
        </div>

        <!-- Security -->
        <div class="feature-panel" id="panel-security" role="tabpanel">
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">SSO / SAML</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Role-based access</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Audit logging</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">Data encryption</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">SOC 2 compliance</span><span class="feature-item-badge live">Live</span></div>
          <div class="feature-item"><span class="feature-item-dot"></span><span class="feature-item-name">GDPR compliance</span><span class="feature-item-badge live">Live</span></div>
        </div>
      </div>

      <!-- Comparison Bar -->
      <div class="comparison-bar reveal">
        <div class="comparison-stats">
          <div class="comparison-stat">
            <div class="comparison-stat-label">Proposal Speed</div>
            <div class="comparison-stat-before">Days</div>
            <div class="comparison-stat-arrow">&darr;</div>
            <div class="comparison-stat-after">Minutes</div>
          </div>
          <div class="comparison-stat">
            <div class="comparison-stat-label">Knowledge</div>
            <div class="comparison-stat-before">Tribal</div>
            <div class="comparison-stat-arrow">&darr;</div>
            <div class="comparison-stat-after">Encoded</div>
          </div>
          <div class="comparison-stat">
            <div class="comparison-stat-label">Estimate Accuracy</div>
            <div class="comparison-stat-before">&plusmn;30%</div>
