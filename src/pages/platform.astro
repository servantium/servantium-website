  .ptab-check { width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px; }

  .ptab-illus { display: flex; align-items: center; justify-content: center; }
  .ptab-illus svg { width: 100%; max-width: 280px; height: auto; border-radius: 12px; }

  .ptab-noscript details { border-bottom: 1px solid var(--neutral-300); padding: 1rem 0; }
  .ptab-noscript summary { font-weight: 600; cursor: pointer; font-size: 1rem; color: var(--green-600); }
  .ptab-noscript p { margin-top: 0.75rem; color: var(--neutral-700); line-height: 1.6; }

  /* Comparison Bar */
  .comparison-bar { background: var(--green-950); border-radius: 16px; padding: 2.5rem; margin-top: 3rem; }
  .comparison-stats { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
  .comparison-stat { text-align: center; }
  .comparison-stat-label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--green-100); margin-bottom: 0.75rem; }
  .comparison-stat-before { font-size: 0.85rem; color: rgba(255,255,255,0.45); margin-bottom: 0.25rem; text-decoration: line-through; text-decoration-color: rgba(255,92,112,0.5); }
  .comparison-stat-arrow { color: var(--green-500); font-size: 0.9rem; margin-bottom: 0.25rem; }
  .comparison-stat-after { font-size: 0.95rem; font-weight: 600; color: white; line-height: 1.3; }

  /* CTA */
  .platform-cta { padding: 4rem 0; background: var(--green-950); text-align: center; }
  .platform-cta h2 { color: white; margin-bottom: 1rem; }
  .platform-cta > .container > p { font-size: 1.1rem; color: rgba(255,255,255,0.7); margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto; }
  .platform-cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .platform-cta .btn-secondary { border-color: rgba(255,255,255,0.2); color: white; }
  .platform-cta .btn-secondary:hover { border-color: var(--green-500); background: rgba(0, 194, 109, 0.1); }

  /* Contact Modal */
  .contact-modal-overlay { position: fixed; inset: 0; z-index: 10000; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
  .contact-modal-overlay.open { opacity: 1; pointer-events: auto; }
  .contact-modal { background: white; border-radius: 16px; padding: 2.5rem; width: 90%; max-width: 480px; position: relative; transform: translateY(20px) scale(0.97); transition: transform 0.3s ease; box-shadow: 0 25px 60px rgba(0,0,0,0.15); }
  .contact-modal-overlay.open .contact-modal { transform: translateY(0) scale(1); }
  .contact-modal-close { position: absolute; top: 16px; right: 20px; background: none; border: none; font-size: 1.5rem; color: #999; cursor: pointer; line-height: 1; }
  .contact-modal-close:hover { color: #333; }
  .contact-modal h2 { font-family: var(--font-heading, 'Playfair Display', serif); font-size: 1.5rem; margin-bottom: 0.25rem; }
  .contact-modal-form input, .contact-modal-form textarea { display: block; width: 100%; padding: 0.75rem 1rem; border: 1px solid #E1E3E6; border-radius: 8px; font-family: inherit; font-size: 0.95rem; margin-bottom: 0.75rem; transition: border-color 0.2s; }
  .contact-modal-form input:focus, .contact-modal-form textarea:focus { outline: none; border-color: #00C26D; }
  .contact-modal-form .btn { width: 100%; justify-content: center; padding: 0.85rem; font-size: 1rem; }
  .contact-modal-status { font-size: 0.85rem; margin-top: 0.75rem; padding: 0.5rem; border-radius: 6px; text-align: center; }
  .contact-modal-status.error { background: rgba(255,92,112,0.1); color: #cc3344; }
  .contact-modal-success { text-align: center; padding: 2rem 0; }
  .contact-modal-check { width: 56px; height: 56px; border-radius: 50%; background: rgba(0,194,109,0.1); color: #00C26D; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
  .contact-modal-check svg { width: 28px; height: 28px; stroke: #00C26D; }
  .contact-modal-success h3 { font-family: var(--font-heading, 'Playfair Display', serif); margin-bottom: 0.5rem; }
  .contact-modal-success p { color: #6B7280; }

  /* Responsive */
  @media (max-width: 1024px) {
    .comparison-stats { grid-template-columns: repeat(3, 1fr); }
    .ptab-content { grid-template-columns: 1.2fr 1fr; gap: 2rem; }
  }

  @media (max-width: 768px) {
    .platform-hero { padding: 7rem 0 3.5rem; }
    .pillar-section { padding: 3rem 0; }
    .pillar-story { flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
    .story-arrow { transform: rotate(90deg); width: auto; }
    .pillar-features-expand { padding: 0 1.5rem; }
    .pillar-grid { grid-template-columns: 1fr; gap: 2rem; }
    .pillar-grid.reversed .pillar-text { order: 1; }
    .pillar-grid.reversed .pillar-visual { order: 0; }
    .mini-illus { max-width: 100%; }
    .wave-flow-wrapper { display: none; }
    .wave-mobile { display: grid; }
    .features-section, .integrations, .platform-cta { padding: 3rem 0; }
    .ptab-content { grid-template-columns: 1fr; gap: 1.5rem; }
    .ptab-illus { order: -1; }
    .ptab-illus svg { max-width: 220px; }
    .comparison-bar { padding: 1.5rem; border-radius: 12px; }
    .comparison-stats { grid-template-columns: 1fr 1fr; }
    .comparison-stat:last-child { grid-column: 1 / -1; }
    .platform-cta-buttons, .hero-buttons { flex-direction: column; align-items: center; }
    .ptabs-bar { gap: 0; }
  }
</style>

<script is:inline>
  // Contact Modal
  function openContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    var form = document.getElementById('contact-modal-form');
    var success = document.getElementById('contact-modal-success');
    if (form) form.style.display = '';
    if (success) success.style.display = 'none';
  }
  document.getElementById('contact-modal').addEventListener('click', function(e) {
    if (e.target === this) closeContactModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeContactModal();
  });
  document.getElementById('contact-modal-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('contact-modal-submit');
    var statusEl = document.getElementById('contact-modal-status');
    btn.disabled = true;
    btn.textContent = 'Sending...';
    if (statusEl) { statusEl.className = 'contact-modal-status'; statusEl.style.display = 'none'; }

    var formData = {
      name: this.querySelector('[name="name"]').value,
      email: this.querySelector('[name="email"]').value,
      message: this.querySelector('[name="message"]').value
    };

    try {
      var response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (response.ok) {
        this.style.display = 'none';
        document.getElementById('contact-modal-success').style.display = 'block';
        this.reset();
        setTimeout(closeContactModal, 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch(err) {
      if (statusEl) {
        statusEl.className = 'contact-modal-status error';
        statusEl.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        statusEl.style.display = 'block';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });

  // Platform Feature Tabs
  (function() {
    var tabs = document.querySelectorAll('.ptab');
    var panels = document.querySelectorAll('.ptab-panel');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        var targetId = tab.getAttribute('aria-controls');
        panels.forEach(function(p) {
          if (p.id === targetId) {
            p.classList.add('active');
          } else {
            p.classList.remove('active');
          }
        });
      });
    });
  })();

  // Wave flow: no additional JS needed (CSS animations handle it)

  // Scroll reveal — smooth opacity/transform animation
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var reveals = document.querySelectorAll('.reveal');
    reveals.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.5s cubic-bezier(0.16,1,0.3,1)';
    });
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'none';
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      reveals.forEach(function(el) { observer.observe(el); });
    } else {
      reveals.forEach(function(el) { el.style.opacity = '1'; el.style.transform = 'none'; });
    }
  })();
</script>

<!-- Timed pillar section animations -->
<script is:inline>
  function initPillarAnimations() {
    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var pillar1 = document.querySelector('[data-pillar="1"]');
    var pillar2 = document.querySelector('[data-pillar="2"]');
    var pillar3 = document.querySelector('[data-pillar="3"]');
    var pillar4 = document.querySelector('[data-pillar="4"]');
    var pillars = [pillar1, pillar2, pillar3, pillar4];

    if (!pillar1) return;

    if (prefersReduced) {
      pillars.forEach(function(el) {
        if (el) { el.style.opacity = '1'; el.style.transform = 'none'; }
      });
      return;
    }

    var transition = 'opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1)';

    // Set all 4 hidden
    pillars.forEach(function(el) {
      if (el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(30px)';
        el.style.transition = transition;
      }
    });

    function reveal(el) {
      if (el) { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }
    }

    // Pillar 1: appear 3 seconds after page load
    setTimeout(function() { reveal(pillar1); }, 800);

    // Pillar 2: appear 1.5s after first scroll event
    var scrollHandled = false;
    function onFirstScroll() {
      if (scrollHandled) return;
      scrollHandled = true;
      window.removeEventListener('scroll', onFirstScroll);
      setTimeout(function() { reveal(pillar2); }, 400);
    }
    window.addEventListener('scroll', onFirstScroll, { passive: true });

    // Pillars 3 and 4: IntersectionObserver with 1.5s delay
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          io.unobserve(el);
          setTimeout(function() { reveal(el); }, 400);
        }
      });
    }, { threshold: 0.15 });

    if (pillar3) io.observe(pillar3);
    if (pillar4) io.observe(pillar4);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPillarAnimations);
  } else {
    initPillarAnimations();
  }
  document.addEventListener('astro:page-load', initPillarAnimations);
</script>
