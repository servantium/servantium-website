---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';

const jsonLd = {
  "@type": "WebPage",
  "name": "Platform — Professional Services CPQ & Engagement Management",
  "description": "Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory.",
  "url": "https://servantium.com/platform",
  "isPartOf": {
    "@id": "https://servantium.com/#website"
  },
  "about": {
    "@id": "https://servantium.com/#software"
  },
  "publisher": {
    "@id": "https://servantium.com/#organization"
  }
};
---

<BaseLayout activePage="platform">
  <SEO
    slot="head"
    title="Platform — Professional Services CPQ & Engagement Management | Servantium"
    description="Explore Servantium's professional services platform. See the full capability set — from engagement scoping and AI-powered estimation to resource planning, Salesforce integration, and institutional memory."
    ogType="website"
    jsonLd={jsonLd}
  />

  <!-- Section 1: Hero -->
  <section class="platform-hero">
    <div class="container">
      <span class="section-label">The Platform That Remembers</span>
      <h1>Every engagement makes your firm smarter.</h1>
      <p class="platform-hero-desc">Most platforms record what happened. Servantium learns from it. Scope, price, staff, and deliver &mdash; with a system that compounds your knowledge into a permanent advantage.</p>
      <div class="hero-buttons">
        <button class="btn btn-primary btn-large" data-cal-link="christopher-veale/servantium-introduction?duration=15" data-cal-namespace="servantium-introduction" data-cal-config='{"layout":"month_view"}'>Book a Demo</button>
        <button class="btn btn-secondary btn-large" onclick="openContactModal()">Contact Us</button>
      </div>
    </div>
  </section>

  <!-- Section 2: Four Pillars -->

  <!-- Pillar 1: Scope -->
  <section class="pillar-section tinted" id="scope" data-pillar="1" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-story">
      <div class="story-pain">
        <span class="story-label">The problem</span>
        <p>Your senior consultant just landed a new client. She spends 3 hours searching Slack, email, and old proposals to understand how you've handled similar work before.</p>
      </div>
      <div class="story-arrow">&rarr;</div>
      <div class="story-solution">
        <span class="story-label">With Servantium</span>
        <p>She opens Similar Engagements and finds 4 comparable projects in seconds &mdash; complete with pricing, delivery outcomes, and lessons learned.</p>
      </div>
    </div>
    <div class="pillar-grid">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-green">Scope with confidence</h3>
        <p class="pillar-desc">AI-assisted discovery that captures context, not just notes. Your service catalog provides the building blocks for every engagement.</p>
        <ul class="pillar-bullets green">
          <li>Engagement workspace</li>
          <li>AI note parsing</li>
          <li>Service catalog library</li>
          <li>Similar engagement matching</li>
        </ul>
        <details class="pillar-features-expand">
          <summary>See all features &rarr;</summary>
          <div class="features-grid">
            <div class="feature-card"><div class="feature-card-icon">&#128196;</div><strong>Engagement Workspace</strong><span>Full project context in one unified view</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128209;</div><strong>6-Tab System</strong><span>Scope, quote, resources, notes, docs, activity</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128203;</div><strong>Templates</strong><span>Engagement templates for repeatable work</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128269;</div><strong>Similar Matching</strong><span>Vector search finds comparable past projects</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#127991;</div><strong>Tags &amp; Categories</strong><span>Organize and filter engagements your way</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#129302;</div><strong>AI Context Extraction</strong><span>Auto-extract key details from notes and calls</span></div>
          </div>
        </details>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-eng-card">
            <div class="mock-eng-header">
              <div class="mock-eng-dot"></div>
              <div class="mock-eng-title">KVWN &mdash; Initial Discovery</div>
            </div>
            <div class="mock-eng-keywords">
              <span class="mock-eng-kw">Salesforce CRM</span>
              <span class="mock-eng-kw">60 users</span>
              <span class="mock-eng-kw">Q3 2026</span>
            </div>
            <div class="mock-eng-insight">
              3 similar engagements found &mdash; avg. 14 weeks, 92% estimate accuracy
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 2: Price -->
  <section class="pillar-section" id="price" data-pillar="2" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-story">
      <div class="story-pain">
        <span class="story-label">The problem</span>
        <p>Building a quote means opening three spreadsheets, guessing at margins, and hoping someone remembers the actual cost of the last similar project.</p>
      </div>
      <div class="story-arrow">&rarr;</div>
      <div class="story-solution">
        <span class="story-label">With Servantium</span>
        <p>The quote builder draws from your learning catalog &mdash; real costs from real projects. AI generates a complete quote structure from your notes and history.</p>
      </div>
    </div>
    <div class="pillar-grid reversed">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-blue">Price with precision</h3>
        <p class="pillar-desc">Build estimates informed by every project you've ever delivered. Grouped line items, role-based pricing, automatic margin calculations.</p>
        <ul class="pillar-bullets blue">
          <li>Grouped estimate builder</li>
          <li>Role &amp; rate management</li>
          <li>Margin analysis</li>
          <li>One-click proposal generation</li>
        </ul>
        <details class="pillar-features-expand">
          <summary>See all features &rarr;</summary>
          <div class="features-grid">
            <div class="feature-card"><div class="feature-card-icon">&#128176;</div><strong>Quote Builder</strong><span>Structured estimates with grouped sections</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128202;</div><strong>Grouped Sections</strong><span>Subtotals and roll-ups for clarity</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128221;</div><strong>Line Items</strong><span>Role-based with hours, cost, and rates</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128200;</div><strong>Margin Calculator</strong><span>Markup and margin analysis in real-time</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#129302;</div><strong>AI Generation</strong><span>Generate quotes from discovery notes</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128218;</div><strong>Service Catalog</strong><span>Reusable building blocks with standard pricing</span></div>
          </div>
        </details>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-est">
            <div class="mock-est-header">
              <span>Item Type</span>
              <span>Item Name</span>
              <span>Qty</span>
              <span>Cost</span>
              <span>Markup</span>
              <span>Total</span>
            </div>
            <div class="mock-est-group">
              <span>Discovery &amp; Requirements</span>
              <span>$24,000</span>
              <span>35%</span>
              <span>$32,400</span>
            </div>
            <div class="mock-est-row">
              <span><span class="mock-est-badge">Resource</span></span>
              <span>Sr. Business Analyst</span>
              <span>120h</span>
              <span>$12,000</span>
              <span>35%</span>
              <span>$16,200</span>
            </div>
            <div class="mock-est-row">
              <span><span class="mock-est-badge">Resource</span></span>
              <span>Solutions Architect</span>
              <span>80h</span>
              <span>$12,000</span>
              <span>35%</span>
              <span>$16,200</span>
            </div>
            <div class="mock-est-total">$167,450</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 3: Staff -->
  <section class="pillar-section tinted" id="staff" data-pillar="3" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-story">
      <div class="story-pain">
        <span class="story-label">The problem</span>
        <p>You just won a large implementation. Now you need to figure out who's available without double-booking your best people across five active projects.</p>
      </div>
      <div class="story-arrow">&rarr;</div>
      <div class="story-solution">
        <span class="story-label">With Servantium</span>
        <p>The resource planner shows real-time capacity across all engagements. Assign the right people based on skills, availability, and historical performance.</p>
      </div>
    </div>
    <div class="pillar-grid">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-teal">Staff with clarity</h3>
        <p class="pillar-desc">See who's available, who's overloaded, and who's perfect for the job &mdash; across every active engagement.</p>
        <ul class="pillar-bullets teal">
          <li>Cross-engagement visibility</li>
          <li>Utilization tracking</li>
          <li>Skill-based matching</li>
          <li>Capacity forecasting</li>
        </ul>
        <details class="pillar-features-expand">
          <summary>See all features &rarr;</summary>
          <div class="features-grid">
            <div class="feature-card"><div class="feature-card-icon">&#128101;</div><strong>Resource Plans</strong><span>Plans linked directly to engagements</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128197;</div><strong>Assignment Grid</strong><span>Monthly drag-and-drop assignments</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128200;</div><strong>Capacity Forecasting</strong><span>See capacity gaps before they happen</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128202;</div><strong>Utilization Tracking</strong><span>Color-coded thresholds across the team</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128337;</div><strong>Interval Planning</strong><span>Weekly, monthly, or quarterly time horizons</span></div>
          </div>
        </details>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-res">
            <div class="mock-res-project">KVWN &mdash; Salesforce CRM</div>
            <div class="mock-res-header">
              <span>Resource</span>
              <span>Apr</span>
              <span>May</span>
              <span>Jun</span>
              <span>Jul</span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">R. Burgundy</span><br><span class="mock-res-role">Lead</span></span>
              <span><span class="mock-res-cell normal">72%</span></span>
              <span><span class="mock-res-cell heavy">88%</span></span>
              <span><span class="mock-res-cell normal">65%</span></span>
              <span><span class="mock-res-cell normal">40%</span></span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">B. Fantana</span><br><span class="mock-res-role">Architect</span></span>
              <span><span class="mock-res-cell normal">60%</span></span>
              <span><span class="mock-res-cell normal">75%</span></span>
              <span><span class="mock-res-cell heavy">90%</span></span>
              <span><span class="mock-res-cell over">105%</span></span>
            </div>
            <div class="mock-res-row">
              <span><span class="mock-res-name">B. Tamland</span><br><span class="mock-res-role">Developer</span></span>
              <span><span class="mock-res-cell normal">50%</span></span>
              <span><span class="mock-res-cell normal">70%</span></span>
              <span><span class="mock-res-cell heavy">85%</span></span>
              <span><span class="mock-res-cell normal">75%</span></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillar 4: Learn -->
  <section class="pillar-section" id="learn" data-pillar="4" style="opacity:0; transform:translateY(30px);">
    <div class="pillar-story">
      <div class="story-pain">
        <span class="story-label">The problem</span>
        <p>Your firm completes 200 engagements a year, but each one starts from scratch. The knowledge walks out the door every time someone leaves.</p>
      </div>
      <div class="story-arrow">&rarr;</div>
      <div class="story-solution">
        <span class="story-label">With Servantium</span>
        <p>Every engagement feeds institutional memory. Notes become embeddings. Quotes become catalog items. Outcomes become benchmarks. Your firm gets smarter with every project.</p>
      </div>
    </div>
    <div class="pillar-grid reversed">
      <div class="pillar-text reveal">
        <h3 class="pillar-title accent-amber">Learn from everything</h3>
        <p class="pillar-desc">This is what competitors can't copy. Every delivered engagement feeds back into how you scope, price, and staff the next one.</p>
        <ul class="pillar-bullets amber">
          <li>Delivery variance analysis</li>
          <li>Estimate accuracy tracking</li>
          <li>Pattern detection</li>
          <li>Continuous improvement engine</li>
        </ul>
        <details class="pillar-features-expand">
          <summary>See all features &rarr;</summary>
          <div class="features-grid">
            <div class="feature-card"><div class="feature-card-icon">&#129504;</div><strong>Note Embeddings</strong><span>Notes become searchable vectors automatically</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128269;</div><strong>Vector Search</strong><span>Find relevant past work with natural language</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128218;</div><strong>Learning Catalog</strong><span>Curated library of reusable service patterns</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#128196;</div><strong>Document Versioning</strong><span>Track how your knowledge evolves over time</span></div>
            <div class="feature-card"><div class="feature-card-icon">&#127979;</div><strong>Institutional Memory</strong><span>Knowledge persists regardless of staff turnover</span></div>
          </div>
        </details>
      </div>
      <div class="pillar-visual reveal">
        <div class="mini-illus">
          <div class="mock-learn">
            <div class="mock-learn-title">KVWN &mdash; Post-Delivery Analysis</div>
            <div class="mock-learn-metrics">
              <span class="mock-learn-pill green">94% estimate accuracy</span>
              <span class="mock-learn-pill green">8% under budget</span>
              <span class="mock-learn-pill blue">17 weeks actual vs planned</span>
            </div>
            <div class="mock-learn-patterns">
              <div class="mock-learn-patterns-title">Patterns Detected</div>
              <div class="mock-learn-patterns-text">Discovery phases for CRM implementations consistently run 15% under estimate when led by senior analysts. Recommend adjusting catalog effort drivers.</div>
            </div>
            <div class="mock-learn-footer">Feeding insights into <span>Service Catalog</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Integrations — Animated Constellation -->
  <section class="integrations" id="integrations">
    <div class="container">
      <div class="integrations-header reveal">
        <span class="section-label">Integrations</span>
        <h2>Built to connect.</h2>
        <p class="text-large">REST API and MCP Server &mdash; connect anything. Need something we haven't built yet? We build integrations on demand as our ecosystem grows.</p>
      </div>

      <!-- Wave Flow Integration Design -->
      <div class="wave-flow-wrapper reveal">
        <div class="wave-flow-center-text">Servantium connects your tools</div>
        <div class="wave-flow-container">
          <svg class="wave-flow-svg" viewBox="0 0 960 200" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="waveGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#00C26D" stop-opacity="0.3"/>
                <stop offset="50%" stop-color="#26A899" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#4C82A7" stop-opacity="0.3"/>
              </linearGradient>
              <filter id="wave-glow-green">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feFlood flood-color="#00C26D" flood-opacity="0.25" result="color"/>
                <feComposite in="color" in2="blur" operator="in" result="shadow"/>
                <feMerge><feMergeNode in="shadow"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <!-- Wave path background -->
            <path class="wave-path-bg" d="M 0,100 C 60,40 120,40 180,100 C 240,160 300,160 360,100 C 420,40 480,40 540,100 C 600,160 660,160 720,100 C 780,40 840,40 900,100 C 930,120 960,130 960,120" fill="none" stroke="url(#waveGrad)" stroke-width="3"/>
            <!-- Wave path animated -->
            <path class="wave-path-animated" d="M 0,100 C 60,40 120,40 180,100 C 240,160 300,160 360,100 C 420,40 480,40 540,100 C 600,160 660,160 720,100 C 780,40 840,40 900,100 C 930,120 960,130 960,120" fill="none" stroke="#00C26D" stroke-width="2" stroke-dasharray="8 6" opacity="0.6"/>
            <!-- Green data particles along the path -->
            <circle class="wave-dot" r="4" fill="#00C26D" opacity="0.8">
              <animateMotion dur="4s" repeatCount="indefinite" path="M 0,100 C 60,40 120,40 180,100 C 240,160 300,160 360,100 C 420,40 480,40 540,100 C 600,160 660,160 720,100 C 780,40 840,40 900,100 C 930,120 960,130 960,120"/>
            </circle>
            <circle class="wave-dot" r="3" fill="#00C26D" opacity="0.6">
              <animateMotion dur="4s" repeatCount="indefinite" begin="1.3s" path="M 0,100 C 60,40 120,40 180,100 C 240,160 300,160 360,100 C 420,40 480,40 540,100 C 600,160 660,160 720,100 C 780,40 840,40 900,100 C 930,120 960,130 960,120"/>
            </circle>
            <circle class="wave-dot" r="3.5" fill="#26A899" opacity="0.7">
              <animateMotion dur="4s" repeatCount="indefinite" begin="2.6s" path="M 0,100 C 60,40 120,40 180,100 C 240,160 300,160 360,100 C 420,40 480,40 540,100 C 600,160 660,160 720,100 C 780,40 840,40 900,100 C 930,120 960,130 960,120"/>
            </circle>
          </svg>

          <!-- Integration logos positioned along the wave -->
          <div class="wave-node wave-node-live" style="left: 2%; top: 36%;">
            <div class="wave-node-icon" style="background:#EBF5FF;color:#00A1E0;">sf</div>
            <span class="wave-node-name">Salesforce</span>
          </div>
          <div class="wave-node wave-node-live" style="left: 15.5%; top: 36%;">
            <div class="wave-node-icon" style="background:#E8FBF1;color:#00C26D;">CSV</div>
            <span class="wave-node-name">CSV Import</span>
          </div>
          <div class="wave-node wave-node-soon" style="left: 31%; top: 60%;">
            <div class="wave-node-icon" style="background:#FFF0EB;color:#FF7A59;">H</div>
            <span class="wave-node-name">HubSpot</span>
          </div>
          <div class="wave-node wave-node-soon" style="left: 46%; top: 12%;">
            <div class="wave-node-icon" style="background:#E8F5E3;color:#2CA01C;">QB</div>
            <span class="wave-node-name">QuickBooks</span>
          </div>
          <div class="wave-node wave-node-soon" style="left: 61%; top: 60%;">
            <div class="wave-node-icon" style="background:#E8F0FF;color:#0052CC;">J</div>
            <span class="wave-node-name">Jira</span>
          </div>
          <div class="wave-node wave-node-soon" style="left: 76%; top: 12%;">
            <div class="wave-node-icon" style="background:#F3E8F9;color:#4A154B;">#</div>
            <span class="wave-node-name">Slack</span>
          </div>
          <div class="wave-node wave-node-soon" style="left: 85%; top: 36%;">
            <div class="wave-node-icon" style="background:#EDEEF8;color:#6264A7;">T</div>
            <span class="wave-node-name">Teams</span>
          </div>
          <div class="wave-node wave-node-soon" style="left: 94%; top: 36%;">
            <div class="wave-node-icon" style="background:#FFF0E8;color:#FF4A00;">Z</div>
            <span class="wave-node-name">Zapier</span>
          </div>
        </div>
        <div class="wave-flow-count">8 integrations and growing</div>
      </div>

      <!-- Mobile: Integration cards -->
      <div class="wave-mobile reveal">
        <div class="wave-mobile-card live">
          <div class="constellation-icon" style="background:#EBF5FF;color:#00A1E0;">sf</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">Salesforce</span>
            <span class="constellation-badge live">Live</span>
          </div>
        </div>
        <div class="wave-mobile-card live">
          <div class="constellation-icon" style="background:#E8FBF1;color:#00C26D;">CSV</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">CSV Import</span>
            <span class="constellation-badge live">Live</span>
          </div>
        </div>
        <div class="wave-mobile-card">
          <div class="constellation-icon" style="background:#FFF0EB;color:#FF7A59;">H</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">HubSpot</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="wave-mobile-card">
          <div class="constellation-icon" style="background:#E8F5E3;color:#2CA01C;">QB</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">QuickBooks</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="wave-mobile-card">
          <div class="constellation-icon" style="background:#E8F0FF;color:#0052CC;">J</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">Jira</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="wave-mobile-card">
          <div class="constellation-icon" style="background:#F3E8F9;color:#4A154B;">#</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">Slack</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="wave-mobile-card">
          <div class="constellation-icon" style="background:#EDEEF8;color:#6264A7;">T</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">Teams</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="wave-mobile-card">
          <div class="constellation-icon" style="background:#FFF0E8;color:#FF4A00;">Z</div>
          <div class="wave-mobile-info">
            <span class="constellation-name">Zapier</span>
            <span class="constellation-badge soon">Coming Soon</span>
          </div>
        </div>
        <div class="wave-flow-count" style="grid-column: 1 / -1;">8 integrations and growing</div>
      </div>

      <div class="integration-request reveal">
        <a href="/#contact">Request an integration &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Section 4: Built for How You Work — Feature Tabs -->
  <section class="features-section" id="features">
    <div class="container">
      <div class="features-header reveal">
        <span class="section-label">Built for How You Work</span>
        <h2>Everything you need.</h2>
      </div>

      <div class="platform-tabs reveal">
        <!-- Tab Buttons -->
        <div class="ptabs-bar" role="tablist" aria-label="Platform features">
          <button class="ptab active" role="tab" aria-selected="true" aria-controls="ptab-engagements" id="ptab-btn-engagements">Engagements</button>
          <button class="ptab" role="tab" aria-selected="false" aria-controls="ptab-quotes" id="ptab-btn-quotes">Quotes &amp; Pricing</button>
