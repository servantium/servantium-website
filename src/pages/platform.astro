    overflow: hidden;
    background: white;
    border: 1px solid var(--neutral-300);
    font-family: 'Source Sans 3', sans-serif;
    font-size: 10px;
    color: var(--neutral-900);
    margin: 0 auto;
  }

  /* Mockup 1: Engagement Card */
  .mock-eng-card { padding: 16px; }
  .mock-eng-header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .mock-eng-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green-500); }
  .mock-eng-title { font-weight: 600; font-size: 11px; letter-spacing: 0.02em; }
  .mock-eng-keywords { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
