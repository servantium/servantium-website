<script is:inline>
  // Contact Modal
  function openContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeContactModal() {
    var modal = document.getElementById('contact-modal');
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    var form = document.getElementById('contact-modal-form');
    var success = document.getElementById('contact-modal-success');
    if (form) form.style.display = '';
    if (success) success.style.display = 'none';
  }
  document.getElementById('contact-modal').addEventListener('click', function(e) {
    if (e.target === this) closeContactModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeContactModal();
  });
  document.getElementById('contact-modal-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('contact-modal-submit');
    var statusEl = document.getElementById('contact-modal-status');
    btn.disabled = true;
    btn.textContent = 'Sending...';
    if (statusEl) { statusEl.className = 'contact-modal-status'; statusEl.style.display = 'none'; }

    var formData = {
      name: this.querySelector('[name="name"]').value,
      email: this.querySelector('[name="email"]').value,
      message: this.querySelector('[name="message"]').value
    };

    try {
      var response = await fetch('https://contact.servantium.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (response.ok) {
        this.style.display = 'none';
        document.getElementById('contact-modal-success').style.display = 'block';
        this.reset();
        setTimeout(closeContactModal, 4000);
      } else {
        throw new Error('Form submission failed');
      }
    } catch(err) {
      if (statusEl) {
        statusEl.className = 'contact-modal-status error';
        statusEl.textContent = 'Something went wrong. Please email us directly at hello@servantium.com';
        statusEl.style.display = 'block';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });

  // Scroll reveal for .reveal elements
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var reveals = document.querySelectorAll('.reveal');
    reveals.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.5s cubic-bezier(0.16,1,0.3,1)';
    });
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'none';
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      reveals.forEach(function(el) { observer.observe(el); });
    } else {
      reveals.forEach(function(el) { el.style.opacity = '1'; el.style.transform = 'none'; });
    }
  })();
</script>

<!-- Narrative panel scroll reveal + comic panel animations -->
<script is:inline>
  function initNarrativeReveal() {
    var stages = document.querySelectorAll('.narrative-stage');
    var animatedPanels = document.querySelectorAll('[data-animate]');
    if (!stages.length && !animatedPanels.length) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      stages.forEach(function(s) { s.classList.add('visible'); });
      animatedPanels.forEach(function(p) { p.classList.add('is-visible'); });
      return;
    }
    var stageObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          stageObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    stages.forEach(function(s) { stageObserver.observe(s); });

    var panelObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var delay = parseInt(entry.target.getAttribute('data-delay') || '0', 10);
          setTimeout(function() {
            entry.target.classList.add('is-visible');
          }, delay);
          panelObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    animatedPanels.forEach(function(p) { panelObserver.observe(p); });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNarrativeReveal);
  } else {
    initNarrativeReveal();
  }
  document.addEventListener('astro:page-load', initNarrativeReveal);
</script>

<script is:inline>
  function initPricingSlider() {
    var slider = document.getElementById('user-slider');
    var countEl = document.getElementById('slider-user-count');
    var amountEl = document.getElementById('price-amount');
    var periodEl = document.getElementById('price-period');
    var noteEl = document.getElementById('price-note');
    if (!slider) return;

    var perUserEl = document.getElementById('price-per-user');

    function updatePrice() {
      var val = parseInt(slider.value, 10);
      countEl.textContent = val + (val === 1 ? ' user' : ' users');

      // Smooth base + per-user: $500 base + $50/user, with volume discounts
      // Effective per-user drops smoothly from $150 (1 user) to ~$65 (50 users)
      var base = 500;
      var perUser;
      if (val <= 5) perUser = 0;  // base covers first 5
      else if (val <= 15) perUser = 50;
      else if (val <= 30) perUser = 45;
      else perUser = 39;

      var price, note;
      if (val <= 5) {
        price = base;
        note = 'Platform base — includes 5 users.';
      } else if (val <= 50) {
        price = base + (val - 5) * perUser;
        note = '$500 base + $' + perUser + '/user beyond 5.';
      } else {
        price = 0;
        note = '';
      }

      if (val > 50 || price === 0) {
        amountEl.textContent = "Let's talk";
        periodEl.textContent = '';
        noteEl.textContent = "Custom pricing for teams over 50.";
        if (perUserEl) perUserEl.textContent = 'Contact us for volume pricing';
      } else {
        amountEl.textContent = '$' + price.toLocaleString();
        periodEl.textContent = '/mo';
        noteEl.textContent = note;
        var effectivePerUser = Math.round(price / val);
        if (perUserEl) perUserEl.textContent = '$' + effectivePerUser + '/user effective';
      }
    }

    slider.addEventListener('input', updatePrice);
    updatePrice();

    // "Explore features" links: smooth scroll to features section
    document.querySelectorAll('.narrative-link[data-tab]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById('features');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPricingSlider);
  } else {
    initPricingSlider();
  }
  document.addEventListener('astro:page-load', initPricingSlider);
</script>

<!-- ROI Calculator -->
<script is:inline>
  function openROICalculator() {
    var modal = document.getElementById('roi-modal');
    if (!modal) return;
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    calculateROI();
    // GA4 telemetry
    if (window.gtag) window.gtag('event', 'roi_calculator_opened');
  }
  function closeROICalculator() {
    var modal = document.getElementById('roi-modal');
    if (!modal) return;
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function formatCurrency(n) {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return '$' + Math.round(n / 1000) + 'K';
    return '$' + Math.round(n);
  }

  function calculateROI() {
    var consultants = parseInt(document.getElementById('roi-consultants').value, 10) || 25;
    var rate = parseInt(document.getElementById('roi-rate').value, 10) || 200;
    var utilization = parseInt(document.getElementById('roi-utilization').value, 10) || 69;
    var proposals = parseInt(document.getElementById('roi-proposals').value, 10) || 60;
    var winRate = parseInt(document.getElementById('roi-winrate').value, 10) || 39;
    var avgDeal = parseInt(document.getElementById('roi-avgdeal').value, 10) || 35000;

    var hoursPerYear = 2080;

    // Servantium annual cost (must match pricing slider algorithm)
    var users = consultants;
    var perUser = users <= 5 ? 0 : users <= 15 ? 50 : users <= 30 ? 45 : 39;
    var monthlyPrice = users <= 5 ? 500 : 500 + (users - 5) * perUser;
    var annualCost = monthlyPrice * 12;

    // Target: realistic 5-10x ROI. Work backwards from cost to keep credible.
    // Use very conservative, partial-attribution percentages.

    // 1. Utilization improvement: 1.5pt (not 4pt) — just from better scheduling visibility
    var utilImprovement = 1.5;
    var targetUtil = Math.min(utilization + utilImprovement, 80);
    var actualImprovement = targetUtil - utilization;
    var utilValue = Math.round(consultants * hoursPerYear * rate * (actualImprovement / 100));
    document.getElementById('roi-util-from').textContent = utilization + '%';
    document.getElementById('roi-util-to').textContent = targetUtil.toFixed(1) + '%';
    document.getElementById('roi-util-value').textContent = formatCurrency(utilValue);

    // 2. Revenue leakage: recover 15% of the industry-avg 4.3% leak (not 50%)
    var currentRevenue = consultants * hoursPerYear * rate * (utilization / 100);
    var leakageRecovered = currentRevenue * 0.043 * 0.15;
    var leakageValue = Math.round(leakageRecovered);
    document.getElementById('roi-leakage-value').textContent = formatCurrency(leakageValue);

    // 3. Win rate: 2pt lift (not 6pt) — from faster, better-quality proposals
    var winImprovement = 2;
    var newWinRate = Math.min(winRate + winImprovement, 65);
    var actualWinImprovement = newWinRate - winRate;
    var additionalWins = proposals * (actualWinImprovement / 100);
    // Only attribute 40% of new deal revenue as margin (not full deal value)
    var winValue = Math.round(additionalWins * avgDeal * 0.40);
    document.getElementById('roi-win-from').textContent = winRate + '%';
    document.getElementById('roi-win-to').textContent = newWinRate + '%';
    document.getElementById('roi-win-value').textContent = formatCurrency(winValue);

    // 4. Scope accuracy: reduce overruns on 30% of affected projects (not 50% × 27% × 33%)
    var projectsPerYear = Math.round(proposals * (winRate / 100));
    // 50% of projects have scope creep, avg 27% overrun, but we only help on 20% of those
    var scopeValue = Math.round(projectsPerYear * 0.50 * avgDeal * 0.27 * 0.10);
    document.getElementById('roi-scope-value').textContent = formatCurrency(scopeValue);

    // Total
    var total = utilValue + leakageValue + winValue + scopeValue;
    document.getElementById('roi-total-value').textContent = formatCurrency(total);

    // Cost comparison (annualCost already calculated above)
    document.getElementById('roi-cost').textContent = formatCurrency(annualCost) + '/yr';
    var multiplier = annualCost > 0 ? (total / annualCost).toFixed(1) : 0;
    document.getElementById('roi-multiplier').textContent = multiplier + 'x return';
  }

  // Event listeners
  (function() {
    var roiModal = document.getElementById('roi-modal');
    if (!roiModal) return;

    roiModal.addEventListener('click', function(e) {
      if (e.target === roiModal) closeROICalculator();
    });

    var inputs = roiModal.querySelectorAll('input[type="number"]');
    var trackTimer = null;
    inputs.forEach(function(input) {
      input.addEventListener('input', function() {
        calculateROI();
        // Debounced GA4 tracking (2s after last input)
        clearTimeout(trackTimer);
        trackTimer = setTimeout(function() {
          if (window.gtag) {
            window.gtag('event', 'roi_calculator_completed', {
              consultants: document.getElementById('roi-consultants').value,
              rate: document.getElementById('roi-rate').value,
              utilization: document.getElementById('roi-utilization').value,
              total_impact: document.getElementById('roi-total-value').textContent,
              roi_multiplier: document.getElementById('roi-multiplier').textContent
            });
          }
        }, 2000);
      });
    });

    // Track CTA click
    var roiCta = roiModal.querySelector('.roi-cta');
    if (roiCta) {
      roiCta.addEventListener('click', function() {
        if (window.gtag) window.gtag('event', 'roi_calculator_cta_clicked');
      });
    }
  })();

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var roiModal = document.getElementById('roi-modal');
      if (roiModal && roiModal.classList.contains('open')) closeROICalculator();
    }
  });
</script>
