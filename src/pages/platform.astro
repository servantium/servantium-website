  }
  .wave-flow-container {
    position: relative;
    width: 100%;
    height: 340px;
  }
  .wave-flow-svg {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }
  @keyframes wave-dash {
    to { stroke-dashoffset: -28; }
  }
  .wave-path-animated {
    animation: wave-dash 1.5s linear infinite;
  }

  /* Wave integration nodes */
  .wave-node {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    z-index: 2;
    transition: transform 0.2s ease;
  }
  .wave-node:hover { transform: translateY(-4px) scale(1.1); }
  .wave-node-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    font-family: 'Source Sans 3', sans-serif;
    border: 1px solid var(--neutral-300);
    transition: box-shadow 0.2s ease;
    position: relative;
  }

  /* Tier 1: Live - green glow */
  .wave-node-live .wave-node-icon {
    box-shadow: 0 0 16px rgba(0, 194, 109, 0.35);
    border: 2px solid var(--green-500);
    background: white;
