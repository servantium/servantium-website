  .narrative-text {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .narrative-text.hidden {
    display: none;
  }

  .narrative-dot {
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  /* Astronaut costume switching */
  .astro-variant {
    transition: opacity 0.3s ease;
  }
  .astro-variant.hidden {
    display: none;
  }

  /* Mobile narrative cards */
  .narrative-mobile-card {
    padding: 1.25rem;
    background: #F9FDFB;
    border-radius: 12px;
