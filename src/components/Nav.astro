---
import { Image } from 'astro:assets';
import logoSrc from '/public/logo.png';
import ResourceIcon from '@/components/ResourceIcons.astro';

interface Props {
  activePage?: string;
}

const { activePage } = Astro.props;

interface DropdownItem {
  href: string;
  label: string;
  description?: string;
  icon?: string;
}
interface DropdownGroup {
  heading: string;
  items: DropdownItem[];
}
interface NavLink {
  href: string;
  label: string;
  id: string;
  dropdown?: DropdownGroup[];
  megaFooter?: { label: string; description: string; href: string };
}

const navLinks: NavLink[] = [
  { href: '/', label: 'Home', id: 'home' },
  { href: '/platform/', label: 'Platform', id: 'platform' },
  {
    href: '/resources/',
    label: 'Resources',
    id: 'resources',
    dropdown: [
      {
        heading: 'Build',
        items: [
          { href: '/resources/templates/', label: 'Templates', description: 'SOWs, dashboards, rate cards, and checklists', icon: 'template' },
          { href: '/resources/guides/', label: 'Guides & Playbooks', description: 'Long-form field guides for services operators', icon: 'playbook' },
          { href: '/compare/', label: 'Comparisons', description: 'How Servantium fits next to other categories', icon: 'comparison' },
        ],
      },
      {
        heading: 'Read',
        items: [
          { href: '/blog/', label: 'Blog', description: 'Strategy essays and operator op-eds', icon: 'blog' },
          { href: '/resources/customers/', label: 'Customer Stories', description: 'How firms run their operations on Servantium', icon: 'customer' },
        ],
      },
    ],
    megaFooter: {
      label: 'The Resources Hub',
      description: 'Browse every template, playbook, and story in one place.',
      href: '/resources/',
    },
  },
  { href: '/help/', label: 'Help', id: 'help' },
  { href: '/about', label: 'About', id: 'about' },
];
---

<nav aria-label="Main navigation" data-pagefind-ignore>
  <div class="container">
    <a href="/" class="logo">
      <Image src={logoSrc} alt="Servantium" class="logo-image object-contain" width={180} height={40} />
    </a>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li class={link.dropdown ? 'has-dropdown' : ''}>
          <a
            href={link.href}
            class={activePage === link.id ? 'active' : ''}
            aria-haspopup={link.dropdown ? 'true' : undefined}
            aria-expanded={link.dropdown ? 'false' : undefined}
          >
            {link.label}
            {link.dropdown && (
              <svg class="nav-caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
          {link.dropdown && (
            <div class="nav-mega" role="menu" aria-label={`${link.label} menu`}>
              <div class="nav-mega-grid">
                {link.dropdown.map(group => (
                  <div class="nav-mega-col">
                    <div class="nav-mega-heading">{group.heading}</div>
                    <ul class="nav-mega-list">
                      {group.items.map(item => (
                        <li>
                          <a href={item.href} class="nav-mega-item" role="menuitem">
                            <span class="nav-mega-icon" aria-hidden="true">
                              {item.icon && <ResourceIcon name={item.icon as any} size={20} />}
                            </span>
                            <span class="nav-mega-text">
                              <span class="nav-mega-label">{item.label}</span>
                              {item.description && <span class="nav-mega-desc">{item.description}</span>}
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
              {link.megaFooter && (
                <a href={link.megaFooter.href} class="nav-mega-footer" role="menuitem">
                  <svg class="nav-mega-footer-art" width="140" height="96" viewBox="0 0 140 96" fill="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="rhArtGrad" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.45"/>
                        <stop offset="100%" stop-color="#ffffff" stop-opacity="0.05"/>
                      </linearGradient>
                    </defs>
                    <circle cx="108" cy="20" r="28" fill="url(#rhArtGrad)"/>
                    <rect x="58" y="44" width="34" height="44" rx="4" fill="#ffffff" fill-opacity="0.18" stroke="#ffffff" stroke-opacity="0.55" stroke-width="1.5"/>
                    <rect x="96" y="30" width="34" height="58" rx="4" fill="#ffffff" fill-opacity="0.22" stroke="#ffffff" stroke-opacity="0.7" stroke-width="1.5"/>
                    <rect x="20" y="56" width="34" height="32" rx="4" fill="#ffffff" fill-opacity="0.14" stroke="#ffffff" stroke-opacity="0.45" stroke-width="1.5"/>
                    <path d="M28 66 h18 M28 74 h14" stroke="#ffffff" stroke-opacity="0.75" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M66 54 h18 M66 62 h14 M66 70 h16" stroke="#ffffff" stroke-opacity="0.85" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M104 42 h18 M104 50 h14 M104 58 h16 M104 66 h12" stroke="#ffffff" stroke-opacity="0.95" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  <div class="nav-mega-footer-copy">
                    <div class="nav-mega-footer-label">{link.megaFooter.label}</div>
                    <div class="nav-mega-footer-desc">{link.megaFooter.description}</div>
                  </div>
                  <span class="nav-mega-footer-arrow" aria-hidden="true">
                    <ResourceIcon name="arrow-right" size={18} />
                  </span>
                </a>
              )}
            </div>
          )}
        </li>
      ))}
    </ul>
    <div class="nav-buttons">
      <button
        class="btn btn-secondary btn-nav"
        data-cal-link="christopher-veale/servantium-introduction?duration=15"
        data-cal-namespace="servantium-introduction"
        data-cal-config='{"layout":"month_view"}'
      >
        Book a Demo
      </button>
      <a href="https://app.servantium.com" class="btn btn-primary btn-nav" data-astro-prefetch="false" rel="noopener" autocomplete="off">Log In</a>
    </div>
    <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <button class="mobile-menu-close" aria-label="Close menu" id="mobile-menu-close-btn">
    <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  {navLinks.map(link => (
    link.dropdown ? (
      <div class="mobile-dropdown">
        <button
          class="mobile-dropdown-toggle"
          type="button"
          aria-expanded="false"
        >
          {link.label}
          <svg class="mobile-dropdown-caret" width="12" height="12" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="mobile-dropdown-items" hidden>
          {link.dropdown.map(group => (
            group.items.map(item => (
              <a href={item.href} class="mobile-dropdown-link">{item.label}</a>
            ))
          ))}
          {link.id === 'resources' && (
            <a href="/resources/" class="mobile-dropdown-link" style="font-weight: 600; color: var(--color-green);">Browse the Resources Hub</a>
          )}
        </div>
      </div>
    ) : (
      <a href={link.href}>{link.label}</a>
    )
  ))}
  <button
    class="btn btn-secondary"
    data-cal-link="christopher-veale/servantium-introduction?duration=15"
    data-cal-namespace="servantium-introduction"
    data-cal-config='{"layout":"month_view"}'
  >
    Book a Demo
  </button>
  <a href="https://app.servantium.com" class="btn btn-primary" data-astro-prefetch="false" rel="noopener" autocomplete="off">Log In</a>
</div>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: var(--space-sm, 1rem) 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6);
    transition: transform 0.3s ease;
  }
  nav .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    overflow: visible;
  }
  .logo-image {
    height: 40px;
    width: auto;
    min-width: 180px;
  }
  .nav-links {
    display: flex;
    gap: var(--space-lg, 2.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links li { position: relative; display: block; }
  .nav-links a {
    color: var(--color-ink-light, #3d3d3d);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-servantium-green, #00C26D);
  }
  .nav-caret { transition: transform 0.25s ease; opacity: 0.7; }
  .has-dropdown:hover .nav-caret,
  .has-dropdown:focus-within .nav-caret { transform: rotate(180deg); opacity: 1; }

  /* Mega menu — Vidyard style: wide panel, multi-column, icon + label + description, bottom callout */
  .nav-mega {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translate(-50%, -6px);
    width: min(760px, 92vw);
    background: #ffffff;
    border: 1px solid var(--color-cloud-grey, #E1E3E6);
    border-radius: 18px;
    box-shadow: 0 30px 80px rgba(13, 13, 13, 0.14), 0 2px 8px rgba(13, 13, 13, 0.04);
    padding: 1.5rem 1.5rem 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 200;
    overflow: hidden;
  }
  .nav-mega::before {
    content: '';
    position: absolute;
    top: -10px; left: 0; right: 0; height: 10px;
  }
  .has-dropdown:hover > .nav-mega,
  .has-dropdown:focus-within > .nav-mega,
  .has-dropdown.is-open > .nav-mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }
  .nav-mega-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding-bottom: 1.25rem;
  }
  .nav-mega-col { min-width: 0; }
  .nav-mega-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-muted, #6b6b6b);
    margin: 0 0 0.5rem 0.75rem;
  }
  .nav-mega-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.125rem; }
  .nav-mega-item {
    display: flex !important;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.7rem 0.75rem !important;
    border-radius: 10px;
    color: var(--color-ink, #0D0D0D) !important;
    transition: background 0.15s ease;
    text-decoration: none;
  }
  .nav-mega-item:hover {
    background: var(--color-soft-mint, #E8FBF1);
    color: var(--color-ink, #0D0D0D) !important;
  }
  .nav-mega-item:hover .nav-mega-icon {
    background: #ffffff;
    color: var(--color-green, #00C26D);
    border-color: var(--color-green, #00C26D);
  }
  .nav-mega-icon {
    flex-shrink: 0;
    width: 38px; height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-mist-grey, #F5F6F7);
    border: 1px solid var(--color-cloud-grey, #E1E3E6);
    border-radius: 10px;
    color: var(--color-ink, #0D0D0D);
    transition: all 0.15s ease;
  }
  .nav-mega-text { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; line-height: 1.35; }
  .nav-mega-label {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-ink, #0D0D0D);
    line-height: 1.2;
  }
  .nav-mega-desc {
    font-size: 0.78rem;
    color: var(--color-ink-muted, #6b6b6b);
    font-weight: 400;
    line-height: 1.35;
  }
  .nav-mega-footer {
    display: flex !important;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    position: relative;
    margin: 0 -1.5rem;
    padding: 1.15rem 1.75rem !important;
    background: linear-gradient(115deg, #023E25 0%, #015c38 50%, #00C26D 100%);
    border-top: 1px solid var(--color-cloud-grey, #E1E3E6);
    text-decoration: none;
    color: #ffffff !important;
    overflow: hidden;
    transition: filter 0.2s ease, transform 0.2s ease;
  }
  .nav-mega-footer::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 85% 50%, rgba(255,255,255,0.18) 0%, transparent 60%);
    pointer-events: none;
  }
  .nav-mega-footer:hover { filter: brightness(1.08); color: #ffffff !important; }
  .nav-mega-footer:hover .nav-mega-footer-arrow { transform: translateX(4px); color: #ffffff; }
  .nav-mega-footer-art {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.85;
    pointer-events: none;
  }
  .nav-mega-footer-copy {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 0;
  }
  .nav-mega-footer-label {
    font-size: 0.98rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }
  .nav-mega-footer-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 0.2rem;
  }
  .nav-mega-footer-arrow {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    color: #ffffff;
    transition: transform 0.18s ease, background 0.18s ease;
  }
  .nav-mega-footer:hover .nav-mega-footer-arrow { background: rgba(255, 255, 255, 0.3); }
  @media (max-width: 900px) {
    .nav-mega-grid { grid-template-columns: 1fr; gap: 1.25rem; }
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
    border: none;
    font-family: inherit;
  }
  .btn-primary {
    background: var(--color-servantium-green, #00C26D);
    color: #FFFFFF;
    box-shadow: 0 2px 8px rgba(0, 194, 109, 0.25);
  }
  .btn-primary:hover {
    background: var(--color-green-hover, #00A95E);
    transform: translateY(-1px);
  }
  .btn-secondary {
    background: transparent;
    color: var(--color-ink, #0D0D0D);
    border: 1.5px solid var(--color-cloud-grey, #E1E3E6);
  }
  .btn-secondary:hover {
    border-color: var(--color-servantium-green, #00C26D);
    color: var(--color-servantium-green, #00C26D);
  }
  .btn-nav { padding: 0.5rem 1rem; font-size: 0.85rem; }
  .nav-buttons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }
  .mobile-menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-ink, #0D0D0D);
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  .mobile-menu-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .mobile-menu-toggle.active span:nth-child(2) { opacity: 0; }
  .mobile-menu-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: var(--color-white, #FFFFFF);
    z-index: 999;
    padding: var(--space-lg, 2.5rem);
    padding-top: 80px;
    flex-direction: column;
    gap: var(--space-sm, 1rem);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .mobile-menu.active { display: flex; }
  .mobile-menu-close {
    position: absolute;
    top: calc(env(safe-area-inset-top, 0px) + var(--space-sm, 1rem));
    right: var(--space-lg, 2.5rem);
    width: 44px; height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    z-index: 1002;
  }
  .mobile-menu-close svg {
    width: 28px; height: 28px;
    stroke: var(--color-ink, #0D0D0D);
    stroke-width: 2;
  }
  .mobile-menu-close:hover svg { stroke: var(--color-servantium-green, #00C26D); }
  .mobile-menu a:not(.btn) {
    display: block;
    padding: var(--space-md, 1.5rem) 0;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-ink, #0D0D0D);
    text-decoration: none;
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6);
    transition: color 0.2s;
  }
  .mobile-menu a:not(.btn):hover { color: var(--color-servantium-green, #00C26D); }
  .mobile-menu .btn {
    margin-top: var(--space-md, 1.5rem);
    justify-content: center;
    padding: 1rem 2rem;
    font-size: 1rem;
  }

  /* Mobile dropdown for Resources sub-items */
  .mobile-dropdown {
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6);
  }
  .mobile-dropdown-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-md, 1.5rem) 0;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-ink, #0D0D0D);
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: color 0.2s;
  }
  .mobile-dropdown-toggle:hover { color: var(--color-servantium-green, #00C26D); }
  .mobile-dropdown-caret {
    transition: transform 0.25s ease;
    opacity: 0.5;
    flex-shrink: 0;
  }
  .mobile-dropdown-toggle[aria-expanded="true"] .mobile-dropdown-caret {
    transform: rotate(180deg);
    opacity: 1;
  }
  .mobile-dropdown-items {
    padding: 0 0 0.5rem 1rem;
  }
  .mobile-dropdown-items[hidden] { display: none; }
  .mobile-dropdown-link {
    display: block;
    padding: 0.65rem 0;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-ink-light, #3d3d3d);
    text-decoration: none;
    transition: color 0.2s;
  }
  .mobile-dropdown-link:hover { color: var(--color-servantium-green, #00C26D); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-buttons { display: none; }
    .mobile-menu-toggle { display: flex; }
  }
</style>

<script>
  // Mobile Menu Toggle
  const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuCloseBtn = document.getElementById('mobile-menu-close-btn');

  function closeMobileMenu() {
    mobileMenu?.classList.remove('active');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    mobileMenuToggle?.classList.remove('active');
    mobileMenuToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  mobileMenuToggle?.addEventListener('click', function() {
    const isActive = mobileMenu?.classList.toggle('active');
    this.classList.toggle('active');
    this.setAttribute('aria-expanded', String(isActive));
    mobileMenu?.setAttribute('aria-hidden', String(!isActive));
    document.body.style.overflow = isActive ? 'hidden' : '';
  });

  mobileMenuCloseBtn?.addEventListener('click', closeMobileMenu);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('active')) {
      closeMobileMenu();
    }
  });

  // Mobile dropdown toggles (Resources sub-items)
  document.querySelectorAll('.mobile-dropdown-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var items = btn.nextElementSibling;
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      if (expanded) {
        items.setAttribute('hidden', '');
      } else {
        items.removeAttribute('hidden');
      }
    });
  });

  // Mega-menu persistence: JS-managed open state so the panel stays open
  // while the pointer moves from trigger → panel and doesn't collapse
  // mid-click. Hover opens, pointer-leave closes after a short delay,
  // click-on-caret pins open, click-outside or Escape closes.
  (function() {
    var OPEN_DELAY = 80;
    var CLOSE_DELAY = 220;
    var triggers = document.querySelectorAll('.has-dropdown');
    triggers.forEach(function(li) {
      var openT = null, closeT = null;
      function clearTimers() { if (openT) clearTimeout(openT); if (closeT) clearTimeout(closeT); openT = closeT = null; }
      function open() {
        clearTimers();
        // Close any other open mega menu first.
        triggers.forEach(function(o) { if (o !== li) o.classList.remove('is-open'); });
        openT = setTimeout(function() { li.classList.add('is-open'); }, OPEN_DELAY);
      }
      function close() {
        clearTimers();
        closeT = setTimeout(function() { li.classList.remove('is-open'); }, CLOSE_DELAY);
      }
      li.addEventListener('mouseenter', open);
      li.addEventListener('mouseleave', close);
      li.addEventListener('focusin', open);
      li.addEventListener('focusout', function(e) {
        // Only close if focus actually left this li.
        if (!li.contains(e.relatedTarget)) close();
      });
      // Click on the caret/trigger link toggles pinned state on desktop
      // without navigating away immediately.
      var trigger = li.querySelector(':scope > a');
      if (trigger) {
        trigger.addEventListener('click', function(e) {
          if (window.innerWidth <= 768) return;
          // If already open and the user clicks the trigger, let navigation happen.
          if (li.classList.contains('is-open')) return;
          e.preventDefault();
          open();
          clearTimeout(openT);
          li.classList.add('is-open');
        });
      }
    });
    // Click outside closes all
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.has-dropdown')) {
        triggers.forEach(function(li) { li.classList.remove('is-open'); });
      }
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        triggers.forEach(function(li) { li.classList.remove('is-open'); });
      }
    });
  })();

  // Scroll-hide header on mobile and tablet (including landscape).
  // Pauses while hovering the nav so mega-menu interactions don't collapse.
  let lastScroll = 0;
  let navHovered = false;
  const nav = document.querySelector('nav');
  if (nav) {
    nav.addEventListener('mouseenter', () => { navHovered = true; });
    nav.addEventListener('mouseleave', () => { navHovered = false; });
    nav.addEventListener('focusin', () => { navHovered = true; });
    nav.addEventListener('focusout', () => { navHovered = false; });
  }
  window.addEventListener('scroll', () => {
    if (window.innerWidth > 1024) return;
    if (navHovered) return;
    const current = window.scrollY;
    if (current > lastScroll && current > 100) {
      nav.style.transform = 'translateY(-100%)';
    } else {
      nav.style.transform = 'translateY(0)';
    }
    lastScroll = current;
  });
</script>
