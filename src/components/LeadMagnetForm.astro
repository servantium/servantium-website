---
/**
 * LeadMagnetForm — Inline, in-page email capture for gated resources.
 *
 * Posts to leads.servantium.com (separate from the contact-us pipeline) so
 * submissions land in the lead-capture database, not a founder inbox.
 * On success, hides the form and triggers an automatic download of the file.
 *
 * Usage:
 *   <LeadMagnetForm
 *     resourceTitle="Professional Services SOW Template"
 *     fileUrl="/downloads/sow.docx"
 *     resourceId="sow-template"
 *   />
 */
interface Props {
  resourceTitle: string;
  fileUrl: string;
  resourceId: string;
  ctaLabel?: string;
  description?: string;
}

const {
  resourceTitle,
  fileUrl,
  resourceId,
  ctaLabel = 'Send it to me',
  description = 'Drop your email and we\'ll send the file. No spam, no drip campaigns — just the resource.',
} = Astro.props;

const formId = `lead-form-${resourceId}`;
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<form
  id={formId}
  class="lead-form"
  data-file-url={fileUrl}
  data-resource={resourceTitle}
  novalidate
>
  <h3 class="lead-form-title">Get your copy</h3>
  <p class="lead-form-desc">{description}</p>

  <div class="lead-form-row">
    <label class="sr-only" for={`${formId}-name`}>Name</label>
    <input
      type="text"
      id={`${formId}-name`}
      name="name"
      placeholder="Your name"
      required
      autocomplete="name"
    />
    <label class="sr-only" for={`${formId}-email`}>Work email</label>
    <input
      type="email"
      id={`${formId}-email`}
      name="email"
      placeholder="you@firm.com"
      required
      autocomplete="email"
    />
  </div>

  <label class="sr-only" for={`${formId}-firm`}>Firm</label>
  <input
    type="text"
    id={`${formId}-firm`}
    name="firm"
    placeholder="Firm or company (optional)"
    autocomplete="organization"
    class="lead-form-firm"
  />

  {/* Honeypot — bots fill all fields. Real users won't see this one. */}
  <input
    type="text"
    name="company_website"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
    class="lead-form-hp"
  />

  {turnstileKey && (
    <div class="cf-turnstile" data-sitekey={turnstileKey} data-size="flexible"></div>
  )}

  <button type="submit" class="lead-form-submit btn btn-primary">{ctaLabel}</button>

  <p class="lead-form-note">
    We'll email you the file and occasionally share new templates.
    No spam. Unsubscribe anytime.
  </p>

  <div class="lead-form-status" role="status" aria-live="polite"></div>
</form>

<div class="lead-form-success" data-for={formId} hidden>
  <div class="lead-form-success-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </div>
  <h3>You're all set.</h3>
  <p>We've logged your request. Your download should start automatically — if it doesn't, <a href={fileUrl} download>click here</a>.</p>
</div>

<script define:vars={{ formId }}>
  (function() {
    var form = document.getElementById(formId);
    if (!form) return;
    var successEl = document.querySelector('[data-for="' + formId + '"]');
    var statusEl = form.querySelector('.lead-form-status');
    var submitBtn = form.querySelector('.lead-form-submit');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var fd = new FormData(form);
      // Silent honeypot drop. Bots fill all fields; humans don't see this one.
      if (String(fd.get('company_website') || '').trim().length > 0) {
        form.setAttribute('hidden', '');
        if (successEl) successEl.removeAttribute('hidden');
        return;
      }
      var payload = {
        name: String(fd.get('name') || '').trim(),
        email: String(fd.get('email') || '').trim(),
        firm: String(fd.get('firm') || '').trim(),
        turnstileToken: String(fd.get('cf-turnstile-response') || ''),
        resource: form.dataset.resource,
        resourceId: form.id.replace('lead-form-', ''),
        fileUrl: form.dataset.fileUrl,
        source: 'lead-magnet',
        referrer: document.referrer || '',
        pagePath: window.location.pathname,
        submittedAt: new Date().toISOString(),
      };
      if (!payload.name || !payload.email) {
        statusEl.textContent = 'Name and email are required.';
        statusEl.className = 'lead-form-status error';
        return;
      }
      submitBtn.disabled = true;
      var originalLabel = submitBtn.textContent;
      submitBtn.textContent = 'Sending…';
      statusEl.textContent = '';
      statusEl.className = 'lead-form-status';

      try {
        // Posts to the dedicated lead-capture endpoint (NOT contact.servantium.com).
        // The endpoint is a separate Cloudflare Worker backed by a D1 database so
        // lead submissions land in a queryable table, not a founder inbox.
        var res = await fetch('https://leads.servantium.com/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('Request failed');

        // Telemetry
        if (window.gtag) {
          window.gtag('event', 'lead_magnet_submitted', {
            resource: payload.resource,
            form_id: formId,
          });
        }

        // Hide form, reveal success, trigger download
        form.setAttribute('hidden', '');
        if (successEl) successEl.removeAttribute('hidden');
        var fileUrl = form.dataset.fileUrl;
        if (fileUrl) {
          var a = document.createElement('a');
          a.href = fileUrl;
          a.download = '';
          a.style.display = 'none';
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
        }
      } catch (err) {
        statusEl.textContent = 'Something went wrong. Please email hello@servantium.com and we\'ll send it directly.';
        statusEl.className = 'lead-form-status error';
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    });
  })();
</script>

<style>
  .lead-form,
  .lead-form-success {
    padding: 1.75rem;
    background: var(--color-mist-grey, #F5F6F7);
    border: 1px solid var(--color-cloud-grey, #E1E3E6);
    border-radius: 14px;
    margin-bottom: 2rem;
  }
  .lead-form-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
    color: var(--color-ink, #0D0D0D);
  }
  .lead-form-desc {
    font-size: 0.9rem;
    color: var(--color-ink-muted, #6b6b6b);
    margin: 0 0 1rem;
    line-height: 1.5;
  }
  .lead-form-row {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }
  @media (max-width: 600px) {
    .lead-form-row { grid-template-columns: 1fr; }
  }
  .lead-form input[type="text"],
  .lead-form input[type="email"] {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-size: 0.95rem;
    font-family: inherit;
    background: #ffffff;
    border: 1.5px solid var(--color-cloud-grey, #E1E3E6);
    border-radius: 10px;
    color: var(--color-ink, #0D0D0D);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .lead-form input:focus {
    outline: none;
    border-color: var(--color-servantium-green, #00C26D);
    box-shadow: 0 0 0 3px rgba(0, 194, 109, 0.12);
  }
  .lead-form-firm { margin-bottom: 0.75rem; }
  .lead-form-hp {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }
  .lead-form-submit {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    border-radius: 10px;
  }
  .lead-form-submit[disabled] { opacity: 0.6; cursor: wait; }
  .lead-form-note {
    font-size: 0.8rem;
    color: var(--color-ink-muted, #6b6b6b);
    margin: 0.85rem 0 0;
  }
  .lead-form-note a { color: var(--color-servantium-green, #00C26D); }
  .lead-form-status {
    font-size: 0.85rem;
    margin-top: 0.75rem;
    min-height: 1.2em;
  }
  .lead-form-status.error { color: #d93025; }

  .lead-form-success { text-align: center; }
  .lead-form-success-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-servantium-green, #00C26D);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.75rem;
  }
  .lead-form-success-icon svg { width: 24px; height: 24px; }
  .lead-form-success h3 {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 1.35rem;
    margin: 0 0 0.35rem;
  }
  .lead-form-success p {
    font-size: 0.9rem;
    color: var(--color-ink-muted, #6b6b6b);
    margin: 0;
  }
  .lead-form-success a { color: var(--color-servantium-green, #00C26D); }
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }
</style>
