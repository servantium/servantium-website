---
/**
 * Search -- Shared Pagefind search UI for blog and help.
 * Loads Pagefind's client-side search. Gracefully handles missing index.
 * Supports Cmd+K keyboard shortcut to focus.
 */
interface Props {
  id?: string;
  placeholder?: string;
  variant?: 'blog' | 'docs';
}

const {
  id = 'pagefind-search',
  placeholder = 'Search...',
  variant = 'blog',
} = Astro.props;
---

<div class={`search-wrapper search-wrapper--${variant}`}>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id={id} data-pagefind-search data-placeholder={placeholder}></div>
</div>

<!-- Pagefind scripts: only inject once per page even if multiple Search instances exist -->
<script is:inline>
  (function() {
    // Define init on window so all script blocks + onload callbacks share it.
    if (!window.__pagefindInit) {
      window.__pagefindInit = function initAllSearches() {
        var nodes = document.querySelectorAll('[data-pagefind-search]');
        nodes.forEach(function(el) {
          if (el.getAttribute('data-pagefind-initialized') === '1') return;
          if (!el.id) {
            // PagefindUI requires a DOM id selector
            el.id = 'pagefind-auto-' + Math.random().toString(36).slice(2, 9);
          }
          var placeholder = el.getAttribute('data-placeholder') || 'Search...';
          if (typeof PagefindUI === 'undefined') {
            // Script not loaded yet — bail; will retry on script onload
            return;
          }
          try {
            new PagefindUI({
              element: '#' + el.id,
              showSubResults: false,
              showImages: false,
              excerptLength: 20,
              bundlePath: '/pagefind/',
              translations: { placeholder: placeholder },
            });
            el.setAttribute('data-pagefind-initialized', '1');
          } catch (e) {
            console.warn('Pagefind init failed for', el.id, e);
            el.innerHTML = '<p style="color:#6b6b6b;font-size:0.85rem;padding:0.5rem 0;">Search is loading or unavailable. Try refreshing.</p>';
          }
        });
      };
    }

    // Inject the pagefind-ui.js script exactly once per page load.
    if (!window.__pagefindScriptLoaded) {
      window.__pagefindScriptLoaded = true;
      var s = document.createElement('script');
      s.src = '/pagefind/pagefind-ui.js';
      s.onload = function() { window.__pagefindInit(); };
      s.onerror = function() {
        document.querySelectorAll('[data-pagefind-search]').forEach(function(el) {
          el.innerHTML = '<p style="color:#6b6b6b;font-size:0.85rem;padding:0.5rem 0;">Search index not found. Run a production build to enable search.</p>';
        });
      };
      document.head.appendChild(s);
    } else if (typeof PagefindUI !== 'undefined') {
      // Script already cached from prior Astro navigation
      window.__pagefindInit();
    }

    // Re-init after Astro client-side navigations.
    if (!window.__pagefindRouteBound) {
      window.__pagefindRouteBound = true;
      document.addEventListener('astro:page-load', function() {
        if (typeof PagefindUI !== 'undefined') window.__pagefindInit();
      });
    }

    // Cmd+K / Ctrl+K focuses the first search input.
    if (!window.__pagefindCmdKBound) {
      window.__pagefindCmdKBound = true;
      document.addEventListener('keydown', function(e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          var input = document.querySelector('[data-pagefind-search] input');
          if (input) {
            e.preventDefault();
            input.focus();
          }
        }
      });
    }
  })();
</script>

<style is:global>
  /* Shared search input styling */
  .search-wrapper .pagefind-ui__search-input {
    font-family: var(--font-body, 'Source Sans 3', sans-serif) !important;
    border: 1.5px solid var(--color-cloud-grey, #E1E3E6) !important;
    border-radius: 12px !important;
    font-size: 0.95rem !important;
    width: 100% !important;
  }
  .search-wrapper .pagefind-ui__search-input:focus {
    border-color: var(--color-green, #00C26D) !important;
    box-shadow: 0 0 0 3px rgba(0, 194, 109, 0.12) !important;
    outline: none !important;
  }
  .search-wrapper .pagefind-ui__result-link {
    color: var(--color-green, #00C26D) !important;
    font-weight: 500 !important;
  }
  .search-wrapper .pagefind-ui__message,
  .search-wrapper .pagefind-ui__result-excerpt {
    font-family: var(--font-body, 'Source Sans 3', sans-serif) !important;
  }
  .search-wrapper .pagefind-ui__form::before {
    display: none !important;
  }
  /* Tighter result density — enterprise-style compact list */
  .search-wrapper .pagefind-ui__result {
    padding: 0.75rem 0 !important;
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6) !important;
  }
  .search-wrapper .pagefind-ui__result-link {
    font-size: 0.95rem !important;
    line-height: 1.3 !important;
  }
  .search-wrapper .pagefind-ui__result-excerpt {
    font-size: 0.825rem !important;
    line-height: 1.5 !important;
    color: var(--color-ink-muted, #6b6b6b) !important;
    margin-top: 0.2rem !important;
    -webkit-line-clamp: 2 !important;
    display: -webkit-box !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
  }
  .search-wrapper .pagefind-ui__result-nested { display: none !important; }
  .search-wrapper .pagefind-ui__result-title { margin: 0 !important; }
  .search-wrapper .pagefind-ui__results-area { margin-top: 0.5rem !important; }

  /* Blog variant: slightly larger padding */
  .search-wrapper--blog .pagefind-ui__search-input {
    padding: 0.65rem 1rem !important;
  }

  /* Docs variant: compact padding */
  .search-wrapper--docs .pagefind-ui__search-input {
    padding: 0.6rem 0.85rem !important;
    font-size: 0.875rem !important;
    border-radius: 10px !important;
  }
</style>
