---
/**
 * ResourceIndexPage — shared filter index page frame.
 * Used by /resources/calculators/, /resources/templates/, etc.
 * Renders breadcrumb + hero + search + ResourceGrid.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import ResourceGrid from '@/components/ResourceGrid.astro';
import Search from '@/components/Search.astro';
import type { Tile } from '@/lib/resourceTiles';

interface Props {
  seoTitle: string;
  seoDescription: string;
  eyebrow: string;
  h1: string;
  lede: string;
  crumbLabel: string;
  tiles: Tile[];
  emptyMessage?: string;
  searchId: string;
}

const {
  seoTitle,
  seoDescription,
  eyebrow,
  h1,
  lede,
  crumbLabel,
  tiles,
  emptyMessage,
  searchId,
} = Astro.props;
---

<BaseLayout activePage="resources">
  <SEO slot="head" title={seoTitle} description={seoDescription} ogType="website" />

  <section class="rix-hero">
    <div class="rix-container">
      <nav class="rix-crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/resources/">Resources</a>
        <span aria-hidden="true">›</span>
        <span>{crumbLabel}</span>
      </nav>
      <div class="rix-eyebrow">{eyebrow}</div>
      <h1>{h1}</h1>
      <p class="rix-lede">{lede}</p>
      <div class="rix-search">
        <Search id={searchId} placeholder="Search all resources..." variant="blog" />
      </div>
    </div>
  </section>

  <section class="rix-body">
    <div class="rix-container">
      <ResourceGrid tiles={tiles} emptyMessage={emptyMessage} />
    </div>
  </section>
</BaseLayout>

<style>
  .rix-container { max-width: var(--content-width, 1180px); margin: 0 auto; padding: 0 var(--space-lg, 2.5rem); }
  .rix-hero {
    padding: 7rem 0 2.5rem;
    background: linear-gradient(180deg, var(--color-soft-mint, #E8FBF1) 0%, #ffffff 100%);
    text-align: center;
  }
  .rix-crumbs {
    display: flex; gap: 0.5rem; align-items: center; justify-content: center;
    font-size: 0.85rem; color: var(--color-ink-muted, #6b6b6b); margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .rix-crumbs a { color: var(--color-green, #00C26D); text-decoration: none; }
  .rix-eyebrow {
    display: inline-block; font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--color-green, #00C26D); margin-bottom: 0.75rem;
  }
  .rix-hero h1 {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500; line-height: 1.15; letter-spacing: -0.02em;
    color: var(--color-ink, #0D0D0D); margin: 0 0 1rem;
  }
  .rix-lede {
    font-size: 1.1rem; line-height: 1.6; color: var(--color-ink-muted, #6b6b6b);
    max-width: 620px; margin: 0 auto 1.75rem;
  }
  .rix-search { max-width: 560px; margin: 0 auto; }
  .rix-body { padding: 3rem 0 6rem; background: var(--color-mist-grey, #F5F6F7); }
</style>
