---
/**
 * ResourceIndexPage — shared filter index page frame.
 * Used by /resources/calculators/, /resources/templates/, etc.
 * Renders breadcrumb + hero + search + ResourceGrid.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SEO from '@/components/SEO.astro';
import ResourceGrid from '@/components/ResourceGrid.astro';
import Search from '@/components/Search.astro';
import type { Tile } from '@/lib/resourceTiles';

interface Props {
  seoTitle: string;
  seoDescription: string;
  eyebrow: string;
  h1: string;
  lede: string;
  crumbLabel: string;
  tiles: Tile[];
  emptyMessage?: string;
  searchId: string;
}

const {
  seoTitle,
  seoDescription,
  eyebrow,
  h1,
  lede,
  crumbLabel,
  tiles,
  emptyMessage,
  searchId,
} = Astro.props;
---

<BaseLayout activePage="resources">
  <SEO slot="head" title={seoTitle} description={seoDescription} ogType="website" />

  <section class="rix-hero">
    <div class="rix-hero-bg" aria-hidden="true">
      <svg class="rix-hero-blob rix-hero-blob-1" viewBox="0 0 600 600" preserveAspectRatio="none">
        <defs>
          <radialGradient id="rixBlob1" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="300" cy="300" r="280" fill="url(#rixBlob1)"/>
      </svg>
      <svg class="rix-hero-blob rix-hero-blob-2" viewBox="0 0 600 600" preserveAspectRatio="none">
        <defs>
          <radialGradient id="rixBlob2" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.12"/>
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="300" cy="300" r="280" fill="url(#rixBlob2)"/>
      </svg>
      <svg class="rix-hero-grid" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice">
        <defs>
          <pattern id="rixDots" x="0" y="0" width="16" height="16" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="1" fill="#ffffff" fill-opacity="0.14"/>
          </pattern>
        </defs>
        <rect width="200" height="200" fill="url(#rixDots)"/>
      </svg>
    </div>
    <div class="rix-container">
      <nav class="rix-crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/resources/">Resources</a>
        <span aria-hidden="true">›</span>
        <span>{crumbLabel}</span>
      </nav>
      <div class="rix-eyebrow">{eyebrow}</div>
      <h1>{h1}</h1>
      <p class="rix-lede">{lede}</p>
      <div class="rix-search">
        <Search id={searchId} placeholder="Search all resources..." variant="blog" />
      </div>
    </div>
  </section>

  <section class="rix-body">
    <div class="rix-container">
      <ResourceGrid tiles={tiles} emptyMessage={emptyMessage} />
    </div>
  </section>
</BaseLayout>

<style>
  .rix-container {
    position: relative;
    max-width: var(--content-width, 1180px);
    margin: 0 auto;
    padding: 0 var(--space-lg, 2.5rem);
    z-index: 2;
  }
  .rix-hero {
    position: relative;
    padding: 8rem 0 3.5rem;
    background: linear-gradient(135deg, var(--color-green, #00C26D) 0%, var(--color-deep-forest, #023E25) 100%);
    text-align: center;
    overflow: hidden;
  }
  .rix-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .rix-hero-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.6;
  }
  .rix-hero-blob {
    position: absolute;
    width: 700px;
    height: 700px;
    filter: blur(2px);
  }
  .rix-hero-blob-1 { top: -300px; left: -200px; }
  .rix-hero-blob-2 { bottom: -350px; right: -200px; }
  .rix-crumbs {
    display: flex; gap: 0.5rem; align-items: center; justify-content: center;
    font-size: 0.85rem; color: rgba(255, 255, 255, 0.75); margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .rix-crumbs a {
    color: #ffffff;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }
  .rix-crumbs a:hover { opacity: 1; }
  .rix-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #ffffff;
    opacity: 0.9;
    margin-bottom: 0.9rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(4px);
  }
  .rix-hero h1 {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1.1rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.18);
  }
  .rix-lede {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.92);
    max-width: 640px;
    margin: 0 auto 2rem;
  }
  .rix-search {
    max-width: 560px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 12px;
    padding: 0.4rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }
  .rix-body {
    padding: 3.5rem 0 6rem;
    background: var(--color-mist-grey, #F5F6F7);
  }
  @media (max-width: 700px) {
    .rix-hero { padding: 6.5rem 0 2.75rem; }
    .rix-hero-blob { width: 400px; height: 400px; }
  }
</style>
