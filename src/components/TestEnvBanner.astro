<!-- Test environment detection: noindex + orange banner -->
<script>
  (function() {
    const isTestEnv = window.location.hostname === 'test.servantium.com';
    if (isTestEnv) {
      // Block indexing
      const noindex = document.createElement('meta');
      noindex.name = 'robots';
      noindex.content = 'noindex, nofollow';
      document.head.appendChild(noindex);

      // Show banner
      document.addEventListener('DOMContentLoaded', function() {
        const banner = document.createElement('div');
        banner.setAttribute('role', 'alert');
        banner.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#ff6b35;color:#fff;text-align:center;padding:8px;font-size:14px;font-weight:600;z-index:99999;';
        banner.textContent = 'TEST ENVIRONMENT — Changes here do not affect production';
        document.body.prepend(banner);
        document.body.style.paddingTop = '40px';
        const nav = document.querySelector('nav');
        if (nav) (nav as HTMLElement).style.top = '40px';
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileMenu) mobileMenu.style.paddingTop = '120px';
      });
    }
  })();
</script>
