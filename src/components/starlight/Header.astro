---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import Nav from '../Nav.astro';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<!-- Reuse the exact same Nav component from the main site -->
<div class="starlight-header-wrapper">
  <Nav activePage="help" />

  {shouldRenderSearch && (
    <div class="sl-search-bar">
      <div class="sl-search-inner"><Search /></div>
    </div>
  )}
</div>

<!-- Force light theme -->
<script is:inline>
  document.documentElement.dataset.theme = 'light';
  localStorage.setItem('starlight-theme', 'light');
</script>

<style is:global>
  /* Override Nav's fixed positioning inside Starlight - let Starlight handle stacking */
  .starlight-header-wrapper > nav {
    position: relative !important;
    z-index: auto;
    border-bottom: none;
    padding: 1rem 0 !important;
  }

  /* Match main site nav container width */
  .starlight-header-wrapper > nav .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Search bar sits below the nav, visually separated */
  .sl-search-bar {
    display: flex;
    justify-content: center;
    padding: 0.5rem 2rem 0.75rem;
    border-top: 1px solid var(--color-cloud-grey, #E1E3E6);
    border-bottom: 1px solid var(--color-cloud-grey, #E1E3E6);
    background: rgba(255, 255, 255, 0.95);
  }

  .sl-search-inner {
    width: 640px;
    max-width: 100%;
  }

  /* Starlight header container */
  header.header {
    padding: 0 !important;
    border-bottom: none !important;
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(12px);
  }

  /* Adjust content below for the taller header */
  :root {
    --sl-nav-height: 6.5rem;
  }
  @media (min-width: 50rem) {
    :root {
      --sl-nav-height: 7rem;
    }
  }
</style>
