---
const GA_ID = import.meta.env.PUBLIC_GA_ID ?? '';
---

<div id="cookie-consent" role="dialog" aria-label="Cookie consent" style="display: none; position: fixed; bottom: 0; left: 0; right: 0; background: var(--color-ink, #1a1a2e); padding: 16px 24px; z-index: 999999; box-shadow: 0 -4px 20px rgba(0,0,0,0.3);">
  <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
    <p style="margin: 0; flex: 1; min-width: 280px; font-size: 14px; line-height: 1.5; color: var(--color-cloud-grey, #d1d5db);">
      We use cookies to analyze site traffic and improve your experience. By clicking "Accept All", you consent to our use of analytics cookies.
      <a href="/privacy" style="color: var(--color-green, #00C26D); text-decoration: underline;">Privacy Policy</a>
    </p>
    <div style="display: flex; gap: 12px; flex-shrink: 0;">
      <button id="cookie-decline" style="padding: 10px 20px; background: transparent; border: 1px solid var(--color-cloud-grey, #9ca3af); color: var(--color-white, #ffffff); border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 500; transition: all 0.2s;">Decline All</button>
      <button id="cookie-accept" style="padding: 10px 20px; background: var(--color-green, #00C26D); border: none; color: var(--color-white, #ffffff); border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 500; transition: all 0.2s;">Accept All</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ GA_ID }}>
  // Two-track analytics during the GTM migration:
  //   1. Legacy: loadGA() injects gtag.js directly when consent is granted.
  //      Drives the standalone GA4 property for now.
  //   2. New: Consent Mode v2 default state is set in BaseLayout BEFORE GTM
  //      loads. This component pushes consent updates so GTM-managed tags
  //      respect the user's choice once they exist.
  // Once a GA4 tag is configured inside GTM and confirmed firing, remove
  // loadGA() and the PUBLIC_GA_ID dependency. The consent-update pushes stay.
  (function() {
    var consent = null;
    try { consent = localStorage.getItem('servantium_cookie_consent'); } catch(e) {}
    var isTestEnv = window.location.hostname === 'test.servantium.com';

    window.dataLayer = window.dataLayer || [];
    function gtag(){window.dataLayer.push(arguments);}

    function updateConsent(granted) {
      if (isTestEnv) return; // never grant on test environment
      var state = granted ? 'granted' : 'denied';
      gtag('consent', 'update', {
        ad_storage: state,
        analytics_storage: state,
        ad_user_data: state,
        ad_personalization: state,
      });
    }

    function loadGA() {
      if (!GA_ID || isTestEnv) return;
      if (window.__svGALoaded) return;
      window.__svGALoaded = true;
      var script = document.createElement('script');
      script.async = true;
      script.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(script);
      window.gtag = window.gtag || gtag;
      gtag('js', new Date());
      gtag('config', GA_ID);
    }

    if (!consent) {
      var banner = document.getElementById('cookie-consent');
      if (banner) {
        banner.style.display = 'block';
        document.body.style.paddingBottom = '80px';
      }
    }

    // If user previously accepted, fire the legacy loader on this page load.
    // Consent default state was already set to granted in BaseLayout.
    if (consent === 'accepted') loadGA();

    document.getElementById('cookie-accept')?.addEventListener('click', function() {
      try { localStorage.setItem('servantium_cookie_consent', 'accepted'); } catch(e) {}
      var banner = document.getElementById('cookie-consent');
      if (banner) banner.style.display = 'none';
      document.body.style.paddingBottom = '';
      updateConsent(true);
      loadGA();
    });

    document.getElementById('cookie-decline')?.addEventListener('click', function() {
      try { localStorage.setItem('servantium_cookie_consent', 'declined'); } catch(e) {}
      var banner = document.getElementById('cookie-consent');
      if (banner) banner.style.display = 'none';
      document.body.style.paddingBottom = '';
      updateConsent(false);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        var banner = document.getElementById('cookie-consent');
        if (banner && banner.style.display !== 'none') {
          try { localStorage.setItem('servantium_cookie_consent', 'declined'); } catch(e2) {}
          banner.style.display = 'none';
          document.body.style.paddingBottom = '';
          updateConsent(false);
        }
      }
    });
  })();
</script>
