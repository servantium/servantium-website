/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()

# Hashed static assets (CSS, JS, fonts, images) generated by Astro have
# fingerprinted filenames that change on every build. Safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind search index regenerates every build with new content.
# Cache for 1 hour so repeat searches are fast, but updates land quickly.
/pagefind/*
  Cache-Control: public, max-age=3600

# CSP is enforced via <meta> tag in BaseLayout.astro instead of a response
# header. Reason: Pagefind spawns a dedicated Web Worker that compiles WASM.
# When CSP is set as a response header, Chrome applies it to the worker's
# execution context too, blocking WebAssembly.instantiate() even with
# unsafe-eval. A <meta> CSP only applies to the document context and does
# not restrict workers, so Pagefind WASM loads cleanly.

# Pagefind indexes are publicly readable across origins so help.servantium.com
# can federate search with servantium.com's index.
# See https://pagefind.app/docs/multisite/
/pagefind/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
